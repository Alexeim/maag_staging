{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:firebase": "ts-node src/test-firebase-direct.ts",
    "migrate:news:dry": "node scripts/migrateArticlesNewsToNewsCollection.js",
    "migrate:news:copy": "node scripts/migrateArticlesNewsToNewsCollection.js --apply-copy",
    "migrate:news:delete": "node scripts/migrateArticlesNewsToNewsCollection.js --apply-delete",
    "migrate:news:cleanup-flags": "node scripts/migrateArticlesNewsToNewsCollection.js --cleanup-flags",
    "migrate:landing:dry": "node scripts/removeLegacyIsOnLanding.js",
    "migrate:landing:apply": "node scripts/removeLegacyIsOnLanding.js --apply",
    "migrate:landing:seed": "node scripts/removeLegacyIsOnLanding.js --seed-landing-doc",
    "repair:landing-main-hero:dry": "node scripts/fixLandingMainHeroSchema.js",
    "repair:landing-main-hero:apply": "node scripts/fixLandingMainHeroSchema.js --apply",
    "migrate:published:dry": "node scripts/backfillPublishedFields.js",
    "migrate:published:apply": "node scripts/backfillPublishedFields.js --apply",
    "deploy:prod": "bash deploy.sh",
    "images:compress:dry": "node scripts/compressStorageImages.js --dry-run",
    "images:compress:live": "node scripts/compressStorageImages.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "firebase-admin": "^13.5.0",
    "sharp": "^0.34.5",
    "stripe": "^18.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/sharp": "^0.31.1",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
