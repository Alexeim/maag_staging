---
import Layout from "../../Layouts/Layout.astro";
import ArticleHeader from "../../components/article/ArticleHeader.astro";
import ArticleAuthor from "../../components/article/ArticleAuthor.astro";
import ArticleDate from "@/components/article/ArticleDate.astro";
import ArticleImage from "../../components/article/ArticleImage.astro";
import ArticleBody from "../../components/article/ArticleBody.astro";
import ArticleTips from "../../components/article/ArticleTips.astro";
import EventDetails from "../../components/article/EventDetails.astro";
import RelatedContentMarquee from "@/components/article/RelatedContentMarquee.astro";
import picture1 from "@/assets/images/culture.jpg";
import { getKnownTagLabel } from "@/content/tags/parisTags";
import {
  ApiError,
  articlesApi,
  eventsApi,
  flippersApi,
  guidesApi,
  interviewsApi,
  newsApi,
  visualStoriesApi,
} from "@/lib/api/api";

const { id } = Astro.params;

const CATEGORY_LABELS: Record<string, string> = {
  culture: "Культура",
  paris: "Париж",
  hotContent: "Самое Читаемое",
};

const TAG_LABEL_ALIASES: Record<string, string> = {
  exhibition: "Выставка",
  exhibitions: "Выставка",
  concert: "Концерт",
  concerts: "Концерт",
  performance: "Спектакль",
  performances: "Спектакль",
  theatre: "Театр",
  theater: "Театр",
  theatres: "Театры",
  theaters: "Театры",
  culture: "Культура",
  paris: "Париж",
  books: "Книги",
  artmarket: "Арт-рынок",
  architecture: "Архитектура",
  museums: "Музеи",
  tourism: "Туризм",
  strike: "Забастовка",
  kids: "Дети",
  opera: "Опера",
  ballet: "Балет",
  dance: "Танец",
  music: "Музыка",
  route: "Маршрут",
  address: "Адрес",
  notebook: "Записная книжка",
  place: "Место",
  interview: "Интервью",
  news: "Новости",
  guide: "Гид",
  flipper: "Флиппер",
  "visual-story": "Visual Story",
  event: "Событие",
  ...Object.fromEntries(
    Array.from({ length: 20 }, (_, i) => [
      `district-${i + 1}`,
      `${i + 1}-й округ`,
    ]),
  ),
};

const normalizeCategory = (value?: string | null) => {
  if (!value) {
    return null;
  }
  const normalizedValue = value.trim().toLowerCase();
  const entry = Object.entries(CATEGORY_LABELS).find(
    ([key, label]) =>
      key.toLowerCase() === normalizedValue ||
      label.toLowerCase() === normalizedValue,
  );
  return entry ? entry[0] : normalizedValue;
};

const normalizeTags = (value: unknown): string[] => {
  if (!Array.isArray(value)) {
    return [];
  }
  return value
    .map((tag) => (typeof tag === "string" ? tag.trim() : ""))
    .filter(Boolean);
};

const toDate = (value: unknown): Date | null => {
  if (!value) {
    return null;
  }
  if (value instanceof Date) {
    return Number.isNaN(value.getTime()) ? null : value;
  }
  if (typeof value === "string" || typeof value === "number") {
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? null : parsed;
  }
  if (typeof value === "object") {
    const maybeSeconds =
      (value as { seconds?: number; _seconds?: number }).seconds ??
      (value as { seconds?: number; _seconds?: number })._seconds;
    if (typeof maybeSeconds === "number") {
      const parsed = new Date(maybeSeconds * 1000);
      return Number.isNaN(parsed.getTime()) ? null : parsed;
    }
    if (typeof (value as { toDate?: () => Date }).toDate === "function") {
      const parsed = (value as { toDate: () => Date }).toDate();
      return parsed instanceof Date && !Number.isNaN(parsed.getTime())
        ? parsed
        : null;
    }
  }
  return null;
};

const toContentHref = (item: any) => {
  if (item?.contentType === "event") {
    return `/events/${item.id}`;
  }
  if (item?.contentType === "interview") {
    return `/interviews/${item.id}`;
  }
  if (item?.contentType === "flipper") {
    return `/flippers/${item.id}`;
  }
  if (item?.contentType === "guide") {
    return `/guide/${item.id}`;
  }
  if (item?.contentType === "visual-story") {
    return `/visual-story/${item.id}`;
  }
  if (item?.contentType === "article" && item?.articleType === "tips") {
    return `/tips/${item.id}`;
  }
  return `/${item?.isNews ? "news" : "article"}/${item.id}`;
};

const getPrimaryTag = (item: any): string => {
  const tags = normalizeTags(item?.tags);
  if (item?.contentType === "interview") {
    return "Интервью";
  }
  if (tags.length === 0) {
    if (item?.isNews) {
      return "Новости";
    }
    const category = typeof item?.category === "string" ? item.category.trim() : "";
    const normalizedCategory = category.toLowerCase();
    return TAG_LABEL_ALIASES[normalizedCategory] ?? category;
  }
  const firstTag = tags[0];
  const normalized = firstTag.toLowerCase();
  return TAG_LABEL_ALIASES[normalized] ?? getKnownTagLabel(firstTag);
};

let articleData: any;
let relatedContentItems: any[] = [];
let sameCategoryItems: any[] = [];
let error: string | null = null;

try {
  articleData = await articlesApi.getById(id);
} catch (e: any) {
  console.error(e);
  if (e instanceof ApiError) {
    error =
      e.status === 404
        ? "Article not found."
        : `Error fetching article: ${e.message}`;
  } else {
    error = `Error fetching article: ${e.message}`;
  }
}

// Redirect tips articles to their dedicated page
if (articleData?.articleType === 'tips') {
  return Astro.redirect(`/tips/${id}`);
}

// Normalize data for the template
const rawCategory =
  articleData?.category ?? articleData?.header?.category ?? null;

const displayArticle = {
  title: articleData?.header?.title || articleData?.title || 'Article',
  lead: articleData?.lead || '',
  category: rawCategory
    ? CATEGORY_LABELS[rawCategory] || rawCategory
    : 'Category',
  authorName: articleData?.author ? `${articleData.author.firstName} ${articleData.author.lastName}` : 'Author',
  authorAvatar: articleData?.author?.avatar,
  readTime: articleData?.meta?.readTime || '5 min read',
  imageUrl: articleData?.imageUrl, // For dynamic articles
  imageCaption: articleData?.imageCaption || '', // <-- Get the caption
  imageAlt: articleData?.mainImage?.alt || 'Article image',
  contentBlocks: articleData?.content || [],
  tips: Array.isArray(articleData?.tips) ? articleData.tips : [],
};

const transitionAliases = [`landing-body-main-article-image-${id}`];

const isStandardCategoryArticle = (item: any) =>
  !item?.isNews &&
  item?.articleType !== "tips" &&
  item?.articleType !== "le_saviez_vous";

if (!error && articleData) {
  try {
    const [
      allArticlesRaw,
      allNewsRaw,
      allInterviewsRaw,
      allEventsRaw,
      allFlippersRaw,
      allGuidesRaw,
      allVisualStoriesRaw,
    ] = await Promise.all([
      articlesApi.list(),
      newsApi.list(),
      interviewsApi.list(),
      eventsApi.list(),
      flippersApi.list(),
      guidesApi.list(),
      visualStoriesApi.list(),
    ]);

    const allArticles = allArticlesRaw
      .map((article) => ({
        ...article,
        contentType: "article",
        tags: normalizeTags(article?.tags),
      }))
      .filter((article) => article.id !== id);

    const allNews = allNewsRaw.map((item) => ({
      ...item,
      isNews: true,
      contentType: "news",
      tags: normalizeTags(item?.tags),
    }));

    const allInterviews = allInterviewsRaw.map((item) => ({
      ...item,
      contentType: "interview",
      tags: normalizeTags(item?.tags),
    }));

    const allEvents = allEventsRaw.map((item) => ({
      ...item,
      contentType: "event",
      tags: normalizeTags(item?.tags),
    }));

    const allFlippers = allFlippersRaw.map((item) => ({
      ...item,
      contentType: "flipper",
      imageUrl: item?.carouselContent?.[0]?.imageUrl || null,
      tags: normalizeTags(item?.tags),
    }));

    const allGuides = allGuidesRaw.map((item) => ({
      ...item,
      contentType: "guide",
      tags: normalizeTags(item?.tags),
    }));

    const allVisualStories = allVisualStoriesRaw.map((item) => ({
      ...item,
      contentType: "visual-story",
      imageUrl: item?.imageUrl || item?.slides?.[0]?.imageUrl || null,
      tags: normalizeTags(item?.tags),
    }));

    const relatedContent = articleData?.relatedContent ?? {};

    const articleMap = new Map(allArticles.map((item) => [item.id, item]));
    const newsMap = new Map(allNews.map((item) => [item.id, item]));
    const interviewMap = new Map(allInterviews.map((item) => [item.id, item]));
    const eventMap = new Map(allEvents.map((item) => [item.id, item]));
    const flipperMap = new Map(allFlippers.map((item) => [item.id, item]));
    const guideMap = new Map(allGuides.map((item) => [item.id, item]));
    const visualStoryMap = new Map(allVisualStories.map((item) => [item.id, item]));

    const relatedSequence = [
      ...((Array.isArray(relatedContent.article) ? relatedContent.article : []).map((entryId: string) => articleMap.get(entryId))),
      ...((Array.isArray(relatedContent.event) ? relatedContent.event : []).map((entryId: string) => eventMap.get(entryId))),
      ...((Array.isArray(relatedContent.interview) ? relatedContent.interview : []).map((entryId: string) => interviewMap.get(entryId))),
      ...((Array.isArray(relatedContent.guide) ? relatedContent.guide : []).map((entryId: string) => guideMap.get(entryId))),
      ...((Array.isArray(relatedContent.news) ? relatedContent.news : []).map((entryId: string) => newsMap.get(entryId))),
      ...((Array.isArray(relatedContent.flipper) ? relatedContent.flipper : []).map((entryId: string) => flipperMap.get(entryId))),
      ...((Array.isArray(relatedContent.visualStory) ? relatedContent.visualStory : []).map((entryId: string) => visualStoryMap.get(entryId))),
    ]
      .filter((item): item is NonNullable<typeof item> => Boolean(item))
      .map((item) => ({
        ...item,
        href: toContentHref(item),
      }));

    const dedupedRelatedKeys = new Set<string>();
    relatedContentItems = relatedSequence.filter((item) => {
      const key = `${item.contentType}:${item.id}`;
      if (dedupedRelatedKeys.has(key)) {
        return false;
      }
      dedupedRelatedKeys.add(key);
      return true;
    });

    const currentCategory = normalizeCategory(articleData?.category);
    const relatedArticleIds = new Set(
      relatedContentItems
        .filter((item) => item.contentType === "article")
        .map((item) => item.id),
    );

    sameCategoryItems = allArticles
      .filter((item) => isStandardCategoryArticle(item))
      .filter((item) => normalizeCategory(item?.category) === currentCategory)
      .filter((item) => item.id !== id && !relatedArticleIds.has(item.id))
      .sort((left, right) => {
        const leftDate = toDate(left?.createdAt)?.getTime() ?? 0;
        const rightDate = toDate(right?.createdAt)?.getTime() ?? 0;
        return rightDate - leftDate;
      })
      .slice(0, 12)
      .map((item) => ({
        ...item,
        href: toContentHref(item),
      }));
  } catch (relatedError) {
    console.error("Failed to fetch related content for article page:", relatedError);
  }
}
---

<Layout
  navbarVariant="default"
  includePreFooterCTA={false}
  title={`${displayArticle.title} - Maag`}
  useClientRouter={true}
>
  <main class="bg-base-200 min-h-screen">
    <div class="max-w-[1512px] mx-auto">
      {error && <div class="text-red-500 text-center pt-40">{error}</div>}
      {!error && articleData && (
        <>
          <!-- Article Header Section -->
          <div class="pt-[50px] pb-[70px] px-4 lg:px-0 flex flex-col items-center gap-[50px]">
            <div class="flex flex-col gap-4 max-w-[825px] w-full">
              <ArticleHeader
                category={displayArticle.category}
                title={displayArticle.title}
                lead={displayArticle.lead}
              />
              <div class="h-10 flex flex-row items-center justify-start gap-4">
                <ArticleAuthor
                  name={displayArticle.authorName}
                  avatarUrl={displayArticle.authorAvatar}
                />
                <ArticleDate createdAt={articleData.createdAt} />
                {/* <SocialShare readTime={displayArticle.readTime} /> */}
              </div>
            </div>

            {displayArticle.imageUrl && (
              <ArticleImage
                src={displayArticle.imageUrl}
                alt={displayArticle.imageAlt}
                caption={displayArticle.imageCaption}
                transitionName={`main-article-image-${id}`}
                transitionAliases={transitionAliases}
                figureClass="max-w-[1200px]"
                imageClass="shadow-lg"
                figcaptionClass="text-center text-gray-500 mt-2"
              />
            )}
          </div>

          <!-- Article Content -->
          <div class="max-w-[1400px] mx-auto px-4 lg:px-14 pb-[100px]">
            <ArticleBody contentBlocks={displayArticle.contentBlocks} />
            <ArticleTips tips={displayArticle.tips} />
            
            {/* Conditionally render EventDetails only if the data exists */}
            {(articleData?.eventDetails) && (
              <EventDetails
                address={articleData.eventDetails.address}
                dates={articleData.eventDetails.dates}
              />
            )}

            <RelatedContentMarquee
              relatedItems={relatedContentItems}
              categoryItems={sameCategoryItems}
              fallbackImageSrc={picture1.src}
            />
          </div>
        </>
      )}
    </div>
  </main>
</Layout>
