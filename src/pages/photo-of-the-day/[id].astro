---
import Layout from "@/Layouts/Layout.astro";
import ArticleHeader from "@/components/article/ArticleHeader.astro";
import ArticleAuthor from "@/components/article/ArticleAuthor.astro";
import ArticleDate from "@/components/article/ArticleDate.astro";
import ContentActions from "@/components/common/ContentActions.astro";
import { ApiError, photosOfTheDayApi } from "@/lib/api/api";
import { buildImageStructuredData } from "@/lib/seo/structuredData";

const { id } = Astro.params;

let photo: any;
let error: string | null = null;

try {
  photo = await photosOfTheDayApi.getById(id!);
} catch (e: any) {
  if (e instanceof ApiError) {
    error = e.status === 404 ? "Фото не найдено." : `Ошибка загрузки: ${e.message}`;
  } else {
    error = `Ошибка загрузки: ${e.message}`;
  }
}

if (!error && photo?.published !== true) {
  error = "Фото не найдено.";
  photo = null;
}

const authorName = photo?.author
  ? `${photo.author.firstName} ${photo.author.lastName}`
  : "Автор";
const imageStructuredData = photo
  ? buildImageStructuredData({
      siteOrigin: Astro.site?.origin ?? Astro.url.origin,
      path: `/photo-of-the-day/${id}`,
      name: photo.title,
      description: photo.caption || photo.title,
      image: photo.imageUrl,
      datePublished: photo.createdAt,
      dateModified: photo.updatedAt ?? photo.createdAt,
      authorName: photo.author ? authorName : undefined,
    })
  : [];

// Alpine lazy-load init — same pattern as LazyImage.astro
const xInit = "$el.complete ? ($el.style.opacity='1') : $el.addEventListener('load', () => $el.style.opacity='1')";
---

<Layout
  title={`${photo?.title ?? "Фото дня"} - Maag`}
  description={photo?.title ?? "Фото дня"}
  image={photo?.imageUrl}
  canonicalPath={`/photo-of-the-day/${id}`}
  type="article"
  structuredData={imageStructuredData}
  navbarVariant="default"
  includePreFooterCTA={false}
  useClientRouter={true}
>
  <main class="bg-base-200 min-h-screen">
    <div class="max-w-[1512px] mx-auto">
      {error && <div class="text-red-500 text-center pt-40">{error}</div>}

      {!error && photo && (
        <>
          <div class="pt-[50px] pb-[40px] px-4 lg:px-0 flex flex-col items-center">
            <div class="flex flex-col gap-4 max-w-[825px] w-full">
              <ArticleHeader
                category="Фото дня"
                title={photo.title}
                titleClass="text-3xl lg:text-[42px]"
              />
              <div class="h-10 flex flex-row items-center justify-start gap-4">
                <ArticleAuthor
                  name={authorName}
                  avatarUrl={photo.author?.avatar}
                />
                <ArticleDate createdAt={photo.createdAt} />
              </div>
              <ContentActions
                contentType="photoOfTheDay"
                contentId={id!}
                title={photo.title}
                href={`/photo-of-the-day/${id}`}
                imageUrl={photo.imageUrl}
              />
            </div>
          </div>

          <div class="w-full px-4 lg:px-14 pb-[100px] flex flex-col items-center gap-4">
            <div class="w-full max-w-[1200px] h-[460px] lg:h-[700px] overflow-hidden bg-base-200">
              <img
                src={photo.imageUrl}
                alt={photo.title}
                class="opacity-0 transition-opacity duration-300 w-full h-full object-cover object-center shadow-lg"
                loading="lazy"
                x-data=""
                x-init={xInit}
              />
            </div>

            {photo.caption && (
              <div class="max-w-[826px] w-full">
                <p class="text-sm text-black/60 font-inter font-normal text-center">
                  {photo.caption}
                </p>
                <hr class="w-full border-t border-neutral-200 mt-3" />
              </div>
            )}
          </div>
        </>
      )}
    </div>
  </main>
</Layout>
