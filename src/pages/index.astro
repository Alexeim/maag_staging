---
import Layout from "../Layouts/Layout.astro";
import Hero from "../components/HomePage/Hero.astro";
import MainLandingBlock from "../components/common/MainLandingBlock.astro";
import LandingBody from "../components/common/LandingBody.astro";
import { publicLandingApi } from "@/lib/api/api";

const EMPTY_PUBLIC_LANDING = {
  mainBlock: {
    mainArticle: null,
    newsArticles: [],
    landingEvent: null,
  },
  body: {
    cultureHero: null,
    cultureCardItems: [],
    parisHero: null,
    parisCardItems: [],
    maagChoiceItems: [],
    latestInterview: null,
    carouselItems: [],
    leSaviezVousArticle: null,
    photoOfTheDay: null,
  },
};

const publicLanding = await publicLandingApi.get().catch((error) => {
  console.error("Failed to load public landing data:", error);
  return EMPTY_PUBLIC_LANDING;
});
---

<Layout
  navbarVariant="default"
  includePreFooterCTA={false}
  title="MAAG France — медиа о культуре, искусстве и жизни Парижа"
  description="Авторитетный русскоязычный источник информации о французской культуре и актуальных событиях во Франции. Интервью, рецензии, обзоры выставок, путеводители, афиша и авторские материалы о городе — всё необходимое, чтобы понимать Париж, открывать его новые стороны и чувствовать себя частью его культурной жизни."
  useClientRouter={true}
>
  <Hero />
  <MainLandingBlock data={publicLanding.mainBlock} />
  <LandingBody data={publicLanding.body} />
</Layout>
