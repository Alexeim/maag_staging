---
import AuthorIcon from "@/assets/icons/ix_pen-filled.svg";
import logo from "@/assets/logo/logo.svg";
import { ApiError, visualStoriesApi } from "@/lib/api/api";
import { Info, MoveRight, MoveLeft } from "lucide-astro";

const { id } = Astro.params;

let storyData: any;
let error: string | null = null;

try {
  storyData = await visualStoriesApi.getById(id);
} catch (e: any) {
  if (e instanceof ApiError) {
    error =
      e.status === 404
        ? "Визуальная история не найдена."
        : `Ошибка загрузки: ${e.message}`;
  } else {
    error = `Ошибка загрузки: ${e.message}`;
  }
}

const slides: Array<{ imageUrl: string; text: string; caption?: string }> =
  Array.isArray(storyData?.slides) ? storyData.slides : [];

const title = storyData?.title || "Визуальная история";
const lead = storyData?.lead || "";
const category = storyData?.category || "";
const authorName = storyData?.author
  ? `${storyData.author.firstName ?? ""} ${storyData.author.lastName ?? ""}`.trim()
  : "";

const CATEGORY_LABELS: Record<string, string> = {
  culture: "Культура",
  paris: "Париж",
  hotContent: "Самое Читаемое",
};
const categoryLabel =
  CATEGORY_LABELS[category] || category || "Визуальная история";

const normalizeDate = (value: any): Date | null => {
  if (!value) return null;
  if (typeof value === "string") {
    const d = new Date(value);
    return isNaN(d.getTime()) ? null : d;
  }
  if (typeof value === "object" && typeof value._seconds === "number") {
    return new Date(value._seconds * 1000);
  }
  return null;
};

const createdAt = normalizeDate(storyData?.createdAt);
const dateFormatted = createdAt
  ? createdAt.toLocaleDateString("ru-RU", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";

// Dedicated cover takes priority; fall back to first slide's image
const heroImageUrl = storyData?.imageUrl || slides[0]?.imageUrl || "";
const heroImageCaption =
  storyData?.imageCaption ||
  (!storyData?.imageUrl ? slides[0]?.caption || "" : "");
---

<!doctype html>
<html lang="ru" data-theme="maag">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Maag</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900&family=Old+Standard+TT:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --maag-bg: #ffffff;
        --maag-surface: #faf7f2;
        --maag-text: #000000;
        --maag-muted: rgba(48, 40, 33, 0.6);
        --maag-muted-soft: rgba(48, 40, 33, 0.4);
        --maag-accent: #d92f1c;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Inter", sans-serif;
        background: var(--maag-bg);
        color: var(--maag-text);
        overflow: hidden;
      }

      /* ── slider mechanics ─────────────────────────── */
      .story {
        position: relative;
        width: 100vw;
        height: 100vh;
        overflow: hidden;
      }

      .slider {
        display: flex;
        width: 100%;
        height: 100%;
        transition: transform 0.5s ease;
        will-change: transform;
      }

      .slide {
        min-width: 100vw;
        height: 100vh;
        display: flex;
      }

      /* ── shared halves ────────────────────────────── */
      .slide-image {
        position: relative;
        width: 50%;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-color: var(--maag-surface);
        flex-shrink: 0;
      }

      .image-caption-hint {
        position: absolute;
        right: 22px;
        bottom: 22px;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 10px;
        z-index: 3;
      }

      .image-caption-trigger {
        width: 38px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        cursor: pointer;
        background: none;
        border: none;
        padding: 0;
        transition: transform 0.2s ease;
      }

      .image-caption-trigger:hover,
      .image-caption-trigger:focus-visible {
        transform: translateY(-1px);
        outline: none;
      }

      .image-caption-popover {
        max-width: min(320px, calc(100vw - 64px));
        padding: 12px 14px;
        border-radius: 0;
        background: rgba(0, 0, 0, 0.76);
        color: #ffffff;
        font-family: "Inter", sans-serif;
        font-size: 0.8125rem;
        line-height: 1.5;
        box-shadow: 0 18px 42px rgba(0, 0, 0, 0.22);
        opacity: 0;
        transform: translateX(8px);
        pointer-events: none;
        transition:
          opacity 0.2s ease,
          transform 0.2s ease;
      }

      .image-caption-hint:hover .image-caption-popover,
      .image-caption-hint:focus-within .image-caption-popover {
        opacity: 1;
        transform: translateX(0);
      }

      .slide-content {
        width: 50%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 56px 64px;
        flex-shrink: 0;
        background: var(--maag-bg);
      }

      /* ── hero slide ───────────────────────────────── */
      .hero-category {
        font-family: "Inter", sans-serif;
        font-size: 0.75rem;
        line-height: 1rem;
        font-weight: 700;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--maag-accent);
        margin: 0;
      }

      .hero-title {
        font-family: "Old Standard TT", serif;
        font-size: clamp(1.875rem, 4vw, 3.25rem);
        font-weight: 400;
        line-height: 1.1;
        letter-spacing: -0.02em;
        margin: 8px 0 0;
        color: var(--maag-text);
      }

      .hero-lead {
        font-family: "Inter", sans-serif;
        font-size: clamp(1.125rem, 1.7vw, 1.25rem);
        font-weight: 400;
        line-height: 1.7;
        letter-spacing: -0.01em;
        margin: 12px 0 0;
        color: rgba(0, 0, 0, 0.8);
        max-width: 38rem;
      }

      .hero-meta {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 20px;
      }

      .hero-meta-author {
        display: inline-flex;
        align-items: center;
        gap: 17px;
        font-family: "Old Standard TT", serif;
        font-size: 1.25rem;
        font-style: italic;
        line-height: 1.2;
        color: var(--maag-text);
      }

      .hero-meta-author-icon {
        width: 1rem;
        height: 1rem;
        flex-shrink: 0;
      }

      .hero-meta-date {
        font-family: "Inter", sans-serif;
        font-size: 0.875rem;
        line-height: 1;
        color: var(--maag-muted);
      }

      .hero-meta-dot {
        font-size: 10px;
        color: var(--maag-muted-soft);
      }

      /* ── content slide text ───────────────────────── */
      .slide-counter {
        font-family: "Inter", sans-serif;
        font-size: 0.75rem;
        line-height: 1rem;
        font-weight: 700;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--maag-muted);
        margin-bottom: auto;
        padding-bottom: 0;
        align-self: flex-end;
      }

      .slide-text-body {
        flex: 1;
        display: flex;
        align-items: center;
      }

      .slide-text-body p {
        font-family: "Inter", sans-serif;
        font-size: clamp(1.125rem, 1.6vw, 1.25rem);
        font-weight: 400;
        line-height: 1.7;
        letter-spacing: -0.01em;
        margin: 0;
        color: rgba(0, 0, 0, 0.8);
        max-width: 34rem;
      }

      /* ── nav ──────────────────────────────────────── */
      .nav {
        position: fixed;
        right: 30px;
        bottom: 30px;
        display: flex;
        align-items: center;
        gap: 10px;
        z-index: 10;
      }

      .nav button {
        background: transparent;
        border: 1px solid rgba(0, 0, 0, 0.45);
        color: var(--maag-text);
        padding: 10px 18px;
        cursor: pointer;
        font-family: "Inter", sans-serif;
        font-size: 0.75rem;
        line-height: 1rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        transition:
          opacity 0.2s ease,
          border-color 0.2s ease;
      }

      .nav button:hover:not(:disabled) {
        border-color: var(--maag-text);
      }

      .nav button:disabled {
        opacity: 0.25;
        cursor: default;
      }

      /* ── back link ────────────────────────────────── */
      .back-link {
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease-out;
      }

      .back-link:hover {
        transform: scale(1.05);
      }

      .error-state {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 32px;
      }

      .error-message {
        margin: 0;
        font-family: "Inter", sans-serif;
        font-size: 0.95rem;
        line-height: 1.6;
        color: var(--maag-muted);
      }

      /* ── mobile ───────────────────────────────────── */
      @media (max-width: 900px) {
        body {
          overflow: auto;
        }

        .story {
          height: auto;
          min-height: 100vh;
          padding-bottom: 92px;
        }

        .slider {
          height: auto;
        }

        .slide {
          min-width: 100vw;
          height: auto;
          min-height: 100vh;
          flex-direction: column;
        }

        .slide-image {
          width: 100%;
          min-height: 52vh;
        }

        .image-caption-hint {
          right: 16px;
          bottom: 16px;
        }

        .image-caption-popover {
          max-width: min(280px, calc(100vw - 48px));
        }

        .slide-content {
          width: 100%;
          padding: 36px 28px;
          justify-content: flex-start;
        }

        .slide-text-body p {
          font-size: 1.125rem;
          max-width: none;
        }

        .hero-title {
          font-size: 2.25rem;
        }

        .hero-meta-author {
          font-size: 1.1rem;
        }

        .hero-meta-date {
          font-size: 0.75rem;
        }

        .nav {
          right: 16px;
          bottom: 16px;
        }
      }
    </style>
  </head>

  <body class="bg-base-100 text-base-content">
    {
      error ? (
        <div class="error-state">
          <p class="error-message">{error}</p>
        </div>
      ) : (
        <main class="story">
          <div class="slider" id="slider">
            {/* ── Hero slide ──────────────────────────── */}
            <section class="slide">
              <div
                class="slide-image bg-base-200"
                style={
                  heroImageUrl ? `background-image:url('${heroImageUrl}')` : ""
                }
              >
                {heroImageCaption && (
                  <div class="image-caption-hint">
                    <div class="image-caption-popover">{heroImageCaption}</div>
                    <button
                      type="button"
                      class="image-caption-trigger"
                      aria-label="Показать подпись к изображению"
                    >
                      <Info class="w-4 h-4" />
                    </button>
                  </div>
                )}
              </div>
              <div class="slide-content bg-base-100">
                <p class="hero-category text-accent">{categoryLabel}</p>
                <h1 class="hero-title text-base-content">{title}</h1>
                {lead && <p class="hero-lead text-base-content">{lead}</p>}
                {(authorName || dateFormatted) && (
                  <div class="hero-meta text-base-content">
                    {authorName && (
                      <span class="hero-meta-author">
                        <AuthorIcon class="hero-meta-author-icon" />
                        <span>{authorName}</span>
                      </span>
                    )}
                    {dateFormatted && (
                      <span class="hero-meta-date">{dateFormatted}</span>
                    )}
                  </div>
                )}
              </div>
            </section>

            {/* ── Content slides ──────────────────────── */}
            {slides.map((slide, i) => (
              <section class="slide">
                <div
                  class="slide-image"
                  style={`background-image:url('${slide.imageUrl}')`}
                >
                  {slide.caption && (
                    <div class="image-caption-hint">
                      <div class="image-caption-popover">{slide.caption}</div>
                      <button
                        type="button"
                        class="image-caption-trigger"
                        aria-label="Показать подпись к изображению"
                      >
                        <Info class="w-4 h-4" />
                      </button>
                    </div>
                  )}
                </div>
                <div class="slide-content bg-base-100">
                  <span class="slide-counter text-base-content">
                    {String(i + 1).padStart(2, "0")} /{" "}
                    {String(slides.length).padStart(2, "0")}
                  </span>
                  <div class="slide-text-body">
                    <p class="text-base-content">{slide.text}</p>
                  </div>
                </div>
              </section>
            ))}
          </div>

          <div class="nav">
            <a href="/" class="back-link" aria-label="На главную">
              <img src={logo.src} alt="Maag logo" class="w-10" />
            </a>
            <button
              id="prev-button"
              type="button"
              aria-label="Предыдущий слайд"
              class="border border-base-content text-base-content flex items-center justify-center"
            >
              <MoveLeft class="w-2 h-2" />
            </button>
            <button
              id="next-button"
              type="button"
              aria-label="Следующий слайд"
              class="border border-base-content text-base-content flex items-center justify-center"
            >
              <MoveRight class="w-2 h-2" />
            </button>
          </div>
        </main>
      )
    }

    <script>
      const slider = document.getElementById("slider");
      const prevBtn = document.getElementById(
        "prev-button",
      ) as HTMLButtonElement | null;
      const nextBtn = document.getElementById(
        "next-button",
      ) as HTMLButtonElement | null;
      const total = document.querySelectorAll(".slide").length;

      let index = 0;

      const update = () => {
        if (!slider || !prevBtn || !nextBtn) return;
        slider.style.transform = `translateX(-${index * 100}vw)`;
        prevBtn.disabled = index === 0;
        nextBtn.disabled = index === total - 1;
      };

      prevBtn?.addEventListener("click", () => {
        if (index > 0) {
          index--;
          update();
        }
      });
      nextBtn?.addEventListener("click", () => {
        if (index < total - 1) {
          index++;
          update();
        }
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "ArrowRight" || e.key === "ArrowDown") {
          if (index < total - 1) {
            index++;
            update();
          }
        } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
          if (index > 0) {
            index--;
            update();
          }
        }
      });

      update();
    </script>
  </body>
</html>
