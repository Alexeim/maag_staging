---
import Layout from "../../Layouts/Layout.astro";
import TipsArticleBody from "../../components/article/TipsArticleBody.astro";
import ContentCollectionMarquee from "@/components/article/ContentCollectionMarquee.astro";
import ContentActions from "@/components/common/ContentActions.astro";
import TipsHero from "@/components/tips/TipsHero.astro";
import picture1 from "@/assets/images/culture.jpg";
import { getKnownTagLabel } from "@/content/tags/parisTags";
import {
  ApiError,
  articlesApi,
} from "@/lib/api/api";
import {
  buildContentCollectionItems,
  fetchPublicContentPools,
  toDate,
} from "@/lib/utils/contentCollectionMarquee";
import { buildArticleStructuredData } from "@/lib/seo/structuredData";

const { id } = Astro.params as { id: string };

const CATEGORY_LABELS: Record<string, string> = {
  culture: "Культура",
  paris: "Париж",
  hotContent: "Самое Читаемое",
};

let articleData: any;
let error: string | null = null;

try {
  articleData = await articlesApi.getById(id);
} catch (e: any) {
  console.error(e);
  if (e instanceof ApiError) {
    error =
      e.status === 404
        ? "Статья не найдена."
        : `Ошибка загрузки: ${e.message}`;
  } else {
    error = `Ошибка загрузки: ${e.message}`;
  }
}

if (!error && articleData?.published !== true) {
  error = "Статья не найдена.";
  articleData = null;
}

const rawCategory =
  articleData?.category ?? articleData?.header?.category ?? null;

const displayArticle = {
  title: articleData?.header?.title || articleData?.title || "Статья",
  lead: articleData?.lead || "",
  category: rawCategory
    ? CATEGORY_LABELS[rawCategory] || rawCategory
    : "Категория",
  authorName: articleData?.author
    ? `${articleData.author.firstName} ${articleData.author.lastName}`
    : "Автор",
  authorAvatar: articleData?.author?.avatar,
  imageUrl: articleData?.imageUrl,
  imageCaption: articleData?.imageCaption || "",
  imageAlt: articleData?.mainImage?.alt || "Обложка статьи",
  contentBlocks: articleData?.content || [],
};

const firstBookmarkTag =
  Array.isArray(articleData?.tags) && typeof articleData.tags[0] === "string"
    ? getKnownTagLabel(articleData.tags[0]) || ""
    : "";
const bookmarkCategory =
  rawCategory === "culture" || rawCategory === "paris"
    ? CATEGORY_LABELS[rawCategory]
    : "";
const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const articleStructuredData = articleData
  ? buildArticleStructuredData({
      siteOrigin,
      path: `/tips/${id}`,
      headline: displayArticle.title,
      description: displayArticle.lead,
      image: displayArticle.imageUrl,
      datePublished: articleData.createdAt,
      dateModified: articleData.updatedAt ?? articleData.createdAt,
      authorName: articleData.author ? displayArticle.authorName : undefined,
    })
  : [];

let collectionContentItems: any[] = [];
let sameCategoryItems: any[] = [];

if (!error && articleData) {
  try {
    const pools = await fetchPublicContentPools();
    const allArticles = pools.allArticles;
    collectionContentItems = await buildContentCollectionItems({
      contentCollectionId: articleData?.contentCollectionId,
      currentContentType: "article",
      currentId: id,
      pools,
    });

    const currentCategory = rawCategory?.toLowerCase() ?? null;
    const relatedArticleIds = new Set(collectionContentItems.filter((i) => i.contentType === "article").map((i) => i.id));
    sameCategoryItems = allArticles
      .filter((i) => i.id !== id && !relatedArticleIds.has(i.id))
      .filter((i) => i?.articleType === "tips")
      .filter((i) => !currentCategory || i?.category?.toLowerCase() === currentCategory)
      .sort((a, b) => (toDate(b?.createdAt)?.getTime() ?? 0) - (toDate(a?.createdAt)?.getTime() ?? 0))
      .slice(0, 12)
      .map((item) => ({ ...item }));
  } catch (e) {
    console.error("Failed to fetch collection content for tips page:", e);
  }
}
---

<Layout
  navbarVariant="default"
  includePreFooterCTA={false}
  title={`${displayArticle.title} - Maag`}
  description={displayArticle.lead}
  image={displayArticle.imageUrl}
  canonicalPath={`/tips/${id}`}
  type="article"
  structuredData={articleStructuredData}
  useClientRouter={true}
>
  <main class="bg-base-200 min-h-screen">
    <div class="max-w-[1512px] mx-auto">
      {error && <div class="text-red-500 text-center pt-40">{error}</div>}
      {!error && articleData && (
        <>
          <TipsHero
            category={displayArticle.category}
            title={displayArticle.title}
            lead={displayArticle.lead}
            authorName={displayArticle.authorName}
            authorAvatar={displayArticle.authorAvatar}
            createdAt={articleData.createdAt}
            imageUrl={displayArticle.imageUrl}
            imageAlt={displayArticle.imageAlt}
            imageCaption={displayArticle.imageCaption}
            heroOrientation={articleData?.heroOrientation ?? "image-right"}
          />

          <!-- Tips content -->
          <div class="w-full px-4 lg:px-14 pt-10 pb-[100px] lg:pt-16">
            <div class="mx-auto mb-10 max-w-[826px]">
              <ContentActions
                contentType="tips"
                contentId={id}
                title={displayArticle.title}
                href={`/tips/${id}`}
                category={bookmarkCategory}
                tag={firstBookmarkTag}
                imageUrl={displayArticle.imageUrl}
                align="center"
              />
            </div>
            <TipsArticleBody contentBlocks={displayArticle.contentBlocks} />
            <ContentCollectionMarquee
              collectionItems={collectionContentItems}
              categoryItems={sameCategoryItems}
              fallbackImageSrc={picture1.src}
            />
          </div>
        </>
      )}
    </div>
  </main>
</Layout>
