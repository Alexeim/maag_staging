---
import Layout from "@/Layouts/Layout.astro";
import { Share2, Clock, MapPin, ExternalLink } from "lucide-astro";

const displayArticle = {
  category: "culture",
  title: "ТЕАТРАЛЬНЫЙ ПАРИЖ: ЧТО СМОТРЕТЬ В МАЕ",
  lead: "Главные постановки сезона в Комеди Франсез и театре Шатле.",
  cardLead: "От классических трагедий до авангардных перформансов — наш гид по лучшим сценам города.",
  authorName: "Стендаль",
  createdAt: new Date(),
  imageUrl: "https://images.unsplash.com/photo-1516307365427-ba5b1c287c1b?q=80&w=2070&auto=format&fit=crop",
  imageCaption: "Интерьеры театра Шатле после реставрации.",
  tags: ["Театр", "Париж", "Культура"],
  contentBlocks: [
    { type: 'paragraph', text: 'Май обещает быть насыщенным на премьеры. Особое внимание стоит уделить новой трактовке "Мольера", которая объединила классический текст с электронной музыкой.' },
    { type: 'url-link', text: 'Заказать билеты онлайн', url: 'https://theatre.fr' }
  ]
};

const CATEGORY_LABELS: Record<string, string> = { culture: "Культура", paris: "Париж" };
const categoryLabel = CATEGORY_LABELS[displayArticle.category] || "Новости";
const formattedDate = new Intl.DateTimeFormat('ru-RU', { day: 'numeric', month: 'short' }).format(displayArticle.createdAt);
---

<Layout title="Brutalist Box - News Variant 5">
  <main class="bg-base-200 min-h-screen py-10 lg:py-24">
    <div class="max-w-[1000px] mx-auto px-4">
      
      <div class="bg-base-100 border-2 border-base-content shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] overflow-hidden">
        
        <!-- Header -->
        <header class="p-8 lg:p-12 border-b-2 border-base-content bg-primary/10">
           <div class="flex items-center gap-4 mb-6">
              <span class="bg-base-content text-base-100 px-3 py-1 font-oswald text-[10px] uppercase tracking-widest">{categoryLabel}</span>
              <span class="text-base-content/40 font-inter text-[10px] uppercase tracking-widest">{formattedDate}</span>
           </div>
           <h1 class="text-5xl lg:text-7xl font-oswald font-bold leading-[0.9] uppercase tracking-tighter mb-8">
              {displayArticle.title}
           </h1>
           <p class="text-xl lg:text-2xl font-inter font-medium leading-tight">
              {displayArticle.lead}
           </p>
        </header>

        <!-- Image with brutalist frame -->
        <div class="p-4 bg-base-100 border-b-2 border-base-content">
           <img src={displayArticle.imageUrl} class="w-full h-auto grayscale contrast-125" alt="" />
           <p class="mt-4 text-[9px] font-oswald text-base-content/40 uppercase tracking-[0.3em] text-center">
             {displayArticle.imageCaption}
           </p>
        </div>

        <!-- Content Body -->
        <div class="p-8 lg:p-16">
           <div class="max-w-[700px] mx-auto space-y-12">
              {displayArticle.cardLead && (
                <div class="p-8 bg-base-200 border-2 border-base-content shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
                   <p class="text-lg font-inter italic leading-relaxed">{displayArticle.cardLead}</p>
                </div>
              )}

              <div class="space-y-8 font-article-body text-base-content/90 text-xl leading-relaxed">
                 {displayArticle.contentBlocks.map(block => (
                   block.type === 'paragraph' ? (
                     <p>{block.text}</p>
                   ) : (
                     <a href={block.url} target="_blank" class="flex items-center justify-between p-6 border-2 border-base-content bg-accent text-accent-content hover:translate-x-1 hover:-translate-y-1 transition-transform shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
                        <span class="font-oswald uppercase text-lg tracking-tight font-bold">{block.text}</span>
                        <ExternalLink class="w-6 h-6" />
                     </a>
                   )
                 ))}
              </div>

              <!-- Footer info -->
              <footer class="mt-20 pt-10 border-t-2 border-base-content/10 flex flex-col sm:flex-row justify-between items-center gap-8">
                 <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-base-content text-base-100 flex items-center justify-center font-bold text-xl uppercase">
                       {displayArticle.authorName[0]}
                    </div>
                    <div>
                       <p class="text-[9px] uppercase font-oswald text-base-content/30 mb-1">Editor-in-Chief</p>
                       <p class="font-oswald uppercase text-base">{displayArticle.authorName}</p>
                    </div>
                 </div>
                 <div class="flex flex-wrap gap-2 justify-center">
                    {displayArticle.tags.map(tag => <span class="px-3 py-1 border-2 border-base-content text-[10px] font-oswald uppercase font-bold tracking-widest">{tag}</span>)}
                 </div>
              </footer>
           </div>
        </div>

      </div>
    </div>
  </main>
</Layout>
