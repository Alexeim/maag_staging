---
import { Image } from "astro:assets";
import Layout from "@/Layouts/Layout.astro";
import ArticleHeader from "@/components/article/ArticleHeader.astro";
import ArticleAuthor from "@/components/article/ArticleAuthor.astro";
import ArticleDate from "@/components/article/ArticleDate.astro";
import ArticleImage from "@/components/article/ArticleImage.astro";
import ArticleBody from "@/components/article/ArticleBody.astro";
import ContentCollectionMarquee from "@/components/article/ContentCollectionMarquee.astro";
import ContentActions from "@/components/common/ContentActions.astro";
import picture1 from "@/assets/images/culture.jpg";
import { getKnownTagLabel } from "@/content/tags/parisTags";
import { ApiError, newsApi } from "@/lib/api/api";
import {
  buildLinkedContentLookup,
  buildContentCollectionItems,
  fetchPublicContentPools,
  toDate,
  type LinkedContentLookup,
} from "@/lib/utils/contentCollectionMarquee";

const { id } = Astro.params;

const CATEGORY_LABELS: Record<string, string> = {
  culture: "Культура",
  paris: "Париж",
  hotContent: "Самое Читаемое",
  interview: "Интервью",
  ballet: "Балет",
  opera: "Опера",
  dance: "Танец",
  music: "Музыка",
  theatre: "Театр",
  theater: "Театр",
  performance: "Спектакль",
  performances: "Спектакль",
  concert: "Концерт",
  concerts: "Концерт",
  exhibition: "Выставка",
  exhibitions: "Выставка",
  books: "Книги",
  artMarket: "Арт-рынок",
  artmarket: "Арт-рынок",
  architecture: "Архитектура",
  museums: "Музеи",
  tourism: "Туризм",
  strike: "Забастовка",
  kids: "Дети",
  route: "Маршрут",
  address: "Адрес",
  notebook: "Записная книжка",
  place: "Место",
  news: "Новости",
  ...Object.fromEntries(
    Array.from({ length: 20 }, (_, i) => [
      `district-${i + 1}`,
      `${i + 1}-й округ`,
    ]),
  ),
};

const normalizeCategory = (value?: string) => {
  if (!value) {
    return value;
  }
  const lowerCaseValue = value.toLowerCase();
  const entry = Object.entries(CATEGORY_LABELS).find(
    ([key, label]) =>
      key.toLowerCase() === lowerCaseValue ||
      label.toLowerCase() === lowerCaseValue,
  );
  return entry ? entry[0] : value;
};

const getCategoryLabel = (value?: string) => {
  const normalized = normalizeCategory(value);
  if (normalized && CATEGORY_LABELS[normalized]) {
    return CATEGORY_LABELS[normalized];
  }
  return value ?? "";
};

const getPrimaryTag = (article: any) => {
  const rawTags = Array.isArray(article?.tags)
    ? article.tags
    : typeof article?.tags === "string"
      ? [article.tags]
      : [];

  const firstTag = rawTags.find(
    (tag) => typeof tag === "string" && tag.trim().length > 0,
  );

  if (firstTag) {
    return (
      getKnownTagLabel(firstTag.trim()) || getCategoryLabel(firstTag.trim())
    );
  }

  if (article?.isHotContent) {
    return CATEGORY_LABELS.hotContent;
  }

  return getCategoryLabel(article?.category);
};

let articleData: any;
let error: string | null = null;

try {
  articleData = await newsApi.getById(id!);
} catch (e: any) {
  console.error(e);
  if (e instanceof ApiError) {
    error =
      e.status === 404
        ? "Новость не найдена."
        : `Ошибка загрузки: ${e.message}`;
  } else {
    error = `Ошибка загрузки: ${e.message}`;
  }
}

if (!error && articleData?.published !== true) {
  error = "Новость не найдена.";
  articleData = null;
}

const displayArticle = {
  title: articleData?.title || "Новость",
  lead: articleData?.lead || "",
  category: getPrimaryTag(articleData) || "Новость",
  authorName: articleData?.author
    ? `${articleData.author.firstName} ${articleData.author.lastName}`
    : "Автор",
  authorAvatar: articleData?.author?.avatar,
  imageUrl: articleData?.imageUrl,
  imageCaption: articleData?.imageCaption || "",
  imageAlt: articleData?.title || "News image",
  contentBlocks: articleData?.content || [],
};

const bookmarkCategory =
  articleData?.category === "culture" || articleData?.category === "paris"
    ? getCategoryLabel(articleData.category)
    : "";
const firstBookmarkTag =
  Array.isArray(articleData?.tags) && typeof articleData.tags[0] === "string"
    ? articleData.tags[0].trim()
    : "";
const bookmarkTag = firstBookmarkTag
  ? getKnownTagLabel(firstBookmarkTag) || getCategoryLabel(firstBookmarkTag)
  : "";

const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const canonicalUrl = new URL(`/news/${id}`, siteOrigin).toString();
const organizationId = new URL("/#organization", siteOrigin).toString();
const toAbsoluteUrl = (value?: string) =>
  value ? new URL(value, siteOrigin).toString() : undefined;
const toIsoDate = (value: unknown) => toDate(value)?.toISOString();
const articleAuthor = articleData?.author
  ? {
      "@type": "Person",
      name: displayArticle.authorName,
    }
  : {
      "@id": organizationId,
    };
const articleStructuredData = articleData
  ? {
      "@context": "https://schema.org",
      "@type": "NewsArticle",
      headline: displayArticle.title,
      description: displayArticle.lead,
      image: displayArticle.imageUrl
        ? [toAbsoluteUrl(displayArticle.imageUrl)]
        : undefined,
      datePublished: toIsoDate(articleData.createdAt),
      dateModified: toIsoDate(articleData.updatedAt ?? articleData.createdAt),
      author: articleAuthor,
      publisher: {
        "@id": organizationId,
      },
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": canonicalUrl,
      },
      inLanguage: "ru",
    }
  : [];

let collectionContentItems: any[] = [];
let sameCategoryItems: any[] = [];
let moreNewsItems: any[] = [];
let linkedContentLookup: LinkedContentLookup = {};

if (!error && articleData) {
  try {
    const pools = await fetchPublicContentPools();
    linkedContentLookup = buildLinkedContentLookup(pools);
    const allNews = pools.allNews;
    collectionContentItems = await buildContentCollectionItems({
      contentCollectionId: articleData?.contentCollectionId,
      currentContentType: "news",
      currentId: id,
      pools,
    });

    const currentCategory = articleData?.category?.toLowerCase?.() ?? null;
    const relatedNewsIds = new Set(
      collectionContentItems
        .filter((i) => i.contentType === "news")
        .map((i) => i.id),
    );
    sameCategoryItems = allNews
      .filter((i) => i.id !== id && !relatedNewsIds.has(i.id))
      .filter(
        (i) =>
          !currentCategory || i?.category?.toLowerCase() === currentCategory,
      )
      .sort(
        (a, b) =>
          (toDate(b?.createdAt)?.getTime() ?? 0) -
          (toDate(a?.createdAt)?.getTime() ?? 0),
      )
      .slice(0, 12)
      .map((item) => ({ ...item }));

    const seenMoreNewsIds = new Set<string>();
    const appendUniqueNewsItems = (items: any[]) => {
      items.forEach((item) => {
        if (
          item?.contentType !== "news" ||
          item?.id === id ||
          seenMoreNewsIds.has(item.id)
        ) {
          return;
        }
        seenMoreNewsIds.add(item.id);
        moreNewsItems.push(item);
      });
    };

    appendUniqueNewsItems(collectionContentItems);
    appendUniqueNewsItems(sameCategoryItems);
    moreNewsItems = moreNewsItems.slice(0, 6);
  } catch (e) {
    console.error("Failed to fetch collection content for news page:", e);
  }
}
---

<Layout
  title={`${displayArticle.title} - Maag`}
  description={displayArticle.lead}
  image={displayArticle.imageUrl}
  canonicalPath={`/news/${id}`}
  type="article"
  structuredData={articleStructuredData}
  navbarVariant="default"
  includePreFooterCTA={false}
  useClientRouter={true}
>
  <main class="bg-base-200 min-h-screen">
    <div class="max-w-[1512px] mx-auto">
      {error && <div class="text-red-500 text-center pt-40">{error}</div>}
      {
        !error && articleData && (
          <>
            <div class="px-4 pb-[100px] pt-[50px] lg:px-14">
              <section class="grid gap-10 lg:grid-cols-12 lg:gap-8 lg:items-start">
                <div class="grid gap-10 lg:col-span-9">
                  <article class="grid gap-10">
                    <div class="mx-auto flex w-full max-w-[825px] flex-col gap-4 lg:mx-0">
                      <ArticleHeader
                        category={displayArticle.category}
                        title={displayArticle.title}
                        lead={displayArticle.lead}
                        titleClass="text-3xl lg:text-[42px]"
                      />
                      <div class="flex flex-col items-start justify-center gap-4">
                        <ArticleAuthor
                          name={displayArticle.authorName}
                          avatarUrl={displayArticle.authorAvatar}
                        />
                        <ArticleDate createdAt={articleData.createdAt} />
                        <ContentActions
                          contentType="news"
                          contentId={id!}
                          title={displayArticle.title}
                          href={`/news/${id}`}
                          category={bookmarkCategory}
                          tag={bookmarkTag}
                          imageUrl={displayArticle.imageUrl}
                        />
                      </div>
                    </div>

                    {displayArticle.imageUrl && (
                      <div class="mx-auto w-full max-w-[826px] lg:mx-0">
                        <ArticleImage
                          src={displayArticle.imageUrl}
                          alt={displayArticle.imageAlt}
                          caption={displayArticle.imageCaption}
                          figureClass="max-w-[826px]"
                          imageClass="shadow-lg"
                          figcaptionClass="text-center text-gray-500 mt-2"
                          objectFit="cover"
                        />
                      </div>
                    )}

                    <div class="pt-2">
                      <div class="bg-base-200 px-0 pb-0 pt-0 text-base-content">
                        <div class="mx-auto w-full max-w-[826px] lg:mx-0">
                          <ArticleBody
                            contentBlocks={displayArticle.contentBlocks}
                            linkedContentLookup={linkedContentLookup}
                          />
                        </div>
                      </div>
                    </div>
                  </article>
                </div>

                <aside class="lg:col-span-3 lg:border-l lg:border-base-content/10 lg:pl-6">
                  <div class="grid gap-6 lg:sticky lg:top-8">
                    <h2 class="m-0 font-old_standard text-lg font-semibold uppercase tracking-[0.3em] text-base-content">
                      новости
                    </h2>

                    {moreNewsItems.length > 0 ? (
                      <div class="flex gap-6 overflow-x-auto pb-2 -mx-2 px-2 lg:flex-col lg:gap-0 lg:mx-0 lg:px-0 lg:overflow-x-visible lg:overflow-y-hidden">
                        {moreNewsItems.map((newsItem) => (
                          <div class="flex-shrink-0 w-[280px] sm:w-1/2 md:w-1/3 lg:w-full lg:py-4 lg:border-b lg:border-base-content/15 last:lg:border-b-0">
                            <div
                              class="flex items-start gap-4"
                            >
                              <a
                                href={`/news/${newsItem.id}`}
                                class="linked-image-hover bg-base-200 z-10"
                              >
                                <Image
                                  src={newsItem.imageUrl || picture1.src}
                                  alt={`News image for ${newsItem.title}`}
                                  class="linked-image-hover__media w-20 h-20 object-cover flex-shrink-0"
                                  width={80}
                                  height={80}
                                />
                              </a>
                              <div class="flex-1 max-w-max">
                                <div class="mb-1 flex items-start">
                                  <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                                    {getPrimaryTag(newsItem) || "Новости"}
                                  </span>
                                </div>
                                <a
                                  href={`/news/${newsItem.id}`}
                                  class="block bg-base-200 z-10 transition-opacity duration-200 hover:opacity-90"
                                >
                                  <h3 class="text-xl font-normal font-old_standard tracking-[-0.02em] hover:underline transition-opacity duration-200 hover:opacity-90">
                                    {newsItem.title}
                                  </h3>
                                </a>
                              </div>
                            </div>
                          </div>
                        ))}
                      </div>
                    ) : (
                      <p class="m-0 font-inter text-[0.9rem] leading-[1.6] text-base-content/60">
                        Пока нет других новостей в этой категории.
                      </p>
                    )}
                  </div>
                </aside>
              </section>

              <ContentCollectionMarquee
                collectionItems={collectionContentItems}
                categoryItems={sameCategoryItems}
                fallbackImageSrc={picture1.src}
              />
            </div>
          </>
        )
      }
    </div>
  </main>
</Layout>
