  @keyframes rubric-marquee-scroll {
    from {
      transform: translateX(-50%);
    }
    to {
      transform: translateX(0);
    }
  }

  .rubric-marquee-track {
    animation: rubric-marquee-scroll 240s linear infinite;
  }

  .rubric-marquee-track:hover {
