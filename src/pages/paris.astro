---
import Layout from "../Layouts/Layout.astro";
import NetlenkaCard from "@/components/common/NetlenkaCard.astro";
import MaagLogoPaid from "../assets/logo/maaglogo.svg";
import { getKnownTagLabel, isLegacyParisTag } from "@/content/tags/parisTags";
import picture1 from "../assets/images/culture.jpg";
import {
  articlesApi,
  editorialPlacementsApi,
  flippersApi,
  guidesApi,
  visualStoriesApi,
  newsApi,
  type ParisPagePlacementsResponse,
} from "@/lib/api/api";

const CATEGORY_LABELS: Record<string, string> = {
  paris: "Париж",
  hotContent: "Самое Читаемое",
};

const PARIS_CATEGORY_KEY = "paris";
const HOT_CONTENT_CATEGORY_KEY = "hotContent";
const MAX_EDITORIAL_GRID_ITEMS = 12;

const normalizeCategory = (value?: string) => {
  if (!value) return null;
  const lowerCaseValue = value.toLowerCase().trim();
  const entry = Object.entries(CATEGORY_LABELS).find(
    ([key, label]) =>
      key.toLowerCase() === lowerCaseValue ||
      label.toLowerCase() === lowerCaseValue,
  );
  return entry ? entry[0] : lowerCaseValue;
};

const TAG_LABEL_ALIASES: Record<string, string> = {
  exhibition: "Выставка",
  exhibitions: "Выставка",
  concert: "Концерт",
  concerts: "Концерт",
  performance: "Спектакль",
  performances: "Спектакль",
  theatre: "Театр",
  theater: "Театр",
  theatres: "Театры",
  theaters: "Театры",
  culture: "Культура",
  paris: "Париж",
  books: "Книги",
  artMarket: "Арт-рынок",
  artmarket: "Арт-рынок",
  architecture: "Архитектура",
  museums: "Музеи",
  tourism: "Туризм",
  strike: "Забастовка",
  kids: "Дети",
  opera: "Опера",
  ballet: "Балет",
  dance: "Танец",
  music: "Музыка",
  route: "Маршрут",
  address: "Адрес",
  notebook: "Записная книжка",
  place: "Место",
  ...Object.fromEntries(
    Array.from({ length: 20 }, (_, i) => [
      `district-${i + 1}`,
      `${i + 1}-й округ`,
    ]),
  ),
};

const isHotContent = (item: any) =>
  Boolean(item?.isHotContent) ||
  normalizeCategory(item?.category) === HOT_CONTENT_CATEGORY_KEY;

const isMainInCategoryItem = (item: any) =>
  item?.isMainInCategory === true ||
  item?.isMainInCategory === "true" ||
  item?.isMainInCategory === 1 ||
  item?.isMainInCategory === "1";

const isLeSaviezVousArticle = (item: any) =>
  item?.articleType === "le_saviez_vous";

const getDate = (timestamp: any): Date => {
  if (timestamp instanceof Date) {
    return timestamp;
  }
  if (timestamp && typeof timestamp === "object" && "_seconds" in timestamp) {
    return new Date((timestamp as { _seconds: number })._seconds * 1000);
  }
  return new Date(timestamp);
};

const formatDate = (value: unknown) => {
  const date = getDate(value);
  if (Number.isNaN(date.getTime())) {
    return "";
  }
  return date
    .toLocaleDateString("ru-RU", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    })
    .replace(" г.", "");
};

const normalizeTags = (value: unknown): string[] => {
  if (!Array.isArray(value)) {
    return [];
  }
  return value
    .map((tag) => (typeof tag === "string" ? tag.trim() : ""))
    .filter((tag) => Boolean(tag) && !isLegacyParisTag(tag));
};

const getPrimaryTag = (item: any): string => {
  const tags = normalizeTags(item?.tags);
  if (tags.length === 0) {
    return item?.isNews ? "Новости" : "";
  }
  const firstTag = tags[0];
  const normalized = firstTag.toLowerCase();
  return TAG_LABEL_ALIASES[normalized] ?? getKnownTagLabel(firstTag);
};

const getCardLead = (item: any): string => {
  const cardLead =
    typeof item?.cardLead === "string" ? item.cardLead.trim() : "";
  return cardLead;
};

const toContentHref = (item: any) => {
  if (item?.contentType === "flipper") {
    return `/flippers/${item.id}`;
  }
  if (item?.contentType === "guide") {
    return `/guide/${item.id}`;
  }
  if (item?.contentType === "visual-story") {
    return `/visual-story/${item.id}`;
  }
  return `/${item?.isNews ? "news" : "article"}/${item.id}`;
};

const truncateText = (text?: string, maxLength: number = 220) => {
  if (!text) return "";
  if (text.length <= maxLength) return text;
  const truncated = text.slice(0, maxLength).trim();
  const lastSpaceIndex = truncated.lastIndexOf(" ");
  const safeText =
    lastSpaceIndex > 0 ? truncated.slice(0, lastSpaceIndex) : truncated;
  return `${safeText.trim()}...`;
};

const getTransitionName = (item: any) => {
  if (!item?.id) {
    return undefined;
  }
  const href = typeof item?.href === "string" ? item.href : "";
  if (href.startsWith("/events/")) {
    return `event-image-${item.id}`;
  }
  if (
    href.startsWith("/article/") ||
    href.startsWith("/news/") ||
    href.startsWith("/interviews/") ||
    href.startsWith("/flippers/") ||
    href.startsWith("/guide/") ||
    href.startsWith("/visual-story/")
  ) {
    return `main-article-image-${item.id}`;
  }
  return undefined;
};

let primaryParisArticle: any = null;
let secondaryStories: any[] = [];
let editorialSidebarItems: any[] = [];
let parisFeed: any[] = [];
let leSaviezVousArticle: any = null;
let parisPagePlacements: ParisPagePlacementsResponse | null = null;

try {
  const [articles, flippers, guides, visualStories, newsItemsRaw, parisPagePlacementsResponse] =
    await Promise.all([
      articlesApi.list(),
      flippersApi.list(),
      guidesApi.list(),
      visualStoriesApi.list(),
      newsApi.list(),
      editorialPlacementsApi.getParisPage().catch(() => null),
    ]);

  parisPagePlacements = parisPagePlacementsResponse;

  const standardArticles = articles.filter(
    (article) => !isLeSaviezVousArticle(article),
  );
  const newsItems = newsItemsRaw.map((item) => ({
    ...item,
    isNews: true,
    contentType: "news",
    tags: normalizeTags(item?.tags),
  }));
  const leSaviezVousArticles = articles
    .filter((article) => isLeSaviezVousArticle(article))
    .sort(
      (a, b) => getDate(b.createdAt).getTime() - getDate(a.createdAt).getTime(),
    );

  const leSaviezVousFeaturePlacement = parisPagePlacements?.leSaviezVousFeature ?? null;
  if (!parisPagePlacements || leSaviezVousFeaturePlacement?.mode === "auto-latest") {
    leSaviezVousArticle = leSaviezVousArticles[0] ?? null;
  } else if (leSaviezVousFeaturePlacement?.mode === "manual") {
    leSaviezVousArticle =
      articles.find(
        (a) => isLeSaviezVousArticle(a) && a.id === leSaviezVousFeaturePlacement.id,
      ) ?? null;
  } else {
    leSaviezVousArticle = null;
  }

  if (leSaviezVousArticle) {
    leSaviezVousArticle = {
      ...leSaviezVousArticle,
      href: toContentHref(leSaviezVousArticle),
    };
  }

  const allContent = [
    ...standardArticles.map((article) => ({
      ...article,
      contentType: "article",
      tags: normalizeTags(article?.tags),
    })),
    ...newsItems,
    ...flippers.map((flipper) => ({
      ...flipper,
      contentType: "flipper",
      imageUrl: flipper?.carouselContent?.[0]?.imageUrl || null,
      tags: normalizeTags(flipper?.tags),
    })),
    ...guides.map((guide) => ({
      ...guide,
      contentType: "guide",
      tags: normalizeTags(guide?.tags),
    })),
    ...visualStories.map((story) => ({
      ...story,
      contentType: "visual-story",
      imageUrl: story?.imageUrl || story?.slides?.[0]?.imageUrl || null,
      tags: normalizeTags(story?.tags),
    })),
  ];

  const sortedContent = [...allContent].sort(
    (a, b) => getDate(b.createdAt).getTime() - getDate(a.createdAt).getTime(),
  );

  const allParisItems = sortedContent
    .filter((item) => normalizeCategory(item.category) === PARIS_CATEGORY_KEY)
    .map((item) => ({
      ...item,
      href: toContentHref(item),
    }));

  const topItems = allParisItems.filter((item) => !isHotContent(item));

  const heroPlacement = parisPagePlacements?.hero ?? null;
  if (heroPlacement?.mode === "manual") {
    primaryParisArticle =
      allParisItems.find(
        (item) => item.id === heroPlacement.id && item.contentType === heroPlacement.type,
      ) ?? null;
  } else {
    // fallback during migration: isMainInCategory or first item
    primaryParisArticle =
      topItems.find((item) => isMainInCategoryItem(item)) ?? topItems[0] ?? null;
  }

  const topWithoutPrimary = topItems.filter((item) =>
    primaryParisArticle ? item.id !== primaryParisArticle.id : true,
  );

  const secondaryPlacement = parisPagePlacements?.secondaryStories ?? null;
  if (secondaryPlacement === null) {
    secondaryStories = [];
  } else if (secondaryPlacement.mode === "manual") {
    const itemsByKey = new Map(
      topItems.map((item) => [`${item.contentType}:${item.id}`, item]),
    );
    secondaryStories = secondaryPlacement.items
      .map(({ type, id }) => itemsByKey.get(`${type}:${id}`))
      .filter(Boolean);
  } else {
    secondaryStories = topWithoutPrimary.slice(0, secondaryPlacement.limit ?? 4);
  }

  const topIds = new Set(
    [
      primaryParisArticle?.id,
      ...secondaryStories.map((item) => item?.id),
    ].filter(Boolean),
  );

  const parisHotContentItems = allParisItems.filter(
    (item) => !topIds.has(item.id) && isHotContent(item),
  );

  editorialSidebarItems = parisHotContentItems.slice(0, 4);

  const sidebarIds = new Set(editorialSidebarItems.map((item) => item.id));

  parisFeed = allParisItems.filter(
    (item) =>
      !topIds.has(item.id) && !sidebarIds.has(item.id) && !isHotContent(item),
  );
} catch (error) {
  console.error("Failed to fetch paris page articles:", error);
}

const editorialGridItems = parisFeed.slice(0, MAX_EDITORIAL_GRID_ITEMS);
const editorialCarouselItems = parisFeed.slice(MAX_EDITORIAL_GRID_ITEMS);

const splitTitle = (t: string) => {
  const s = t.trimEnd();
  const i = s.lastIndexOf(" ");
  return { start: i >= 0 ? s.slice(0, i) : "", last: i >= 0 ? s.slice(i + 1) : s };
};

const primaryParisTrunc = primaryParisArticle
  ? truncateText(primaryParisArticle.title, 96)
  : "";
const primaryParisSplit = splitTitle(primaryParisTrunc);

const leSaviezTrunc = leSaviezVousArticle
  ? String(leSaviezVousArticle.title)
  : "";
const leSaviezSplit = splitTitle(leSaviezTrunc);
---

<Layout
  navbarVariant="default"
  includePreFooterCTA={false}
  title="Париж - Maag"
  useClientRouter={true}
>
  <main class="min-h-screen bg-base-200 text-black">
    <div
      class="mx-auto max-w-[1440px] px-4 pt-8 pb-20 sm:px-6 lg:px-8 lg:pt-10 lg:pb-[6.5rem]"
    >
      <h1
        class="text-3xl lg:text-[28px] font-old_standard font-normal uppercase tracking-[0.46em] text-base-content w-full mb-10"
      >
        Париж
      </h1>

      <section class="mt-6 grid gap-7 lg:grid-cols-12 lg:gap-4 lg:items-start">
        <div class="grid gap-8 lg:col-span-9">
          {
            primaryParisArticle ? (
              <article class="grid overflow-hidden bg-white/70 lg:min-h-[21rem] lg:grid-cols-[minmax(0,1.45fr)_minmax(16rem,0.95fr)]">
                <a
                  href={primaryParisArticle.href}
                  class="linked-image-hover aspect-[3/2]"
                  aria-label={primaryParisArticle.title}
                >
                  <img
                    src={primaryParisArticle.imageUrl || picture1.src}
                    alt={primaryParisArticle.title}
                    class="linked-image-hover__media block h-full w-full object-cover"
                    loading="lazy"
                    transition:name={getTransitionName(primaryParisArticle)}
                  />
                </a>

                <div class="grid content-start gap-[0.55rem] bg-white/90 p-[1.2rem] lg:px-[1.3rem] lg:pt-[1.35rem] lg:pb-[1.1rem]">
                  <p class="m-0">
                    <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                      {getPrimaryTag(primaryParisArticle) || "Париж"}
                    </span>
                  </p>

                  <a
                    href={primaryParisArticle.href}
                    class="text-current no-underline hover:underline"
                  >
                    <h2 class="text-3xl font-normal font-old_standard tracking-[-0.02em] transition-opacity duration-200 hover:opacity-90 mb-2">
                      {primaryParisArticle.paid ? (
                        <>
                          {primaryParisSplit.start && <>{primaryParisSplit.start}{" "}</>}
                          <span class="whitespace-nowrap">{primaryParisSplit.last}{" "}<MaagLogoPaid class="w-4 h-4 inline-block align-baseline" /></span>
                        </>
                      ) : primaryParisTrunc}
                    </h2>
                  </a>

                  {getCardLead(primaryParisArticle) && (
                    <p class="m-0 text-base text-black/60 font-inter font-normal">
                      {truncateText(getCardLead(primaryParisArticle), 280)}
                    </p>
                  )}

                  <p class="hidden mt-[0.4rem] font-inter text-[0.68rem] uppercase tracking-[0.18em] text-[#30282185]">
                    {formatDate(primaryParisArticle.createdAt)}
                  </p>
                </div>
              </article>
            ) : (
              <article class="border border-[#3028211a] bg-white/70 p-5 text-[1.05rem] font-light leading-[1.5]">
                Пока нет материалов категории «Париж».
              </article>
            )
          }

          {
            secondaryStories.length > 0 && (
              <div class="grid gap-4 sm:grid-cols-2 sm:items-stretch">
                {secondaryStories.map((item) => (
                  <article class="grid h-full grid-rows-[auto_1fr] gap-[0.8rem]">
                    <a
                      href={item.href}
                      class="linked-image-hover aspect-[3/2]"
                      aria-label={item.title}
                    >
                      <img
                        src={item.imageUrl || picture1.src}
                        alt={item.title}
                        class="linked-image-hover__media block h-full w-full object-cover"
                        loading="lazy"
                        transition:name={getTransitionName(item)}
                      />
                    </a>

                    <div class="grid h-full content-start gap-[0.55rem]">
                      <p class="m-0">
                        <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                          {getPrimaryTag(item) || "Париж"}
                        </span>
                      </p>

                      <a
                        href={item.href}
                        class="block text-current no-underline hover:underline"
                      >
                        <h3 class="m-0 line-clamp-3 text-[1.4rem] font-normal font-old_standard tracking-[-0.02em] leading-[1.12]">
                          {(() => {
                            const t = truncateText(item.title, 88);
                            const { start, last } = splitTitle(t);
                            return item.paid ? (
                              <>
                                {start && <>{start}{" "}</>}
                                <span class="whitespace-nowrap">{last}{" "}<MaagLogoPaid class="w-4 h-4 inline-block align-baseline" /></span>
                              </>
                            ) : t;
                          })()}
                        </h3>
                      </a>

                      {getCardLead(item) && (
                        <p class="m-0 line-clamp-3 text-sm text-black/60 font-inter font-normal">
                          {truncateText(getCardLead(item), 120)}
                        </p>
                      )}

                      <p class="hidden m-0 text-xs font-inter uppercase tracking-[0.22em] text-base-content/55">
                        {formatDate(item.createdAt)}
                      </p>
                    </div>
                  </article>
                ))}
              </div>
            )
          }
        </div>

        <aside
          class="min-w-0 border-t border-[#3028211f] pt-4 lg:col-span-3 lg:border-t-0 lg:border-l lg:border-[#3028211f] lg:pt-0 lg:pl-4"
        >
          <section class="grid gap-4">
            <p
              class="m-0 text-lg font-normal uppercase tracking-[0.3em] font-old_standard"
            >
              Le saviez-vous?
            </p>

            {
              leSaviezVousArticle ? (
                <article class="overflow-hidden bg-white">
                  <a
                    href={leSaviezVousArticle.href}
                    class="block"
                    aria-label={leSaviezVousArticle.title}
                  >
                    <img
                      src={leSaviezVousArticle.imageUrl || picture1.src}
                      alt={leSaviezVousArticle.title}
                      class="block h-auto w-full object-cover lg:h-[240px]"
                      loading="lazy"
                    />
                  </a>

                  <div class="grid gap-[0.55rem] p-4 lg:px-4 lg:py-6">
                    <p class="m-0">
                      <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                        {getPrimaryTag(leSaviezVousArticle) || "Париж"}
                      </span>
                    </p>

                    <a
                      href={leSaviezVousArticle.href}
                      class="text-current no-underline hover:underline"
                    >
                      <h2 class="m-0 text-xl font-normal font-old_standard tracking-[-0.02em] leading-[1.16]">
                        {leSaviezVousArticle.paid ? (
                          <>
                            {leSaviezSplit.start && <>{leSaviezSplit.start}{" "}</>}
                            <span class="whitespace-nowrap">{leSaviezSplit.last}{" "}<MaagLogoPaid class="w-4 h-4 inline-block align-baseline" /></span>
                          </>
                        ) : leSaviezTrunc}
                      </h2>
                    </a>

                    <p class="m-0 text-sm text-black/60 font-inter font-normal">
                      {truncateText(
                        getCardLead(leSaviezVousArticle) ||
                          leSaviezVousArticle?.lead ||
                          "",
                        150,
                      )}
                    </p>
                  </div>
                </article>
              ) : (
                <article class="overflow-hidden bg-white">
                  <img
                    src={picture1.src}
                    alt="Le saviez-vous placeholder"
                    class="block h-auto w-full object-cover lg:h-[240px]"
                    loading="lazy"
                  />

                  <div class="grid gap-[0.55rem] p-4 lg:px-4 lg:py-6">
                    <p class="m-0">
                      <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                        Париж
                      </span>
                    </p>

                    <h2 class="m-0 text-xl font-normal font-old_standard tracking-[-0.02em] leading-[1.16]">
                      Неочевидный факт о городе скоро появится здесь
                    </h2>

                    <p class="m-0 text-sm text-black/60 font-inter font-normal">
                      Пока это плейсхолдер: здесь будет короткий визуальный факт
                      или наблюдение в духе карточки календаря, но без даты.
                    </p>
                  </div>
                </article>
              )
            }
          </section>

          <div class="grid gap-4 border-t border-[#3028211f] pt-4 mt-4">
            <p
              class="m-0 text-lg font-normal uppercase tracking-[0.3em] font-old_standard"
            >
              Нетленка
            </p>

            {
              editorialSidebarItems.length > 0 ? (
                editorialSidebarItems.map((item) => (
                  <NetlenkaCard
                    title={item.title}
                    category={getPrimaryTag(item) || "Париж"}
                    imageUrl={item.imageUrl}
                    href={item.href}
                    transitionName={getTransitionName(item)}
                    hideDate={true}
                  />
                ))
              ) : (
                <p class="m-0 font-inter text-[0.88rem] leading-[1.5] text-[#3028219e]">
                  Пока нет материалов для боковой колонки.
                </p>
              )
            }
          </div>
        </aside>
      </section>

      <section class="mt-[2.2rem] border-t border-[#3028211f] pt-[1.6rem]">
        <div>
          {
            editorialGridItems.length > 0 ? (
              <>
                <div class="grid grid-cols-2 gap-x-4 gap-y-[1.4rem] lg:grid-cols-4 lg:gap-x-5 lg:gap-y-[1.9rem]">
                  {editorialGridItems.map((item) => (
                    <article class="grid h-full grid-rows-[auto_1fr] gap-[0.8rem]">
                      <a
                        href={item.href}
                        class="linked-image-hover bg-white/50 aspect-[1.02/1]"
                        aria-label={item.title}
                      >
                        <img
                          src={item.imageUrl || picture1.src}
                          alt={item.title}
                          class="linked-image-hover__media block h-full w-full object-cover"
                          loading="lazy"
                          transition:name={getTransitionName(item)}
                        />
                      </a>

                      <div class="grid h-full content-start gap-[0.55rem]">
                        <p class="m-0">
                          <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                            {getPrimaryTag(item) || "Париж"}
                          </span>
                        </p>

                        <a
                          href={item.href}
                          class="block text-current no-underline hover:underline"
                        >
                          <h3 class="text-2xl font-normal font-old_standard tracking-[-0.02em] transition-opacity duration-200 hover:opacity-90">
                            {(() => {
                              const t = truncateText(item.title, 72);
                              const { start, last } = splitTitle(t);
                              return item.paid ? (
                                <>
                                  {start && <>{start}{" "}</>}
                                  <span class="whitespace-nowrap">{last}{" "}<MaagLogoPaid class="w-4 h-4 inline-block align-baseline" /></span>
                                </>
                              ) : t;
                            })()}
                          </h3>
                        </a>

                        <p class="hidden m-0 text-xs font-inter uppercase tracking-[0.22em] text-base-content/55">
                          {formatDate(item.createdAt)}
                        </p>
                      </div>
                    </article>
                  ))}
                </div>

                {editorialCarouselItems.length > 0 && (
                  <div class="mt-[2rem] overflow-hidden">
                    <div
                      class="rubric-marquee-track flex items-start gap-6 py-2"
                      style="width: max-content;"
                    >
                      {[
                        ...editorialCarouselItems,
                        ...editorialCarouselItems,
                      ].map((item, i) => (
                        <div class="w-[240px] sm:w-[260px] lg:w-[280px] flex-shrink-0">
                          <article class="grid h-full grid-rows-[auto_1fr] gap-[0.8rem]">
                            <a
                              href={item.href}
                              class="linked-image-hover bg-white/50 aspect-[1.02/1]"
                              aria-label={item.title}
                            >
                              <img
                                src={item.imageUrl || picture1.src}
                                alt={item.title}
                                class="linked-image-hover__media block h-full w-full object-cover"
                                loading="lazy"
                                transition:name={i < editorialCarouselItems.length ? getTransitionName(item) : undefined}
                              />
                            </a>

                            <div class="grid h-full content-start gap-[0.55rem]">
                              <p class="m-0">
                                <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                                  {getPrimaryTag(item) || "Париж"}
                                </span>
                              </p>

                              <a
                                href={item.href}
                                class="block text-current no-underline hover:underline"
                              >
                                <h3 class="text-2xl font-normal font-old_standard tracking-[-0.02em] transition-opacity duration-200 hover:opacity-90">
                                  {truncateText(item.title, 72)}{" "}
                                  {item.paid && <MaagLogoPaid class="w-4 h-4 inline-block align-baseline" />}
                                </h3>
                              </a>

                              <p class="hidden m-0 text-xs font-inter uppercase tracking-[0.22em] text-base-content/55">
                                {formatDate(item.createdAt)}
                              </p>
                            </div>
                          </article>
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </>
            ) : (
              <article class="bg-white/70 p-5 text-[1.05rem] font-light leading-[1.5]">
                Больше материалов пока нет.
              </article>
            )
          }
        </div>
      </section>
    </div>
  </main>
</Layout>

