---
import Layout from "../../Layouts/Layout.astro";
import {
  interviewsApi,
  articlesApi,
  eventsApi,
  flippersApi,
  guidesApi,
  newsApi,
  visualStoriesApi,
} from "../../lib/api/api";
import ArticleHeader from "../../components/article/ArticleHeader.astro";
import ArticleAuthor from "../../components/article/ArticleAuthor.astro";
import ArticleImage from "@/components/article/ArticleImage.astro";
import ArticleDate from "../../components/article/ArticleDate.astro";
import ArticleBody from "../../components/article/ArticleBody.astro";
import ContentCollectionMarquee from "@/components/article/ContentCollectionMarquee.astro";
import picture1 from "@/assets/images/culture.jpg";
import {
  buildContentCollectionItems,
  buildLinkedContentLookup,
  fetchPublicContentPools,
  type LinkedContentLookup,
  toDate,
} from "@/lib/utils/contentCollectionMarquee";

const { id } = Astro.params;

let interview = null;
try {
  if (id) {
    interview = await interviewsApi.getById(id);
  }
} catch (error) {
  console.error("Failed to fetch interview:", error);
}

if (!interview) {
  return Astro.redirect("/404");
}

const {
  title,
  author,
  interviewee,
  content,
  imageUrl,
  imageCaption,
  tags,
  lead,
} = interview;
const authorName = author ? `${author.firstName} ${author.lastName}` : "MAAG";
const transitionAliases = [`landing-body-main-article-image-${id}`];

let collectionContentItems: any[] = [];
let recentInterviewItems: any[] = [];
let linkedContentLookup: LinkedContentLookup = {};

try {
  const pools = await fetchPublicContentPools();
  linkedContentLookup = buildLinkedContentLookup(pools);
  const allInterviews = pools.allInterviews;
  collectionContentItems = await buildContentCollectionItems({
    contentCollectionId: (interview as any)?.contentCollectionId,
    currentContentType: "interview",
    currentId: id,
    pools,
  });

  const relatedInterviewIds = new Set(collectionContentItems.filter((i) => i.contentType === "interview").map((i) => i.id));
  recentInterviewItems = allInterviews
    .filter((i) => i.id !== id && !relatedInterviewIds.has(i.id))
    .sort((a, b) => (toDate(b?.createdAt)?.getTime() ?? 0) - (toDate(a?.createdAt)?.getTime() ?? 0))
    .slice(0, 12)
    .map((item) => ({ ...item }));
} catch (e) {
  console.error("Failed to fetch collection content for interview page:", e);
}
---

<Layout
  navbarVariant="default"
  includePreFooterCTA={false}
  title={`${title} - Maag`}
  useClientRouter={true}
>
  <main class="bg-base-200 min-h-screen">
    <div class="max-w-[1512px] mx-auto">
      <div
        class="pt-[50px] pb-[70px] flex flex-col items-center gap-[50px] px-4 lg:px-0"
      >
        <div class="flex flex-col gap-4 max-w-[825px] w-full">
          <ArticleHeader category={"Интервью"} title={title} lead={lead} />
          <div class="flex flex-row items-center justify-start gap-4">
            <ArticleAuthor name={authorName} avatarUrl={author?.avatar} />
            <div>·</div>
            <ArticleDate createdAt={interview.createdAt} />
          </div>
        </div>

        {
          imageUrl && (
            <ArticleImage
              src={imageUrl}
              alt={imageCaption || title}
              caption={imageCaption}
              transitionName={`main-article-image-${id}`}
              transitionAliases={transitionAliases}
              figureClass="max-w-[1200px]"
              imageClass="shadow-lg"
              figcaptionClass="text-center font-oswald text-sm text-gray-500 mt-2"
            />
          )
        }

        <div class="w-full px-4 lg:px-14 pb-[100px]">
          <ArticleBody
            contentBlocks={Array.isArray(content) ? content : []}
            linkedContentLookup={linkedContentLookup}
          />
          <ContentCollectionMarquee
            collectionItems={collectionContentItems}
            categoryItems={recentInterviewItems}
            fallbackImageSrc={picture1.src}
          />
        </div>
      </div>
    </div>
  </main>
</Layout>
