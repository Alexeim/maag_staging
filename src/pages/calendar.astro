---
import Layout from "../Layouts/Layout.astro";
import FilterButtons from "../components/calendar/FilterButtons.astro";
import CalendarWidget from "../components/calendar/CalendarWidget.astro";
import EventList from "../components/calendar/EventList.astro";
import baletImage from "../assets/images/calendar/balet.png";
import theatreShowImage from "../assets/images/calendar/theatre-show.png";
import smallEventImage from "../assets/images/calendar/small-event.png";
import locationIcon from "../assets/images/calendar/location.svg?raw";
import picture1 from "../assets/images/culture.jpg";
import { getKnownTagLabel } from "@/content/tags/parisTags";
import { eventsApi } from "@/lib/api/api";

const EVENT_CATEGORY_LABELS: Record<string, string> = {
  exhibition: "Выставка",
  concert: "Концерт",
  performance: "Спектакль",
};

const TAG_LABEL_ALIASES: Record<string, string> = {
  exhibition: "Выставка",
  exhibitions: "Выставки",
  concert: "Концерт",
  concerts: "Концерты",
  performance: "Спектакль",
  performances: "Спектакли",
  theatre: "Театр",
  theatres: "Театры",
  theater: "Театр",
  theaters: "Театры",
  event: "Событие",
  events: "События",
  culture: "Культура",
  paris: "Париж",
  books: "Книги",
  artMarket: "Арт-рынок",
  artmarket: "Арт-рынок",
  kids: "Дети",
  opera: "Опера",
  ballet: "Балет",
  dance: "Танец",
  music: "Музыка",
  route: "Маршрут",
  address: "Адрес",
  notebook: "Записная книжка",
  place: "Место",
  ...Object.fromEntries(
    Array.from({ length: 20 }, (_, i) => [
      `district-${i + 1}`,
      `${i + 1}-й округ`,
    ]),
  ),
};

const toRoman = (num: number): string => {
  if (!Number.isFinite(num) || num <= 0) {
    return "";
  }
  const values = [1000, 900, 500, 400, 100, 90, 50, 40, 10, 9, 5, 4, 1];
  const symbols = [
    "M",
    "CM",
    "D",
    "CD",
    "C",
    "XC",
    "L",
    "XL",
    "X",
    "IX",
    "V",
    "IV",
    "I",
  ];
  let n = Math.floor(num);
  let out = "";
  for (let i = 0; i < values.length; i += 1) {
    while (n >= values[i]) {
      out += symbols[i];
      n -= values[i];
    }
  }
  return out;
};

const toDate = (value: unknown): Date | null => {
  if (!value) {
    return null;
  }
  if (value instanceof Date) {
    return value;
  }
  if (typeof value === "string") {
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? null : parsed;
  }
  if (typeof value === "number") {
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? null : parsed;
  }
  if (typeof value === "object") {
    const maybeSeconds =
      (value as { seconds?: number; _seconds?: number }).seconds ??
      (value as { seconds?: number; _seconds?: number })._seconds;
    if (typeof maybeSeconds === "number") {
      return new Date(maybeSeconds * 1000);
    }
    if (typeof (value as { toDate?: () => Date }).toDate === "function") {
      const parsed = (value as { toDate: () => Date }).toDate();
      return parsed instanceof Date && !Number.isNaN(parsed.getTime())
        ? parsed
        : null;
    }
  }
  return null;
};

const extractDescription = (blocks: any): string => {
  if (!Array.isArray(blocks)) {
    return "Подробнее скоро.";
  }
  const blockWithText = blocks.find(
    (block) => typeof block?.text === "string" && block.text.trim().length > 0,
  );
  if (!blockWithText) {
    return "Подробнее скоро.";
  }
  const text = blockWithText.text.trim();
  return text.length > 180 ? `${text.slice(0, 177).trim()}...` : text;
};

const resolveTagLabel = (rawTag: unknown, fallback: string): string => {
  if (typeof rawTag !== "string") {
    return fallback;
  }
  const trimmed = rawTag.trim();
  if (!trimmed) {
    return fallback;
  }
  const normalized = trimmed.toLowerCase();
  const districtMatch = normalized.match(/^district[-\s_]?(\d{1,2})$/i);
  if (districtMatch) {
    const districtNum = Number(districtMatch[1]);
    const roman = toRoman(districtNum);
    if (roman) {
      return roman;
    }
  }
  return TAG_LABEL_ALIASES[normalized] ?? getKnownTagLabel(trimmed);
};

const formatShortDateRange = (
  startIso: string,
  endIso: string | null,
): string => {
  const fmt = (d: Date) =>
    `${d.getUTCDate()}/${String(d.getUTCMonth() + 1).padStart(2, "0")}`;
  const start = toDate(startIso);
  if (!start) return "";
  const end = endIso ? toDate(endIso) : null;
  if (!end || start.getTime() === end.getTime()) return fmt(start);
  return `${fmt(start)} – ${fmt(end)}`;
};

const formatCardDateRange = (
  startIso: string,
  endIso: string | null,
): string => {
  const fmt = (d: Date) =>
    `${d.getUTCDate()} / ${String(d.getUTCMonth() + 1).padStart(2, "0")}`;
  const start = toDate(startIso);
  if (!start) return "";
  const end = endIso ? toDate(endIso) : null;
  if (!end || start.getTime() === end.getTime()) return fmt(start);
  return `${fmt(start)} — ${fmt(end)}`;
};

const getMonthGenitive = (d: Date): string =>
  new Intl.DateTimeFormat("ru-RU", { day: "numeric", month: "long", timeZone: "UTC" })
    .formatToParts(d)
    .find((p) => p.type === "month")?.value ?? "";

const getDateParts = (
  startIso: string,
  endIso: string | null,
): {
  dateDay: string;
  dateMonth: string;
  dateWeekday: string;
  dateYear: string;
  dateEndDay: string | null;
  dateEndMonth: string | null;
  dateEndWeekday: string | null;
  isDateRange: boolean;
} => {
  const start = toDate(startIso);
  if (!start) {
    return {
      dateDay: "",
      dateMonth: "",
      dateWeekday: "",
      dateYear: "",
      dateEndDay: null,
      dateEndMonth: null,
      dateEndWeekday: null,
      isDateRange: false,
    };
  }
  const end = endIso ? toDate(endIso) : null;
  const isRange = Boolean(end && end.getTime() !== start.getTime());
  return {
    dateDay: String(start.getUTCDate()),
    dateMonth: getMonthGenitive(start),
    dateWeekday: start.toLocaleDateString("ru-RU", { weekday: "long", timeZone: "UTC" }),
    dateYear: String(start.getUTCFullYear()),
    dateEndDay: isRange && end ? String(end.getUTCDate()) : null,
    dateEndMonth: isRange && end ? getMonthGenitive(end) : null,
    dateEndWeekday:
      isRange && end
        ? end.toLocaleDateString("ru-RU", { weekday: "long", timeZone: "UTC" })
        : null,
    isDateRange: isRange,
  };
};

const formatDateRange = (startIso: string, endIso: string | null): string => {
  const start = toDate(startIso);
  if (!start) {
    return "Дата уточняется";
  }
  const end = endIso ? toDate(endIso) : null;
  const format = (date: Date, withYear = false) =>
    date.toLocaleDateString("ru-RU", {
      day: "numeric",
      month: "long",
      ...(withYear ? { year: "numeric" } : {}),
    });
  if (!end || start.getTime() === end.getTime()) {
    return format(start, true);
  }
  const sameYear = end.getUTCFullYear() === start.getUTCFullYear();
  return `${format(start, !sameYear)} – ${format(end, true)}`;
};

let eventsResponse: any[] = [];

try {
  eventsResponse = await eventsApi.list();
} catch (error) {
  console.error("Failed to fetch events:", error);
}

const normalizedEvents = eventsResponse
  .map((event) => {
    const startDate = toDate(event?.startDate);
    if (!startDate) {
      return null;
    }
    startDate.setUTCHours(0, 0, 0, 0);
    const endDate = toDate(event?.endDate);
    if (endDate) {
      endDate.setUTCHours(0, 0, 0, 0);
    }
    const category = typeof event?.category === "string" ? event.category : "";
    const categoryLabel =
      EVENT_CATEGORY_LABELS[category as keyof typeof EVENT_CATEGORY_LABELS] ||
      "Событие";
    const primaryTag = resolveTagLabel(
      Array.isArray(event?.tags) && event.tags.length > 0
        ? event.tags[0]
        : null,
      categoryLabel,
    );

    return {
      id: event.id,
      title: event.title ?? "Событие",
      imageUrl: typeof event.imageUrl === "string" ? event.imageUrl : null,
      startDate: startDate.toISOString(),
      endDate: endDate ? endDate.toISOString() : null,
      dateType: event?.dateType === "duration" ? "duration" : "single",
      address: typeof event?.address === "string" ? event.address : "",
      timeMode:
        event?.timeMode === "start" || event?.timeMode === "range"
          ? event.timeMode
          : "none",
      startTime: typeof event?.startTime === "string" ? event.startTime : null,
      endTime: typeof event?.endTime === "string" ? event.endTime : null,
      category,
      categoryLabel,
      tagLabel: primaryTag,
      description: extractDescription(event?.content),
      isMainEvent: Boolean(event?.isMainEvent),
      url: `/events/${event.id}`,
    };
  })
  .filter((event): event is NonNullable<typeof event> => Boolean(event))
  .sort(
    (a, b) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime(),
  );

const heroFallbackImages = [baletImage, picture1, theatreShowImage];

const now = new Date();
const todayUtc = new Date(
  Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate()),
);
const weekEndUtc = new Date(todayUtc);
weekEndUtc.setUTCDate(weekEndUtc.getUTCDate() + 6);

const upcomingOrCurrentEvents = normalizedEvents.filter((event) => {
  const end = toDate(event.endDate ?? event.startDate);
  return end ? end.getTime() >= todayUtc.getTime() : false;
});

const currentMonthMainEvents = upcomingOrCurrentEvents.filter((event) => {
  if (!event.isMainEvent) {
    return false;
  }
  const start = toDate(event.startDate);
  return (
    start &&
    start.getUTCFullYear() === todayUtc.getUTCFullYear() &&
    start.getUTCMonth() === todayUtc.getUTCMonth()
  );
});

const otherMainEvents = upcomingOrCurrentEvents.filter((event) => {
  if (!event.isMainEvent) {
    return false;
  }
  const start = toDate(event.startDate);
  return !(
    start &&
    start.getUTCFullYear() === todayUtc.getUTCFullYear() &&
    start.getUTCMonth() === todayUtc.getUTCMonth()
  );
});

const fallbackFeaturedEvent =
  upcomingOrCurrentEvents[upcomingOrCurrentEvents.length - 1] ??
  normalizedEvents[normalizedEvents.length - 1] ??
  null;

const featuredMainEventsSource =
  currentMonthMainEvents.length > 0
    ? [...currentMonthMainEvents, ...otherMainEvents]
    : upcomingOrCurrentEvents.filter((event) => event.isMainEvent);

const featuredEventCards =
  featuredMainEventsSource.length > 0
    ? featuredMainEventsSource.map((event, index) => ({
        ...event,
        dateRange: formatDateRange(event.startDate, event.endDate),
        fallbackImage:
          heroFallbackImages[index % heroFallbackImages.length] ?? baletImage,
      }))
    : fallbackFeaturedEvent
      ? [
          {
            ...fallbackFeaturedEvent,
            dateRange: formatDateRange(
              fallbackFeaturedEvent.startDate,
              fallbackFeaturedEvent.endDate,
            ),
            fallbackImage: heroFallbackImages[0] ?? baletImage,
          },
        ]
      : [];

const featuredEventIds = new Set(featuredEventCards.map((event) => event.id));

const weeklyEvents = upcomingOrCurrentEvents.filter((event) => {
  const start = toDate(event.startDate);
  const end = toDate(event.endDate ?? event.startDate);
  if (!start || !end) {
    return false;
  }
  return (
    start.getTime() <= weekEndUtc.getTime() &&
    end.getTime() >= todayUtc.getTime()
  );
});

const upcomingWithoutMain = upcomingOrCurrentEvents.filter(
  (event) => !featuredEventIds.has(event.id),
);

const weeklyFallbackPool = (
  weeklyEvents.length >= 3 ? weeklyEvents : upcomingWithoutMain
)
  .filter((event) => !featuredEventIds.has(event.id))
  .slice(0, 4);

const weeklyHighlights = weeklyFallbackPool.map((event, index) => ({
  ...event,
  dateRange: formatDateRange(event.startDate, event.endDate),
  fallbackImage:
    heroFallbackImages[(index + 1) % heroFallbackImages.length] ?? baletImage,
  ...getDateParts(event.startDate, event.endDate),
}));

const calendarState = JSON.stringify({
  imagePaths: {
    theatreShowSrc: theatreShowImage.src,
    smallEventSrc: smallEventImage.src,
  },
  events: normalizedEvents,
  featuredEvents: featuredEventCards.map((event) => ({
    id: event.id,
    title: event.title,
    imageUrl: event.imageUrl ?? event.fallbackImage.src,
    address: event.address || "Место",
    categoryLabel: event.categoryLabel,
    dateLabel: formatCardDateRange(event.startDate, event.endDate),
    url: event.url,
    ...getDateParts(event.startDate, event.endDate),
  })),
}).replace(/</g, "\\u003c");

const topCards = weeklyHighlights.slice(0, 4);
---

<Layout
  navbarVariant="default"
  includePreFooterCTA={false}
  title="Календарь - Maag"
  useClientRouter={true}
>
  <main
    id="calendar-wrapper"
    class="min-h-screen bg-base-200 text-black"
    x-data={`$lazy('calendar', ${calendarState})`}
    @change-month.window="changeMonth($event.detail)"
    @date-selected.window="selectDate($event.detail)"
    @filter-changed.window="setFilter($event.detail.filter)"
  >
    <div
      class="mx-auto max-w-[1440px] px-4 pt-8 pb-20 sm:px-6 lg:px-8 lg:pt-10 lg:pb-[6.5rem]"
    >
      <h1
        class="text-3xl lg:text-[28px] font-old_standard font-normal uppercase tracking-[0.46em] text-base-content w-full mb-10"
      >
        Календарь
      </h1>

      <section class="mt-6">
        <h2
          class="m-0 font-old_standard text-[1.05rem] font-normal uppercase tracking-[0.5em] text-black"
        >
          События месяца
        </h2>

        {
          featuredEventCards.length > 0 ? (
            <div
              class="relative mt-8"
              @mouseenter="setFeaturedHover(true)"
              @mouseleave="setFeaturedHover(false)"
              @focusin="setFeaturedFocus(true)"
              @focusout="if (!$event.relatedTarget || !$el.contains($event.relatedTarget)) setFeaturedFocus(false)"
            >
              <button
                type="button"
                aria-label="Предыдущее"
                class="absolute left-[-1rem] top-1/2 -translate-y-1/2 z-10 hidden h-10 w-10 items-center justify-center rounded-full bg-white/80 text-[1.6rem] text-[#7d726a] md:flex cursor-pointer"
                x-show="hasMultipleFeaturedEvents()"
                @click.prevent="prevFeaturedEvent()"
              >
                ←
              </button>
              <button
                type="button"
                aria-label="Следующее"
                class="absolute right-[-1rem] top-1/2 -translate-y-1/2 z-10 hidden h-10 w-10 items-center justify-center rounded-full bg-white/80 text-[1.6rem] text-[#7d726a] md:flex cursor-pointer"
                x-show="hasMultipleFeaturedEvents()"
                @click.prevent="nextFeaturedEvent()"
              >
                →
              </button>

              <div class="mx-auto max-w-[1052px] lg:min-h-[21rem]">
                <article
                  x-show="isFeaturedEventVisible && getCurrentFeaturedEvent()"
                  x-transition.opacity.duration.220ms
                  class="grid overflow-hidden bg-white lg:min-h-[21rem] lg:grid-cols-[minmax(0,1.45fr)_minmax(16rem,0.95fr)]"
                >
                  <a
                    :href="getCurrentFeaturedEvent()?.url || '#'"
                    class="linked-image-hover aspect-[3/2]"
                    :aria-label="getCurrentFeaturedEvent()?.title || 'Событие месяца'"
                  >
                    <img
                      :src="getCurrentFeaturedEvent()?.imageUrl || ''"
                      :alt="getCurrentFeaturedEvent()?.title || 'Событие месяца'"
                      class="linked-image-hover__media block h-full w-full object-cover"
                    />
                  </a>

                  <div class="grid content-start gap-[0.55rem] bg-white p-[1.2rem] lg:px-8 lg:pt-[1.35rem] lg:pb-[1.1rem]">
                    <div class="mb-6 flex w-full items-start justify-start">
                      <template x-if="!getCurrentFeaturedEvent()?.isDateRange">
                        <div class="flex flex-col items-start justify-center">
                          <p
                            class="mx-0 mt-4 font-old_standard text-7xl tracking-[-0.06em] uppercase text-black"
                            x-text="getCurrentFeaturedEvent()?.dateDay || ''"
                          ></p>
                          <p
                            class="m-0 -mt-2 font-inter text-xl font-bold uppercase text-black/70"
                            x-text="getCurrentFeaturedEvent()?.dateMonth || ''"
                          ></p>
                          <div class="mb-1 w-full border-t border-black/30"></div>
                          <p
                            class="m-0 mb-1 font-old_standard text-xl font-bold italic text-black/70"
                            x-text="getCurrentFeaturedEvent()?.dateWeekday || ''"
                          ></p>
                        </div>
                      </template>

                      <template x-if="getCurrentFeaturedEvent()?.isDateRange">
                        <div class="w-full flex items-center justify-between gap-4 sm:gap-5">
                          <div class="flex flex-col items-start justify-center">
                            <p
                              class="mx-0 mt-4 font-old_standard text-6xl tracking-[-0.06em] uppercase text-black sm:text-7xl"
                              x-text="getCurrentFeaturedEvent()?.dateDay || ''"
                            ></p>
                            <p
                              class="m-0 -mt-2 font-inter text-lg font-bold uppercase text-black/70 sm:text-xl"
                              x-text="getCurrentFeaturedEvent()?.dateMonth || ''"
                            ></p>
                            <div class="mb-1 w-full border-t border-black/30"></div>
                            <p
                              class="m-0 mb-1 font-old_standard text-lg font-bold italic text-black/70 sm:text-xl"
                              x-text="getCurrentFeaturedEvent()?.dateWeekday || ''"
                            ></p>
                          </div>

                          <div class="mt-3 flex items-center text-black/80">
                            <span class="font-old_standard text-3xl leading-none sm:text-4xl">→</span>
                          </div>

                          <div class="flex flex-col items-start justify-center">
                            <p
                              class="mx-0 mt-4 font-old_standard text-6xl tracking-[-0.06em] uppercase text-black sm:text-7xl"
                              x-text="getCurrentFeaturedEvent()?.dateEndDay || ''"
                            ></p>
                            <p
                              class="m-0 -mt-2 font-inter text-lg font-bold uppercase text-black/70 sm:text-xl"
                              x-text="getCurrentFeaturedEvent()?.dateEndMonth || ''"
                            ></p>
                            <div class="mb-1 w-full border-t border-black/30"></div>
                            <p
                              class="m-0 mb-1 font-old_standard text-lg font-bold italic text-black/70 sm:text-xl"
                              x-text="getCurrentFeaturedEvent()?.dateEndWeekday || ''"
                            ></p>
                          </div>
                        </div>
                      </template>
                    </div>
                    <p class="m-0">
                      <span
                        class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']"
                        x-text="getCurrentFeaturedEvent()?.categoryLabel || ''"
                      ></span>
                    </p>

                    <a
                      :href="getCurrentFeaturedEvent()?.url || '#'"
                      class="text-current no-underline hover:underline [text-decoration-thickness:1px] underline-offset-[0.14em]"
                    >
                      <h2
                        class="m-0 font-old_standard text-[clamp(1.4rem,2.2vw,1.9rem)] font-normal leading-[1.04]"
                        x-text="getCurrentFeaturedEvent()?.title || ''"
                      ></h2>
                    </a>

                    <div class="mt-[0.4rem] flex items-center gap-2 font-inter text-[0.95rem] text-[#302821bd]">
                      <span class="h-4 w-4 shrink-0" set:html={locationIcon} />
                      <span x-text="getCurrentFeaturedEvent()?.address || 'Место'"></span>
                    </div>
                  </div>
                </article>
              </div>
            </div>
          ) : (
            <article class="mt-8 border border-[#3028211a] bg-white/70 p-5 text-[1.05rem] font-light leading-[1.5]">
              Скоро здесь появятся события.
            </article>
          )
        }
      </section>

      {
        topCards.length > 0 && (
          <section class="mt-10">
            <h2 class="hidden m-0 font-old_standard text-[1.05rem] font-normal uppercase tracking-[0.5em] text-[#15110e]">
              Главное на этой неделе
            </h2>

            <div class="mt-8 grid grid-cols-2 gap-x-4 gap-y-6 lg:grid-cols-4 lg:gap-x-5 lg:gap-y-[1.9rem]">
              {topCards.map((event) => (
                <article class="grid h-full grid-rows-[auto_1fr] overflow-hidden bg-white">
                  <a
                    href={event.url}
                    class="linked-image-hover aspect-[1.12/1] lg:aspect-[3/2]"
                    aria-label={event.title}
                  >
                    <img
                      src={event.imageUrl ?? event.fallbackImage.src}
                      alt={event.title}
                      class="linked-image-hover__media block h-full w-full object-cover"
                    />
                  </a>

                  <div class="grid h-full grid-rows-[auto_auto_1fr_auto] gap-[0.55rem] content-start p-4 lg:p-[1.15rem]">
                    {
                      event.isDateRange ? (
                        <div class="mb-2 flex w-full items-start justify-between gap-3">
                          <div class="flex flex-col items-start justify-center">
                            <p class="m-0 font-old_standard text-[3rem] leading-[0.9] tracking-[-0.06em] uppercase text-black lg:text-[3.3rem]">
                              {event.dateDay}
                            </p>
                            <p class="m-0 -mt-1 font-inter text-[0.82rem] font-bold uppercase tracking-[0.18em] text-black/80 lg:text-[0.95rem]">
                              {event.dateMonth}
                            </p>
                            <div class="mb-1 mt-1 w-full border-t border-black/30"></div>
                            <p class="m-0 font-old_standard text-[0.9rem] italic text-black/70 lg:text-[1rem]">
                              {event.dateWeekday}
                            </p>
                          </div>

                          <div class="mt-[1.45rem] flex items-center text-black/80">
                            <span class="font-old_standard text-[1.6rem] leading-none lg:text-[1.85rem]">→</span>
                          </div>

                          <div class="flex flex-col items-start justify-center">
                            <p class="m-0 font-old_standard text-[3rem] leading-[0.9] tracking-[-0.06em] uppercase text-black lg:text-[3.3rem]">
                              {event.dateEndDay}
                            </p>
                            <p class="m-0 -mt-1 font-inter text-[0.82rem] font-bold uppercase tracking-[0.18em] text-black/80 lg:text-[0.95rem]">
                              {event.dateEndMonth}
                            </p>
                            <div class="mb-1 mt-1 w-full border-t border-black/30"></div>
                            <p class="m-0 font-old_standard text-[0.9rem] italic text-black/70 lg:text-[1rem]">
                              {event.dateEndWeekday}
                            </p>
                          </div>
                        </div>
                      ) : (
                        <div class="mb-2 flex flex-col items-start justify-center">
                          <p class="m-0 font-old_standard text-[3rem] leading-[0.9] tracking-[-0.06em] uppercase text-black lg:text-[3.3rem]">
                            {event.dateDay}
                          </p>
                          <p class="m-0 -mt-1 font-inter text-[0.82rem] font-bold uppercase tracking-[0.18em] text-black/80 lg:text-[0.95rem]">
                            {event.dateMonth}
                          </p>
                          <div class="mb-1 mt-1 w-full border-t border-black/30"></div>
                          <p class="m-0 font-old_standard text-[0.9rem] italic text-black/70 lg:text-[1rem]">
                            {event.dateWeekday}
                          </p>
                        </div>
                      )
                    }

                    <p class="m-0">
                      <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                        {event.categoryLabel}
                      </span>
                    </p>

                    <a
                      href={event.url}
                      class="text-current no-underline hover:underline [text-decoration-thickness:1px] underline-offset-[0.14em]"
                    >
                      <h3 class="m-0 line-clamp-3 font-old_standard text-[1.2rem] font-normal leading-[1.08] lg:text-[1.4rem] lg:leading-[1.12]">
                        {event.title}
                      </h3>
                    </a>

                    <div class="flex items-center gap-2 font-inter text-[0.95rem] text-[#302821bd]">
                      <span class="h-4 w-4 shrink-0" set:html={locationIcon} />
                      <span>{event.address || "Место"}</span>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </section>
        )
      }

      <section class="mt-16">
        <h2
          class="m-0 font-old_standard text-[1.05rem] font-normal uppercase tracking-[0.5em] text-[#15110e]"
        >
          Расписание
        </h2>

        <div class="mt-8 bg-white px-8 py-8 lg:px-8 lg:py-10">
          <div
            class="grid gap-10 lg:grid-cols-[25.5rem_minmax(0,1fr)] lg:gap-16 xl:gap-20"
          >
            <CalendarWidget />
            <div class="pt-1">
              <FilterButtons />
            </div>
          </div>
        </div>
      </section>

      <section class="mt-16">
        <EventList />
      </section>
    </div>
  </main>
</Layout>
