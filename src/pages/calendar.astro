---
import Layout from "../Layouts/Layout.astro";
import { ChevronLeft, ChevronRight } from "lucide-astro";
import FilterButtons from "../components/calendar/FilterButtons.astro";
import CalendarWidget from "../components/calendar/CalendarWidget.astro";
import EventList from "../components/calendar/EventList.astro";
import EventMetaIcon from "../components/common/EventMetaIcon.astro";
import baletImage from "../assets/images/calendar/balet.png";
import theatreShowImage from "../assets/images/calendar/theatre-show.png";
import smallEventImage from "../assets/images/calendar/small-event.png";
import picture1 from "../assets/images/culture.jpg";
import { publicCalendarApi } from "@/lib/api/api";

const TAG_LABEL_ALIASES: Record<string, string> = {
  exhibition: "Выставки",
  exhibitions: "Выставки",
  выставка: "Выставки",
  выставки: "Выставки",
  concert: "Классическая музыка",
  concerts: "Классическая музыка",
  performance: "Театр",
  performances: "Театр",
  theatre: "Театр",
  theatres: "Театр",
  theater: "Театр",
  theaters: "Театр",
  event: "Событие",
  events: "События",
  culture: "Событие",
  paris: "Событие",
  books: "Событие",
  artMarket: "Арт-рынок",
  artmarket: "Арт-рынок",
  kids: "Дети",
  opera: "Опера",
  ballet: "Балет",
  dance: "Танец",
  music: "Классическая музыка",
  route: "Экскурсия",
  address: "Событие",
  notebook: "Событие",
  place: "Событие",
  cinema: "Кино",
  festival: "Фестиваль",
  fashion: "Мода",
  meetup: "Встреча",
  visit: "Визит",
  excursion: "Экскурсия",
  classicalmusic: "Классическая музыка",
  classical_music: "Классическая музыка",
};

const toDate = (value: unknown): Date | null => {
  if (!value) {
    return null;
  }
  if (value instanceof Date) {
    return value;
  }
  if (typeof value === "string") {
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? null : parsed;
  }
  if (typeof value === "number") {
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? null : parsed;
  }
  if (typeof value === "object") {
    const maybeSeconds =
      (value as { seconds?: number; _seconds?: number }).seconds ??
      (value as { seconds?: number; _seconds?: number })._seconds;
    if (typeof maybeSeconds === "number") {
      return new Date(maybeSeconds * 1000);
    }
    if (typeof (value as { toDate?: () => Date }).toDate === "function") {
      const parsed = (value as { toDate: () => Date }).toDate();
      return parsed instanceof Date && !Number.isNaN(parsed.getTime())
        ? parsed
        : null;
    }
  }
  return null;
};

const extractDescription = (blocks: any): string => {
  if (!Array.isArray(blocks)) {
    return "Подробнее скоро.";
  }
  const blockWithText = blocks.find(
    (block) => typeof block?.text === "string" && block.text.trim().length > 0,
  );
  if (!blockWithText) {
    return "Подробнее скоро.";
  }
  const text = blockWithText.text.trim();
  return text.length > 180 ? `${text.slice(0, 177).trim()}...` : text;
};

const resolveTagLabel = (rawTag: unknown, fallback: string): string => {
  if (typeof rawTag !== "string") {
    return fallback;
  }
  const trimmed = rawTag.trim();
  if (!trimmed) {
    return fallback;
  }
  const normalized = trimmed.toLowerCase();
  if (/^district[-\s_]?\d{1,2}$/i.test(normalized)) {
    return fallback;
  }
  return TAG_LABEL_ALIASES[normalized] ?? fallback;
};

const normalizeCalendarEventLabels = (event: any) => {
  const fallbackLabel = resolveTagLabel(event?.category, "Событие");
  const tagLabel = resolveTagLabel(event?.tagLabel, fallbackLabel);
  const categoryLabel = resolveTagLabel(event?.categoryLabel, tagLabel);

  return {
    ...event,
    tagLabel,
    categoryLabel,
  };
};

const formatShortDateRange = (
  startIso: string,
  endIso: string | null,
): string => {
  const fmt = (d: Date) =>
    `${d.getUTCDate()}/${String(d.getUTCMonth() + 1).padStart(2, "0")}`;
  const start = toDate(startIso);
  if (!start) return "";
  const end = endIso ? toDate(endIso) : null;
  if (!end || start.getTime() === end.getTime()) return fmt(start);
  return `${fmt(start)} – ${fmt(end)}`;
};

const formatCardDateRange = (
  startIso: string,
  endIso: string | null,
): string => {
  const fmt = (d: Date) =>
    `${d.getUTCDate()} / ${String(d.getUTCMonth() + 1).padStart(2, "0")}`;
  const start = toDate(startIso);
  if (!start) return "";
  const end = endIso ? toDate(endIso) : null;
  if (!end || start.getTime() === end.getTime()) return fmt(start);
  return `${fmt(start)} — ${fmt(end)}`;
};

const getMonthGenitive = (d: Date): string =>
  new Intl.DateTimeFormat("ru-RU", { day: "numeric", month: "long", timeZone: "UTC" })
    .formatToParts(d)
    .find((p) => p.type === "month")?.value ?? "";

const getDateParts = (
  startIso: string,
  endIso: string | null,
): {
  dateDay: string;
  dateMonth: string;
  dateWeekday: string;
  dateYear: string;
  dateEndDay: string | null;
  dateEndMonth: string | null;
  dateEndWeekday: string | null;
  isDateRange: boolean;
} => {
  const start = toDate(startIso);
  if (!start) {
    return {
      dateDay: "",
      dateMonth: "",
      dateWeekday: "",
      dateYear: "",
      dateEndDay: null,
      dateEndMonth: null,
      dateEndWeekday: null,
      isDateRange: false,
    };
  }
  const end = endIso ? toDate(endIso) : null;
  const isRange = Boolean(end && end.getTime() !== start.getTime());
  return {
    dateDay: String(start.getUTCDate()),
    dateMonth: getMonthGenitive(start),
    dateWeekday: start.toLocaleDateString("ru-RU", { weekday: "long", timeZone: "UTC" }),
    dateYear: String(start.getUTCFullYear()),
    dateEndDay: isRange && end ? String(end.getUTCDate()) : null,
    dateEndMonth: isRange && end ? getMonthGenitive(end) : null,
    dateEndWeekday:
      isRange && end
        ? end.toLocaleDateString("ru-RU", { weekday: "long", timeZone: "UTC" })
        : null,
    isDateRange: isRange,
  };
};

const formatDateRange = (startIso: string, endIso: string | null): string => {
  const start = toDate(startIso);
  if (!start) {
    return "Дата уточняется";
  }
  const end = endIso ? toDate(endIso) : null;
  const format = (date: Date, withYear = false) =>
    date.toLocaleDateString("ru-RU", {
      day: "numeric",
      month: "long",
      ...(withYear ? { year: "numeric" } : {}),
    });
  if (!end || start.getTime() === end.getTime()) {
    return format(start, true);
  }
  const sameYear = end.getUTCFullYear() === start.getUTCFullYear();
  return `${format(start, !sameYear)} – ${format(end, true)}`;
};

let normalizedEvents: any[] = [];
let featuredEventSourceCards: any[] = [];
let topSourceCards: any[] = [];
let lastChanceSourceCards: any[] = [];

try {
  const calendarPage = await publicCalendarApi.get();
  normalizedEvents = (calendarPage.events as any[]).map(normalizeCalendarEventLabels);
  featuredEventSourceCards = (calendarPage.featuredEventCards as any[]).map(
    normalizeCalendarEventLabels,
  );
  topSourceCards = (calendarPage.topCards as any[]).map(normalizeCalendarEventLabels);
  lastChanceSourceCards = (calendarPage.lastChanceCards as any[]).map(normalizeCalendarEventLabels);
} catch (error) {
  console.error("Failed to fetch events:", error);
}

const heroFallbackImages = [baletImage, picture1, theatreShowImage];

const buildCardPayload = (event: (typeof normalizedEvents)[number], index: number) => ({
  ...event,
  dateRange: formatDateRange(event.startDate, event.endDate),
  fallbackImage:
    heroFallbackImages[index % heroFallbackImages.length] ?? baletImage,
  ...getDateParts(event.startDate, event.endDate),
});

const featuredEventCards = featuredEventSourceCards.map((event, index) =>
  buildCardPayload(event, index),
);

const topCards = topSourceCards.map((event, index) =>
  buildCardPayload(event, index + 1),
);

const lastChanceCards = lastChanceSourceCards.map((event, index) =>
  buildCardPayload(event, index + 2),
);

const calendarState = JSON.stringify({
  imagePaths: {
    theatreShowSrc: theatreShowImage.src,
    smallEventSrc: smallEventImage.src,
  },
  events: normalizedEvents,
  featuredEvents: featuredEventCards.map((event) => ({
    id: event.id,
    title: event.title,
    imageUrl: event.imageUrl ?? event.fallbackImage.src,
    address: event.address || "Место",
    categoryLabel: event.categoryLabel,
    dateLabel: formatCardDateRange(event.startDate, event.endDate),
    url: event.url,
    ...getDateParts(event.startDate, event.endDate),
  })),
}).replace(/</g, "\\u003c");
---

<Layout
  navbarVariant="default"
  includePreFooterCTA={false}
  title="Афиша Парижа — события и календарь | MAAG France"
  description="Календарь событий в Париже: выставки, концерты, спектакли, встречи и культурные мероприятия на русском языке."
  useClientRouter={true}
>
  <main
    id="calendar-wrapper"
    class="min-h-screen bg-base-200 text-black"
    x-data={`$lazy('calendar', ${calendarState})`}
    @change-month.window="changeMonth($event.detail)"
    @date-selected.window="selectDate($event.detail)"
    @filter-changed.window="setFilter($event.detail.filter)"
  >
    <div
      x-cloak
      x-show="!$store.auth.isLoading && (!$store.auth.isLoggedIn || ($store.auth.isProfileLoaded && $store.auth.profile?.stripeSubscriptionStatus !== 'active' && $store.auth.profile?.stripeSubscriptionStatus !== 'trialing'))"
      class="fixed inset-0 z-10 flex items-center justify-center pointer-events-none"
    >
      <div class="pointer-events-auto mx-4 max-w-sm bg-white p-10 text-center shadow-[0_8px_40px_rgba(0,0,0,0.12)]">
        <p class="mb-3 font-inter text-xs font-bold uppercase tracking-[0.35em] text-accent">
          Maag
        </p>
        <h2 class="mb-4 font-old_standard text-[1.75rem] font-normal leading-[1.1] text-black">
          Только для подписчиков
        </h2>
        <p class="mb-8 font-inter text-[0.9rem] leading-relaxed text-black/60">
          Календарь событий доступен по подписке. Оформите подписку, чтобы получить полный доступ к афише.
        </p>

        <div x-show="!$store.auth.isLoggedIn" class="flex flex-col gap-3">
          <button
            type="button"
            @click="$store.auth.openAuthModal()"
            class="w-full cursor-pointer bg-black py-3 font-inter text-sm font-bold uppercase tracking-[0.25em] text-white transition-opacity hover:opacity-75"
          >
            Войти
          </button>
          <a
            href="/profile"
            class="block w-full border border-black py-3 font-inter text-sm font-bold uppercase tracking-[0.25em] text-black no-underline transition-opacity hover:opacity-60"
          >
            Оформить подписку
          </a>
        </div>

        <div x-show="$store.auth.isLoggedIn && $store.auth.isProfileLoaded">
          <a
            href="/profile"
            class="block w-full bg-black py-3 font-inter text-sm font-bold uppercase tracking-[0.25em] text-white no-underline transition-opacity hover:opacity-75"
          >
            Оформить подписку
          </a>
        </div>
      </div>
    </div>
    <div
      :class="!$store.auth.isLoading && (!$store.auth.isLoggedIn || ($store.auth.isProfileLoaded && $store.auth.profile?.stripeSubscriptionStatus !== 'active' && $store.auth.profile?.stripeSubscriptionStatus !== 'trialing')) ? 'blur-sm pointer-events-none select-none' : ''"
      class="mx-auto max-w-[1440px] px-4 pt-8 pb-20 sm:px-6 lg:px-8 lg:pt-10 lg:pb-[6.5rem]"
    >
      <h1
        class="text-3xl lg:text-[28px] font-old_standard font-semibold uppercase tracking-[0.46em] text-base-content w-full mb-10"
      >
        Календарь
      </h1>

      {
        featuredEventCards.length > 0 && (
          <section class="mt-6">
            <h2
              class="m-0 font-old_standard text-[1.05rem] font-semibold uppercase tracking-[0.5em] text-black"
            >
              Главные события
            </h2>

            <div
              class="relative mt-8"
              @mouseenter="setFeaturedHover(true)"
              @mouseleave="setFeaturedHover(false)"
              @focusin="setFeaturedFocus(true)"
              @focusout="if (!$event.relatedTarget || !$el.contains($event.relatedTarget)) setFeaturedFocus(false)"
            >
              <button
                type="button"
                aria-label="Предыдущее"
                class="absolute left-[-1rem] top-1/2 -translate-y-1/2 z-10 hidden h-10 w-10 items-center justify-center rounded-full text-base-content md:flex cursor-pointer"
                x-show="hasMultipleFeaturedEvents()"
                @click.prevent="prevFeaturedEvent()"
              >
                <ChevronLeft class="h-5 w-5" />
              </button>
              <button
                type="button"
                aria-label="Следующее"
                class="absolute right-[-1rem] top-1/2 -translate-y-1/2 z-10 hidden h-10 w-10 items-center justify-center rounded-full text-base-content md:flex cursor-pointer"
                x-show="hasMultipleFeaturedEvents()"
                @click.prevent="nextFeaturedEvent()"
              >
                <ChevronRight class="h-5 w-5" />
              </button>

              <div class="mx-auto max-w-[1052px] lg:min-h-[21rem]">
                <article
                  x-show="isFeaturedEventVisible && getCurrentFeaturedEvent()"
                  x-transition.opacity.duration.220ms
                  class="grid overflow-hidden bg-white lg:min-h-[21rem] lg:grid-cols-[minmax(0,1.45fr)_minmax(16rem,0.95fr)]"
                >
                  <a
                    :href="getCurrentFeaturedEvent()?.url || '#'"
                    class="linked-image-hover aspect-[3/2]"
                    :aria-label="getCurrentFeaturedEvent()?.title || 'Событие месяца'"
                  >
                    <img
                      :src="getCurrentFeaturedEvent()?.imageUrl || ''"
                      :alt="getCurrentFeaturedEvent()?.title || 'Событие месяца'"
                      class="linked-image-hover__media block h-full w-full object-cover"
                    />
                  </a>

                  <div class="grid content-start gap-[0.55rem] bg-white p-[1.2rem] lg:px-8 lg:pt-[1.35rem] lg:pb-[1.1rem]">
                    <div class="mb-6 flex w-full items-start justify-start">
                      <template x-if="!getCurrentFeaturedEvent()?.isDateRange">
                        <div class="flex flex-col items-start justify-center">
                          <p
                            class="mx-0 mt-4 font-old_standard text-7xl tracking-[-0.06em] uppercase text-black"
                            x-text="getCurrentFeaturedEvent()?.dateDay || ''"
                          ></p>
                          <p
                            class="m-0 -mt-2 font-inter text-xl font-bold uppercase text-black/70"
                            x-text="getCurrentFeaturedEvent()?.dateMonth || ''"
                          ></p>
                          <div class="mb-1 w-full border-t border-black/30"></div>
                          <p
                            class="m-0 mb-1 font-old_standard text-xl font-bold italic text-black/70"
                            x-text="getCurrentFeaturedEvent()?.dateWeekday || ''"
                          ></p>
                        </div>
                      </template>

                      <template x-if="getCurrentFeaturedEvent()?.isDateRange">
                        <div class="w-full flex items-center justify-between gap-4 sm:gap-5">
                          <div class="flex flex-col items-start justify-center">
                            <p
                              class="mx-0 mt-4 font-old_standard text-6xl tracking-[-0.06em] uppercase text-black sm:text-7xl"
                              x-text="getCurrentFeaturedEvent()?.dateDay || ''"
                            ></p>
                            <p
                              class="m-0 -mt-2 font-inter text-lg font-bold uppercase text-black/70 sm:text-xl"
                              x-text="getCurrentFeaturedEvent()?.dateMonth || ''"
                            ></p>
                            <div class="mb-1 w-full border-t border-black/30"></div>
                            <p
                              class="m-0 mb-1 font-old_standard text-lg font-bold italic text-black/70 sm:text-xl"
                              x-text="getCurrentFeaturedEvent()?.dateWeekday || ''"
                            ></p>
                          </div>

                          <div class="mt-3 flex items-center text-black/80">
                            <span class="font-old_standard text-3xl leading-none sm:text-4xl">→</span>
                          </div>

                          <div class="flex flex-col items-start justify-center">
                            <p
                              class="mx-0 mt-4 font-old_standard text-6xl tracking-[-0.06em] uppercase text-black sm:text-7xl"
                              x-text="getCurrentFeaturedEvent()?.dateEndDay || ''"
                            ></p>
                            <p
                              class="m-0 -mt-2 font-inter text-lg font-bold uppercase text-black/70 sm:text-xl"
                              x-text="getCurrentFeaturedEvent()?.dateEndMonth || ''"
                            ></p>
                            <div class="mb-1 w-full border-t border-black/30"></div>
                            <p
                              class="m-0 mb-1 font-old_standard text-lg font-bold italic text-black/70 sm:text-xl"
                              x-text="getCurrentFeaturedEvent()?.dateEndWeekday || ''"
                            ></p>
                          </div>
                        </div>
                      </template>
                    </div>
                    <p class="m-0">
                      <span
                        class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']"
                        x-text="getCurrentFeaturedEvent()?.categoryLabel || ''"
                      ></span>
                    </p>

                    <a
                      :href="getCurrentFeaturedEvent()?.url || '#'"
                      class="text-current no-underline hover:underline"
                    >
                      <h2
                        class="m-0 font-old_standard text-[clamp(1.4rem,2.2vw,1.9rem)] font-normal leading-[1.04]"
                        x-text="getCurrentFeaturedEvent()?.title || ''"
                      ></h2>
                    </a>

                    <div class="mt-[0.4rem] flex items-center gap-2 font-inter text-[0.95rem] text-[#302821bd]">
                      <EventMetaIcon type="location" class="h-4 w-4 shrink-0 text-accent" />
                      <span x-text="getCurrentFeaturedEvent()?.address || 'Место'"></span>
                    </div>
                  </div>
                </article>
              </div>

              <div
                class="flex md:hidden justify-center items-center gap-6 mt-4"
                x-show="hasMultipleFeaturedEvents()"
              >
                <button
                  type="button"
                  aria-label="Предыдущее"
                  class="flex h-10 w-10 items-center justify-center bg-white text-[#7d726a] cursor-pointer"
                  @click.prevent="prevFeaturedEvent()"
                >
                  <ChevronLeft class="h-5 w-5" />
                </button>
                <button
                  type="button"
                  aria-label="Следующее"
                  class="flex h-10 w-10 items-center justify-center bg-white text-[#7d726a] cursor-pointer"
                  @click.prevent="nextFeaturedEvent()"
                >
                  <ChevronRight class="h-5 w-5" />
                </button>
              </div>
            </div>
          </section>
        )
      }

      {
        topCards.length > 0 && (
          <section class="mt-10">
            <h2 class="m-0 font-old_standard text-[1.05rem] font-semibold uppercase tracking-[0.5em] text-[#15110e]">
              Обязательная программа
            </h2>

            <div class="mt-8 grid grid-cols-1 gap-y-6 sm:grid-cols-2 sm:gap-x-4 lg:grid-cols-4 lg:gap-x-5 lg:gap-y-[1.9rem]">
              {topCards.map((event) => (
                <article class="grid h-full grid-rows-[auto_1fr] overflow-hidden bg-white">
                  <a
                    href={event.url}
                    class="linked-image-hover aspect-[1.12/1] lg:aspect-[3/2]"
                    aria-label={event.title}
                  >
                    <img
                      src={event.imageUrl ?? event.fallbackImage.src}
                      alt={event.title}
                      class="linked-image-hover__media block h-full w-full object-cover"
                    />
                  </a>

                  <div class="grid h-full grid-rows-[auto_auto_1fr_auto] gap-[0.55rem] content-start p-4 lg:p-[1.15rem]">
                    {
                      event.isDateRange ? (
                        <div class="mb-2 flex w-full items-start justify-between gap-3">
                          <div class="flex flex-col items-start justify-center">
                            <p class="m-0 font-old_standard text-[3rem] leading-[0.9] tracking-[-0.06em] uppercase text-black lg:text-[3.3rem]">
                              {event.dateDay}
                            </p>
                            <p class="m-0 -mt-1 font-inter text-[0.82rem] font-bold uppercase tracking-[0.18em] text-black/80 lg:text-[0.95rem]">
                              {event.dateMonth}
                            </p>
                            <div class="mb-1 mt-1 w-full border-t border-black/30"></div>
                            <p class="m-0 font-old_standard text-[0.9rem] italic text-black/70 lg:text-[1rem]">
                              {event.dateWeekday}
                            </p>
                          </div>

                          <div class="mt-[1.45rem] flex items-center text-black/80">
                            <span class="font-old_standard text-[1.6rem] leading-none lg:text-[1.85rem]">→</span>
                          </div>

                          <div class="flex flex-col items-start justify-center">
                            <p class="m-0 font-old_standard text-[3rem] leading-[0.9] tracking-[-0.06em] uppercase text-black lg:text-[3.3rem]">
                              {event.dateEndDay}
                            </p>
                            <p class="m-0 -mt-1 font-inter text-[0.82rem] font-bold uppercase tracking-[0.18em] text-black/80 lg:text-[0.95rem]">
                              {event.dateEndMonth}
                            </p>
                            <div class="mb-1 mt-1 w-full border-t border-black/30"></div>
                            <p class="m-0 font-old_standard text-[0.9rem] italic text-black/70 lg:text-[1rem]">
                              {event.dateEndWeekday}
                            </p>
                          </div>
                        </div>
                      ) : (
                        <div class="mb-2 flex flex-col items-start justify-center">
                          <p class="m-0 font-old_standard text-[3rem] leading-[0.9] tracking-[-0.06em] uppercase text-black lg:text-[3.3rem]">
                            {event.dateDay}
                          </p>
                          <p class="m-0 -mt-1 font-inter text-[0.82rem] font-bold uppercase tracking-[0.18em] text-black/80 lg:text-[0.95rem]">
                            {event.dateMonth}
                          </p>
                          <div class="mb-1 mt-1 w-full border-t border-black/30"></div>
                          <p class="m-0 font-old_standard text-[0.9rem] italic text-black/70 lg:text-[1rem]">
                            {event.dateWeekday}
                          </p>
                        </div>
                      )
                    }

                    <p class="m-0">
                      <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                        {event.categoryLabel}
                      </span>
                    </p>

                    <a
                      href={event.url}
                      class="text-current no-underline hover:underline"
                    >
                      <h3 class="m-0 line-clamp-3 font-old_standard text-[1.2rem] font-normal leading-[1.08] lg:text-[1.4rem] lg:leading-[1.12]">
                        {event.title}
                      </h3>
                    </a>

                    <div class="flex items-center gap-2 font-inter text-[0.95rem] text-[#302821bd]">
                      <EventMetaIcon type="location" class="h-4 w-4 shrink-0 text-accent" />
                      <span>{event.address || "Место"}</span>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </section>
        )
      }

      {
        lastChanceCards.length > 0 && (
          <section class="mt-10">
            <h2 class="m-0 font-old_standard text-[1.05rem] font-semibold uppercase tracking-[0.5em] text-[#15110e]">
              Последний шанс
            </h2>

            <div class="mt-8 grid grid-cols-1 gap-y-6 sm:grid-cols-2 sm:gap-x-4 lg:grid-cols-4 lg:gap-x-5 lg:gap-y-[1.9rem]">
              {lastChanceCards.map((event) => (
                <article class="grid h-full grid-rows-[auto_1fr] overflow-hidden bg-white">
                  <a
                    href={event.url}
                    class="linked-image-hover aspect-[1.12/1] lg:aspect-[3/2]"
                    aria-label={event.title}
                  >
                    <img
                      src={event.imageUrl ?? event.fallbackImage.src}
                      alt={event.title}
                      class="linked-image-hover__media block h-full w-full object-cover"
                    />
                  </a>

                  <div class="grid h-full grid-rows-[auto_auto_1fr_auto] gap-[0.55rem] content-start p-4 lg:p-[1.15rem]">
                    <div class="mb-2 flex flex-row items-center justify-start gap-4">
                      <div class="flex flex-col items-center justify-center gap-0">
                        <p class="m-0 font-old_standard text-lg italic text-base-content lg:text-3xl">до</p>
                        <p class="m-0 font-inter text-xl font-bold uppercase tracking-[0.18em] text-black/80 lg:text-4xl">
                          →
                        </p>
                      </div>
                      <div>
                          <p class="m-0 font-old_standard text-[3rem] leading-[0.9] tracking-[-0.06em] uppercase text-base-content lg:text-[3.3rem]">
                            {event.isDateRange ? event.dateEndDay : event.dateDay}
                          </p>
                        <p class="m-0 -mt-1 font-inter text-[0.82rem] font-bold uppercase tracking-[0.18em] text-base-content lg:text-[0.95rem]">{event.isDateRange ? event.dateEndMonth : event.dateMonth}</p>
                        <div class="mb-1 mt-1 w-full border-t border-black/30"></div>
                        <p class="m-0 font-old_standard text-[0.9rem] italic text-base-content lg:text-[1rem]">
                          {event.isDateRange ? event.dateEndWeekday : event.dateWeekday}
                        </p>
                      </div>
                    </div>

                    <p class="m-0">
                      <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                        {event.categoryLabel}
                      </span>
                    </p>

                    <a
                      href={event.url}
                      class="text-current no-underline hover:underline"
                    >
                      <h3 class="m-0 line-clamp-3 font-old_standard text-[1.2rem] font-normal leading-[1.08] lg:text-[1.4rem] lg:leading-[1.12]">
                        {event.title}
                      </h3>
                    </a>

                    <div class="flex items-center gap-2 font-inter text-[0.95rem] text-[#302821bd]">
                      <EventMetaIcon type="location" class="h-4 w-4 shrink-0 text-accent" />
                      <span>{event.address || "Место"}</span>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </section>
        )
      }

      <section class="mt-16">
        <h2
          class="m-0 font-old_standard text-[1.05rem] font-semibold uppercase tracking-[0.5em] text-[#15110e]"
        >
          Афиша
        </h2>

        <div class="mt-8 bg-white p-4 sm:p-6 lg:px-8 lg:py-10">
          <div
            class="grid gap-10 lg:grid-cols-[25.5rem_minmax(0,1fr)] lg:gap-16 xl:gap-20"
          >
            <CalendarWidget />
            <div class="pt-1">
              <FilterButtons />
            </div>
          </div>
        </div>
      </section>

      <section class="mt-16">
        <EventList />
      </section>
    </div>
  </main>
</Layout>
