---
import DashboardLayout from "@/Layouts/DashboardLayout.astro";
import AuthorIcon from "@/assets/icons/ix_pen-filled.svg";
import Button from "@/components/common/Button.astro";
import DashboardTipsBodyPreview from "@/components/dashboard/DashboardTipsBodyPreview.astro";
---

<DashboardLayout title="Предпросмотр tips-статьи" active="tips">
  <div
    id="preview-container"
    class="max-w-[1512px] mx-auto"
    x-data="$lazy('tipsArticleCreator', { isPreview: true })"
  >
    <div class="bg-base-100 border border-base-300 rounded-xl shadow-sm">
      <div class="px-6 py-6 border-b border-base-300 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-semibold">Предпросмотр tips-статьи</h1>
          <p class="text-sm text-base-content/70 mt-1">
            Используй кнопки справа, чтобы вернуться к редактированию или сохранить материал.
          </p>
        </div>
        <div class="flex gap-2">
          <Button variant="secondary" @click="returnToEdit()">Вернуться к редактированию</Button>
          <Button variant="primary" @click="saveArticle()">Сохранить статью</Button>
        </div>
      </div>

      <main class="bg-base-100">
        <section class="pt-[50px] pb-[70px] px-4 lg:px-0 flex flex-col items-center gap-[50px]">
          <div class="flex flex-col gap-4 max-w-[825px] w-full">
            <p
              class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter'] mt-2"
              x-text="getCategoryLabel(article.category)"
            ></p>
            <h1
              class="text-3xl lg:text-[52px] leading-tight font-old_standard text-base-content w-full"
              x-text="article.title"
            ></h1>
            <p
              x-show="article.lead"
              x-text="article.lead"
              class="text-base font-light text-base-content font-article-body mt-2"
            ></p>
            <div class="flex items-center gap-[17px]">
              <AuthorIcon class="w-4 h-4" />
              <div
                class="text-base lg:text-xl font-thin font-old_standard italic text-base-content"
                x-text="getPreviewAuthorName()"
              ></div>
            </div>
          </div>

          <template x-if="article.imageUrl">
            <figure class="w-full max-w-[1200px] px-6">
              <img
                :src="article.imageUrl"
                :alt="article.imageCaption || article.title || 'Tips image'"
                class="w-full h-auto shadow-lg"
              />
              <figcaption
                x-show="article.imageCaption"
                x-text="article.imageCaption"
                class="text-center text-gray-500 mt-2"
              ></figcaption>
            </figure>
          </template>
        </section>

        <div class="w-full px-4 lg:px-14 pt-10 pb-[100px] lg:pt-16">
          <DashboardTipsBodyPreview />
        </div>
      </main>
    </div>
  </div>
</DashboardLayout>
