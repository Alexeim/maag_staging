---
import DashboardLayout from "@/Layouts/DashboardLayout.astro";
import TipsArticleComposer from "@/components/dashboard/TipsArticleComposer.astro";
import { articlesApi, authorsApi } from "@/lib/api/api";
import { categoryTags, parisDistrictTags } from "@/content/tags/parisTags";

const { id } = Astro.params;

let article = null;
let authors: any[] = [];
let loadFailed = false;

if (id) {
  try {
    [article, authors] = await Promise.all([
      articlesApi.getById(id),
      authorsApi.list(),
    ]);
  } catch (error) {
    console.error(`Failed to load tips article with id ${id}`, error);
    loadFailed = true;
  }
}

const tipsCreatorState = JSON.stringify({
  categoryTags,
  parisDistrictOptions: parisDistrictTags,
  isEditMode: true,
  articleId: id,
  initialArticle: article,
  initialAuthors: authors,
  onSaveRedirect: "/dashboard/tips",
});
---

<DashboardLayout title="Редактировать tips-статью" active="create-tips">
  {loadFailed ? (
    <div class="p-8 text-center text-base-content/70">
      <p>Не удалось загрузить данные для редактирования. Обнови страницу.</p>
    </div>
  ) : article ? (
    <TipsArticleComposer
      heading="Редактировать tips-статью"
      submitLabel="Сохранить изменения"
      tipsCreatorState={tipsCreatorState}
      cancelHref="/dashboard/tips"
      deleteArticleId={id}
      deleteRedirect="/dashboard/tips"
    />
  ) : (
    <div class="p-8 text-center text-base-content/70">
      <p>Статья не найдена.</p>
    </div>
  )}
</DashboardLayout>
