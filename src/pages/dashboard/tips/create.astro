---
import DashboardLayout from "@/Layouts/DashboardLayout.astro";
import TipsArticleComposer from "@/components/dashboard/TipsArticleComposer.astro";
import { categoryTags, parisDistrictTags } from "@/content/tags/parisTags";

const tipsCreatorState = JSON.stringify({
  categoryTags,
  parisDistrictOptions: parisDistrictTags,
  isEditMode: false,
  onSaveRedirect: "/dashboard",
});
---

<DashboardLayout title="Создать tips-статью" active="create-tips">
  <TipsArticleComposer
    heading="Создать tips-статью"
    submitLabel="Сохранить статью"
    tipsCreatorState={tipsCreatorState}
    cancelHref="/dashboard"
  />
</DashboardLayout>
