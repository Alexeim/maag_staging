---
import DashboardLayout from "../../../Layouts/DashboardLayout.astro";
import FlipperComposer from "../../../components/dashboard/FlipperComposer.astro";
import { categoryTags, parisDistrictTags } from "@/content/tags/parisTags";

const creatorState = JSON.stringify({
  initialFlipper: null,
  flipperId: null,
  isEditMode: false,
  categoryTags,
  parisDistrictOptions: parisDistrictTags,
});
---

<DashboardLayout title="Создать листалку" active="create-flipper">
  <FlipperComposer creatorState={creatorState} />
</DashboardLayout>
