---
import DashboardLayout from "../../../../Layouts/DashboardLayout.astro";
import FlipperComposer from "../../../../components/dashboard/FlipperComposer.astro";
import { flippersApi } from "../../../../lib/api/api";
import { categoryTags, parisDistrictTags } from "@/content/tags/parisTags";

const { id } = Astro.params;
const flipper = await flippersApi.getById(id);

if (!flipper) {
  return Astro.redirect("/404");
}

const creatorState = JSON.stringify({
  initialFlipper: flipper,
  flipperId: id,
  isEditMode: true,
  onSaveRedirect: "/dashboard/flippers",
  categoryTags,
  parisDistrictOptions: parisDistrictTags,
});
---

<DashboardLayout title={`Редактирование: ${flipper.title}`} active="flippers">
  <FlipperComposer
    heading={`Редактирование: ${flipper.title}`}
    submitLabel="Обновить листалку"
    creatorState={creatorState}
    cancelHref="/dashboard/flippers"
    deleteFlipperId={id}
  />
</DashboardLayout>
