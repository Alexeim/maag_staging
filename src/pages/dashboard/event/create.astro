---
import DashboardLayout from "@/Layouts/DashboardLayout.astro";
import EventComposer from "@/components/dashboard/EventComposer.astro";
import cultureTags from "@/content/tags/CultureTags.json";
import parisTags from "@/content/tags/ParisTags.json";
import { authorsApi } from "@/lib/api/api";

let authors: any[] = [];
let loadFailed = false;

try {
  authors = await authorsApi.list();
} catch (error) {
  console.error("Failed to fetch authors", error);
  loadFailed = true;
}

const eventCreatorState = JSON.stringify({
  categoryTags: {
    culture: cultureTags.cultureTags,
    paris: parisTags.parisTags,
  },
  initialAuthors: authors,
  isEditMode: false,
  onSaveRedirect: "/dashboard/events",
}).replace(/</g, "\\u003c");
---

<DashboardLayout title="Создать событие" active="create-event">
  {loadFailed ? (
    <div class="bg-base-100 border border-base-300 rounded-xl p-6">
      <h2 class="text-xl font-semibold mb-2">Не удалось загрузить данные для редактирования</h2>
      <p class="text-base-content/70">Обнови страницу — похоже, произошёл временный сбой сети.</p>
      <a href="/dashboard/events" class="text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 me-2 mb-2">Вернуться к списку событий</a>
    </div>
  ) : (
    <EventComposer
      heading="Создать новое событие"
      submitLabel="Сохранить событие"
      eventCreatorState={eventCreatorState}
      cancelHref="/dashboard/events"
    />
  )}
</DashboardLayout>
