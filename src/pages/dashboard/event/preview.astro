---
import DashboardLayout from "@/Layouts/DashboardLayout.astro";
import ArticleAuthor from "@/components/article/ArticleAuthor.astro";
import Button from "@/components/common/Button.astro";
import DashboardArticleBodyPreview from "@/components/dashboard/DashboardArticleBodyPreview.astro";
import articleData from "@/content/articlePage/RU/Article.json";
---

<DashboardLayout title="Предпросмотр события" active="events">
  <div
    id="preview-container"
    class="max-w-[1512px] mx-auto"
    x-data="$lazy('eventCreator', { isPreview: true })"
  >
    <div class="bg-base-100 border border-base-300 rounded-xl shadow-sm">
      <div class="px-6 py-6 border-b border-base-300 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-semibold">Предпросмотр события</h1>
          <p class="text-sm text-base-content/70 mt-1">
            Используй кнопки справа, чтобы вернуться к редактированию или сохранить событие.
          </p>
        </div>
        <div class="flex gap-2">
          <Button variant="secondary" @click="returnToEdit()">Вернуться к редактированию</Button>
          <Button variant="primary" @click="saveEvent()">Сохранить событие</Button>
        </div>
      </div>

      <main class="bg-base-100">
        <section class="pt-[50px] pb-[70px] px-4 lg:px-0 flex flex-col items-center gap-[50px]">
          <div class="flex flex-col gap-4 max-w-[825px] w-full">
            <p
              class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter'] mt-2"
              x-text="article.tags?.length ? getTagLabel(article.tags[0]) : 'Событие'"
            ></p>
            <h1
              class="text-3xl lg:text-[52px] leading-tight font-old_standard text-base-content w-full"
              x-text="article.title"
            ></h1>
            <p
              x-show="article.lead"
              x-text="article.lead"
              class="text-base font-light text-base-content font-article-body mt-2"
            ></p>
            <div class="flex flex-wrap gap-3 text-sm text-base-content/70">
              <span x-show="eventForm.startDate" x-text="eventForm.startDate"></span>
              <span x-show="eventForm.endDate && eventForm.dateType === 'duration'" x-text="'— ' + eventForm.endDate"></span>
              <span x-show="eventForm.address" x-text="eventForm.address"></span>
              <span x-show="eventForm.startTime" x-text="eventForm.endTime ? `${eventForm.startTime} — ${eventForm.endTime}` : eventForm.startTime"></span>
            </div>
            <ArticleAuthor
              name={articleData.author.name}
              avatarUrl={articleData.author.avatarUrl}
            />
          </div>

          <template x-if="article.imageUrl">
            <figure class="w-full max-w-[1200px] px-6">
              <img
                :src="article.imageUrl"
                :alt="article.imageCaption || article.title || 'Event image'"
                class="w-full h-auto shadow-lg"
              />
              <figcaption
                x-show="article.imageCaption"
                x-text="article.imageCaption"
                class="text-center text-gray-500 mt-2"
              ></figcaption>
            </figure>
          </template>
        </section>

        <div class="w-full px-4 lg:px-14 pt-10 pb-[100px] lg:pt-16">
          <DashboardArticleBodyPreview imageAltLabel="Event image" />
        </div>
      </main>
    </div>
  </div>
</DashboardLayout>
