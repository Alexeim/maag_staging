---
import DashboardLayout from "@/Layouts/DashboardLayout.astro";
import AuthorIcon from "@/assets/icons/ix_pen-filled.svg";
import Button from "@/components/common/Button.astro";
import DashboardArticleBodyPreview from "@/components/dashboard/DashboardArticleBodyPreview.astro";
---

<DashboardLayout title="Предпросмотр статьи" active="create-article">
  <div
    id="preview-container"
    class="max-w-[1512px] mx-auto"
    x-data="$lazy('articleCreator', { isPreview: true })"
  >
    <div class="bg-base-100 border border-base-300 rounded-xl shadow-sm">
      <div class="px-6 py-6 border-b border-base-300 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-semibold">Предпросмотр статьи</h1>
          <p class="text-sm text-base-content/70 mt-1">
            Используй кнопки внизу, чтобы вернуться к редактированию или сохранить материал.
          </p>
        </div>
        <div class="flex gap-2">
          <Button variant="secondary" @click="returnToEdit()">Вернуться к редактированию</Button>
          <Button variant="primary" @click="saveArticle()">Сохранить статью</Button>
        </div>
      </div>

      <main class="bg-base-100">
        <div class="pt-16 pb-20 flex flex-col items-center gap-16">
          <div class="flex flex-col gap-8 max-w-[825px] w-full px-6">
            <div>
              <p
                class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter'] mt-2 mb-2"
                x-text="getCategoryLabel(article.category)">
              </p>
              <h1
                class="text-3xl lg:text-[52px] leading-tight font-old_standard text-base-content w-full"
                x-text="article.title">
              </h1>
              <p
                x-show="article.lead"
                x-text="article.lead"
                class="text-base font-light text-base-content font-article-body mt-2">
              </p>
            </div>
            <div class="flex items-center gap-[17px]">
              <AuthorIcon class="w-4 h-4" />
              <div
                class="text-base lg:text-xl font-thin font-old_standard italic text-base-content"
                x-text="getPreviewAuthorName()"
              ></div>
            </div>
          </div>

          <template x-if="article.imageUrl">
            <figure class="w-full max-w-[1200px] px-6">
              <img
                :src="article.imageUrl"
                alt="Article Image Preview"
                class="w-full h-auto rounded-lg shadow-lg"
              />
              <figcaption
                x-show="article.imageCaption"
                x-text="article.imageCaption"
                class="text-center text-sm text-base-content/60 mt-2"
              ></figcaption>
            </figure>
          </template>
        </div>

        <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-14 pb-16">
          <DashboardArticleBodyPreview imageAltLabel="Article image" />
        </div>
      </main>
    </div>
  </div>
</DashboardLayout>
