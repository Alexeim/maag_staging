---
import DashboardLayout from "@/Layouts/DashboardLayout.astro";
import ArticleComposer from "@/components/dashboard/ArticleComposer.astro";
import { categoryTags, parisDistrictTags } from "@/content/tags/parisTags";
import { articlesApi } from "@/lib/api/api";

const { id } = Astro.params;

let article = null;
try {
  article = await articlesApi.getById(id);
} catch (error) {
  console.error("Failed to fetch Le saviez-vous article", error);
}

const articleCreatorState = JSON.stringify({
  categoryTags,
  parisDistrictOptions: parisDistrictTags,
  initialArticle: article,
  articleId: id,
  articleType: "le_saviez_vous",
  isEditMode: true,
  onSaveRedirect: "/dashboard/le-saviez-vous",
  createSuccessRedirect: "/dashboard/le-saviez-vous",
  editRouteBase: "/dashboard/le-saviez-vous",
  createRoute: "/dashboard/le-saviez-vous/create",
});
---

<DashboardLayout title="Редактировать Le saviez-vous" active="le-saviez-vous">
  {article ? (
    <ArticleComposer
      heading="Редактировать Le saviez-vous"
      submitLabel="Сохранить материал"
      articleCreatorState={articleCreatorState}
      cancelHref="/dashboard/le-saviez-vous"
      deleteArticleId={id}
      deleteRedirect="/dashboard/le-saviez-vous"
    />
  ) : (
    <div class="bg-base-100 border border-base-300 rounded-xl p-6">
      <h2 class="text-xl font-semibold mb-2">Материал не найден</h2>
      <p class="text-base-content/70">
        Возможно, запись была удалена или указан неверный идентификатор.
      </p>
      <a
        href="/dashboard/le-saviez-vous"
        class="text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 me-2 mb-2"
      >
        Вернуться к списку
      </a>
    </div>
  )}
</DashboardLayout>
