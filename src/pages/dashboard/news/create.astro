---
import DashboardLayout from "@/Layouts/DashboardLayout.astro";
import NewsComposer from "@/components/dashboard/NewsComposer.astro";
import newsTags from "@/content/tags/NewsTags.json";

const newsCreatorState = JSON.stringify({
  categoryTags: {
    culture: newsTags.newsTags,
    paris: newsTags.newsTags,
  },
  isEditMode: false,
  onSaveRedirect: "/dashboard/news",
});
---

<DashboardLayout title="Создать новость" active="create-news">
  <NewsComposer
    heading="Создать новость"
    submitLabel="Сохранить новость"
    newsCreatorState={newsCreatorState}
    cancelHref="/dashboard/news"
  />
</DashboardLayout>
