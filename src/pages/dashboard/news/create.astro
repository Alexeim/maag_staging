---
import DashboardLayout from "@/Layouts/DashboardLayout.astro";
import NewsComposer from "@/components/dashboard/NewsComposer.astro";
import newsTags from "@/content/tags/NewsTags.json";
import { authorsApi } from "@/lib/api/api";

let authors: any[] = [];
let loadFailed = false;

try {
  authors = await authorsApi.list();
} catch (error) {
  console.error("Failed to fetch authors", error);
  loadFailed = true;
}

const newsCreatorState = JSON.stringify({
  categoryTags: {
    culture: newsTags.newsTags,
    paris: newsTags.newsTags,
  },
  initialAuthors: authors,
  isEditMode: false,
  onSaveRedirect: "/dashboard/news",
});
---

<DashboardLayout title="Создать новость" active="create-news">
  {loadFailed ? (
    <div class="bg-base-100 border border-base-300 rounded-xl p-6">
      <h2 class="text-xl font-semibold mb-2">Не удалось загрузить данные для редактирования</h2>
      <p class="text-base-content/70">Обнови страницу — похоже, произошёл временный сбой сети.</p>
      <a href="/dashboard/news" class="text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 me-2 mb-2">Назад к новостям</a>
    </div>
  ) : (
    <NewsComposer
      heading="Создать новость"
      submitLabel="Сохранить новость"
      newsCreatorState={newsCreatorState}
      cancelHref="/dashboard/news"
    />
  )}
</DashboardLayout>
