---
import DashboardLayout from "@/Layouts/DashboardLayout.astro";
import GuideComposer from "@/components/dashboard/GuideComposer.astro";
import cultureTags from "@/content/tags/CultureTags.json";
import parisTags from "@/content/tags/ParisTags.json";
import { guidesApi } from "@/lib/api/api";

const { id } = Astro.params;

let guide = null;
try {
  guide = await guidesApi.getById(id);
} catch (error) {
  console.error("Failed to fetch guide", error);
}

const guideCreatorState = JSON.stringify({
  categoryTags: {
    culture: cultureTags.cultureTags,
    paris: parisTags.parisTags,
  },
  initialArticle: guide,
  articleId: id,
  isEditMode: true,
  onSaveRedirect: "/dashboard/guides",
});
---

<DashboardLayout title="Редактировать путеводитель" active="guides">
  {guide ? (
    <GuideComposer
      heading="Редактировать путеводитель"
      submitLabel="Обновить путеводитель"
      guideCreatorState={guideCreatorState}
      cancelHref="/dashboard/guides"
      deleteGuideId={id}
      deleteRedirect="/dashboard/guides"
    />
  ) : (
    <div class="bg-base-100 border border-base-300 rounded-xl p-6">
      <h2 class="text-xl font-semibold mb-2">Путеводитель не найден</h2>
      <p class="text-base-content/70">Возможно, материал был удалён или указан неверный идентификатор.</p>
      <a href="/dashboard/guides" class="text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 me-2 mb-2">Вернуться к путеводителям</a>
    </div>
  )}
</DashboardLayout>
