---
import DashboardLayout from "@/Layouts/DashboardLayout.astro";
import GuideComposer from "@/components/dashboard/GuideComposer.astro";
import { categoryTags, parisDistrictTags } from "@/content/tags/parisTags";

const guideCreatorState = JSON.stringify({
  categoryTags,
  parisDistrictOptions: parisDistrictTags,
  isEditMode: false,
  onSaveRedirect: "/dashboard/guides",
});
---

<DashboardLayout title="Создать путеводитель" active="create-guide">
  <GuideComposer
    heading="Создать новый путеводитель"
    submitLabel="Сохранить путеводитель"
    guideCreatorState={guideCreatorState}
    cancelHref="/dashboard/guides"
  />
</DashboardLayout>
