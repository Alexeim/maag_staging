      cultureCardsOptions,
      initialCultureCards: initialCultureCardsState,
      parisCardsOptions,
      initialParisCards: initialParisCardsState,
      eventOptions,
      initialEventCard: initialEventCardState,
      interviewOptions,
      initialCultureInterview: initialCultureInterviewState,
      leSaviezVousOptions,
