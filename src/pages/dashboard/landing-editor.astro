---
import DashboardLayout from "@/Layouts/DashboardLayout.astro";
import { PUBLIC_API_BASE_URL } from "@/lib/utils/constants";
import {
  articlesApi,
  editorialPlacementsApi,
  eventsApi,
  flippersApi,
  guidesApi,
  interviewsApi,
  newsApi,
  visualStoriesApi,
  photosOfTheDayApi,
  type LandingCategoryCardsItemType,
  type LandingMainHeroType,
  type LandingNetlenkaItemType,
  type LandingPlacementsResponse,
} from "@/lib/api/api";

const DEFAULT_LANDING_PLACEMENTS: LandingPlacementsResponse = {
  schemaVersion: 4,
  mainHero: null,
  newsRail: {
    mode: "auto-latest",
    limit: 4,
  },
  netlenkaRail: {
    mode: "auto-latest",
    limit: 4,
  },
  cultureHero: null,
  cultureCards: {
    mode: "auto-latest",
    limit: 3,
  },
  parisHero: null,
  parisCards: {
    mode: "auto-latest",
    limit: 3,
  },
  eventCard: {
    mode: "auto-nearest",
  },
  cultureInterviewBlock: {
    mode: "auto-latest",
  },
  leSaviezVousFeature: {
    mode: "auto-latest",
  },
  photoOfTheDayFeature: {
    mode: "auto-latest",
  },
  updatedAt: null,
  updatedBy: null,
};

const MAIN_HERO_TYPE_LABELS: Record<LandingMainHeroType, string> = {
  article: "Статья",
  guide: "Путеводитель",
  interview: "Интервью",
  flipper: "Листалка",
  "visual-story": "Визуальная история",
};

const NETLENKA_TYPE_LABELS: Record<LandingNetlenkaItemType, string> = {
  ...MAIN_HERO_TYPE_LABELS,
};

const CATEGORY_CARDS_TYPE_LABELS: Record<LandingCategoryCardsItemType, string> = {
  article: MAIN_HERO_TYPE_LABELS.article,
  guide: MAIN_HERO_TYPE_LABELS.guide,
  flipper: MAIN_HERO_TYPE_LABELS.flipper,
  "visual-story": MAIN_HERO_TYPE_LABELS["visual-story"],
};

const ARTICLE_BUCKET_LABELS = {
  culture: "Culture",
  paris: "Paris",
  tips: "Tips",
} as const;

const normalizeArticleBucket = (item: { articleType?: string; category?: string }) => {
  if (item.articleType === "tips") {
    return "tips" as const;
  }

  const normalizedCategory = item.category?.trim().toLowerCase();
  if (normalizedCategory === "culture") {
    return "culture" as const;
  }
  if (normalizedCategory === "paris") {
    return "paris" as const;
  }

  return null;
};

const isLeSaviezVousArticle = (item: { articleType?: string }) =>
  item.articleType === "le_saviez_vous";

const isHotContentItem = (item: { isHotContent?: boolean }) =>
  Boolean(item.isHotContent);

const normalizeCategoryKey = (value?: string) => value?.trim().toLowerCase() ?? "";

const toDate = (value: unknown): Date | null => {
  if (!value) {
    return null;
  }
  if (value instanceof Date) {
    return value;
  }
  if (typeof value === "string" || typeof value === "number") {
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? null : parsed;
  }
  if (typeof value === "object") {
    const seconds =
      (value as { seconds?: number }).seconds ??
      (value as { _seconds?: number })._seconds;
    const nanoseconds =
      (value as { nanoseconds?: number }).nanoseconds ??
      (value as { _nanoseconds?: number })._nanoseconds ??
      0;
    if (typeof seconds === "number") {
      return new Date(seconds * 1000 + nanoseconds / 1_000_000);
    }
    if (typeof (value as { toDate?: () => Date }).toDate === "function") {
      const parsed = (value as { toDate: () => Date }).toDate();
      return Number.isNaN(parsed.getTime()) ? null : parsed;
    }
  }
  return null;
};

const formatUpdatedAt = (value: unknown) => {
  const date = toDate(value);
  if (!date) {
    return "—";
  }

  return date.toLocaleString("ru-RU", {
    day: "2-digit",
    month: "long",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });
};

let landingPlacements = DEFAULT_LANDING_PLACEMENTS;
let loadError = "";
let leSaviezVousItems: Array<{ id: string; title: string; createdAt: unknown }> = [];
let photoOfTheDayItems: Array<{ id: string; title: string }> = [];

const contentTitleMaps = {
  mainHero: new Map<string, string>(),
  news: new Map<string, string>(),
  netlenka: new Map<string, string>(),
  events: new Map<string, string>(),
  interviews: new Map<string, string>(),
};
const netlenkaOptionItems: Array<{
  id: string;
  title: string;
  type: LandingNetlenkaItemType;
  typeLabel: string;
  createdAt: unknown;
}> = [];
const cultureCardsOptionItems: Array<{
  id: string;
  title: string;
  type: LandingCategoryCardsItemType;
  typeLabel: string;
  createdAt: unknown;
}> = [];
const parisCardsOptionItems: Array<{
  id: string;
  title: string;
  type: LandingCategoryCardsItemType;
  typeLabel: string;
  createdAt: unknown;
}> = [];
const cultureHeroOptionItems: Array<{
  id: string;
  title: string;
  type: LandingCategoryCardsItemType;
  typeLabel: string;
  createdAt: unknown;
}> = [];
const parisHeroOptionItems: Array<{
  id: string;
  title: string;
  type: LandingCategoryCardsItemType;
  typeLabel: string;
  createdAt: unknown;
}> = [];
const mainHeroArticleMeta = new Map<
  string,
  {
    articleBucket: keyof typeof ARTICLE_BUCKET_LABELS;
    articleBucketLabel: string;
  }
>();

try {
  const [
    placements,
    articles,
    guides,
    interviews,
    flippers,
    visualStories,
    newsItems,
    events,
  ] = await Promise.all([
    editorialPlacementsApi.getLanding().catch(() => DEFAULT_LANDING_PLACEMENTS),
    articlesApi.list(),
    guidesApi.list(),
    interviewsApi.list(),
    flippersApi.list(),
    visualStoriesApi.list(),
    newsApi.list(),
    eventsApi.list(),
  ]);

  landingPlacements = placements;
  const currentMainHeroKey = landingPlacements.mainHero
    ? `${landingPlacements.mainHero.type}:${landingPlacements.mainHero.id}`
    : null;

  articles.forEach((item) => {
    const key = `article:${item.id}`;
    const articleBucket = normalizeArticleBucket(item);
    contentTitleMaps.mainHero.set(key, item.title);
    if (isHotContentItem(item)) {
      contentTitleMaps.netlenka.set(key, item.title);
      netlenkaOptionItems.push({
        id: key,
        title: item.title,
        type: "article",
        typeLabel: NETLENKA_TYPE_LABELS.article,
        createdAt: item.createdAt,
      });
    }
    if (articleBucket) {
      mainHeroArticleMeta.set(key, {
        articleBucket,
        articleBucketLabel: ARTICLE_BUCKET_LABELS[articleBucket],
      });
    }
  });
  guides.forEach((item) => {
    contentTitleMaps.mainHero.set(`guide:${item.id}`, item.title);
    if (isHotContentItem(item)) {
      contentTitleMaps.netlenka.set(`guide:${item.id}`, item.title);
      netlenkaOptionItems.push({
        id: `guide:${item.id}`,
        title: item.title,
        type: "guide",
        typeLabel: NETLENKA_TYPE_LABELS.guide,
        createdAt: item.createdAt,
      });
    }
  });
  interviews.forEach((item) => {
    contentTitleMaps.mainHero.set(`interview:${item.id}`, item.title);
    if (isHotContentItem(item)) {
      contentTitleMaps.netlenka.set(`interview:${item.id}`, item.title);
      netlenkaOptionItems.push({
        id: `interview:${item.id}`,
        title: item.title,
        type: "interview",
        typeLabel: NETLENKA_TYPE_LABELS.interview,
        createdAt: item.createdAt,
      });
    }
    contentTitleMaps.interviews.set(item.id, item.title);
  });
  flippers.forEach((item) => {
    contentTitleMaps.mainHero.set(`flipper:${item.id}`, item.title);
    if (isHotContentItem(item)) {
      contentTitleMaps.netlenka.set(`flipper:${item.id}`, item.title);
      netlenkaOptionItems.push({
        id: `flipper:${item.id}`,
        title: item.title,
        type: "flipper",
        typeLabel: NETLENKA_TYPE_LABELS.flipper,
        createdAt: item.createdAt,
      });
    }
  });
  visualStories.forEach((item) => {
    contentTitleMaps.mainHero.set(`visual-story:${item.id}`, item.title);
    if (isHotContentItem(item)) {
      contentTitleMaps.netlenka.set(`visual-story:${item.id}`, item.title);
      netlenkaOptionItems.push({
        id: `visual-story:${item.id}`,
        title: item.title,
        type: "visual-story",
        typeLabel: NETLENKA_TYPE_LABELS["visual-story"],
        createdAt: item.createdAt,
      });
    }
  });
  newsItems.forEach((item) => {
    contentTitleMaps.news.set(item.id, item.title);
  });
  events.forEach((item) => contentTitleMaps.events.set(item.id, item.title));

  leSaviezVousItems = articles
    .filter((item) => isLeSaviezVousArticle(item))
    .sort((a, b) => {
      const aTime = toDate(a.createdAt)?.getTime() ?? 0;
      const bTime = toDate(b.createdAt)?.getTime() ?? 0;
      return bTime - aTime;
    });

  const categoryCardsCandidates = [
    ...articles
      .filter((item) => !isLeSaviezVousArticle(item))
      .map((item) => ({
        id: `article:${item.id}`,
        title: item.title,
        type: "article" as const,
        typeLabel: CATEGORY_CARDS_TYPE_LABELS.article,
        createdAt: item.createdAt,
        category: normalizeCategoryKey(item.category),
        isHotContent: isHotContentItem(item),
      })),
    ...guides.map((item) => ({
      id: `guide:${item.id}`,
      title: item.title,
      type: "guide" as const,
      typeLabel: CATEGORY_CARDS_TYPE_LABELS.guide,
      createdAt: item.createdAt,
      category: normalizeCategoryKey(item.category),
      isHotContent: isHotContentItem(item),
    })),
    ...flippers.map((item) => ({
      id: `flipper:${item.id}`,
      title: item.title,
      type: "flipper" as const,
      typeLabel: CATEGORY_CARDS_TYPE_LABELS.flipper,
      createdAt: item.createdAt,
      category: normalizeCategoryKey(item.category),
      isHotContent: isHotContentItem(item),
    })),
    ...visualStories.map((item) => ({
      id: `visual-story:${item.id}`,
      title: item.title,
      type: "visual-story" as const,
      typeLabel: CATEGORY_CARDS_TYPE_LABELS["visual-story"],
      createdAt: item.createdAt,
      category: normalizeCategoryKey(item.category),
      isHotContent: isHotContentItem(item),
    })),
  ]
    .filter((item) => !item.isHotContent && item.id !== currentMainHeroKey)
    .sort((left, right) => {
      const leftDate = toDate(left.createdAt)?.getTime() ?? 0;
      const rightDate = toDate(right.createdAt)?.getTime() ?? 0;
      if (leftDate !== rightDate) {
        return rightDate - leftDate;
      }

      return left.title.localeCompare(right.title, "ru-RU");
    });

  const cultureCandidates = categoryCardsCandidates.filter(
    (item) => item.category === "culture",
  );
  cultureHeroOptionItems.push(...cultureCandidates);
  const cultureHeroKey = landingPlacements.cultureHero
    ? `${landingPlacements.cultureHero.type}:${landingPlacements.cultureHero.id}`
    : null;

  cultureCardsOptionItems.push(
    ...cultureCandidates.filter((item) => item.id !== cultureHeroKey),
  );

  const parisCandidates = categoryCardsCandidates.filter(
    (item) => item.category === "paris",
  );
  parisHeroOptionItems.push(...parisCandidates);
  const parisHeroKey = landingPlacements.parisHero
    ? `${landingPlacements.parisHero.type}:${landingPlacements.parisHero.id}`
    : null;

  parisCardsOptionItems.push(
    ...parisCandidates.filter((item) => item.id !== parisHeroKey),
  );
} catch (error) {
  console.error("Failed to load landing editor overview:", error);
  loadError =
    error instanceof Error
      ? error.message
      : "Не удалось загрузить editorial slots landing.";
}

try {
  const photos = await photosOfTheDayApi.list();
  photoOfTheDayItems = photos.map((p) => ({ id: p.id, title: p.title }));
} catch (e) {
  console.error("Failed to fetch photos of the day for landing editor:", e);
}

const getBadgeClass = (modeLabel: string): string => {
  if (modeLabel === "Пусто") {
    return "inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-medium bg-neutral-100 text-neutral-400 border-neutral-200";
  }
  if (modeLabel === "Manual") {
    return "inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-medium bg-blue-50 text-blue-500 border-blue-200";
  }
  if (modeLabel.startsWith("Auto")) {
    return "inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-medium bg-emerald-50 text-emerald-600 border-emerald-200";
  }
  return "inline-flex items-center rounded-full border border-base-300 px-2.5 py-0.5 text-xs font-medium text-base-content/60";
};

const mainHeroSummary = (() => {
  if (!landingPlacements.mainHero) {
    return {
      modeLabel: "Пусто",
      details: "Главный hero-slot сейчас пуст.",
    };
  }

  const { type, id } = landingPlacements.mainHero;
  const title = contentTitleMaps.mainHero.get(`${type}:${id}`) || "Материал не найден";

  return {
    modeLabel: "Manual",
    details: `${MAIN_HERO_TYPE_LABELS[type]}: ${title}`,
  };
})();

const newsRailSummary = (() => {
  if (!landingPlacements.newsRail) {
    return {
      modeLabel: "Пусто",
      details: "Блок новостей сейчас пуст.",
    };
  }

  if (landingPlacements.newsRail.mode === "auto-latest") {
    return {
      modeLabel: "Auto latest",
      details: `Последние ${landingPlacements.newsRail.limit} новости.`,
    };
  }

  const items = landingPlacements.newsRail.ids.map(
    (id) => contentTitleMaps.news.get(id) || `Новость ${id}`,
  );

  return {
    modeLabel: "Manual",
    details: items.length > 0 ? items.join(" | ") : "Список новостей пуст.",
  };
})();

const netlenkaRailSummary = (() => {
  if (!landingPlacements.netlenkaRail) {
    return {
      modeLabel: "Пусто",
      details: "Блок «Самое Читаемое» сейчас пуст.",
    };
  }

  if (landingPlacements.netlenkaRail.mode === "auto-latest") {
    return {
      modeLabel: "Auto latest",
      details: `Последние ${landingPlacements.netlenkaRail.limit} материала(ов) из «Самое Читаемое».`,
    };
  }

  const items = landingPlacements.netlenkaRail.items.map(({ type, id }) => {
    const key = `${type}:${id}`;
    const title = contentTitleMaps.netlenka.get(key) || `${NETLENKA_TYPE_LABELS[type]} ${id}`;
    return `[${NETLENKA_TYPE_LABELS[type]}] ${title}`;
  });

  return {
    modeLabel: "Manual",
    details: items.length > 0 ? items.join(" | ") : "Список материалов пуст.",
  };
})();

const cultureHeroSummary = (() => {
  if (!landingPlacements.cultureHero) {
    return {
      modeLabel: "Пусто",
      details: "Culture hero slot пуст.",
    };
  }

  const key = `${landingPlacements.cultureHero.type}:${landingPlacements.cultureHero.id}`;
  return {
    modeLabel: "Manual",
    details:
      contentTitleMaps.mainHero.get(key) ||
      `${CATEGORY_CARDS_TYPE_LABELS[landingPlacements.cultureHero.type]} ${landingPlacements.cultureHero.id}`,
  };
})();

const cultureCardsSummary = (() => {
  if (!landingPlacements.cultureCards) {
    return {
      modeLabel: "Пусто",
      details: "Карточки culture section на landing сейчас пусты.",
    };
  }

  if (landingPlacements.cultureCards.mode === "auto-latest") {
    return {
      modeLabel: "Auto latest",
      details: `Последние ${landingPlacements.cultureCards.limit} карточки в culture section, с исключением global main hero и hero рубрики.`,
    };
  }

  const items = landingPlacements.cultureCards.items.map(({ type, id }) => {
    const key = `${type}:${id}`;
    const title = contentTitleMaps.mainHero.get(key) || `${CATEGORY_CARDS_TYPE_LABELS[type]} ${id}`;
    return `[${CATEGORY_CARDS_TYPE_LABELS[type]}] ${title}`;
  });

  return {
    modeLabel: "Manual",
    details: items.length > 0 ? items.join(" | ") : "Список материалов пуст.",
  };
})();

const parisHeroSummary = (() => {
  if (!landingPlacements.parisHero) {
    return {
      modeLabel: "Пусто",
      details: "Paris hero slot пуст.",
    };
  }

  const key = `${landingPlacements.parisHero.type}:${landingPlacements.parisHero.id}`;
  return {
    modeLabel: "Manual",
    details:
      contentTitleMaps.mainHero.get(key) ||
      `${CATEGORY_CARDS_TYPE_LABELS[landingPlacements.parisHero.type]} ${landingPlacements.parisHero.id}`,
  };
})();

const parisCardsSummary = (() => {
  if (!landingPlacements.parisCards) {
    return {
      modeLabel: "Пусто",
      details: "Карточки paris section на landing сейчас пусты.",
    };
  }

  if (landingPlacements.parisCards.mode === "auto-latest") {
    return {
      modeLabel: "Auto latest",
      details: `Последние ${landingPlacements.parisCards.limit} карточки в paris section, с исключением global main hero и hero рубрики.`,
    };
  }

  const items = landingPlacements.parisCards.items.map(({ type, id }) => {
    const key = `${type}:${id}`;
    const title = contentTitleMaps.mainHero.get(key) || `${CATEGORY_CARDS_TYPE_LABELS[type]} ${id}`;
    return `[${CATEGORY_CARDS_TYPE_LABELS[type]}] ${title}`;
  });

  return {
    modeLabel: "Manual",
    details: items.length > 0 ? items.join(" | ") : "Список материалов пуст.",
  };
})();

const eventCardSummary = (() => {
  if (!landingPlacements.eventCard) {
    return {
      modeLabel: "Пусто",
      details: "Event card сейчас пустая.",
    };
  }

  if (landingPlacements.eventCard.mode === "auto-nearest") {
    return {
      modeLabel: "Auto nearest",
      details:
        "Сначала single-day событие на сегодня по latest created, если его нет — последний созданный active range event, затем ближайшее upcoming событие.",
    };
  }

  return {
    modeLabel: "Manual",
    details:
      contentTitleMaps.events.get(landingPlacements.eventCard.id) ||
      `Событие ${landingPlacements.eventCard.id}`,
  };
})();

const cultureInterviewSummary = (() => {
  if (!landingPlacements.cultureInterviewBlock) {
    return {
      modeLabel: "Пусто",
      details: "Interview block в culture section landing сейчас пуст.",
    };
  }

  if (landingPlacements.cultureInterviewBlock.mode === "auto-latest") {
    return {
      modeLabel: "Auto latest",
      details: "Автоматически показывается последнее интервью.",
    };
  }

  return {
    modeLabel: "Manual",
    details:
      contentTitleMaps.interviews.get(landingPlacements.cultureInterviewBlock.id) ||
      `Интервью ${landingPlacements.cultureInterviewBlock.id}`,
  };
})();

const slotCards = [
  {
    title: "Main Hero",
    description: "Большой блок «Главное» на landing.",
    modeLabel: mainHeroSummary.modeLabel,
    details: mainHeroSummary.details,
  },
  {
    title: "News Rail",
    description: "Блок новостей в main landing block.",
    modeLabel: newsRailSummary.modeLabel,
    details: newsRailSummary.details,
  },
  {
    title: "Netlenka Rail",
    description: "Блок «Самое Читаемое» в landing body.",
    modeLabel: netlenkaRailSummary.modeLabel,
    details: netlenkaRailSummary.details,
  },
  {
    title: "Culture Hero",
    description: "Главный материал culture section на landing.",
    modeLabel: cultureHeroSummary.modeLabel,
    details: cultureHeroSummary.details,
  },
  {
    title: "Culture Cards",
    description: "Три карточки под hero в culture section на landing.",
    modeLabel: cultureCardsSummary.modeLabel,
    details: cultureCardsSummary.details,
  },
  {
    title: "Paris Hero",
    description: "Главный материал paris section на landing.",
    modeLabel: parisHeroSummary.modeLabel,
    details: parisHeroSummary.details,
  },
  {
    title: "Paris Cards",
    description: "Три карточки под hero в paris section на landing.",
    modeLabel: parisCardsSummary.modeLabel,
    details: parisCardsSummary.details,
  },
  {
    title: "Event Card",
    description: "Карточка события в main landing block.",
    modeLabel: eventCardSummary.modeLabel,
    details: eventCardSummary.details,
  },
  {
    title: "Culture Interview Block",
    description: "Interview block в culture section именно на landing.",
    modeLabel: cultureInterviewSummary.modeLabel,
    details: cultureInterviewSummary.details,
  },
  {
    title: "Фото дня",
    description: "Блок «Фото дня» в sidebar на landing.",
    modeLabel: (() => {
      if (!landingPlacements.photoOfTheDayFeature) return "Пусто";
      if (landingPlacements.photoOfTheDayFeature.mode === "auto-latest") return "Auto latest";
      return "Manual";
    })(),
    details: (() => {
      if (!landingPlacements.photoOfTheDayFeature) return "Фото дня slot пуст.";
      if (landingPlacements.photoOfTheDayFeature.mode === "auto-latest") return "Автоматически показывается последнее фото дня.";
      const id = landingPlacements.photoOfTheDayFeature.id;
      const found = photoOfTheDayItems.find((i) => i.id === id);
      return found ? found.title : `Фото ${id}`;
    })(),
  },
  {
    title: "Le Saviez-Vous",
    description: "Блок «Le saviez-vous?» в paris section на landing.",
    modeLabel: (() => {
      if (!landingPlacements.leSaviezVousFeature) return "Пусто";
      if (landingPlacements.leSaviezVousFeature.mode === "auto-latest") return "Auto latest";
      return "Manual";
    })(),
    details: (() => {
      if (!landingPlacements.leSaviezVousFeature) return "Le saviez-vous slot пуст.";
      if (landingPlacements.leSaviezVousFeature.mode === "auto-latest") return "Автоматически показывается последний le saviez-vous материал.";
      const id = landingPlacements.leSaviezVousFeature.id;
      const found = leSaviezVousItems.find((i) => i.id === id);
      return found ? found.title : `Материал ${id}`;
    })(),
  },
];

const initialNewsRailState = (() => {
  if (!landingPlacements.newsRail) {
    return {
      mode: "empty" as const,
      limit: 4,
      ids: [],
    };
  }

  if (landingPlacements.newsRail.mode === "auto-latest") {
    return {
      mode: "auto-latest" as const,
      limit: landingPlacements.newsRail.limit,
      ids: [],
    };
  }

  return {
    mode: "manual" as const,
    limit: 4,
    ids: landingPlacements.newsRail.ids,
  };
})();

const newsOptions = Array.from(contentTitleMaps.news.entries()).map(([id, title]) => ({
  id,
  title,
}));

const initialNetlenkaRailState = (() => {
  if (!landingPlacements.netlenkaRail) {
    return {
      mode: "empty" as const,
      limit: 4,
      keys: [],
    };
  }

  if (landingPlacements.netlenkaRail.mode === "auto-latest") {
    return {
      mode: "auto-latest" as const,
      limit: landingPlacements.netlenkaRail.limit,
      keys: [],
    };
  }

  const availableNetlenkaKeys = new Set(netlenkaOptionItems.map((item) => item.id));

  return {
    mode: "manual" as const,
    limit: 4,
    keys: landingPlacements.netlenkaRail.items
      .map((item) => `${item.type}:${item.id}`)
      .filter((key) => availableNetlenkaKeys.has(key)),
  };
})();

const initialCultureHeroState = (() => {
  if (!landingPlacements.cultureHero) {
    return { mode: "empty" as const, key: "" };
  }

  return {
    mode: "manual" as const,
    key: `${landingPlacements.cultureHero.type}:${landingPlacements.cultureHero.id}`,
  };
})();

const initialCultureCardsState = (() => {
  if (!landingPlacements.cultureCards) {
    return {
      mode: "empty" as const,
      limit: 3,
      keys: [],
    };
  }

  if (landingPlacements.cultureCards.mode === "auto-latest") {
    return {
      mode: "auto-latest" as const,
      limit: landingPlacements.cultureCards.limit,
      keys: [],
    };
  }

  const availableCultureCardKeys = new Set(cultureCardsOptionItems.map((item) => item.id));

  return {
    mode: "manual" as const,
    limit: 3,
    keys: landingPlacements.cultureCards.items
      .map((item) => `${item.type}:${item.id}`)
      .filter((key) => availableCultureCardKeys.has(key)),
  };
})();

const initialParisHeroState = (() => {
  if (!landingPlacements.parisHero) {
    return { mode: "empty" as const, key: "" };
  }

  return {
    mode: "manual" as const,
    key: `${landingPlacements.parisHero.type}:${landingPlacements.parisHero.id}`,
  };
})();

const initialParisCardsState = (() => {
  if (!landingPlacements.parisCards) {
    return {
      mode: "empty" as const,
      limit: 3,
      keys: [],
    };
  }

  if (landingPlacements.parisCards.mode === "auto-latest") {
    return {
      mode: "auto-latest" as const,
      limit: landingPlacements.parisCards.limit,
      keys: [],
    };
  }

  const availableParisCardKeys = new Set(parisCardsOptionItems.map((item) => item.id));

  return {
    mode: "manual" as const,
    limit: 3,
    keys: landingPlacements.parisCards.items
      .map((item) => `${item.type}:${item.id}`)
      .filter((key) => availableParisCardKeys.has(key)),
  };
})();

const netlenkaOptions = netlenkaOptionItems
  .slice()
  .sort((left, right) => {
    const leftDate = toDate(left.createdAt)?.getTime() ?? 0;
    const rightDate = toDate(right.createdAt)?.getTime() ?? 0;
    if (leftDate !== rightDate) {
      return rightDate - leftDate;
    }

    return left.title.localeCompare(right.title, "ru-RU");
  });

const cultureCardsOptions = cultureCardsOptionItems
  .slice()
  .sort((left, right) => {
    const leftDate = toDate(left.createdAt)?.getTime() ?? 0;
    const rightDate = toDate(right.createdAt)?.getTime() ?? 0;
    if (leftDate !== rightDate) {
      return rightDate - leftDate;
    }

    return left.title.localeCompare(right.title, "ru-RU");
  });

const cultureHeroOptions = cultureHeroOptionItems
  .slice()
  .sort((left, right) => {
    const leftDate = toDate(left.createdAt)?.getTime() ?? 0;
    const rightDate = toDate(right.createdAt)?.getTime() ?? 0;
    if (leftDate !== rightDate) {
      return rightDate - leftDate;
    }

    return left.title.localeCompare(right.title, "ru-RU");
  });

const parisCardsOptions = parisCardsOptionItems
  .slice()
  .sort((left, right) => {
    const leftDate = toDate(left.createdAt)?.getTime() ?? 0;
    const rightDate = toDate(right.createdAt)?.getTime() ?? 0;
    if (leftDate !== rightDate) {
      return rightDate - leftDate;
    }

    return left.title.localeCompare(right.title, "ru-RU");
  });

const parisHeroOptions = parisHeroOptionItems
  .slice()
  .sort((left, right) => {
    const leftDate = toDate(left.createdAt)?.getTime() ?? 0;
    const rightDate = toDate(right.createdAt)?.getTime() ?? 0;
    if (leftDate !== rightDate) {
      return rightDate - leftDate;
    }

    return left.title.localeCompare(right.title, "ru-RU");
  });

const mainHeroOptions = Array.from(contentTitleMaps.mainHero.entries())
  .map(([key, title]) => {
    const separatorIndex = key.indexOf(":");
    const type = key.slice(0, separatorIndex) as LandingMainHeroType;
    const id = key.slice(separatorIndex + 1);
    return {
      id: key,
      title,
      type,
      typeLabel: MAIN_HERO_TYPE_LABELS[type],
      entityId: id,
      ...(type === "article" ? mainHeroArticleMeta.get(key) : {}),
    };
  })
  .sort((left, right) => {
    const typeComparison = left.typeLabel.localeCompare(right.typeLabel, "ru-RU");
    if (typeComparison !== 0) {
      return typeComparison;
    }

    if (left.type === "article" && right.type === "article") {
      const bucketComparison = (left.articleBucketLabel || "").localeCompare(
        right.articleBucketLabel || "",
        "en",
      );
      if (bucketComparison !== 0) {
        return bucketComparison;
      }
    }

    return left.title.localeCompare(right.title, "ru-RU");
  });

const eventOptions = Array.from(contentTitleMaps.events.entries()).map(([id, title]) => ({
  id,
  title,
}));

const interviewOptions = Array.from(contentTitleMaps.interviews.entries()).map(([id, title]) => ({
