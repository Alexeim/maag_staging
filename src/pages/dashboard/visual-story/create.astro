---
import DashboardLayout from "@/Layouts/DashboardLayout.astro";
import VisualStoryComposer from "@/components/dashboard/VisualStoryComposer.astro";
import { categoryTags, parisDistrictTags } from "@/content/tags/parisTags";

const storyCreatorState = JSON.stringify({
  categoryTags,
  parisDistrictOptions: parisDistrictTags,
  isEditMode: false,
  onSaveRedirect: "/dashboard/visual-stories",
});
---

<DashboardLayout title="Создать визуальную историю" active="create-visual-story">
  <VisualStoryComposer
    heading="Создать новую визуальную историю"
    submitLabel="Сохранить историю"
    storyCreatorState={storyCreatorState}
    cancelHref="/dashboard/visual-stories"
  />
</DashboardLayout>
