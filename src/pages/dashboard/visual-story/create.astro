---
import DashboardLayout from "@/Layouts/DashboardLayout.astro";
import VisualStoryComposer from "@/components/dashboard/VisualStoryComposer.astro";
import { categoryTags, parisDistrictTags } from "@/content/tags/parisTags";
import { authorsApi } from "@/lib/api/api";

let authors: any[] = [];
let loadFailed = false;

try {
  authors = await authorsApi.list();
} catch (error) {
  console.error("Failed to fetch authors", error);
  loadFailed = true;
}

const storyCreatorState = JSON.stringify({
  categoryTags,
  parisDistrictOptions: parisDistrictTags,
  initialAuthors: authors,
  isEditMode: false,
  onSaveRedirect: "/dashboard/visual-stories",
});
---

<DashboardLayout title="Создать визуальную историю" active="create-visual-story">
  {loadFailed ? (
    <div class="bg-base-100 border border-base-300 rounded-xl p-6">
      <h2 class="text-xl font-semibold mb-2">Не удалось загрузить данные для редактирования</h2>
      <p class="text-base-content/70">Обнови страницу — похоже, произошёл временный сбой сети.</p>
      <a href="/dashboard/visual-stories" class="text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 font-medium rounded-lg text-sm px-5 py-2.5 me-2 mb-2">Вернуться к визуальным историям</a>
    </div>
  ) : (
    <VisualStoryComposer
      heading="Создать новую визуальную историю"
      submitLabel="Сохранить историю"
      storyCreatorState={storyCreatorState}
      cancelHref="/dashboard/visual-stories"
    />
  )}
</DashboardLayout>
