---
import Layout from "../../Layouts/Layout.astro";
import ArticleBody from "../../components/article/ArticleBody.astro";
import ArticleTips from "../../components/article/ArticleTips.astro";
import GuideHero from "@/components/guide/GuideHero.astro";
import { ApiError, guidesApi } from "@/lib/api/api";

const { id } = Astro.params;

const CATEGORY_LABELS: Record<string, string> = {
  culture: "Культура",
  paris: "Париж",
  hotContent: "Самое Читаемое",
};

let guideData: any;
let error: string | null = null;

try {
  guideData = await guidesApi.getById(id);
} catch (e: any) {
  console.error(e);
  if (e instanceof ApiError) {
    error =
      e.status === 404
        ? "Путеводитель не найден."
        : `Ошибка загрузки путеводителя: ${e.message}`;
  } else {
    error = `Ошибка загрузки путеводителя: ${e.message}`;
  }
}

const rawCategory = guideData?.category ?? null;

const displayGuide = {
  title: guideData?.title || 'Путеводитель',
  lead: guideData?.lead || '',
  category: rawCategory
    ? CATEGORY_LABELS[rawCategory] || rawCategory
    : 'Путеводитель',
  authorName: guideData?.author ? `${guideData.author.firstName} ${guideData.author.lastName}` : 'Автор',
  authorAvatar: guideData?.author?.avatar,
  imageUrl: guideData?.imageUrl,
  imageCaption: guideData?.imageCaption || '',
  imageAlt: 'Guide image',
  contentBlocks: guideData?.content || [],
  tips: Array.isArray(guideData?.tips) ? guideData.tips : [],
};

const transitionAliases = [`landing-body-main-article-image-${id}`];
---

<Layout
  navbarVariant="default"
  includePreFooterCTA={false}
  title={`${displayGuide.title} - Maag`}
  useClientRouter={true}
>
  <main class="bg-base-200 min-h-screen">
    <div class="max-w-[1512px] mx-auto">
      {error && <div class="text-red-500 text-center pt-40">{error}</div>}
      {!error && guideData && (
        <>
          <GuideHero
            category={displayGuide.category}
            title={displayGuide.title}
            lead={displayGuide.lead}
            authorName={displayGuide.authorName}
            authorAvatar={displayGuide.authorAvatar}
            createdAt={guideData.createdAt}
            imageUrl={displayGuide.imageUrl}
            imageAlt={displayGuide.imageAlt}
            imageCaption={displayGuide.imageCaption}
            transitionName={`main-article-image-${id}`}
            transitionAliases={transitionAliases}
          />

          <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-14 pb-[100px]">
            <ArticleBody contentBlocks={displayGuide.contentBlocks} />
            <ArticleTips tips={displayGuide.tips} />
          </div>
        </>
      )}
    </div>
  </main>
</Layout>
