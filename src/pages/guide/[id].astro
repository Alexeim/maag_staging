---
import Layout from "../../Layouts/Layout.astro";
import ArticleBody from "../../components/article/ArticleBody.astro";
import ArticleTips from "../../components/article/ArticleTips.astro";
import ContentActions from "@/components/common/ContentActions.astro";
import GuideHero from "@/components/guide/GuideHero.astro";
import { getKnownTagLabel } from "@/content/tags/parisTags";
import { ApiError, guidesApi } from "@/lib/api/api";
import {
  buildLinkedContentLookup,
  fetchPublicContentPools,
  hasLinkedContentBlocks,
  type LinkedContentLookup,
} from "@/lib/utils/contentCollectionMarquee";
import { buildArticleStructuredData } from "@/lib/seo/structuredData";

const { id } = Astro.params;

const CATEGORY_LABELS: Record<string, string> = {
  culture: "Культура",
  paris: "Париж",
  hotContent: "Самое Читаемое",
};

let guideData: any;
let error: string | null = null;
let linkedContentLookup: LinkedContentLookup = {};

try {
  guideData = await guidesApi.getById(id);
} catch (e: any) {
  console.error(e);
  if (e instanceof ApiError) {
    error =
      e.status === 404
        ? "Путеводитель не найден."
        : `Ошибка загрузки путеводителя: ${e.message}`;
  } else {
    error = `Ошибка загрузки путеводителя: ${e.message}`;
  }
}

if (!error && guideData?.published !== true) {
  error = "Путеводитель не найден.";
  guideData = null;
}

const rawCategory = guideData?.category ?? null;

const displayGuide = {
  title: guideData?.title || 'Путеводитель',
  lead: guideData?.lead || '',
  category: rawCategory
    ? CATEGORY_LABELS[rawCategory] || rawCategory
    : 'Путеводитель',
  authorName: guideData?.author ? `${guideData.author.firstName} ${guideData.author.lastName}` : 'Автор',
  authorAvatar: guideData?.author?.avatar,
  imageUrl: guideData?.imageUrl,
  imageCaption: guideData?.imageCaption || '',
  imageAlt: 'Guide image',
  contentBlocks: guideData?.content || [],
  tips: Array.isArray(guideData?.tips) ? guideData.tips : [],
};

const firstBookmarkTag =
  Array.isArray(guideData?.tags) && typeof guideData.tags[0] === "string"
    ? getKnownTagLabel(guideData.tags[0]) || ""
    : "";
const bookmarkCategory =
  rawCategory === "culture" || rawCategory === "paris"
    ? CATEGORY_LABELS[rawCategory]
    : "";
const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const articleStructuredData = guideData
  ? buildArticleStructuredData({
      siteOrigin,
      path: `/guide/${id}`,
      headline: displayGuide.title,
      description: displayGuide.lead,
      image: displayGuide.imageUrl,
      datePublished: guideData.createdAt,
      dateModified: guideData.updatedAt ?? guideData.createdAt,
      authorName: guideData.author ? displayGuide.authorName : undefined,
    })
  : [];

if (!error && hasLinkedContentBlocks(displayGuide.contentBlocks)) {
  try {
    const pools = await fetchPublicContentPools();
    linkedContentLookup = buildLinkedContentLookup(pools);
  } catch (linkedContentError) {
    console.error("Failed to fetch linked content for guide page:", linkedContentError);
  }
}
---

<Layout
  navbarVariant="default"
  includePreFooterCTA={false}
  title={`${displayGuide.title} - Maag`}
  description={displayGuide.lead}
  image={displayGuide.imageUrl}
  canonicalPath={`/guide/${id}`}
  type="article"
  structuredData={articleStructuredData}
  useClientRouter={true}
>
  <main class="bg-base-200 min-h-screen">
    <div class="max-w-[1512px] mx-auto">
      {error && <div class="text-red-500 text-center pt-40">{error}</div>}
      {!error && guideData && (
        <>
          <GuideHero
            category={displayGuide.category}
            title={displayGuide.title}
            lead={displayGuide.lead}
            authorName={displayGuide.authorName}
            authorAvatar={displayGuide.authorAvatar}
            createdAt={guideData.createdAt}
            imageUrl={displayGuide.imageUrl}
            imageAlt={displayGuide.imageAlt}
            imageCaption={displayGuide.imageCaption}
            transitionName={`main-article-image-${id}`}
            heroOrientation={guideData?.heroOrientation ?? "image-right"}
          />

          <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-14 pt-10 pb-[100px] lg:pt-16">
            <div class="mx-auto mb-10 max-w-[826px]">
              <ContentActions
                contentType="guide"
                contentId={id!}
                title={displayGuide.title}
                href={`/guide/${id}`}
                category={bookmarkCategory}
                tag={firstBookmarkTag}
                imageUrl={displayGuide.imageUrl}
                align="center"
              />
            </div>
            <ArticleBody
              contentBlocks={displayGuide.contentBlocks}
              linkedContentLookup={linkedContentLookup}
            />
            <ArticleTips tips={displayGuide.tips} />
          </div>
        </>
      )}
    </div>
  </main>
</Layout>
