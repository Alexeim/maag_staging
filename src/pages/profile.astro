---
import Layout from "../Layouts/Layout.astro";
import { Bookmark, Trash2 } from "lucide-astro";
---

<Layout
  navbarVariant="default"
  includePreFooterCTA={false}
  title="Личный кабинет - Maag"
  useClientRouter={true}
>
  <div class="min-h-screen bg-base-200 py-8" x-data="{ activeTab: 'account' }">
    <div class="max-w-4xl mx-auto px-4 lg:px-8">
      <!-- Page Header -->
      <div class="mb-8">
        <h1
          class="text-4xl font-old_standard font-normal uppercase tracking-[0.46em] text-base-content mb-5"
        >
          Личный кабинет
        </h1>

        <!-- Navigation Tabs -->
        <div class="flex flex-col lg:flex-row gap-4 lg:gap-8">
          <button
            type="button"
            class="w-full lg:w-auto text-left lg:text-center text-xs font-['Inter'] uppercase tracking-[0.25em] text-base-content pb-1 transition-colors cursor-pointer"
            :class="activeTab === 'account' ? 'font-semibold text-accent border-b-2 border-accent' : 'font-normal text-base-content/70 hover:text-base-content'"
            @click="activeTab = 'account'"
          >
            настройка аккаунта
          </button>
          <button
            type="button"
            class="w-full lg:w-auto text-left lg:text-center text-xs font-['Inter'] uppercase tracking-[0.25em] text-base-content pb-1 transition-colors cursor-pointer"
            :class="activeTab === 'bookmarks' ? 'font-semibold text-accent border-b-2 border-accent' : 'font-normal text-base-content/70 hover:text-base-content'"
            @click="activeTab = 'bookmarks'"
          >
            закладки
          </button>
        </div>
      </div>

      <!-- Main Content -->
      <div class="space-y-20 mb-16" x-show="activeTab === 'account'">
        <!-- Subscription Section -->
        <div class="space-y-8" x-data="$lazy('subscriptionManager')">
          <!-- Section Header -->
          <div class="space-y-6">
            <div class="w-full h-px bg-neutral-200"></div>
            <h2
              class="text-base font-old_standard font-normal uppercase tracking-[0.46em] text-base-content"
            >
              Подписка
            </h2>
          </div>

          <!-- Subscription Content -->
          <div class="space-y-8 w-full max-w-2xl">
            <template x-if="!$store.auth.isProfileLoaded">
              <p>Загрузка данных о подписке...</p>
            </template>

            <template x-if="$store.auth.isProfileLoaded">
              <div>
                <!-- Если подписка активна -->
                <template x-if="isSubscribed">
                  <div class="space-y-4">
                    <p>
                      Статус: <span
                        class="font-bold text-maag-green"
                        x-text="subscriptionStatus"></span>
                      <span class="text-xs text-base-content/60">
                        (Подписка активна)</span
                      >
                    </p>
                    <p>
                      Оплачено до: <span
                        class="font-bold"
                        x-text="subscriptionEndDate"></span>
                    </p>
                    <button
                      @click="manageSubscription()"
                      class="cursor-pointer text-sm border border-base-300 text-primary-content hover:bg-primary hover:border-primary focus:ring-primary p-2 rounded-xl"
                    >
                      Управлять подпиской
                    </button>
                  </div>
                </template>

                <!-- Если подписки нет -->
                <template x-if="!isSubscribed">
                  <div class="space-y-4">
                    <p>У вас нет активной подписки.</p>
                    <button
                      @click="createSubscription()"
                      class="cursor-pointer text-sm border border-base-300 text-primary-content hover:bg-primary hover:border-primary focus:ring-primary p-2 rounded-xl"
                    >
                      Подписаться
                    </button>
                    <button
                      @click="forceRefresh()"
                      class="cursor-pointer text-sm border border-base-300 text-primary-content hover:bg-primary hover:border-primary focus:ring-primary p-2 rounded-xl"
                    >
                      Обновить статус
                    </button>
                  </div>
                </template>
              </div>
            </template>
          </div>
        </div>

        <!-- Account Data Section -->
        <div class="space-y-8">
          <!-- Section Header -->
          <div class="space-y-6">
            <div class="w-full h-px bg-neutral-200"></div>
            <h2
              class="text-base font-old_standard font-normal uppercase tracking-[0.46em] text-base-content"
            >
              Данные аккаунта
            </h2>
          </div>

          <!-- Account Form -->
          <div class="space-y-10 w-full max-w-lg" x-data="$lazy('profile')">
            <!-- Show loading states -->
            <template x-if="$store.auth.isLoading">
              <p>Проверка сессии...</p>
            </template>
            <template x-if="!$store.auth.isLoading && !$store.auth.isLoggedIn">
              <p>Пожалуйста, войдите, чтобы увидеть свой профиль.</p>
            </template>
            <template
              x-if="!$store.auth.isLoading && $store.auth.isLoggedIn && !$store.auth.isProfileLoaded"
            >
              <p>Загрузка данных профиля...</p>
            </template>

            <!-- Show form only when logged in AND profile is loaded -->
            <template x-if="$store.auth.isProfileLoaded">
              <div>
                <!-- Email Field (Read-only) -->
                <div class="space-y-4 mb-10">
                  <label
                    class="text-xs font-['Inter'] font-normal uppercase tracking-[0.25em] text-base-content"
                    >email</label
                  >
                  <div
                    class="bg-base-100 border border-neutral-200 rounded-lg p-2"
                  >
                    <div
                      x-text="$store.auth.user?.email"
                      class="w-full bg-transparent text-xs font-['Inter'] text-neutral-400 outline-none"
                    >
                    </div>
                  </div>
                </div>

                <!-- Password Field -->
                <div class="space-y-4 mb-10">
                  <label
                    class="text-xs font-['Inter'] font-normal uppercase tracking-[0.25em] text-base-content"
                    >Пароль</label
                  >
                  <div
                    class="flex flex-col lg:flex-row lg:items-center gap-4 lg:gap-2"
                  >
                    <div
                      class="bg-base-100 border border-neutral-200 rounded-lg p-2 w-full lg:flex-1"
                    >
                      <input
                        type="password"
                        value="**********"
                        autocomplete="current-password"
                        readonly
                        class="w-full bg-transparent text-[16px] lg:text-xs font-['Inter'] text-neutral-400 outline-none"
                      />
                    </div>
                    <div class="w-full lg:w-auto">
                      <button
                        @click="changePassword()"
                        class="cursor-pointer text-sm border border-base-300 text-primary-content hover:bg-primary hover:border-primary focus:ring-primary p-2 rounded-xl"
                        >Поменять пароль</button
                      >
                    </div>
                  </div>
                </div>

                <!-- Name Fields -->
                <div class="space-y-4 mb-4">
                  <label
                    class="text-xs font-['Inter'] font-normal uppercase tracking-[0.25em] text-base-content"
                    >First Name</label
                  >
                  <div
                    class="bg-base-100 border border-neutral-200 rounded-lg p-2"
                  >
                    <input
                      type="text"
                      x-model="form.firstName"
                      class="w-full bg-transparent text-[16px] lg:text-xs font-['Inter'] text-neutral-400 outline-none"
                    />
                  </div>
                </div>
                <div class="space-y-4">
                  <label
                    class="text-xs font-['Inter'] font-normal uppercase tracking-[0.25em] text-base-content"
                    >Last Name</label
                  >
                  <div
                    class="bg-base-100 border border-neutral-200 rounded-lg p-2"
                  >
                    <input
                      type="text"
                      x-model="form.lastName"
                      class="w-full bg-transparent text-[16px] lg:text-xs font-['Inter'] text-neutral-400 outline-none"
                    />
                  </div>
                </div>

                <!-- Action Buttons -->
                <div class="space-y-4 mt-10">
                  <button
                    @click="saveChanges()"
                    class="w-full cursor-pointer text-sm border border-base-300 text-primary-content hover:bg-primary hover:border-primary focus:ring-primary p-2 rounded-xl"
                  >
                    Сохранить изменения
                  </button>
                  <button
                    @click="deleteAccount()"
                    class="w-full border border-error text-error rounded-xl py-2 px-4 text-sm font-['Inter'] font-normal hover:bg-error/5 transition-colors cursor-pointer"
                  >
                    Удалить аккаунт
                  </button>
                </div>
              </div>
            </template>
          </div>
        </div>
      </div>

      <div class="mb-16" x-show="activeTab === 'bookmarks'" x-cloak>
        <div class="space-y-8" x-data="$lazy('profile')">
          <div class="space-y-6">
            <div class="w-full h-px bg-neutral-200"></div>
            <h2
              class="text-base font-old_standard font-normal uppercase tracking-[0.46em] text-base-content"
            >
              Закладки
            </h2>
          </div>

          <template x-if="$store.auth.isLoading">
            <p class="font-inter text-sm text-base-content/60">
              Проверка сессии...
            </p>
          </template>

          <template x-if="!$store.auth.isLoading && !$store.auth.isLoggedIn">
            <p class="font-inter text-sm text-base-content/60">
              Войдите, чтобы увидеть сохранённые материалы.
            </p>
          </template>

          <template
            x-if="!$store.auth.isLoading && $store.auth.isLoggedIn && bookmarksLoading"
          >
            <p class="font-inter text-sm text-base-content/60">
              Загрузка закладок...
            </p>
          </template>

          <template
            x-if="!$store.auth.isLoading && $store.auth.isLoggedIn && !bookmarksLoading && bookmarks.length === 0"
          >
            <div
              class="flex max-w-2xl items-center gap-4 border border-base-300 bg-white p-5 text-base-content"
            >
              <Bookmark class="h-5 w-5 shrink-0 text-accent" />
              <p class="m-0 font-inter text-sm text-base-content/70">
                Вы пока ничего не сохранили.
              </p>
            </div>
          </template>

          <div
            class="space-y-12"
            x-show="!$store.auth.isLoading && $store.auth.isLoggedIn && !bookmarksLoading && bookmarks.length > 0"
          >
            <template x-for="group in bookmarkGroups" :key="group.contentType">
              <section class="space-y-5">
                <div class="flex items-center gap-4">
                  <h3
                    class="m-0 font-old_standard text-2xl font-normal uppercase tracking-[0.24em] text-base-content"
                    x-text="group.label"
                  >
                  </h3>
                  <div class="h-px flex-1 bg-neutral-200"></div>
                  <span
                    class="font-inter text-xs text-base-content/50"
                    x-text="group.items.length"
                  >
                  </span>
                </div>

                <div class="grid gap-4 md:grid-cols-2">
                  <template
                    x-for="bookmark in group.items"
                    :key="`${bookmark.contentType}-${bookmark.id}`"
                  >
                    <article
                      class="grid gap-4 border border-base-300 bg-white p-4"
                    >
                      <a :href="bookmark.href" class="grid gap-4">
                        <template x-if="bookmark.imageUrl">
                          <img
                            :src="bookmark.imageUrl"
                            :alt="bookmark.title"
                            class="h-44 w-full object-cover"
                            loading="lazy"
                          />
                        </template>
                        <div class="grid gap-2">
                          <div class="flex flex-wrap items-center gap-2">
                            <template x-if="bookmark.category">
                              <span
                                class="font-inter text-[11px] font-semibold uppercase tracking-[0.22em] text-base-content/50"
                                x-text="bookmark.category"
                              >
                              </span>
                            </template>
                            <template x-if="bookmark.tag">
                              <span
                                class="font-inter text-[11px] font-semibold uppercase tracking-[0.22em] text-accent"
                                x-text="bookmark.tag"
                              >
                              </span>
                            </template>
                          </div>
                          <h4
                            class="m-0 font-old_standard text-2xl leading-tight text-base-content"
                            x-text="bookmark.title"
                          >
                          </h4>
                        </div>
                      </a>
                      <button
                        type="button"
                        class="inline-flex w-fit items-center gap-2 font-inter text-sm text-base-content/60 transition hover:text-error cursor-pointer"
                        @click="removeBookmark(bookmark)"
                      >
                        <Trash2 class="h-4 w-4" aria-hidden="true" />
                        Удалить из закладок
                      </button>
                    </article>
                  </template>
                </div>
              </section>
            </template>
          </div>
        </div>
      </div>
    </div>
  </div></Layout
>
