---
import Layout from "../../Layouts/Layout.astro";
import ArticleHeader from "../../components/article/ArticleHeader.astro";
import ArticleAuthor from "../../components/article/ArticleAuthor.astro";
import ArticleDate from "@/components/article/ArticleDate.astro";
import ContentActions from "@/components/common/ContentActions.astro";
import { getKnownTagLabel } from "@/content/tags/parisTags";
import { flippersApi } from "../../lib/api/api";
import { ChevronLeft, ChevronRight } from "lucide-astro";
import ContentCollectionMarquee from "@/components/article/ContentCollectionMarquee.astro";
import picture1 from "@/assets/images/culture.jpg";
import {
  buildContentCollectionItems,
  fetchPublicContentPools,
  toDate,
} from "@/lib/utils/contentCollectionMarquee";

const { id } = Astro.params;
const flipper = await flippersApi.getById(id);

if (!flipper) {
  return Astro.redirect("/404");
}

const CATEGORY_LABELS: Record<string, string> = {
  culture: "Культура",
  paris: "Париж",
  hotContent: "Самое Читаемое",
  ballet: "Балет",
  books: "Книги",
  artMarket: "Арт-рынок",
  artmarket: "Арт-рынок",
  dance: "Танец",
  music: "Музыка",
  opera: "Опера",
  theatre: "Театр",
  theater: "Театр",
  performance: "Спектакль",
  performances: "Спектакль",
  concert: "Концерт",
  concerts: "Концерт",
  exhibition: "Выставка",
  exhibitions: "Выставка",
  route: "Маршрут",
  address: "Адрес",
  notebook: "Записная книжка",
  place: "Место",
};

const getFlipperCategory = () => {
  const firstTag =
    Array.isArray(flipper.tags) && flipper.tags.length > 0
      ? flipper.tags[0]
      : flipper.category;

  if (!firstTag || typeof firstTag !== "string") {
    return "Листалка";
  }

  return CATEGORY_LABELS[firstTag] || getKnownTagLabel(firstTag);
};
const bookmarkCategory =
  flipper.category === "culture"
    ? "Культура"
    : flipper.category === "paris"
      ? "Париж"
      : "";
const firstBookmarkTag =
  Array.isArray(flipper.tags) && typeof flipper.tags[0] === "string"
    ? flipper.tags[0]
    : "";
const bookmarkTag = firstBookmarkTag ? getKnownTagLabel(firstBookmarkTag) : "";

const flipperState = JSON.stringify({
  activeSlide: 0,
  slides: flipper.carouselContent || [],
});

let collectionContentItems: any[] = [];
let recentFlipperItems: any[] = [];

try {
  const pools = await fetchPublicContentPools();
  const allFlippers = pools.allFlippers;
  collectionContentItems = await buildContentCollectionItems({
    contentCollectionId: (flipper as any)?.contentCollectionId,
    currentContentType: "flipper",
    currentId: id,
    pools,
  });

  const relatedFlipperIds = new Set(
    collectionContentItems
      .filter((i) => i.contentType === "flipper")
      .map((i) => i.id),
  );
  recentFlipperItems = allFlippers
    .filter((i) => i.id !== id && !relatedFlipperIds.has(i.id))
    .sort(
      (a, b) =>
        (toDate(b?.createdAt)?.getTime() ?? 0) -
        (toDate(a?.createdAt)?.getTime() ?? 0),
    )
    .slice(0, 12)
    .map((item) => ({ ...item }));
} catch (e) {
  console.error("Failed to fetch collection content for flipper page:", e);
}
---

<Layout
  title={`${flipper.title} - Maag`}
  navbarVariant="default"
  includePreFooterCTA={false}
  useClientRouter={true}
>
  <main class="bg-base-200 min-h-screen">
    <div class="max-w-[1512px] mx-auto" x-data={flipperState}>
      <div
        class="pt-[50px] pb-[70px] px-4 lg:px-0 flex flex-col items-center gap-[50px]"
      >
        <div class="flex flex-col gap-4 max-w-[825px] w-full">
          <ArticleHeader
            category={getFlipperCategory()}
            title={flipper.title}
            lead={flipper.lead}
          />

          <div class="flex flex-col flex-wrap items-start justify-center gap-4">
            {
              flipper.author && (
                <ArticleAuthor
                  name={`${flipper.author.firstName} ${flipper.author.lastName}`}
                  avatarUrl={flipper.author.avatar}
                />
              )
            }
            {flipper.createdAt && <ArticleDate createdAt={flipper.createdAt} />}
            <ContentActions
              contentType="flipper"
              contentId={id!}
              title={flipper.title}
              href={`/flippers/${id}`}
              category={bookmarkCategory}
              tag={bookmarkTag}
              imageUrl={flipper.carouselContent?.[0]?.imageUrl}
            />
          </div>
        </div>
      </div>

      <div class="max-w-[1400px] mx-auto px-4 lg:px-14 pb-[100px]">
        <div class="mx-auto w-full max-w-[1200px]">
          <div class="relative">
            <div
              class="relative flex h-[360px] w-full items-center justify-center sm:h-[460px] lg:h-[600px]"
            >
              <template x-for="(item, index) in slides" :key="index">
                <div
                  x-show="activeSlide === index"
                  class="absolute inset-0 flex items-center justify-center duration-700 ease-in-out"
                  x-transition:enter="transition ease-in-out duration-700"
                  x-transition:enter-start="opacity-0"
                  x-transition:enter-end="opacity-100"
                  x-transition:leave="transition ease-in-out duration-700"
                  x-transition:leave-start="opacity-100"
                  x-transition:leave-end="opacity-0"
                >
                  <img
                    :src="item.imageUrl"
                    class="block h-full w-auto max-w-full object-contain object-center"
                    :alt="item.caption || 'Carousel image'"
                  />
                </div>
              </template>

              <button
                x-show="slides.length > 1"
                @click="activeSlide = (activeSlide - 1 + slides.length) % slides.length"
                class="absolute top-1/2 left-0 -translate-y-1/2 p-2 transition cursor-pointer text-neutral-400 hover:text-neutral-900 lg:-left-12"
                aria-label="Предыдущий слайд"
              >
                <ChevronLeft class="h-6 w-6" />
              </button>
              <button
                x-show="slides.length > 1"
                @click="activeSlide = (activeSlide + 1) % slides.length"
                class="absolute top-1/2 right-0 -translate-y-1/2 p-2 transition cursor-pointer text-neutral-400 hover:text-neutral-900 lg:-right-12"
                aria-label="Следующий слайд"
              >
                <ChevronRight class="h-6 w-6" />
              </button>
            </div>
          </div>

          <div class="mx-auto mt-6 max-w-[825px] min-h-[2.5rem]">
            <p
              class="text-center text-sm text-black/60 font-inter font-normal leading-relaxed"
              x-text="slides[activeSlide]?.caption || ''"
            >
            </p>
          </div>

          <hr class="my-5 border-base-300" />

          <div
            x-show="slides.length > 1"
            class="mb-16 mt-2 flex justify-center gap-2"
          >
            <template x-for="(slide, index) in slides" :key="index">
              <button
                @click="activeSlide = index"
                :class="{'bg-base-content': activeSlide === index, 'bg-base-content/20': activeSlide !== index}"
                class="h-2.5 w-2.5 rounded-full transition hover:bg-base-content/60 cursor-pointer"
                :aria-label="`Перейти к слайду ${index + 1}`"></button>
            </template>
          </div>
        </div>
        <ContentCollectionMarquee
          collectionItems={collectionContentItems}
          categoryItems={recentFlipperItems}
          fallbackImageSrc={picture1.src}
        />
      </div>
    </div>
  </main>
</Layout>
