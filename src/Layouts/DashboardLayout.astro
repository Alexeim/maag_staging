---
import "../styles/global.css";
import "../styles/quill-editor.css";
import "quill/dist/quill.snow.css";
import Toast from "@/components/common/Toast.astro";
import ConfirmationModal from "@/components/common/ConfirmationModal.astro";
import { Pencil } from "@lucide/astro";

interface Props {
  title?: string;
  active?: string;
}

const listItems = [
  { href: "/dashboard", label: "Статьи", id: "articles-overview" },
  {
    href: "/dashboard/articles/culture",
    label: "Статьи Культура",
    id: "articles-culture",
  },
  {
    href: "/dashboard/articles/paris",
    label: "Статьи Париж",
    id: "articles-paris",
  },
  { href: "/dashboard/events", label: "События", id: "events" },
  { href: "/dashboard/news", label: "Новости", id: "news" },
  { href: "/dashboard/flippers", label: "Листалки", id: "flippers" },
  { href: "/dashboard/interviews", label: "Интервью", id: "interviews" },
  { href: "/dashboard/tips", label: "Tips-статьи", id: "tips" },
  {
    href: "/dashboard/le-saviez-vous",
    label: "Le saviez-vous",
    id: "le-saviez-vous",
  },
  {
    href: "/dashboard/photo-of-the-day",
    label: "Фото дня",
    id: "photo-of-the-day",
  },
  { href: "/dashboard/guides", label: "Путеводители", id: "guides" },
  {
    href: "/dashboard/visual-stories",
    label: "Визуальные истории",
    id: "visual-stories",
  },
];

const editorItems = [
  {
    href: "/dashboard/landing-editor",
    label: "Редактор лендинга",
    id: "landing-editor",
    bold: "xl",
  },
  {
    href: "/dashboard/calendar-editor",
    label: "Редактор календаря",
    id: "calendar-editor",
    bold: "xl",
  },
  {
    href: "/dashboard/culture-editor",
    label: "Редактор «Культура»",
    id: "culture-editor",
    bold: "md",
  },
  {
    href: "/dashboard/paris-editor",
    label: "Редактор «Париж»",
    id: "paris-editor",
    bold: "md",
  },
  {
    href: "/dashboard/article/create",
    label: "Создать статью",
    id: "create-article",
  },
  {
    href: "/dashboard/event/create",
    label: "Создать событие",
    id: "create-event",
  },
  {
    href: "/dashboard/news/create",
    label: "Создать новость",
    id: "create-news",
  },
  {
    href: "/dashboard/flippers/create",
    label: "Создать листалку",
    id: "create-flipper",
  },
  {
    href: "/dashboard/interview/create",
    label: "Создать интервью",
    id: "create-interview",
  },
  {
    href: "/dashboard/tips/create",
    label: "Создать tips-статью",
    id: "create-tips",
  },
  {
    href: "/dashboard/le-saviez-vous/create",
    label: "Создать Le saviez-vous",
    id: "create-le-saviez-vous",
  },
  {
    href: "/dashboard/photo-of-the-day/create",
    label: "Создать фото дня",
    id: "create-photo-of-the-day",
  },
  {
    href: "/dashboard/guide/create",
    label: "Создать путеводитель",
    id: "create-guide",
  },
  {
    href: "/dashboard/visual-story/create",
    label: "Создать визуальную историю",
    id: "create-visual-story",
  },
];

const { title = "MAAG Dashboard", active = "articles-overview" } =
  Astro.props as Props;
---

<!doctype html>
<html lang="ru" data-theme="maag">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Jost:ital,wght@0,100..900;1,100..900&family=Old+Standard+TT:ital,wght@0,400;0,700;1,400&family=Oswald:wght@200..700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Jost:ital,wght@0,100..900;1,100..900&family=Old+Standard+TT:ital,wght@0,400;0,700;1,400&family=Oswald:wght@200..700&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <title>{title}</title>
  </head>
  <body class="bg-base-200 min-h-screen">
    <div class="flex min-h-screen">
      <aside
        class="w-64 bg-base-100 border-r border-base-300 hidden lg:flex flex-col"
      >
        <div class="px-6 py-6 border-b border-base-300">
          <a href="/dashboard/" class="block text-xl font-serif">MAAG</a>
          <p
            class="mt-1 text-xs text-base-content/60 uppercase tracking-[0.3em]"
          >
            Dashboard
          </p>
        </div>
        <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto">
          <p class="px-4 pb-1 text-xs font-semibold uppercase tracking-widest text-base-content/40">
            Списки
          </p>
          {
            listItems.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "block px-4 py-2 rounded-md text-sm font-medium transition-colors",
                  active === item.id
                    ? "bg-primary text-primary-content"
                    : "text-base-content/80 hover:bg-base-200",
                ]}
              >
                {item.label}
              </a>
            ))
          }

          <div class="pt-4">
            <p class="px-4 pb-1 text-xs font-semibold uppercase tracking-widest text-base-content/40 flex items-center gap-1.5">
              <Pencil size={11} />
              Редакторы и создание
            </p>
            {
              editorItems.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    "block px-4 py-2 rounded-md text-sm font-medium transition-colors",
                    active === item.id
                      ? "bg-primary text-primary-content"
                      : "text-base-content/80 hover:bg-base-200",
                  ]}
                >
                  <span
                    class:list={[
                      item.bold === "xl" ? "font-bold text-lg" : "",
                      item.bold === "md" ? "font-bold" : "",
                    ]}
                  >
                    {item.label}
                  </span>
                </a>
              ))
            }
          </div>
        </nav>
      </aside>
      <div class="min-w-0 flex-1 flex flex-col" x-data>
        <header
          class="w-full bg-base-100 border-b border-base-300 px-4 sm:px-6 py-4 flex items-center justify-between"
        >
          <h1 class="text-lg sm:text-xl font-semibold text-base-content">
            {title}
          </h1>
          <a href="/" class="text-sm text-primary hover:underline">На сайт</a>
        </header>
        <main class="min-w-0 flex-1 px-4 py-6 sm:px-6">
          <slot />
        </main>
      </div>
    </div>

    <Toast />
    <ConfirmationModal />
  </body>
</html>
