---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { Instagram, X } from "@lucide/astro";

import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";
import AuthModal from "../components/auth/AuthModal.astro";
import Toast from "../components/common/Toast.astro";
import ConfirmationModal from "../components/common/ConfirmationModal.astro";
import StructuredData from "../components/seo/StructuredData.astro";
import { navbarContent } from "../content/navbar/RU/Navbar.json";
import {
  buildGlobalStructuredData,
  toStructuredDataArray,
  type JsonLdObject,
} from "../lib/seo/structuredData";

interface LayoutProps {
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
  type?: "website" | "article";
  structuredData?: JsonLdObject | JsonLdObject[];
  useClientRouter?: boolean;
  navbarVariant?: "default" | "transparent";
  includePreFooterCTA?: boolean;
}

const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const fallbackDescription =
  "MAAG France — медиа о культуре, Париже и жизни во Франции.";

const toAbsoluteUrl = (value?: string) => {
  if (!value) {
    return undefined;
  }

  return new URL(value, siteOrigin).toString();
};

const {
  title = "MAAG France",
  description: rawDescription = fallbackDescription,
  image,
  canonicalPath = Astro.url.pathname,
  type = "website",
  structuredData = [],
  useClientRouter = false,
  navbarVariant = "default",
  includePreFooterCTA = true,
} = Astro.props as LayoutProps;

const description = rawDescription.trim() || fallbackDescription;
const canonicalUrl = toAbsoluteUrl(canonicalPath);
const imageUrl = toAbsoluteUrl(image);
const globalStructuredData = buildGlobalStructuredData(siteOrigin, toAbsoluteUrl);
const allStructuredData = [
  ...globalStructuredData,
  ...toStructuredDataArray(structuredData),
];
---

<!doctype html>
<html lang="ru" data-theme="maag">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta
      name="google-site-verification"
      content="a1g4Q9POWbQ8LXHxizcXDOD5DiG_5gMiXcMMCIa0XQw"
    />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:site_name" content="MAAG France" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    {imageUrl && <meta property="og:image:alt" content={title} />}
    <meta
      name="twitter:card"
      content={imageUrl ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    <StructuredData data={allStructuredData} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Jost:ital,wght@0,100..900;1,100..900&family=Old+Standard+TT:ital,wght@0,400;0,700;1,400&family=Oswald:wght@200..700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Jost:ital,wght@0,100..900;1,100..900&family=Old+Standard+TT:ital,wght@0,400;0,700;1,400&family=Oswald:wght@200..700&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <!-- Google tag (gtag.js) -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-7EDWP4DX2J"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-7EDWP4DX2J");
    </script>
    <!-- Google tag (gtag.js) -->
    {useClientRouter && <ClientRouter />}
    <title>{title}</title>
  </head>
  <body class="bg-base-200">
    <Header
      variant={navbarVariant}
      cultureText={navbarContent.items[0].label}
      guideText={navbarContent.items[1].label}
      childrenText={navbarContent.items[2].label}
      calendarText={navbarContent.items[3].label}
      aboutText={navbarContent.items[4].label}
      languagesText={navbarContent.languages[0]}
      buttonText={navbarContent.button.label}
    />
    <slot />
    <Footer />

    <!-- Mobile Menu -->
    <!-- Overlay -->
    <div
      x-data="{}"
      x-show="$store.navbar.isOpen"
      x-cloak
      @click="$store.navbar.close()"
      class="fixed inset-0 bg-black/30 z-[998] lg:hidden"
      x-transition:enter="transition-opacity ease-linear duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition-opacity ease-linear duration-300"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
    >
    </div>

    <!-- Panel -->
    <div
      x-data="{}"
      id="mobile-menu"
      x-show="$store.navbar.isOpen"
      x-cloak
      class="fixed top-0 right-0 w-[235px] h-screen bg-base-100 z-[999] lg:hidden flex flex-col justify-between p-8"
      x-transition:enter="transform transition ease-in-out duration-300"
      x-transition:enter-start="translate-x-full"
      x-transition:enter-end="translate-x-0"
      x-transition:leave="transform transition ease-in-out duration-300"
      x-transition:leave-start="translate-x-0"
      x-transition:leave-end="translate-x-full"
    >
      <!-- Links -->
      <ul
        class="flex flex-col gap-4 text-base-content"
        @click="$store.navbar.close()"
      >
        <li
          class="font-navbar uppercase text-[18px] tracking-[4px] font-normal"
        >
          <a href="/culture">Культура</a>
        </li>
        <li
          class="font-navbar uppercase text-[18px] tracking-[4px] font-normal"
        >
          <a href="/paris">Париж</a>
        </li>
        <li
          class="font-navbar uppercase text-[18px] tracking-[4px] font-normal"
        >
          <a href="/calendar">Календарь</a>
        </li>
        <li
          class="font-navbar uppercase text-[18px] tracking-[4px] font-normal"
        >
          <a href="/about">О проекте</a>
        </li>
      </ul>

      <!-- Bottom Section -->
      <div class="flex flex-col gap-7" x-data="$lazy('navbar')">
        <!-- Loading State -->
        <template x-if="$store.auth.isLoading">
          <button
            class="bg-primary text-primary-content rounded-[9px] py-1.5 text-center font-oswald text-[14px] w-full"
            disabled>...</button
          >
        </template>
        <!-- Logged Out State -->
        <template x-if="!$store.auth.isLoading && !$store.auth.isLoggedIn">
          <button
            @click.prevent="$store.auth.openAuthModal(); $store.navbar.close()"
            class="bg-primary text-primary-content rounded-[9px] py-1.5 text-center font-oswald text-[14px] w-full"
            >Войти</button
          >
        </template>
        <!-- Logged In State -->
        <template x-if="!$store.auth.isLoading && $store.auth.isLoggedIn">
          <div class="flex flex-col items-center gap-4 w-full">
            <a
              href="/profile"
              class="flex items-center justify-center w-12 h-12 bg-primary text-primary-content rounded-full font-bold text-xl hover:drop-shadow-lg transition-shadow"
            >
              <div x-text="$store.auth.initials"></div>
            </a>
            <button
              @click.prevent="handleSignOut(); $store.navbar.close()"
              class="bg-transparent text-base-content/70 hover:text-base-content text-center font-oswald text-[14px] w-full"
              >Выйти</button
            >
          </div>
        </template>

        <div class="flex items-center justify-center gap-5">
          <a href="#"><Instagram class="h-6 w-6" /></a>
          <a href="#"><X class="h-6 w-6" /></a>
        </div>
      </div>
    </div>

    <!-- Global Modals and Toasts -->
    <AuthModal />
    <Toast />
    <ConfirmationModal />
  </body>
</html>
