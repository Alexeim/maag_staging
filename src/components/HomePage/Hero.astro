---
import logoFull from "../../assets/logo/logoFull.svg";
import logoMobile from "../../assets/logo/logo-mobile.svg";
import { Image } from "astro:assets";
---

<section
  x-data="{}"
  x-bind:class="$store.navbar.isScrolled ? 'z-0' : 'z-[51]'"
  class="relative"
>
  <div class="h-[130px] lg:h-[195px] bg-base-200">
    <!-- This div is only for background and height -->
  </div>
  <Image
    src={logoMobile}
    alt="Maag"
    x-bind:class="$store.navbar.isScrolled ? 'z-0 scale-95 opacity-75' : 'z-30 scale-100 opacity-100'"
    class="absolute -top-14 left-1/2 block h-[250px] w-1/3 -translate-x-1/2 pointer-events-none transition-all duration-300 ease-out lg:hidden"
  />
  <Image
    src={logoFull}
    alt="Maag"
    x-bind:class="$store.navbar.isScrolled ? 'z-0 scale-95 opacity-75' : 'z-30 scale-100 opacity-100'"
    class="absolute -top-10 left-1/2 hidden h-[333px] w-2/3 -translate-x-1/2 pointer-events-none transition-all duration-300 ease-out lg:block"
  />
</section>
