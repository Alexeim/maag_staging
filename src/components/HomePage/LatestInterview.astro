---
import { Image } from "astro:assets";
import picture1 from "../../assets/images/culture.jpg"; // Placeholder

interface Props {
  tag?: string;
  interviewee?: string;
  quote?: string;
  imageUrl?: string;
  href?: string;
  transitionName?: string;
}

const {
  tag = "Интервью",
  interviewee = "Скоро здесь будет имя",
  quote = "Скоро здесь будет интересная цитата...",
  imageUrl = picture1,
  href = "#",
  transitionName,
} = Astro.props;
---

<div
  id="interview-box"
  class="w-full bg-white flex flex-col gap-6 lg:flex-row lg:gap-8 items-center justify-start py-8 px-4 min-h-[100px]"
>
  <a
    href={href}
    class="linked-image-hover w-[200px] h-[200px] rounded-full flex-shrink-0"
  >
    <img
      src={typeof imageUrl === "string" ? imageUrl : imageUrl.src}
      alt={`Фотография ${interviewee}`}
      class="linked-image-hover__media w-full h-full object-cover object-center"
      loading="lazy"
      transition:name={transitionName}
    />
  </a>
  <div class="w-full lg:w-fit">
    <a href={href}>
      <p
        class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter'] mb-4"
      >
        {tag}
      </p>
      <h4
        class="text-xl font-semibold font-old_standard tracking-[-0.02em] hover:underline transition-opacity duration-200 hover:opacity-90 mb-2 [text-decoration-thickness:1px] underline-offset-[0.14em]"
      >
        {interviewee}:
      </h4>
      <p
        class="text-3xl font-normal font-old_standard tracking-[-0.02em] hover:underline transition-opacity duration-200 hover:opacity-90 italic [text-decoration-thickness:1px] underline-offset-[0.14em]"
      >
        "{quote}"
      </p>
    </a>
  </div>
</div>
