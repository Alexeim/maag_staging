---
// Variant A — Magazine Cover: portrait image, gradient overlay, title on photo
import picture3 from "../../assets/images/article_content/par.jpeg";
import LazyImage from "./LazyImage.astro";

interface NetlenkaCardOneProps {
  title?: string;
  category?: string;
  date?: string;
  hideDate?: boolean;
  lead?: string;
  transitionName?: string;
  imageUrl?: string;
  href?: string;
}

const {
  title = "Без названия",
  category = "Самое Читаемое",
  lead = "",
  transitionName,
  imageUrl,
  href = "#",
} = Astro.props as NetlenkaCardOneProps;

const imageLoading: "lazy" | "eager" = imageUrl ? "lazy" : "eager";
---

<div class="w-full min-w-[220px] lg:min-w-0 max-w-[303px]">
  <a
    href={href}
    class="linked-image-hover block relative aspect-[2/3] overflow-hidden"
    aria-label={title}
  >
    <LazyImage
      src={imageUrl || picture3}
      alt={imageUrl ? title : "Editorial image"}
      class="linked-image-hover__media w-full h-full object-cover object-center"
      loading={imageLoading}
      transitionName={transitionName}
    />

    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/25 to-transparent"></div>

    {category && (
      <span class="absolute top-3 left-3 text-[0.6rem] font-bold uppercase tracking-[0.25em] text-white bg-accent px-2 py-1 font-['Inter']">
        {category}
      </span>
    )}

    <div class="absolute bottom-0 left-0 right-0 p-4 pb-5">
      <h3 class="m-0 text-white text-xl font-normal font-old_standard tracking-[-0.02em] leading-[1.2]">
        {title}
      </h3>
      {lead && (
        <p class="mt-2 m-0 text-xs text-white/65 font-inter font-normal line-clamp-2">
          {lead}
        </p>
      )}
    </div>
  </a>
</div>
