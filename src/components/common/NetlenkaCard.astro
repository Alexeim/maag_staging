---
import picture3 from "../../assets/images/article_content/par.jpeg";
import LazyImage from "./LazyImage.astro";

interface NetlenkaCardProps {
  title?: string;
  category?: string;
  date?: string;
  hideDate?: boolean;
  lead?: string;
  transitionName?: string;
  imageUrl?: string;
  href?: string;
}

const {
  title = "Без названия",
  category = "Самое Читаемое",
  date = "",
  hideDate = false,
  lead = "",
  transitionName,
  imageUrl,
  href = "#",
} = Astro.props as NetlenkaCardProps;

const imageLoading: "lazy" | "eager" = imageUrl ? "lazy" : "eager";
---

<div
  class="w-full flex flex-col gap-2 max-h-[380px] min-w-[220px] lg:min-w-0 max-w-[303px] bg-white"
>
  {
    (date || category) && (
      <div class="flex flex-row items-center gap-2 text-xs text-base-content/55 font-inter uppercase tracking-[0.22em] mt-1">
        {date && (
          <span class:list={["text-xs", hideDate && "hidden"]}>{date}</span>
        )}
        {date && category && (
          <span
            class:list={[
              "text-black text-lg font-bold font-['Inter'] leading-none",
              hideDate && "hidden",
            ]}
          >
            ·
          </span>
        )}
        {category && (
          <span class="pl-4 pt-4 pb-2 text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
            {category}
          </span>
        )}
      </div>
    )
  }
  <div class="w-full aspect-[3/2] overflow-hidden">
    <a href={href} class="linked-image-hover w-full h-full">
      <LazyImage
        src={imageUrl || picture3}
        alt={imageUrl ? title : "Hot content image"}
        class="linked-image-hover__media w-full h-full object-cover object-center"
        loading={imageLoading}
        transitionName={transitionName}
      />
    </a>
  </div>
  <h3
    class="text-base lg:text-lg leading-tight font-oswald mt-4 mb-4 text-left px-4"
  >
    <a
      href={href}
      class="text-2xl font-normal font-old_standard tracking-[-0.02em] hover:underline transition-opacity duration-200 hover:opacity-90"
    >
      {title}
    </a>
  </h3>
  {
    lead && (
      <p class="text-sm leading-relaxed text-base-content/75 font-oswald font-thin hidden mb-4">
        {lead}
      </p>
    )
  }
</div>
