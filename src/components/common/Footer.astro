              </svg>
            </a> -->
          </div>
        </div>
      </div>
    </div>

    {/* Divider */}
    <hr class="border-base-content/20 mb-6" />

    {/* Bottom Footer */}
    <div
      class="flex flex-col md:flex-row justify-between items-center gap-4 text-center md:text-left"
    >
      <div class="text-base lg:text-sm text-black/80 font-inter font-normal">
        &copy; 2025 MAAG France. Все права защищены.
      </div>
      <div
        class="flex flex-col lg:flex-row gap-4 sm:gap-6 text-sm text-black/80 font-inter font-normal"
      >
        <template x-if="$store.auth.profile?.role === 'admin'">
          <a href="/dashboard" class="hover:text-accent transition-colors">
            🚧 Для Администрации 🚧
          </a>
        </template>
        <a href="/profile" class="hover:text-accent transition-colors"
          >Личный кабинет</a
        >
        <a href="/privacy" class="hover:text-accent transition-colors"
          >Политика конфиденциальности</a
        >
        <a href="/terms" class="hover:text-accent transition-colors"
          >Пользовательское соглашение</a
        >
        <a href="/cookies" class="hover:text-accent transition-colors"
          >Использование файлов cookie</a
        >
      </div>
    </div>
  </div>
</footer>
