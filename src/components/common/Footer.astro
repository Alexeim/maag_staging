---
// Footer for cultural media website about Paris
import { Instagram } from "lucide-astro";
---

<footer class="bg-white text-base-content" x-data>
  <div class="mx-auto px-4 lg:px-12 py-12">
    {/* Main Footer Content */}
    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-8 text-center sm:text-left"
    >
      {/* About Section */}
      <div>
        <h3 class="text-xl font-normal font-old_standard tracking-[-0.02em]">
          О нас
        </h3>
        <ul class="space-y-2">
          <li>
            <a
              href="/about"
              class="text-base lg:text-sm text-black/80 font-inter font-normal hover:underline"
              >О проекте</a
            >
          </li>
          <li>
            <a href="/team" class="hover:text-gray-500 transition-colors hidden"
              >Редакция</a
            >
          </li>
          <li>
            <a
              href="/contacts"
              class="hover:text-accent transition-colors hidden">Контакты</a
            >
          </li>
          <li>
            <a
              href="/advertise"
              class="hover:text-accent transition-colors hidden">Реклама</a
            >
          </li>
        </ul>
      </div>

      {/* Culture Sections */}
      <div>
        <h3 class="text-xl font-normal font-old_standard tracking-[-0.02em]">
          Культура
        </h3>
        <ul class="space-y-2">
          <li>
            <a
              href="/theater"
              class="hover:text-accent transition-colors hidden">Театр</a
            >
          </li>
          <li>
            <a href="/music" class="hover:text-accent transition-colors hidden"
              >Музыка</a
            >
          </li>
          <li>
            <a href="/art" class="hover:text-accent transition-colors hidden"
              >Искусство</a
            >
          </li>
          <li>
            <a href="/cinema" class="hover:text-accent transition-colors hidden"
              >Кино</a
            >
          </li>
          <li>
            <a
              href="/literature"
              class="hover:text-accent transition-colors hidden">Литература</a
            >
          </li>
        </ul>
      </div>

      {/* Paris Guide */}
      <div>
        <h3 class="text-xl font-normal font-old_standard tracking-[-0.02em]">
          Париж
        </h3>
        <ul class="space-y-2">
          <li>
            <a href="/events" class="hover:text-accent transition-colors hidden"
              >События</a
            >
          </li>
          <li>
            <a
              href="/museums"
              class="hover:text-accent transition-colors hidden">Музеи</a
            >
          </li>
          <li>
            <a
              href="/galleries"
              class="hover:text-accent transition-colors hidden">Галереи</a
            >
          </li>
          <li>
            <a
              href="/festivals"
              class="hover:text-accent transition-colors hidden">Фестивали</a
            >
          </li>
          <li>
            <a href="/guide" class="hover:text-accent transition-colors hidden"
              >Гид по городу</a
            >
          </li>
        </ul>
      </div>

      {/* Contact & Social */}
      <div>
        <h3 class="text-xl font-normal font-old_standard tracking-[-0.02em]">
          Контакты
        </h3>
        <div class="space-y-3">
          <p class="text-base lg:text-sm text-black/80 font-inter font-normal">
            <strong>Адрес:</strong><br />
            1 rue de la Ferme<br />92200 Neuilly-sur-Seine
          </p>
          <p class="text-base lg:text-sm text-black/80 font-inter font-normal">
            <strong>Почта:</strong><br />
            <a href="mailto:contact@maagfrance.fr">contact@maagfrance.fr</a>
          </p>
          <p class="text-base lg:text-sm text-black/80 font-inter font-normal">
            <strong>Для авторов:</strong><br />
            <a href="mailto:contact@maagfrance.fr">contact@maagfrance.fr</a>
          </p>

          {/* Social Media */}
          <div class="flex gap-4 mt-4 justify-center sm:justify-start">
            <a
              href="https://www.instagram.com/stories/maag_france/"
              target="_blank"
              class="hover:text-gray-500 transition-colors"
              aria-label="Instagram"
            >
              <Instagram />
            </a>
