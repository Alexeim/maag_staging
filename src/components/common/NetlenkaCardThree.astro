---
// Variant C — Dark Editorial Split: portrait image, dark panel with M logo as background texture
import picture3 from "../../assets/images/article_content/par.jpeg";
import LazyImage from "./LazyImage.astro";
import MIcon from "../../assets/logo/m.svg";

interface NetlenkaCardThreeProps {
  title?: string;
  category?: string;
  date?: string;
  hideDate?: boolean;
  lead?: string;
  transitionName?: string;
  imageUrl?: string;
  href?: string;
}

const {
  title = "Без названия",
  category = "Самое Читаемое",
  lead = "",
  transitionName,
  imageUrl,
  href = "#",
} = Astro.props as NetlenkaCardThreeProps;

const imageLoading: "lazy" | "eager" = imageUrl ? "lazy" : "eager";
---

<div class="w-full">
  <a
    href={href}
    class="linked-image-hover block relative aspect-[3/4] overflow-hidden"
    aria-label={title}
  >
    <LazyImage
      src={imageUrl || picture3}
      alt={imageUrl ? title : "Editorial image"}
      class="linked-image-hover__media w-full h-full object-cover object-center"
      loading={imageLoading}
      transitionName={transitionName}
    />
    {
      category && (
        <span class="absolute top-3 left-3 text-xs font-semibold uppercase tracking-[0.25em] text-white bg-accent px-2 py-1 font-['Inter']">
          {category}
        </span>
      )
    }
  </a>
  <div class="relative bg-maag-beige px-4 pt-4 pb-5 overflow-hidden min-h-24">
    <!-- M logo fills the panel as background texture, bleeds off the right edge -->
    <MIcon
      class="pointer-events-none absolute -bottom-4 -right-4 w-36 h-auto select-none"
      style="opacity: 0.35;"
      aria-hidden="true"
    />

    <a href={href} class="relative no-underline hover:underline">
      <h3
        class="m-0 text-base-content text-xl font-normal font-old_standard tracking-[-0.02em] leading-[1.2]"
      >
        {title}
      </h3>
    </a>
    {
      lead && (
        <p class="relative mt-2 m-0 text-xs text-white/55 font-inter font-normal line-clamp-2">
          {lead}
        </p>
      )
    }
  </div>
</div>
