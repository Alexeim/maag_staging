---
import LazyImage from "./LazyImage.astro";

interface PhotoOfTheDayCardProps {
  id: string;
  title: string;
  imageUrl: string;
}

const { id, title, imageUrl } = Astro.props as PhotoOfTheDayCardProps;
---

<section class="grid gap-4">
  <h3
    class="m-0 text-lg font-semibold uppercase tracking-[0.3em] font-old_standard"
  >
    Фото дня
  </h3>
  <a
    href={`/photo-of-the-day/${id}`}
    class="block w-full border border-base-content/10 bg-white pt-3 px-3 pb-6"
    aria-label={title}
  >
    <span class="linked-image-hover block aspect-[2/3] overflow-hidden">
      <LazyImage
        src={imageUrl}
        alt={title}
        class="linked-image-hover__media w-full h-full object-cover object-center"
      />
    </span>
    <h4
      class="m-0 mt-4 text-center italic text-base font-old_standard tracking-[-0.01em] text-base-content/80"
    >
      {title}
    </h4>
  </a>
</section>
