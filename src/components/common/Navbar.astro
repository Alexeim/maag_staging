---
import logo from "../../assets/logo/logo.svg";
import { Search, Instagram, Youtube, X } from "lucide-astro";
import { Image } from "astro:assets";
import searchIcon from "../../assets/icons/search-mobile.svg";
import burgerIcon from "../../assets/icons/burger-mobile.svg";
import Button from "./Button.astro";

interface NavbarProps {
  variant: "default" | "transparent";
  languages: string;
  user?: boolean;
  showLogoInNav?: boolean;
}

const {
  variant,
  languages,
  user = true,
  showLogoInNav = true,
} = Astro.props as NavbarProps;

const navbarClasses = variant === "default" ? "bg-base-100" : "bg-transparent";
const positionClasses =
  variant === "default" ? "sticky top-0 z-20" : "absolute";
const colorClasses = "text-base-content";
const borderClasses = "border-none";
const headerScrollClasses =
  variant === "default"
    ? "$store.navbar.isScrolled ? 'z-20 shadow-[0_10px_30px_rgba(0,0,0,0.08)]' : 'z-20 shadow-none'"
    : "";

const logoSrc = logo.src;
const currentPath = Astro.url.pathname;
---

<header
  x-data="{}"
  x-bind:class={headerScrollClasses}
  class:list={[
    "w-full h-[80px] lg:h-[90px] transition-shadow duration-300 ease-out",
    positionClasses,
  ]}
>
  <!-- Background Layer -->
  <div class:list={["absolute inset-0 w-full h-full z-0", navbarClasses]}></div>

  <!-- Content Layer -->
  <nav
    class:list={[
      "relative z-10 w-full h-full px-4 lg:px-[57px] flex items-center justify-between",
      colorClasses,
      borderClasses,
    ]}
  >
    <!-- Left Side Group (Logo + Menu) -->
    <div class="flex items-center relative">
      {
        showLogoInNav && (
          <a
            class="cursor-pointer transition-transform duration-200 ease-out hover:scale-105 inline-block"
            href="/"
          >
            <img src={logo.src} alt="Maag logo" class="w-12 lg:w-16" />
          </a>
        )
      }
      <!-- Desktop Menu -->
      <div
        class="hidden lg:flex absolute top-1/2 left-full -translate-y-1/2 ml-12"
      >
        <ul class="flex items-center text-base-content whitespace-nowrap">
          <li
            class:list={[
              "relative pb-0.5 font-navbar uppercase text-[18px] tracking-[4px] font-normal",
              "after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-full after:h-px after:bg-current after:origin-center after:transition-transform after:duration-[250ms] after:ease-in-out",
              "hover:after:scale-x-100",
              currentPath.startsWith("/culture")
                ? "after:scale-x-100"
                : "after:scale-x-0",
            ]}
          >
            <a href="/culture">Культура</a>
          </li>
          <div class="w-[1px] h-[18px] bg-neutral-200 mx-6"></div>
          <li
            class:list={[
              "relative pb-0.5 font-navbar uppercase text-[18px] tracking-[4px] font-normal",
              "after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-full after:h-px after:bg-current after:origin-center after:transition-transform after:duration-[250ms] after:ease-in-out",
              "hover:after:scale-x-100",
              currentPath.startsWith("/paris")
                ? "after:scale-x-100"
                : "after:scale-x-0",
            ]}
          >
            <a href="/paris">Париж</a>
          </li>
          <div class="w-[1px] h-[18px] bg-neutral-200 mx-6"></div>
          <li
            class:list={[
              "relative pb-0.5 font-navbar uppercase text-[18px] tracking-[4px] font-normal",
              "after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-full after:h-px after:bg-current after:origin-center after:transition-transform after:duration-[250ms] after:ease-in-out",
              "hover:after:scale-x-100",
              currentPath.startsWith("/calendar")
                ? "after:scale-x-100"
                : "after:scale-x-0",
            ]}
          >
            <a href="/calendar">Календарь</a>
          </li>
          <!-- <div class="w-[1px] h-[12px] bg-neutral-300 mx-6"></div>
          <li
            class="nav-item font-oswald uppercase tracking-[.46em] text-base font-normal hover:border-b hover:border-base-content pb-0.5"
          >
            <a href="/about" class="">О проекте</a>
          </li> -->
        </ul>
      </div>
    </div>

    <!-- Mobile Controls -->
    <div x-data="{}" class="flex items-center gap-4 lg:hidden">
      <button type="button" class="p-2">
        <img src={searchIcon.src} alt="Поиск" class="h-5 w-5" />
      </button>
      <button
        type="button"
        class="p-2"
        @click="$store.navbar.toggle()"
        aria-controls="mobile-menu"
        x-bind:aria-expanded="$store.navbar.isOpen"
      >
        <img src={burgerIcon.src} alt="Открыть меню" class="h-5 w-5" />
      </button>
    </div>

    <!-- Right Side -->
    <div class="hidden lg:flex items-center gap-[19px]">
      <button class="p-2">
        <img src={searchIcon.src} alt="Поиск" class="h-5 w-5" />
      </button>
      <button class="p-2">
        <Instagram class="h-6 w-6" />
      </button>
      <button class="p-2">
        <Youtube class="h-7 w-7" />
      </button>
      <div class="flex items-center gap-4" x-data="$lazy('navbar')">
        <!-- Loading State -->
        <template x-if="$store.auth.isLoading">
          <button class="btn btn-outline btn-primary" disabled>...</button>
        </template>
        <!-- Logged Out State -->
        <template x-if="!$store.auth.isLoading && !$store.auth.isLoggedIn">
          <button
            @click.prevent="$store.auth.openAuthModal()"
            class="border border-primary bg-primary text-primary-content rounded-[9px] py-1.5 px-4 text-center font-oswald text-[14px] w-full cursor-pointer hover:bg-primary/80 transition-colors"
          >
            Войти
          </button>
        </template>
        <!-- Logged In State -->
        <template x-if="!$store.auth.isLoading && $store.auth.isLoggedIn">
          <div class="flex items-center gap-4">
            <a
              href="/profile"
              class="flex items-center justify-center w-10 h-10 text-primary-content rounded-full font-bold text-lg hover:drop-shadow-lg transition-shadow"
              :class="$store.auth.profile?.role === 'admin' ? 'bg-error/50' : 'bg-primary'"
            >
              <div
                x-text="($store.auth.profile?.firstName?.[0] || '') + ($store.auth.profile?.lastName?.[0] || '')"
              >
              </div>
            </a>
            <button
              @click.prevent="handleSignOut()"
              class="cursor-pointer p-2 rounded-xl text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-gray-100"
            >
              Выйти
            </button>
          </div>
        </template>
      </div>
    </div>
  </nav>
</header>
