---
import { Image } from "astro:assets";
import MaagLogo from "../../assets/logo/maaglogo.svg";
import picture2 from "../../assets/images/cal.jpeg";
import { articlesApi, eventsApi, guidesApi } from "@/lib/api/api";

const CATEGORY_LABELS: Record<string, string> = {
  culture: "Культура",
  paris: "Париж",
  hotContent: "Самое Читаемое",
  interview: "Интервью",
  ballet: "Балет",
  opera: "Опера",
  dance: "Танец",
  music: "Музыка",
  theatre: "Театр",
  theater: "Театр",
  performance: "Спектакль",
  performances: "Спектакль",
  concert: "Концерт",
  concerts: "Концерт",
  exhibition: "Выставка",
  exhibitions: "Выставка",
  books: "Книги",
  artMarket: "Арт-рынок",
  artmarket: "Арт-рынок",
  architecture: "Архитектура",
  museums: "Музеи",
  tourism: "Туризм",
  strike: "Забастовка",
  kids: "Дети",
  route: "Маршрут",
  address: "Адрес",
  notebook: "Записная книжка",
  place: "Место",
  ...Object.fromEntries(
    Array.from({ length: 20 }, (_, i) => [
      `district-${i + 1}`,
      `${i + 1}-й округ`,
    ]),
  ),
};

const normalizeCategory = (value?: string) => {
  if (!value) {
    return value;
  }
  const lowerCaseValue = value.toLowerCase();
  const entry = Object.entries(CATEGORY_LABELS).find(
    ([key, label]) =>
      key.toLowerCase() === lowerCaseValue ||
      label.toLowerCase() === lowerCaseValue,
  );
  return entry ? entry[0] : value;
};

const getCategoryLabel = (value?: string) => {
  const normalized = normalizeCategory(value);
  if (normalized && CATEGORY_LABELS[normalized]) {
    return CATEGORY_LABELS[normalized];
  }
  return value ?? "";
};

const getPrimaryTag = (article: any) => {
  const rawTags = Array.isArray(article?.tags)
    ? article.tags
    : typeof article?.tags === "string"
      ? [article.tags]
      : [];

  const firstTag = rawTags.find(
    (tag) => typeof tag === "string" && tag.trim().length > 0,
  );

  if (firstTag) {
    return getCategoryLabel(firstTag.trim());
  }

  if (article?.isHotContent) {
    return CATEGORY_LABELS.hotContent;
  }

  return getCategoryLabel(article?.category);
};

const getCardLead = (item: any) => {
  const cardLead =
    typeof item?.cardLead === "string" ? item.cardLead.trim() : "";
  return cardLead;
};

const toContentHref = (item: any) => {
  if (item?.contentType === "guide") {
    return `/guide/${item.id}`;
  }
  return `/${item?.isNews ? "news" : "article"}/${item.id}`;
};

const isHotContentArticle = (article: any) =>
  Boolean(article?.isHotContent) ||
  normalizeCategory(article?.category) === "hotContent";

const isLeSaviezVousArticle = (article: any) =>
  article?.articleType === "le_saviez_vous";

let mainArticle: any = null;
let newsArticles: any[] = [];
let landingEvent: any = null;

try {
  const [articles, guides] = await Promise.all([
    articlesApi.list(),
    guidesApi.list(),
  ]);
  const standardArticles = articles.filter(
    (article) => !isLeSaviezVousArticle(article),
  );
  const landingContent = [
    ...standardArticles.map((article) => ({
      ...article,
      contentType: "article",
      href: toContentHref(article),
    })),
    ...guides.map((guide) => ({
      ...guide,
      contentType: "guide",
      href: toContentHref({ ...guide, contentType: "guide" }),
    })),
  ];

  const isCategoryRubricItem = (item: any) => {
    const cat = normalizeCategory(item?.category);
    return cat === "culture" || cat === "paris";
  };

  // Explicit isOnLanding takes priority; fallback excludes culture/paris rubric articles
  // so they stay in their own sections and don't duplicate on the landing hero.
  mainArticle =
    landingContent.find((item) => item.isOnLanding) ||
    landingContent.find(
      (item) =>
        !item.isNews &&
        !isHotContentArticle(item) &&
        !isCategoryRubricItem(item),
    ) ||
    null;

  // Filter for news articles, limit to 5 for the landing page
  newsArticles = standardArticles
    .filter((article) => Boolean(article.isNews))
    .slice(0, 4);
} catch (error) {
  console.error("Failed to fetch articles:", error);
}

const eventCategoryLabels: Record<string, string> = {
  exhibition: "Выставка",
  concert: "Концерт",
  performance: "Спектакль",
};

const toDate = (value: unknown): Date | null => {
  if (!value) {
    return null;
  }
  if (value instanceof Date) {
    return value;
  }
  if (typeof value === "string") {
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? null : parsed;
  }
  if (typeof value === "number") {
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? null : parsed;
  }
  if (typeof value === "object") {
    const maybeSeconds =
      (value as { seconds?: number; _seconds?: number }).seconds ??
      (value as { seconds?: number; _seconds?: number })._seconds;
    if (typeof maybeSeconds === "number") {
      return new Date(maybeSeconds * 1000);
    }
    if (typeof (value as { toDate?: () => Date }).toDate === "function") {
      const parsed = (value as { toDate: () => Date }).toDate();
      return parsed instanceof Date && !Number.isNaN(parsed.getTime())
        ? parsed
        : null;
    }
  }
  return null;
};

const formatEventDate = (value: unknown) => {
  const date = toDate(value);
  if (!date) {
    return null;
  }
  const dayMonth = date.toLocaleDateString("ru-RU", {
    day: "numeric",
    month: "long",
  });
  const monthGenitive = dayMonth.replace(/^\d+\s+/, "");
  const weekday = date.toLocaleDateString("ru-RU", { weekday: "long" });
  return {
    day: date.getDate().toString().padStart(2, "0"),
    month: monthGenitive,
    weekday,
  };
};

const formatArticleDate = (value: unknown) => {
  const date = toDate(value);
  if (!date) {
    return "";
  }
  return date
    .toLocaleDateString("ru-RU", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    })
    .replace(" г.", "");
};

const formatArticleMeta = (article: any, fallbackCategory = "") => {
  const parts = [
    formatArticleDate(article?.createdAt),
    getPrimaryTag(article) || fallbackCategory,
  ].filter(Boolean);
  return parts.join(" • ");
};

const pickPinnedEvent = (events: any[]) => {
  const pinned = events.find((event) => Boolean(event?.isOnLanding));
  if (!pinned) {
    return null;
  }
  const startDate = toDate(pinned.startDate);
  if (!startDate) {
    return null;
  }
  const endDate = toDate(pinned.endDate);
  return {
    ...pinned,
    startDate,
    endDate,
  };
};

try {
  const events = await eventsApi.list();
  landingEvent = pickPinnedEvent(events);
} catch (error) {
  console.error("Failed to fetch events for landing:", error);
}
---

<section
  class="w-full max-w-[1440px] mx-auto lg:max-h-[990px] px-4 lg:px-8 bg-base-200 mb-0"
>
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-4">
    {/* News Column - THINNER */}
    <aside
      class="lg:col-span-3 px-0 lg:pr-4 lg:border-r lg:border-gray-300 lg:max-h-[980px]"
    >
      <h2
        class="text-lg font-normal mb-6 uppercase tracking-[0.3em] font-old_standard"
      >
        Новости
      </h2>
      <div
        class="flex gap-6 overflow-x-auto pb-2 -mx-2 px-2 lg:flex-col lg:gap-0 lg:mx-0 lg:px-0 lg:overflow-x-visible lg:overflow-y-hidden"
      >
        {
          newsArticles.map((newsItem) => (
            <div class="flex-shrink-0 w-[280px] sm:w-1/2 md:w-1/3 lg:w-full lg:py-4 lg:border-b lg:border-base-content/15 last:lg:border-b-0">
              <div class="flex items-start gap-4">
                <a
                  href={`/news/${newsItem.id}`}
                  class="linked-image-hover bg-base-200 z-10"
                >
                  <Image
                    src={newsItem.imageUrl}
                    alt={`News image for ${newsItem.title}`}
                    class="linked-image-hover__media w-20 h-20 object-cover flex-shrink-0"
                    width={80}
                    height={80}
                    transition:name={`main-article-image-${newsItem.id}`}
                  />
                </a>
                <div class="flex-1 max-w-max">
                  <div class="mb-1">
                    <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                      {getPrimaryTag(newsItem) || "Новости"}
                    </span>
                  </div>
                  <a
                    href={`/news/${newsItem.id}`}
                    class="block bg-base-200 z-10 transition-opacity duration-200 hover:opacity-90"
                  >
                    <h3 class="text-xl font-normal font-old_standard tracking-[-0.02em] hover:underline transition-opacity duration-200 hover:opacity-90">
                      {newsItem.title}
                    </h3>
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </aside>

    {/* Main Column - WIDER */}
    <article class="lg:col-span-6 order-first lg:order-none relative">
      <h2
        class="text-lg font-normal mb-6 uppercase tracking-[0.3em] font-old_standard"
      >
        Главное
      </h2>
      {
        mainArticle ? (
          <div>
            <div class="aspect-[3/2] overflow-hidden relative z-10">
              <a
                href={mainArticle.href}
                class="linked-image-hover w-full h-full"
              >
                <img
                  src={mainArticle.imageUrl}
                  alt={mainArticle.title}
                  class="linked-image-hover__media w-full h-full object-cover"
                  transition:name={`main-article-image-${mainArticle.id}`}
                />
              </a>
            </div>
            <div class="p-4 lg:p-0">
              <div class="flex flex-row items-center gap-2 text-xs text-base-content/55 font-inter uppercase tracking-[0.22em]">
                <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter'] mt-2">
                  {getPrimaryTag(mainArticle) || "Новости"}
                </span>
                <span class="hidden text-black text-lg font-bold font-['Inter']">
                  ·
                </span>
                <span class="hidden text-xs">
                  {formatArticleDate(mainArticle?.createdAt)}
                </span>
              </div>
              <a
                href={mainArticle.href}
                class="block transition-opacity duration-200 hover:opacity-90"
              >
                <h2 class="text-3xl lg:text-[44px] font-normal font-old_standard tracking-[-0.04em] leading-[48px] hover:underline mt-1 mb-2">
                  {mainArticle.title}{" "}
                  <MaagLogo class="w-4 h-4 inline-block align-baseline" />
                </h2>
              </a>
              {getCardLead(mainArticle) ? (
                <p class="text-base lg:text-lg text-black/60 font-inter font-normal leading-[20px]">
                  {getCardLead(mainArticle)}
                </p>
              ) : null}
            </div>
          </div>
        ) : (
          <div>
            <div class="p-4 lg:p-6">
              <p>Главных статей для отображения нет.</p>
            </div>
          </div>
        )
      }
    </article>

    {/* Calendar Column */}
    <aside
      class="lg:col-span-3 px-0 lg:pl-4 lg:border-l lg:border-gray-300 mt-6 lg:mt-0"
    >
      <h2
        class="text-lg font-normal mb-6 uppercase tracking-[0.3em] font-old_standard"
      >
        Календарь
      </h2>
      {
        landingEvent ? (
          <a
            href={`/events/${landingEvent.id}`}
            class="linked-image-hover bg-white"
          >
            <div class="px-4 py-2 flex items-center gap-3">
              <p class="text-[18px] font-inter uppercase font-bold tracking-[0.15em] mt-1 mb-1">
                {formatEventDate(landingEvent.startDate)?.day}{" "}
                {(
                  formatEventDate(landingEvent.startDate)?.month || ""
                ).toUpperCase()}
                {formatEventDate(landingEvent.startDate)?.weekday ? (
                  <span class="font-normal normal-case tracking-normal italic font-old_standard opacity-60 ml-2">
                    {formatEventDate(landingEvent.startDate)?.weekday}
                  </span>
                ) : null}
              </p>
            </div>
            {landingEvent.imageUrl ? (
              <img
                src={landingEvent.imageUrl}
                alt={landingEvent.title}
                class="linked-image-hover__media w-full h-auto lg:h-[240px] object-cover"
                loading="lazy"
                transition:name={`event-image-${landingEvent.id}`}
              />
            ) : (
              <Image
                src={picture2}
                alt="Event"
                class="linked-image-hover__media w-full h-auto lg:h-[240px] object-cover"
                transition:name={`event-image-${landingEvent.id}`}
              />
            )}
            <div class="px-4 py-4">
              <p class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                {eventCategoryLabels[landingEvent.category] || "Событие"}
              </p>
              <h2 class="text-xl font-normal font-old_standard tracking-[-0.02em] hover:underline transition-opacity duration-200 hover:opacity-90 mt-2">
                {landingEvent.title}
              </h2>
            </div>
          </a>
        ) : (
          <div class="bg-white">
            <div class="p-4 lg:p-2 flex items-center gap-3">
              {/* <div class="flex flex-col items-center gap-1 rounded-full bg-base-200 p-3">
                <p class="text-2xl lg:text-2xl text-black/50 font-thin font-oswald">
                  --
                </p>
              </div> */}
              <p class="text-[18px] font-inter uppercase font-bold tracking-[0.15em] mt-1 mb-1">
                Скоро
              </p>
            </div>
            <Image
              src={picture2}
              alt="Event placeholder"
              class="w-full h-auto lg:h-[240px] object-cover"
            />
            <div class="p-4 lg:py-6 lg:px-4">
              <p class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                Событие
              </p>
              <h2 class="text-xl font-normal font-old_standard tracking-[-0.02em] hover:underline transition-opacity duration-200 hover:opacity-90 mt-1">
                Скоро появится событие
              </h2>
              <p class="text-base lg:text-sm text-black/80 font-inter font-normal">
                Следи за обновлениями
              </p>
            </div>
          </div>
        )
      }
    </aside>
  </div>
  <hr class="h-px my-8 border-1" />
</section>
