---
import { Image } from "astro:assets";
import MaagLogoPaid from "../../assets/logo/maaglogo.svg";
import picture2 from "../../assets/images/cal.jpeg";
import { getTransitionName } from "../../lib/utils/transitions";
import { getPrimaryBadgeLabel } from "@/lib/utils/contentBadge";
import { getCalendarToday } from "@/lib/utils/calendarDate";

interface MainLandingBlockProps {
  data?: {
    mainArticle?: any;
    newsArticles?: any[];
    landingEvent?: any;
  };
}

const { data: publicLandingData } = Astro.props as MainLandingBlockProps;

const getPrimaryTag = (article: any) => getPrimaryBadgeLabel(article);

const splitTitle = (t: string) => {
  const s = t.trimEnd();
  const i = s.lastIndexOf(" ");
  return {
    start: i >= 0 ? s.slice(0, i) : "",
    last: i >= 0 ? s.slice(i + 1) : s,
  };
};

const mainArticle = publicLandingData?.mainArticle ?? null;
const newsArticles = publicLandingData?.newsArticles ?? [];
const landingEvent = publicLandingData?.landingEvent ?? null;

function toDate(value: unknown): Date | null {
  if (!value) {
    return null;
  }
  if (value instanceof Date) {
    return value;
  }
  if (typeof value === "string") {
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? null : parsed;
  }
  if (typeof value === "number") {
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? null : parsed;
  }
  if (typeof value === "object") {
    const maybeSeconds =
      (value as { seconds?: number; _seconds?: number }).seconds ??
      (value as { seconds?: number; _seconds?: number })._seconds;
    if (typeof maybeSeconds === "number") {
      return new Date(maybeSeconds * 1000);
    }
    if (typeof (value as { toDate?: () => Date }).toDate === "function") {
      const parsed = (value as { toDate: () => Date }).toDate();
      return parsed instanceof Date && !Number.isNaN(parsed.getTime())
        ? parsed
        : null;
    }
  }
  return null;
}

function resetToUtcMidnight(date: Date) {
  const normalized = new Date(date);
  normalized.setUTCHours(0, 0, 0, 0);
  return normalized;
}

const formatEventDate = (value: unknown) => {
  const date = toDate(value);
  if (!date) {
    return null;
  }
  const dayMonth = date.toLocaleDateString("ru-RU", {
    day: "numeric",
    month: "long",
  });
  const monthGenitive = dayMonth.replace(/^\d+\s+/, "");
  const weekday = date.toLocaleDateString("ru-RU", { weekday: "long" });
  return {
    day: date.getDate().toString().padStart(2, "0"),
    month: monthGenitive,
    weekday,
  };
};

const formatArticleDate = (value: unknown) => {
  const date = toDate(value);
  if (!date) {
    return "";
  }
  return date
    .toLocaleDateString("ru-RU", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    })
    .replace(" г.", "");
};

function getLandingEventDisplayDate(event: any) {
  const startDate = toDate(event?.startDate);
  if (!startDate) {
    return null;
  }

  const startDay = resetToUtcMidnight(new Date(startDate));
  const endDate = toDate(event?.endDate) ?? startDate;
  const endDay = resetToUtcMidnight(new Date(endDate));
  const today = getCalendarToday();
  const isRangeEvent =
    event?.dateType === "duration" || startDay.getTime() !== endDay.getTime();

  if (
    isRangeEvent &&
    startDay.getTime() <= today.getTime() &&
    endDay.getTime() >= today.getTime()
  ) {
    return today;
  }

  return startDate;
}

const landingEventDisplayDate = getLandingEventDisplayDate(landingEvent);
---

<section
  class="w-full max-w-[1440px] mx-auto lg:max-h-[990px] px-4 lg:px-8 bg-base-200 mb-0"
>
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-4">
    {/* News Column - THINNER */}
    <aside
      class="lg:col-span-3 px-0 lg:pr-4 lg:border-r lg:border-base-content/15 lg:max-h-[980px]"
    >
      <h2
        class="text-lg font-semibold mb-6 uppercase tracking-[0.3em] font-old_standard"
      >
        Новости
      </h2>
      <div
        class="flex gap-6 overflow-x-auto pb-2 -mx-2 px-2 lg:flex-col lg:gap-0 lg:mx-0 lg:-mt-2 lg:px-0 lg:overflow-x-visible lg:overflow-y-hidden"
      >
        {
          newsArticles.map((newsItem) => (
            <div class="flex-shrink-0 w-[280px] sm:w-1/2 md:w-1/3 lg:w-full lg:py-4 lg:border-b lg:border-base-content/15 last:lg:border-b-0">
              <div class="flex items-start gap-4">
                <a
                  href={`/news/${newsItem.id}`}
                  class="linked-image-hover bg-base-200 z-10"
                >
                  <Image
                    src={newsItem.imageUrl}
                    alt={`News image for ${newsItem.title}`}
                    class="linked-image-hover__media w-20 h-20 object-cover flex-shrink-0"
                    width={80}
                    height={80}
                  />
                </a>
                <div class="flex-1 max-w-max">
                  <div class="mb-1 flex items-start">
                    <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                      {getPrimaryTag(newsItem)}
                    </span>
                  </div>
                  <a
                    href={`/news/${newsItem.id}`}
                    class="block bg-base-200 z-10 transition-opacity duration-200 hover:opacity-90"
                  >
                    <h3 class="text-xl font-normal font-old_standard tracking-[-0.02em] hover:underline transition-opacity duration-200 hover:opacity-90">
                      {newsItem.title}
                    </h3>
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </aside>

    {/* Main Column - WIDER */}
    <article class="lg:col-span-6 order-first lg:order-none relative">
      <h2
        class="text-lg font-semibold mb-6 uppercase tracking-[0.3em] font-old_standard"
      >
        Главное
      </h2>
      {
        mainArticle ? (
          <div>
            <div class="aspect-[3/2] overflow-hidden relative z-10">
              <a
                href={mainArticle.href}
                class="linked-image-hover w-full h-full"
              >
                <img
                  src={mainArticle.imageUrl}
                  alt={mainArticle.title}
                  width="1200"
                  height="800"
                  loading="eager"
                  fetchpriority="high"
                  class="linked-image-hover__media w-full h-full object-cover"
                  transition:name={getTransitionName(mainArticle)}
                />
              </a>
            </div>
            <div class="p-4 lg:p-0">
              <div class="flex flex-row items-center gap-2 text-xs text-base-content/55 font-inter uppercase tracking-[0.22em]">
                <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter'] mt-2 lg:mt-4">
                  {getPrimaryTag(mainArticle)}
                </span>
                <span class="hidden text-black text-lg font-bold font-['Inter']">
                  ·
                </span>
                <span class="hidden text-xs">
                  {formatArticleDate(mainArticle?.createdAt)}
                </span>
              </div>
              <a
                href={mainArticle.href}
                class="block transition-opacity duration-200 hover:opacity-90"
              >
                <h2 class="text-3xl lg:text-[37px] font-normal font-old_standard tracking-[-0.04em] leading-[48px] hover:underline mt-1 mb-2">
                  {mainArticle.paid ? (
                    <>
                      {splitTitle(mainArticle.title).start && (
                        <>{splitTitle(mainArticle.title).start} </>
                      )}
                      <span class="whitespace-nowrap">
                        {splitTitle(mainArticle.title).last}{" "}
                        <MaagLogoPaid class="w-5 h-5 inline-block align-baseline" />
                      </span>
                    </>
                  ) : (
                    mainArticle.title
                  )}
                </h2>
              </a>
            </div>
          </div>
        ) : (
          <div>
            <div class="p-4 lg:p-6">
              <p>Главных статей для отображения нет.</p>
            </div>
          </div>
        )
      }
    </article>

    {/* Calendar Column */}
    <aside
      class="lg:col-span-3 px-0 lg:pl-4 lg:border-l lg:border-base-content/15 mt-6 lg:mt-0"
    >
      <h2
        class="text-lg font-semibold mb-6 uppercase tracking-[0.3em] font-old_standard"
      >
        Календарь
      </h2>
      {
        landingEvent ? (
          <a
            href={`/events/${landingEvent.id}`}
            class="linked-image-hover bg-white"
          >
            <div class="px-4 py-2 flex items-center gap-3">
              <div class="w-fill flex flex-row gap-2 items-center justify-center mt-2 mb-1">
                <div class="flex items-center justify-center h-full">
                  <p class="text-6xl font-old_standard uppercase font-bold">
                    {formatEventDate(landingEventDisplayDate)?.day}
                  </p>
                </div>
                <div class="h-full flex flex-col items-start justify-center">
                  <p class="font-semibold font-inter text-black/70">
                    {(
                      formatEventDate(landingEventDisplayDate)?.month || ""
                    ).toUpperCase()}
                  </p>
                  <div class="w-full border-t border-black/50" />
                  <p>
                    {formatEventDate(landingEventDisplayDate)?.weekday ? (
                      <span class="font-normal normal-case tracking-normal italic font-old_standard opacity-60">
                        {formatEventDate(landingEventDisplayDate)?.weekday}
                      </span>
                    ) : null}
                  </p>
                </div>
              </div>
            </div>
            {landingEvent.imageUrl ? (
              <img
                src={landingEvent.imageUrl}
                alt={landingEvent.title}
                class="linked-image-hover__media w-full h-auto lg:h-[240px] object-cover"
                loading="eager"
              />
            ) : (
              <Image
                src={picture2}
                alt="Event"
                class="linked-image-hover__media w-full h-auto lg:h-[240px] object-cover"
              />
            )}
            <div class="px-4 py-4">
              <p class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                {getPrimaryBadgeLabel(landingEvent)}
              </p>
              <h2 class="text-2xl font-normal font-old_standard tracking-[-0.02em] hover:underline transition-opacity duration-200 hover:opacity-90 mt-2">
                {landingEvent.title}
              </h2>
            </div>
          </a>
        ) : (
          <div class="bg-white p-4 lg:p-6">
            <p class="text-sm text-base-content/70">
              Блок события сейчас пуст.
            </p>
          </div>
        )
      }
    </aside>
  </div>
</section>
