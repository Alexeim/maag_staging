---
import { Image } from "astro:assets";
import MaagLogoPaid from "../../assets/logo/maaglogo.svg";
import picture2 from "../../assets/images/cal.jpeg";
import {
  articlesApi,
  editorialPlacementsApi,
  eventsApi,
  flippersApi,
  guidesApi,
  interviewsApi,
  newsApi,
  visualStoriesApi,
  type LandingEventCardSelection,
  type LandingNewsRailSelection,
  type LandingPlacementsResponse,
} from "@/lib/api/api";
import { getKnownTagLabel } from "@/content/tags/parisTags";

const CATEGORY_LABELS: Record<string, string> = {
  culture: "Культура",
  paris: "Париж",
  hotContent: "Самое Читаемое",
  interview: "Интервью",
  ballet: "Балет",
  opera: "Опера",
  dance: "Танец",
  music: "Музыка",
  theatre: "Театр",
  theater: "Театр",
  performance: "Спектакль",
  performances: "Спектакль",
  concert: "Концерт",
  concerts: "Концерт",
  exhibition: "Выставка",
  exhibitions: "Выставка",
  books: "Книги",
  artMarket: "Арт-рынок",
  artmarket: "Арт-рынок",
  architecture: "Архитектура",
  museums: "Музеи",
  tourism: "Туризм",
  strike: "Забастовка",
  kids: "Дети",
  route: "Маршрут",
  address: "Адрес",
  notebook: "Записная книжка",
  place: "Место",
  ...Object.fromEntries(
    Array.from({ length: 20 }, (_, i) => [
      `district-${i + 1}`,
      `${i + 1}-й округ`,
    ]),
  ),
};

const normalizeCategory = (value?: string) => {
  if (!value) {
    return value;
  }
  const lowerCaseValue = value.toLowerCase();
  const entry = Object.entries(CATEGORY_LABELS).find(
    ([key, label]) =>
      key.toLowerCase() === lowerCaseValue ||
      label.toLowerCase() === lowerCaseValue,
  );
  return entry ? entry[0] : value;
};

const getCategoryLabel = (value?: string) => {
  const normalized = normalizeCategory(value);
  if (normalized && CATEGORY_LABELS[normalized]) {
    return CATEGORY_LABELS[normalized];
  }
  return value ?? "";
};

const getPrimaryTag = (article: any) => {
  if (article?.contentType === "interview") {
    return CATEGORY_LABELS.interview;
  }
  const rawTags = Array.isArray(article?.tags)
    ? article.tags
    : typeof article?.tags === "string"
      ? [article.tags]
      : [];

  const firstTag = rawTags.find(
    (tag) => typeof tag === "string" && tag.trim().length > 0,
  );

  if (firstTag) {
    return (
      getKnownTagLabel(firstTag.trim()) || getCategoryLabel(firstTag.trim())
    );
  }

  if (article?.isHotContent) {
    return CATEGORY_LABELS.hotContent;
  }

  return getCategoryLabel(article?.category);
};

const getCardLead = (item: any) => {
  const cardLead =
    typeof item?.cardLead === "string" ? item.cardLead.trim() : "";
  return cardLead;
};

const toContentHref = (item: any) => {
  if (item?.contentType === "interview") {
    return `/interviews/${item.id}`;
  }
  if (item?.contentType === "flipper") {
    return `/flippers/${item.id}`;
  }
  if (item?.contentType === "guide") {
    return `/guide/${item.id}`;
  }
  if (item?.contentType === "visual-story") {
    return `/visual-story/${item.id}`;
  }
  return `/${item?.isNews ? "news" : "article"}/${item.id}`;
};

const isHotContentItem = (article: any) =>
  Boolean(article?.isHotContent) ||
  normalizeCategory(article?.category) === "hotContent";

const isLeSaviezVousArticle = (article: any) =>
  article?.articleType === "le_saviez_vous";

const splitTitle = (t: string) => {
  const s = t.trimEnd();
  const i = s.lastIndexOf(" ");
  return {
    start: i >= 0 ? s.slice(0, i) : "",
    last: i >= 0 ? s.slice(i + 1) : s,
  };
};

const DEFAULT_LANDING_PLACEMENTS: LandingPlacementsResponse = {
  schemaVersion: 4,
  mainHero: null,
  newsRail: {
    mode: "auto-latest",
    limit: 4,
  },
  netlenkaRail: {
    mode: "auto-latest",
    limit: 4,
  },
  cultureHero: null,
  cultureCards: {
    mode: "auto-latest",
    limit: 3,
  },
  parisHero: null,
  parisCards: {
    mode: "auto-latest",
    limit: 3,
  },
  eventCard: {
    mode: "auto-nearest",
  },
  cultureInterviewBlock: {
    mode: "auto-latest",
  },
  updatedAt: null,
  updatedBy: null,
};

let mainArticle: any = null;
let newsArticles: any[] = [];
let landingEvent: any = null;

try {
  const [
    articles,
    guides,
    interviews,
    flippers,
    visualStories,
    newsItemsRaw,
    events,
    landingPlacements,
  ] = await Promise.all([
    articlesApi.list(),
    guidesApi.list(),
    interviewsApi.list(),
    flippersApi.list(),
    visualStoriesApi.list(),
    newsApi.list(),
    eventsApi.list(),
    editorialPlacementsApi.getLanding().catch(() => DEFAULT_LANDING_PLACEMENTS),
  ]);
  const standardArticles = articles.filter(
    (article) => !isLeSaviezVousArticle(article),
  );
  const newsItems = newsItemsRaw.map((item) => ({
    ...item,
    isNews: true,
    contentType: "news",
  }));
  const articleHeroCandidates = standardArticles.map((article) => ({
    ...article,
    contentType: "article",
    href: toContentHref(article),
  }));
  const guideHeroCandidates = guides.map((guide) => ({
    ...guide,
    contentType: "guide",
    href: toContentHref({ ...guide, contentType: "guide" }),
  }));
  const interviewHeroCandidates = interviews.map((interview) => ({
    ...interview,
    contentType: "interview",
    href: toContentHref({ ...interview, contentType: "interview" }),
  }));
  const flipperHeroCandidates = flippers.map((flipper) => ({
    ...flipper,
    contentType: "flipper",
    href: toContentHref({ ...flipper, contentType: "flipper" }),
    imageUrl: flipper?.carouselContent?.[0]?.imageUrl || null,
  }));
  const visualStoryHeroCandidates = visualStories.map((story) => ({
    ...story,
    contentType: "visual-story",
    href: toContentHref({ ...story, contentType: "visual-story" }),
    imageUrl: story?.imageUrl || story?.slides?.[0]?.imageUrl || null,
  }));
  const landingContent = [
    ...articleHeroCandidates,
    ...guideHeroCandidates,
    ...interviewHeroCandidates,
    ...flipperHeroCandidates,
    ...visualStoryHeroCandidates,
  ];

  const isCategoryRubricItem = (item: any) => {
    const cat = normalizeCategory(item?.category);
    return cat === "culture" || cat === "paris";
  };

  const mainHeroSelection = landingPlacements.mainHero ?? null;
  const placedMainHero = mainHeroSelection
    ? landingContent.find(
        (item) =>
          item.id === mainHeroSelection.id &&
          item.contentType === mainHeroSelection.type,
      )
    : null;

  mainArticle = placedMainHero || null;

  newsArticles = selectNewsRailItems(newsItems, landingPlacements.newsRail);
  landingEvent = selectEventCard(events, landingPlacements.eventCard);
} catch (error) {
  console.error("Failed to fetch articles:", error);
}

const eventCategoryLabels: Record<string, string> = {
  exhibition: "Выставка",
  concert: "Концерт",
  performance: "Спектакль",
};

function toDate(value: unknown): Date | null {
  if (!value) {
    return null;
  }
  if (value instanceof Date) {
    return value;
  }
  if (typeof value === "string") {
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? null : parsed;
  }
  if (typeof value === "number") {
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? null : parsed;
  }
  if (typeof value === "object") {
    const maybeSeconds =
      (value as { seconds?: number; _seconds?: number }).seconds ??
      (value as { seconds?: number; _seconds?: number })._seconds;
    if (typeof maybeSeconds === "number") {
      return new Date(maybeSeconds * 1000);
    }
    if (typeof (value as { toDate?: () => Date }).toDate === "function") {
      const parsed = (value as { toDate: () => Date }).toDate();
      return parsed instanceof Date && !Number.isNaN(parsed.getTime())
        ? parsed
        : null;
    }
  }
  return null;
}

function resetToUtcMidnight(date: Date) {
  const normalized = new Date(date);
  normalized.setUTCHours(0, 0, 0, 0);
  return normalized;
}

const formatEventDate = (value: unknown) => {
  const date = toDate(value);
  if (!date) {
    return null;
  }
  const dayMonth = date.toLocaleDateString("ru-RU", {
    day: "numeric",
    month: "long",
  });
  const monthGenitive = dayMonth.replace(/^\d+\s+/, "");
  const weekday = date.toLocaleDateString("ru-RU", { weekday: "long" });
  return {
    day: date.getDate().toString().padStart(2, "0"),
    month: monthGenitive,
    weekday,
  };
};

const formatArticleDate = (value: unknown) => {
  const date = toDate(value);
  if (!date) {
    return "";
  }
  return date
    .toLocaleDateString("ru-RU", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    })
    .replace(" г.", "");
};

const formatArticleMeta = (article: any, fallbackCategory = "") => {
  const parts = [
    formatArticleDate(article?.createdAt),
    getPrimaryTag(article) || fallbackCategory,
  ].filter(Boolean);
  return parts.join(" • ");
};

function selectNewsRailItems(
  newsItems: any[],
  newsRail: LandingNewsRailSelection | null,
) {
  if (!newsRail) {
    return [];
  }

  if (newsRail.mode === "auto-latest") {
    return newsItems.slice(0, newsRail.limit);
  }

  const itemsById = new Map(newsItems.map((item) => [item.id, item]));
  return newsRail.ids.map((id) => itemsById.get(id)).filter(Boolean);
}

function normalizeEvents(events: any[]) {
  return events
    .map((event) => {
      const startDate = toDate(event?.startDate);
      const endDate = toDate(event?.endDate);

      if (!startDate) {
        return null;
      }

      return {
        ...event,
        startDate,
        endDate,
        startDay: resetToUtcMidnight(startDate),
        endDay: resetToUtcMidnight(endDate ?? startDate),
      };
    })
    .filter(Boolean) as Array<
    {
      startDate: Date;
      endDate: Date | null;
      startDay: Date;
      endDay: Date;
    } & any
  >;
}

function isSingleDayEvent(event: { startDay: Date; endDay: Date }) {
  return event.startDay.getTime() === event.endDay.getTime();
}

function sortByCreatedAtDesc(left: any, right: any) {
  return (
    (toDate(right?.createdAt)?.getTime() ?? 0) -
    (toDate(left?.createdAt)?.getTime() ?? 0)
  );
}

function selectNearestEvent(events: any[]) {
  const today = resetToUtcMidnight(new Date());
  return (
    normalizeEvents(events)
      .filter((event) => event.endDay.getTime() >= today.getTime())
      .sort((a, b) => {
        const aIsActiveToday =
          a.startDay.getTime() <= today.getTime() &&
          a.endDay.getTime() >= today.getTime();
        const bIsActiveToday =
          b.startDay.getTime() <= today.getTime() &&
          b.endDay.getTime() >= today.getTime();

        if (aIsActiveToday !== bIsActiveToday) {
          return aIsActiveToday ? -1 : 1;
        }

        if (aIsActiveToday && bIsActiveToday) {
          const aDistance = Math.abs(a.startDay.getTime() - today.getTime());
          const bDistance = Math.abs(b.startDay.getTime() - today.getTime());

          if (aDistance !== bDistance) {
            return aDistance - bDistance;
          }

          return b.startDay.getTime() - a.startDay.getTime();
        }

        return a.startDay.getTime() - b.startDay.getTime();
      })[0] || null
  );
}

function selectAutoLandingEvent(events: any[]) {
  const today = resetToUtcMidnight(new Date());
  const normalizedEvents = normalizeEvents(events);

  const singleDayEventsForToday = normalizedEvents
    .filter(
      (event) =>
        isSingleDayEvent(event) && event.startDay.getTime() === today.getTime(),
    )
    .sort(sortByCreatedAtDesc);

  if (singleDayEventsForToday[0]) {
    return singleDayEventsForToday[0];
  }

  const activeRangeEvents = normalizedEvents
    .filter(
      (event) =>
        !isSingleDayEvent(event) &&
        event.startDay.getTime() <= today.getTime() &&
        event.endDay.getTime() >= today.getTime(),
    )
    .sort(sortByCreatedAtDesc);

  if (activeRangeEvents[0]) {
    return activeRangeEvents[0];
  }

  return selectNearestEvent(events);
}

function selectEventCard(
  events: any[],
  eventCard: LandingEventCardSelection | null,
) {
  if (!eventCard) {
    return null;
  }

  if (eventCard.mode === "manual") {
    const matched = events.find((event) => event.id === eventCard.id);
    if (!matched) {
      return null;
    }

    const startDate = toDate(matched.startDate);
    if (!startDate) {
      return null;
    }

    return {
      ...matched,
      startDate,
      endDate: toDate(matched.endDate),
    };
  }

  return selectAutoLandingEvent(events);
}

function getLandingEventDisplayDate(event: any) {
  const startDate = toDate(event?.startDate);
  if (!startDate) {
    return null;
  }

  const startDay = resetToUtcMidnight(new Date(startDate));
  const endDate = toDate(event?.endDate) ?? startDate;
  const endDay = resetToUtcMidnight(new Date(endDate));
  const today = resetToUtcMidnight(new Date());
  const isRangeEvent =
    event?.dateType === "duration" || startDay.getTime() !== endDay.getTime();

  if (
    isRangeEvent &&
    startDay.getTime() <= today.getTime() &&
    endDay.getTime() >= today.getTime()
  ) {
    return today;
  }

  return startDate;
}

const landingEventDisplayDate = getLandingEventDisplayDate(landingEvent);
---

<section
  class="w-full max-w-[1440px] mx-auto lg:max-h-[990px] px-4 lg:px-8 bg-base-200 mb-0"
>
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-4">
    {/* News Column - THINNER */}
    <aside
      class="lg:col-span-3 px-0 lg:pr-4 lg:border-r lg:border-gray-300 lg:max-h-[980px]"
    >
      <h2
        class="text-lg font-semibold mb-6 uppercase tracking-[0.3em] font-old_standard"
      >
        Новости
      </h2>
      <div
        class="flex gap-6 overflow-x-auto pb-2 -mx-2 px-2 lg:flex-col lg:gap-0 lg:mx-0 lg:px-0 lg:overflow-x-visible lg:overflow-y-hidden"
      >
        {
          newsArticles.map((newsItem) => (
            <div class="flex-shrink-0 w-[280px] sm:w-1/2 md:w-1/3 lg:w-full lg:py-4 lg:border-b lg:border-base-content/15 last:lg:border-b-0">
              <div class="flex items-start gap-4">
                <a
                  href={`/news/${newsItem.id}`}
                  class="linked-image-hover bg-base-200 z-10"
                >
                  <Image
                    src={newsItem.imageUrl}
                    alt={`News image for ${newsItem.title}`}
                    class="linked-image-hover__media w-20 h-20 object-cover flex-shrink-0"
                    width={80}
                    height={80}
                    transition:name={`main-article-image-${newsItem.id}`}
                  />
                </a>
                <div class="flex-1 max-w-max">
                  <div class="mb-1 flex items-start">
                    <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                      {getPrimaryTag(newsItem) || "Новости"}
                    </span>
                  </div>
                  <a
                    href={`/news/${newsItem.id}`}
                    class="block bg-base-200 z-10 transition-opacity duration-200 hover:opacity-90"
                  >
                    <h3 class="text-xl font-normal font-old_standard tracking-[-0.02em] hover:underline transition-opacity duration-200 hover:opacity-90">
                      {newsItem.title}
                    </h3>
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </aside>

    {/* Main Column - WIDER */}
    <article class="lg:col-span-6 order-first lg:order-none relative">
      <h2
        class="text-lg font-semibold mb-6 uppercase tracking-[0.3em] font-old_standard"
      >
        Главное
      </h2>
      {
        mainArticle ? (
          <div>
            <div class="aspect-[3/2] overflow-hidden relative z-10">
              <a
                href={mainArticle.href}
                class="linked-image-hover w-full h-full"
              >
                <img
                  src={mainArticle.imageUrl}
                  alt={mainArticle.title}
                  class="linked-image-hover__media w-full h-full object-cover"
                  transition:name={`main-article-image-${mainArticle.id}`}
                />
              </a>
            </div>
            <div class="p-4 lg:p-0">
              <div class="flex flex-row items-center gap-2 text-xs text-base-content/55 font-inter uppercase tracking-[0.22em]">
                <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter'] mt-2 lg:mt-4">
                  {getPrimaryTag(mainArticle) || "Новости"}
                </span>
                <span class="hidden text-black text-lg font-bold font-['Inter']">
                  ·
                </span>
                <span class="hidden text-xs">
                  {formatArticleDate(mainArticle?.createdAt)}
                </span>
              </div>
              <a
                href={mainArticle.href}
                class="block transition-opacity duration-200 hover:opacity-90"
              >
                <h2 class="text-3xl lg:text-[44px] font-normal font-old_standard tracking-[-0.04em] leading-[48px] hover:underline mt-1 mb-2">
                  {mainArticle.paid ? (
                    <>
                      {splitTitle(mainArticle.title).start && (
                        <>{splitTitle(mainArticle.title).start} </>
                      )}
                      <span class="whitespace-nowrap">
                        {splitTitle(mainArticle.title).last}{" "}
                        <MaagLogoPaid class="w-5 h-5 inline-block align-baseline" />
                      </span>
                    </>
                  ) : (
                    mainArticle.title
                  )}
                </h2>
              </a>
              {getCardLead(mainArticle) ? (
                <p class="text-base text-black/70 font-inter font-light leading-[20px]">
                  {getCardLead(mainArticle)}
                </p>
              ) : null}
            </div>
          </div>
        ) : (
          <div>
            <div class="p-4 lg:p-6">
              <p>Главных статей для отображения нет.</p>
            </div>
          </div>
        )
      }
    </article>

    {/* Calendar Column */}
    <aside
      class="lg:col-span-3 px-0 lg:pl-4 lg:border-l lg:border-gray-300 mt-6 lg:mt-0"
    >
      <h2
        class="text-lg font-semibold mb-6 uppercase tracking-[0.3em] font-old_standard"
      >
        Календарь
      </h2>
      {
        landingEvent ? (
          <a
            href={`/events/${landingEvent.id}`}
            class="linked-image-hover bg-white"
          >
            <div class="px-4 py-2 flex items-center gap-3">
              <div class="w-fill flex flex-row gap-2 items-center justify-center mt-2 mb-1">
                <div class="flex items-center justify-center h-full">
                  <p class="text-6xl font-old_standard uppercase font-bold">
                    {formatEventDate(landingEventDisplayDate)?.day}
                  </p>
                </div>
                <div class="h-full flex flex-col items-start justify-center">
                  <p class="font-semibold font-inter text-black/70">
                    {(
                      formatEventDate(landingEventDisplayDate)?.month || ""
                    ).toUpperCase()}
                  </p>
                  <div class="w-full border-t border-black/50" />
                  <p>
                    {formatEventDate(landingEventDisplayDate)?.weekday ? (
                      <span class="font-normal normal-case tracking-normal italic font-old_standard opacity-60">
                        {formatEventDate(landingEventDisplayDate)?.weekday}
                      </span>
                    ) : null}
                  </p>
                </div>
              </div>
            </div>
            {landingEvent.imageUrl ? (
              <img
                src={landingEvent.imageUrl}
                alt={landingEvent.title}
                class="linked-image-hover__media w-full h-auto lg:h-[240px] object-cover"
                loading="eager"
                transition:name={`event-image-${landingEvent.id}`}
              />
            ) : (
              <Image
                src={picture2}
                alt="Event"
                class="linked-image-hover__media w-full h-auto lg:h-[240px] object-cover"
                transition:name={`event-image-${landingEvent.id}`}
              />
            )}
            <div class="px-4 py-4">
              <p class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                {eventCategoryLabels[landingEvent.category] || "Событие"}
              </p>
              <h2 class="text-2xl font-normal font-old_standard tracking-[-0.02em] hover:underline transition-opacity duration-200 hover:opacity-90 mt-2">
                {landingEvent.title}
              </h2>
            </div>
          </a>
        ) : (
          <div class="bg-white p-4 lg:p-6">
            <p class="text-sm text-base-content/70">
              Блок события сейчас пуст.
            </p>
          </div>
        )
      }
    </aside>
  </div>
</section>
