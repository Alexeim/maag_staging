---
import { Image } from "astro:assets";
import {
  articlesApi,
  interviewsApi,
  flippersApi,
  guidesApi,
  visualStoriesApi,
  type InterviewResponse,
  type FlipperPayload,
} from "@/lib/api/api";

import NetlenkaCard from "./NetlenkaCard.astro";
import ArticleCard from "./ArticleCard.astro";
import LatestInterview from "../HomePage/LatestInterview.astro";

import picture1 from "../../assets/images/culture.jpg";

interface LandingBodyProps {
  isLanding?: boolean;
}

interface FlipperResponse extends FlipperPayload {
  id: string;
  createdAt: string | Date;
}

const { isLanding = true } = Astro.props as LandingBodyProps;

const CATEGORY_LABELS: Record<string, string> = {
  culture: "Культура",
  paris: "Париж",
  hotContent: "Самое Читаемое",
  ballet: "Балет",
  interview: "Интервью",
  performance: "Спектакль",
  performances: "Спектакль",
  concert: "Концерт",
  concerts: "Концерт",
  exhibition: "Выставка",
  exhibitions: "Выставка",
  theatre: "Театр",
  theater: "Театр",
  books: "Книги",
  artMarket: "Арт-рынок",
  artmarket: "Арт-рынок",
  kids: "Дети",
  opera: "Опера",
  dance: "Танец",
  music: "Музыка",
  route: "Маршрут",
  address: "Адрес",
  notebook: "Записная книжка",
  place: "Место",
  ...Object.fromEntries(
    Array.from({ length: 20 }, (_, i) => [
      `district-${i + 1}`,
      `${i + 1}-й округ`,
    ]),
  ),
};

const CULTURE_CATEGORY_KEY = "culture";
const CULTURE_CATEGORY_LABEL = CATEGORY_LABELS[CULTURE_CATEGORY_KEY];
const PARIS_CATEGORY_KEY = "paris";
const HOT_CONTENT_CATEGORY_KEY = "hotContent";
const LANDING_HOT_CONTENT_CATEGORY_KEYS = new Set([
  CULTURE_CATEGORY_KEY,
  PARIS_CATEGORY_KEY,
]);

const normalizeCategory = (value?: string) => {
  if (!value) return null;
  const lowerCaseValue = value.toLowerCase();
  const entry = Object.entries(CATEGORY_LABELS).find(
    ([key, label]) =>
      key === lowerCaseValue || label.toLowerCase() === lowerCaseValue,
  );
  return entry ? entry[0] : lowerCaseValue;
};

const getCategoryLabel = (value?: string) => {
  if (!value) return CATEGORY_LABELS[CULTURE_CATEGORY_KEY];
  const normalized = normalizeCategory(value);
  return normalized ? CATEGORY_LABELS[normalized] || value : value;
};

const getPrimaryTag = (item: any) => {
  if (item?.type === "interview" || item?.contentType === "interview") {
    return CATEGORY_LABELS.interview;
  }
  if (item?.isNews) return "Новости";
  const rawTags = Array.isArray(item?.tags)
    ? item.tags
    : typeof item?.tags === "string"
      ? [item.tags]
      : [];
  const firstTag = rawTags.find(
    (tag: string) => typeof tag === "string" && tag.trim().length > 0,
  );
  if (firstTag) return getCategoryLabel(firstTag.trim());
  if (item?.isHotContent) return CATEGORY_LABELS[HOT_CONTENT_CATEGORY_KEY];
  return getCategoryLabel(item?.category);
};

const getCardLead = (item: any) => {
  const cardLead =
    typeof item?.cardLead === "string" ? item.cardLead.trim() : "";
  return cardLead;
};
const isHotContent = (item: any) =>
  Boolean(item?.isHotContent) ||
  normalizeCategory(item?.category) === HOT_CONTENT_CATEGORY_KEY;

const isLandingHotContentItem = (item: any) =>
  isHotContent(item) &&
  LANDING_HOT_CONTENT_CATEGORY_KEYS.has(
    normalizeCategory(item?.category) || "",
  );

const isMainInCategoryItem = (item: any) =>
  item?.isMainInCategory === true ||
  item?.isMainInCategory === "true" ||
  item?.isMainInCategory === 1 ||
  item?.isMainInCategory === "1";

let cultureItems: any[] = [];
let parisItems: any[] = [];
let hotContentItems: any[] = [];
let latestInterview: any = null;

const getDate = (timestamp: any): Date => {
  if (timestamp && typeof timestamp === "object" && timestamp._seconds) {
    return new Date(timestamp._seconds * 1000);
  }
  return new Date(timestamp);
};

const formatArticleDate = (timestamp: unknown) => {
  const date = getDate(timestamp);
  if (Number.isNaN(date.getTime())) {
    return "";
  }
  return date
    .toLocaleDateString("ru-RU", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    })
    .replace(" г.", "");
};

const formatArticleMeta = (item: any, fallbackCategory = "") => {
  const parts = [
    formatArticleDate(item?.createdAt),
    getPrimaryTag(item) || fallbackCategory,
  ].filter(Boolean);
  return parts.join(" • ");
};

const getTransitionName = (item: any) => {
  if (!item?.id) {
    return undefined;
  }

  const href = typeof item?.href === "string" ? item.href : "";
  if (href.startsWith("/events/")) {
    return `event-image-${item.id}`;
  }
  if (
    href.startsWith("/article/") ||
    href.startsWith("/news/") ||
    href.startsWith("/interviews/") ||
    href.startsWith("/guide/") ||
    href.startsWith("/visual-story/")
  ) {
    // Use a dedicated namespace to avoid duplicate transition names
    // with MainLandingBlock on the same page.
    return `landing-body-main-article-image-${item.id}`;
  }

  return undefined;
};

const toContentHref = (item: any) => {
  if (item?.type === "interview" || item?.contentType === "interview") {
    return `/interviews/${item.id}`;
  }
  if (item?.type === "flipper" || item?.contentType === "flipper") {
    return `/flippers/${item.id}`;
  }
  if (item?.type === "guide" || item?.contentType === "guide") {
    return `/guide/${item.id}`;
  }
  if (item?.type === "visual-story" || item?.contentType === "visual-story") {
    return `/visual-story/${item.id}`;
  }
  return `/${item?.isNews ? "news" : "article"}/${item.id}`;
};

try {
  const [articles, flippers, interviews, guides, visualStories] = await Promise.all([
    articlesApi.list(),
    flippersApi.list() as Promise<FlipperResponse[]>,
    interviewsApi.list() as Promise<InterviewResponse[]>,
    guidesApi.list(),
    visualStoriesApi.list(),
  ]);

  console.log(`--- STEP 1: RAW DATA ---`);
  console.log(
    `Loaded ${articles.length} articles, ${flippers.length} flippers, ${interviews.length} interviews.`,
  );

  const allItems = [
    ...articles.map((article) => ({
      ...article,
      type: "article",
      href: `/article/${article.id}`,
    })),
    ...flippers.map((flipper) => ({
      ...flipper,
      type: "flipper",
      href: `/flippers/${flipper.id}`,
      imageUrl: flipper.carouselContent?.[0]?.imageUrl,
    })),
    ...guides.map((guide) => ({
      ...guide,
      type: "guide",
      href: `/guide/${guide.id}`,
    })),
    ...visualStories.map((story) => ({
      ...story,
      type: "visual-story",
      href: `/visual-story/${story.id}`,
      imageUrl: story?.imageUrl || story?.slides?.[0]?.imageUrl || null,
    })),
  ].sort(
    (a, b) => getDate(b.createdAt).getTime() - getDate(a.createdAt).getTime(),
  );

  console.log(`--- STEP 2: COMBINED ---`);
  console.log(`Total items in allItems: ${allItems.length}`);

  cultureItems = allItems.filter(
    (item) =>
      normalizeCategory(item.category) === CULTURE_CATEGORY_KEY &&
      !isHotContent(item) &&
      !item.isNews &&
      !item.isOnLanding,
  );

  parisItems = allItems.filter(
    (item) =>
      normalizeCategory(item.category) === PARIS_CATEGORY_KEY &&
      !isHotContent(item) &&
      !item.isNews &&
      !item.isOnLanding,
  );

  console.log(`--- STEP 3: FILTERED ---`);
  console.log(`Items in cultureItems after filtering: ${cultureItems.length}`);
  console.log(`Items in parisItems after filtering: ${parisItems.length}`);

  hotContentItems = [
    ...articles.map((article) => ({
      ...article,
      type: "article",
      href: toContentHref(article),
    })),
    ...interviews.map((interview) => ({
      ...interview,
      type: "interview",
      category: CULTURE_CATEGORY_KEY,
      href: toContentHref({ ...interview, type: "interview" }),
    })),
    ...flippers.map((flipper) => ({
      ...flipper,
      type: "flipper",
      href: toContentHref({ ...flipper, type: "flipper" }),
      imageUrl: flipper.carouselContent?.[0]?.imageUrl,
    })),
    ...guides.map((guide) => ({
      ...guide,
      type: "guide",
      href: toContentHref({ ...guide, type: "guide" }),
    })),
    ...visualStories.map((story) => ({
      ...story,
      type: "visual-story",
      href: toContentHref({ ...story, type: "visual-story" }),
      imageUrl: story?.imageUrl || story?.slides?.[0]?.imageUrl || undefined,
    })),
  ]
    .sort(
      (a, b) => getDate(b.createdAt).getTime() - getDate(a.createdAt).getTime(),
    )
    .filter((item) => isLandingHotContentItem(item))
    .slice(0, 4);
  latestInterview = interviews[0] ?? null;
} catch (error) {
  console.error("Failed to fetch data for LandingBody:", error);
}

const cultureHero =
  cultureItems.find((item) => isMainInCategoryItem(item)) ??
  cultureItems[0] ??
  null;

const cultureCardItems = cultureItems
  .filter((item) => (cultureHero ? item.id !== cultureHero.id : true))
  .slice(0, 3);

const parisHero =
  parisItems.find((item) => isMainInCategoryItem(item)) ??
  parisItems[0] ??
  null;

const parisCardItems = parisItems
  .filter((item) => (parisHero ? item.id !== parisHero.id : true))
  .slice(0, 6);

const parisCardRows = [
  parisCardItems.slice(0, 3),
  parisCardItems.slice(3, 6),
].filter((row) => row.length > 0);

const extractQuoteOrAnswer = (interview: any) => {
  if (!interview || !Array.isArray(interview.content)) {
    return null;
  }
  const quoteBlock = interview.content.find(
    (block) => block.type === "quote" && block.text,
  );
  if (quoteBlock) {
    return quoteBlock.text;
  }
  const qaBlock = interview.content.find(
    (block) => block.type === "qa" && block.answer,
  );
  if (qaBlock) {
    return qaBlock.answer;
  }
  return null;
};

const truncateText = (text: string | null, maxLength: number = 100) => {
  if (!text) return null;
  if (text.length <= maxLength) {
    return text;
  }
  return text.substring(0, maxLength) + "...";
};

const interviewQuote = latestInterview?.mainQuote
  ? truncateText(latestInterview.mainQuote)
  : truncateText(extractQuoteOrAnswer(latestInterview));
---

<section
  class="w-full max-w-[1440px] mx-auto px-4 lg:px-8 bg-base-200 mt-0 pb-12 overflow-hidden"
>
  <div
    class="grid grid-cols-1 lg:grid-cols-12 min-h-[200px] gap-6 lg:gap-4 mb-0 lg:mb-6"
  >
    <div class="order-2 lg:order-none lg:col-span-9 flex flex-col">
      <div class="pl-0 pr-0">
        <h2
          class="text-lg font-normal mb-5 uppercase tracking-[0.3em] font-oswald"
        >
          {CATEGORY_LABELS[CULTURE_CATEGORY_KEY]}
        </h2>
        <div class="w-full flex flex-col gap-8">
          <div
            class="w-full bg-white flex flex-col gap-5 lg:flex-row lg:gap-8 items-start justify-start min-h-[100px]"
          >
            {
              cultureHero ? (
                <>
                  <div class="w-full lg:w-3/5 aspect-[3/2] overflow-hidden">
                    {cultureHero.imageUrl ? (
                      <a
                        href={cultureHero.href}
                        class="block w-full h-full transition-opacity duration-200 hover:opacity-90"
                      >
                        <img
                          src={cultureHero.imageUrl}
                          alt={cultureHero.title}
                          class="w-full h-full object-cover object-center"
                          loading="lazy"
                          transition:name={getTransitionName(cultureHero)}
                        />
                      </a>
                    ) : (
                      <Image
                        src={picture1}
                        alt="Culture image"
                        class="w-full h-auto lg:h-[400px] object-cover object-center"
                        loading="eager"
                        transition:name={getTransitionName(cultureHero)}
                      />
                    )}
                  </div>
                  <div class="w-full lg:w-2/5 pt-3 px-4 lg:px-2">
                    {/* <p class="text-xs text-base-content/55 font-inter uppercase tracking-[0.22em] mb-3">
                      {formatArticleMeta(
                        cultureHero,
                        CATEGORY_LABELS[CULTURE_CATEGORY_KEY],
                      )}
                    </p> */}
                    <div class="flex flex-row items-center gap-2 text-xs text-base-content/55 font-inter uppercase tracking-[0.22em] mb-3">
                      <span class="text-xs font-medium uppercase tracking-[0.25em] text-accent font-['Inter']">
                        {getPrimaryTag(cultureHero) || "Новости"}
                      </span>
                      <span class="hidden text-black text-lg font-bold font-['Inter']">
                        ·
                      </span>
                      <span class="hidden text-xs">
                        {formatArticleDate(cultureHero?.createdAt)}
                      </span>
                    </div>
                    <a
                      href={cultureHero.href}
                      class="block transition-opacity duration-200 hover:opacity-90"
                    >
                      <h4 class="text-2xl lg:text-3xl leading-tight font-thin font-oswald text-wrap break-words hover:underline transition-opacity duration-200 hover:opacity-90">
                        {cultureHero.title}
                      </h4>
                    </a>
                    {getCardLead(cultureHero) && (
                      <p class="mt-3 text-base lg:text-lg leading-relaxed text-base-content/80 font-oswald break-words font-thin tracking-wide">
                        {getCardLead(cultureHero)}
                      </p>
                    )}
                  </div>
                </>
              ) : (
                <>
                  <div class="w-full lg:w-3/5 aspect-[3/2] overflow-hidden">
                    <Image
                      src={picture1}
                      alt="Culture image"
                      class="w-full h-full object-cover object-center"
                      loading="eager"
                    />
                  </div>
                  <div class="w-full lg:w-2/5 pt-4 px-4 lg:px-0">
                    <p class="text-error uppercase mb-3 font-inter text-sm tracking-[.46em]">
                      Балет
                    </p>
                    <h4 class="text-2xl lg:text-3xl leading-tight font-thin font-oswald text-wrap break-words">
                      Нет статей в категории
                    </h4>
                  </div>
                </>
              )
            }
          </div>

          <div
            id="culture-articles-box"
            class="w-full flex flex-col gap-6 lg:flex-row lg:gap-8 items-stretch justify-start py-8 px-0 min-h-[100px] border-b border-base-content/15"
          >
            {
              cultureCardItems.length > 0 ? (
                cultureCardItems.map((item) => (
                  <ArticleCard
                    key={item.id}
                    isNetlenka={false}
                    title={item.title}
                    category={getCategoryLabel(item.category)}
                    date={formatArticleDate(item.createdAt)}
                    hideDate={true}
                    lead={truncateText(getCardLead(item), 120) || undefined}
                    transitionName={getTransitionName(item)}
                    imageUrl={item.imageUrl}
                    href={item.href}
                  />
                ))
              ) : (
                <>
                  <ArticleCard isNetlenka={false} />
                  <ArticleCard isNetlenka={false} />
                  <ArticleCard isNetlenka={false} />
                </>
              )
            }
          </div>

          {
            latestInterview && (
              <LatestInterview
                interviewee={latestInterview.interviewee}
                quote={interviewQuote}
                imageUrl={latestInterview.imageUrl}
                href={`/interviews/${latestInterview.id}`}
                transitionName={getTransitionName({
                  id: latestInterview.id,
                  href: `/interviews/${latestInterview.id}`,
                })}
              />
            )
          }
        </div>
      </div>
      <div class="flex flex-row"></div>
    </div>
    <div
      class="order-1 lg:order-none lg:col-span-3 px-0 lg:pl-4 lg:border-l lg:border-gray-300 mt-6 lg:mt-0"
    >
      <div id="netlenka-container">
        <h3
          class="text-lg font-normal mb-5 uppercase tracking-[0.3em] font-oswald"
        >
          {CATEGORY_LABELS[HOT_CONTENT_CATEGORY_KEY]}
        </h3>
        <div
          class="flex gap-6 overflow-x-auto lg:flex-col items-center lg:gap-6 lg:overflow-visible pb-2"
        >
          {
            hotContentItems.length > 0 ? (
              hotContentItems.map((item) => (
                <NetlenkaCard
                  key={item.id}
                  title={item.title}
                  category={getPrimaryTag(item)}
                  date={formatArticleDate(item.createdAt)}
                  hideDate={true}
                  lead={truncateText(getCardLead(item), 90) || undefined}
                  transitionName={getTransitionName(item)}
                  imageUrl={item.imageUrl}
                  href={item.href}
                />
              ))
            ) : (
              <NetlenkaCard
                title="Скоро появится материал"
                category={CATEGORY_LABELS[HOT_CONTENT_CATEGORY_KEY]}
              />
            )
          }
        </div>
      </div>
    </div>
  </div>
  <div class="w-full">
    <hr class="h-px my-4 border-1" />
  </div>
  {
    isLanding && (
      <div class="w-full flex flex-col px-4 lg:px-0 min-h-[200px]">
        <h2 class="text-lg font-normal mb-6 uppercase tracking-[0.3em] font-oswald">
          {CATEGORY_LABELS[PARIS_CATEGORY_KEY]}
        </h2>
        <div class="w-full flex flex-col gap-8">
          <div class="w-full bg-white flex flex-col gap-6 lg:flex-row-reverse lg:gap-8 items-start justify-start min-h-[100px]">
            {parisHero ? (
              <>
                <div class="w-full lg:w-3/5 aspect-[3/2] overflow-hidden">
                  {parisHero.imageUrl ? (
                    <a
                      href={parisHero.href}
                      class="block w-full h-full transition-opacity duration-200 hover:opacity-90"
                    >
                      <img
                        src={parisHero.imageUrl}
                        alt={parisHero.title}
                        class="w-full h-full object-cover object-center"
                        loading="lazy"
                        transition:name={getTransitionName(parisHero)}
                      />
                    </a>
                  ) : (
                    <Image
                      src={picture1}
                      alt="Paris image"
                      class="w-full h-auto lg:h-[470px] object-cover object-center"
                      loading="eager"
                      transition:name={getTransitionName(parisHero)}
                    />
                  )}
                </div>
                <div class="w-full lg:w-2/5 pt-4 px-4 lg:pl-4">
                  <div class="flex flex-row items-center gap-2 text-xs text-base-content/55 font-inter uppercase tracking-[0.22em] mb-3">
                    <span class="text-xs font-medium uppercase tracking-[0.25em] text-accent font-['Inter']">
                      {getPrimaryTag(parisHero) ||
                        CATEGORY_LABELS[PARIS_CATEGORY_KEY]}
                    </span>
                    <span class="hidden text-black text-lg font-bold font-['Inter']">
                      ·
                    </span>
                    <span class="hidden text-xs">
                      {formatArticleDate(parisHero?.createdAt)}
                    </span>
                  </div>
                  <a
                    href={parisHero.href}
                    class="block transition-opacity duration-200 hover:opacity-90"
                  >
                    <h4 class="text-2xl lg:text-3xl leading-tight font-thin font-oswald text-wrap break-words hover:underline transition-opacity duration-200 hover:opacity-90">
                      {parisHero.title}
                    </h4>
                  </a>
                  {getCardLead(parisHero) && (
                    <p class="mt-3 text-base lg:text-lg leading-relaxed text-base-content/80 font-oswald break-words px-2 font-thin tracking-wide">
                      {getCardLead(parisHero)}
                    </p>
                  )}
                </div>
              </>
            ) : (
              <>
                <div class="w-full lg:w-3/5 aspect-[3/2] overflow-hidden">
                  <Image
                    src={picture1}
                    alt="Paris image"
                    class="w-full h-full object-cover object-center"
                    loading="eager"
                  />
                </div>
                <div class="w-full lg:w-2/5 pt-4 px-4 lg:pl-4">
                  <p class="text-error uppercase mb-3 font-inter text-sm tracking-[.46em]">
                    {CATEGORY_LABELS[PARIS_CATEGORY_KEY]}
                  </p>
                  <h4 class="text-2xl lg:text-3xl leading-tight font-thin font-oswald text-wrap break-words">
                    Нет статей в категории
                  </h4>
                </div>
              </>
            )}
          </div>

          {parisCardRows.length > 0 ? (
            parisCardRows.map((row, rowIndex) => (
              <div
                id={`paris-articles-box-${rowIndex + 1}`}
                class="w-full flex flex-col gap-6 lg:flex-row lg:gap-8 items-stretch justify-start py-8 px-0 min-h-[100px]"
              >
                {row.map((item) => (
                  <ArticleCard
                    key={item.id}
                    isNetlenka={false}
                    title={item.title}
                    category={getCategoryLabel(item.category)}
                    date={formatArticleDate(item.createdAt)}
                    hideDate={true}
                    lead={truncateText(getCardLead(item), 120) || undefined}
                    transitionName={getTransitionName(item)}
                    imageUrl={item.imageUrl}
                    href={item.href}
                  />
                ))}
              </div>
            ))
          ) : (
            <div
              id="paris-articles-box-empty"
              class="w-full py-4 px-0 lg:px-4 min-h-[100px]"
            >
              <p class="text-sm text-base-content/70">
                Пока нет дополнительных материалов в разделе «Париж».
              </p>
            </div>
          )}
        </div>
      </div>
    )
  }
</section>
