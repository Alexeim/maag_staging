---
import { Image } from "astro:assets";
import {
  articlesApi,
  editorialPlacementsApi,
  interviewsApi,
  flippersApi,
  guidesApi,
  visualStoriesApi,
  newsApi,
  photosOfTheDayApi,
  type LandingCategoryCardsSelection,
  type LandingCategoryCardsItemTarget,
  type LandingNetlenkaRailSelection,
  type InterviewResponse,
  type FlipperPayload,
  type LandingPlacementsResponse,
} from "@/lib/api/api";
import { getKnownTagLabel, isLegacyParisTag } from "@/content/tags/parisTags";

import NetlenkaCard from "./NetlenkaCard.astro";
import ArticleCard from "./ArticleCard.astro";
import LazyImage from "./LazyImage.astro";
import MaagLogoPaid from "../../assets/logo/maaglogo.svg";
import MaagLogoMobile from "../../assets/logo/logo-mobile.svg";
import LatestInterview from "../HomePage/LatestInterview.astro";

import picture1 from "../../assets/images/culture.jpg";

interface LandingBodyProps {
  isLanding?: boolean;
}

interface FlipperResponse extends FlipperPayload {
  id: string;
  createdAt: string | Date;
}

const { isLanding = true } = Astro.props as LandingBodyProps;

const CATEGORY_LABELS: Record<string, string> = {
  culture: "Культура",
  paris: "Париж",
  hotContent: "Самое Читаемое",
  ballet: "Балет",
  interview: "Интервью",
  performance: "Спектакль",
  performances: "Спектакль",
  concert: "Концерт",
  concerts: "Концерт",
  exhibition: "Выставка",
  exhibitions: "Выставка",
  theatre: "Театр",
  theater: "Театр",
  books: "Книги",
  artMarket: "Арт-рынок",
  artmarket: "Арт-рынок",
  architecture: "Архитектура",
  museums: "Музеи",
  tourism: "Туризм",
  strike: "Забастовка",
  kids: "Дети",
  opera: "Опера",
  dance: "Танец",
  music: "Музыка",
  route: "Маршрут",
  address: "Адрес",
  notebook: "Записная книжка",
  place: "Место",
  ...Object.fromEntries(
    Array.from({ length: 20 }, (_, i) => [
      `district-${i + 1}`,
      `${i + 1}-й округ`,
    ]),
  ),
};

const CULTURE_CATEGORY_KEY = "culture";
const CULTURE_CATEGORY_LABEL = CATEGORY_LABELS[CULTURE_CATEGORY_KEY];
const PARIS_CATEGORY_KEY = "paris";
const HOT_CONTENT_CATEGORY_KEY = "hotContent";

const normalizeCategory = (value?: string) => {
  if (!value) return null;
  const lowerCaseValue = value.toLowerCase();
  const entry = Object.entries(CATEGORY_LABELS).find(
    ([key, label]) =>
      key === lowerCaseValue || label.toLowerCase() === lowerCaseValue,
  );
  return entry ? entry[0] : lowerCaseValue;
};

const getCategoryLabel = (value?: string) => {
  if (!value) return CATEGORY_LABELS[CULTURE_CATEGORY_KEY];
  const normalized = normalizeCategory(value);
  return normalized ? CATEGORY_LABELS[normalized] || value : value;
};

const getPrimaryTag = (item: any) => {
  if (item?.type === "interview" || item?.contentType === "interview") {
    return CATEGORY_LABELS.interview;
  }
  const rawTags = Array.isArray(item?.tags)
    ? item.tags
    : typeof item?.tags === "string"
      ? [item.tags]
      : [];
  const firstTag = rawTags.find(
    (tag: string) =>
      typeof tag === "string" &&
      tag.trim().length > 0 &&
      !isLegacyParisTag(tag),
  );
  if (firstTag)
    return (
      getKnownTagLabel(firstTag.trim()) || getCategoryLabel(firstTag.trim())
    );
  if (item?.isNews) return "Новости";
  if (item?.isHotContent) return CATEGORY_LABELS[HOT_CONTENT_CATEGORY_KEY];
  return getCategoryLabel(item?.category);
};

const getCardLead = (item: any) => {
  const cardLead =
    typeof item?.cardLead === "string" ? item.cardLead.trim() : "";
  return cardLead;
};
const isHotContent = (item: any) => Boolean(item?.isHotContent);

const isLandingHotContentItem = (item: any) =>
  isHotContent(item) && !item?.isNews;

const isLeSaviezVousArticle = (item: any) =>
  item?.articleType === "le_saviez_vous";

let cultureItems: any[] = [];
let parisItems: any[] = [];
let hotContentItems: any[] = [];
let latestInterview: any = null;
let allItemsSorted: any[] = [];
let leSaviezVousArticle: any = null;
let photoOfTheDay: any = null;

const DEFAULT_LANDING_PLACEMENTS: LandingPlacementsResponse = {
  schemaVersion: 4,
  mainHero: null,
  newsRail: {
    mode: "auto-latest",
    limit: 4,
  },
  netlenkaRail: {
    mode: "auto-latest",
    limit: 4,
  },
  cultureHero: null,
  cultureCards: {
    mode: "auto-latest",
    limit: 3,
  },
  parisHero: null,
  parisCards: {
    mode: "auto-latest",
    limit: 3,
  },
  eventCard: {
    mode: "auto-nearest",
  },
  cultureInterviewBlock: {
    mode: "auto-latest",
  },
  leSaviezVousFeature: {
    mode: "auto-latest",
  },
  photoOfTheDayFeature: {
    mode: "auto-latest",
  },
  updatedAt: null,
  updatedBy: null,
};

let landingPlacements = DEFAULT_LANDING_PLACEMENTS;

const getDate = (timestamp: any): Date => {
  if (timestamp && typeof timestamp === "object" && timestamp._seconds) {
    return new Date(timestamp._seconds * 1000);
  }
  return new Date(timestamp);
};

const formatArticleDate = (timestamp: unknown) => {
  const date = getDate(timestamp);
  if (Number.isNaN(date.getTime())) {
    return "";
  }
  return date
    .toLocaleDateString("ru-RU", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    })
    .replace(" г.", "");
};

const formatArticleMeta = (item: any, fallbackCategory = "") => {
  const parts = [
    formatArticleDate(item?.createdAt),
    getPrimaryTag(item) || fallbackCategory,
  ].filter(Boolean);
  return parts.join(" • ");
};

const getTransitionName = (item: any) => {
  if (!item?.id) {
    return undefined;
  }

  const href = typeof item?.href === "string" ? item.href : "";
  if (href.startsWith("/events/")) {
    return `event-image-${item.id}`;
  }
  if (
    href.startsWith("/article/") ||
    href.startsWith("/news/") ||
    href.startsWith("/interviews/") ||
    href.startsWith("/guide/") ||
    href.startsWith("/visual-story/")
  ) {
    // Use a dedicated namespace to avoid duplicate transition names
    // with MainLandingBlock on the same page.
    return `landing-body-main-article-image-${item.id}`;
  }

  return undefined;
};

const toContentHref = (item: any) => {
  if (item?.type === "interview" || item?.contentType === "interview") {
    return `/interviews/${item.id}`;
  }
  if (item?.type === "flipper" || item?.contentType === "flipper") {
    return `/flippers/${item.id}`;
  }
  if (item?.type === "guide" || item?.contentType === "guide") {
    return `/guide/${item.id}`;
  }
  if (item?.type === "visual-story" || item?.contentType === "visual-story") {
    return `/visual-story/${item.id}`;
  }
  return `/${item?.isNews ? "news" : "article"}/${item.id}`;
};

const getPlacementType = (item: any): string | null =>
  item?.contentType || item?.type || null;

const isPlacedMainHero = (
  item: any,
  landingPlacements: LandingPlacementsResponse,
) =>
  Boolean(
    landingPlacements.mainHero &&
    landingPlacements.mainHero.id === item?.id &&
    landingPlacements.mainHero.type === getPlacementType(item),
  );

const getNetlenkaItemKey = (item: any) => {
  const type = getPlacementType(item);
  if (!type || !item?.id) {
    return null;
  }

  return `${type}:${item.id}`;
};

const getCategoryCardItemKey = (item: any) => {
  const type = getPlacementType(item);
  if (!type || type === "interview" || !item?.id) {
    return null;
  }

  return `${type}:${item.id}`;
};

const selectNetlenkaItems = (
  items: any[],
  netlenkaRail: LandingNetlenkaRailSelection | null,
  landingPlacements: LandingPlacementsResponse,
) => {
  if (!netlenkaRail) {
    return [];
  }

  if (netlenkaRail.mode === "auto-latest") {
    return items
      .filter(
        (item) =>
          isLandingHotContentItem(item) &&
          !isPlacedMainHero(item, landingPlacements) &&
          item.id !==
            (landingPlacements.cultureInterviewBlock?.mode === "manual"
              ? landingPlacements.cultureInterviewBlock.id
              : null),
      )
      .slice(0, netlenkaRail.limit);
  }

  const itemsByKey = new Map(
    items
      .map((item) => [getNetlenkaItemKey(item), item] as const)
      .filter(([key]) => Boolean(key)),
  );

  return netlenkaRail.items
    .map((item) => itemsByKey.get(`${item.type}:${item.id}`))
    .filter((item) => Boolean(item) && isLandingHotContentItem(item))
    .filter(Boolean);
};

const selectCategoryCardItems = (
  items: any[],
  selection: LandingCategoryCardsSelection | null,
  excludedIds: Set<string>,
) => {
  const availableItems = items.filter(
    (item) => item?.id && !excludedIds.has(item.id),
  );

  if (!selection) {
    return [];
  }

  if (selection.mode === "auto-latest") {
    return availableItems.slice(0, selection.limit);
  }

  const itemsByKey = new Map(
    availableItems
      .map((item) => [getCategoryCardItemKey(item), item] as const)
      .filter(([key]) => Boolean(key)),
  );

  return selection.items
    .map((item: LandingCategoryCardsItemTarget) =>
      itemsByKey.get(`${item.type}:${item.id}`),
    )
    .filter(Boolean);
};

const selectCategoryHero = (
  items: any[],
  heroSelection:
    | LandingPlacementsResponse["cultureHero"]
    | LandingPlacementsResponse["parisHero"],
) => {
  if (heroSelection?.mode === "manual") {
    return (
      items.find(
        (item) =>
          item?.id === heroSelection.id &&
          getPlacementType(item) === heroSelection.type,
      ) ?? null
    );
  }

  return null;
};

try {
  const [
    articles,
    flippers,
    interviews,
    guides,
    visualStories,
    newsItemsRaw,
    landingPlacementsResponse,
  ] = await Promise.all([
    articlesApi.list(),
    flippersApi.list() as Promise<FlipperResponse[]>,
    interviewsApi.list() as Promise<InterviewResponse[]>,
    guidesApi.list(),
    visualStoriesApi.list(),
    newsApi.list(),
    editorialPlacementsApi.getLanding().catch(() => DEFAULT_LANDING_PLACEMENTS),
  ]);

  landingPlacements = landingPlacementsResponse;

  const standardArticles = articles.filter(
    (article) => !isLeSaviezVousArticle(article),
  );
  const newsItems = newsItemsRaw.map((item) => ({
    ...item,
    type: "news",
    contentType: "news",
    isNews: true,
  }));
  const leSaviezVousArticles = articles
    .filter((article) => isLeSaviezVousArticle(article))
    .sort(
      (a, b) => getDate(b.createdAt).getTime() - getDate(a.createdAt).getTime(),
    );

  const leSaviezVousPlacement = landingPlacements.leSaviezVousFeature ?? null;
  if (!leSaviezVousPlacement || leSaviezVousPlacement.mode === "auto-latest") {
    leSaviezVousArticle = leSaviezVousArticles[0] ?? null;
  } else if (leSaviezVousPlacement.mode === "manual") {
    leSaviezVousArticle =
      leSaviezVousArticles.find((a) => a.id === leSaviezVousPlacement.id) ??
      null;
  } else {
    leSaviezVousArticle = null;
  }

  if (leSaviezVousArticle) {
    leSaviezVousArticle = {
      ...leSaviezVousArticle,
      href: toContentHref(leSaviezVousArticle),
    };
  }

  const allItems = [
    ...standardArticles.map((article) => ({
      ...article,
      type: "article",
      href: `/article/${article.id}`,
    })),
    ...newsItems.map((item) => ({
      ...item,
      href: `/news/${item.id}`,
    })),
    ...flippers.map((flipper) => ({
      ...flipper,
      type: "flipper",
      href: `/flippers/${flipper.id}`,
      imageUrl: flipper.carouselContent?.[0]?.imageUrl,
    })),
    ...guides.map((guide) => ({
      ...guide,
      type: "guide",
      href: `/guide/${guide.id}`,
    })),
    ...visualStories.map((story) => ({
      ...story,
      type: "visual-story",
      href: `/visual-story/${story.id}`,
      imageUrl: story?.imageUrl || story?.slides?.[0]?.imageUrl || null,
    })),
  ].sort(
    (a, b) => getDate(b.createdAt).getTime() - getDate(a.createdAt).getTime(),
  );

  allItemsSorted = allItems;

  cultureItems = allItems.filter(
    (item) =>
      normalizeCategory(item.category) === CULTURE_CATEGORY_KEY &&
      !isHotContent(item) &&
      !item.isNews &&
      !isPlacedMainHero(item, landingPlacements),
  );

  parisItems = allItems.filter(
    (item) =>
      normalizeCategory(item.category) === PARIS_CATEGORY_KEY &&
      !isHotContent(item) &&
      !item.isNews &&
      !isPlacedMainHero(item, landingPlacements),
  );

  const netlenkaCandidates = [
    ...articles.map((article) => ({
      ...article,
      type: "article",
      href: toContentHref(article),
    })),
    ...interviews.map((interview) => ({
      ...interview,
      type: "interview",
      category: CULTURE_CATEGORY_KEY,
      href: toContentHref({ ...interview, type: "interview" }),
    })),
    ...flippers.map((flipper) => ({
      ...flipper,
      type: "flipper",
      href: toContentHref({ ...flipper, type: "flipper" }),
      imageUrl: flipper.carouselContent?.[0]?.imageUrl,
    })),
    ...guides.map((guide) => ({
      ...guide,
      type: "guide",
      href: toContentHref({ ...guide, type: "guide" }),
    })),
    ...visualStories.map((story) => ({
      ...story,
      type: "visual-story",
      href: toContentHref({ ...story, type: "visual-story" }),
      imageUrl: story?.imageUrl || story?.slides?.[0]?.imageUrl || undefined,
    })),
  ].sort(
    (a, b) => getDate(b.createdAt).getTime() - getDate(a.createdAt).getTime(),
  );
  hotContentItems = selectNetlenkaItems(
    netlenkaCandidates,
    landingPlacements.netlenkaRail,
    landingPlacements,
  );
  const cultureInterviewBlock = landingPlacements.cultureInterviewBlock;
  latestInterview =
    cultureInterviewBlock?.mode === "manual"
      ? (interviews.find(
          (interview) => interview.id === cultureInterviewBlock.id,
        ) ?? null)
      : cultureInterviewBlock?.mode === "auto-latest"
        ? (interviews[0] ?? null)
        : null;
} catch (error) {
  console.error("Failed to fetch data for LandingBody:", error);
}

try {
  const placement = landingPlacements.photoOfTheDayFeature;
  if (placement && placement.mode !== "empty") {
    const photos = await photosOfTheDayApi.list();
    if (placement.mode === "manual" && "id" in placement) {
      photoOfTheDay = photos.find((p) => p.id === placement.id) ?? null;
    } else {
      photoOfTheDay = photos[0] ?? null;
    }
  }
} catch (e) {
  console.error("Failed to fetch photo of the day:", e);
}

const cultureHero = selectCategoryHero(
  cultureItems,
  landingPlacements.cultureHero,
);

const cultureCardItems = selectCategoryCardItems(
  cultureItems,
  landingPlacements.cultureCards,
  new Set([cultureHero?.id].filter(Boolean)),
);

const parisHero = selectCategoryHero(parisItems, landingPlacements.parisHero);

const parisCardItems = selectCategoryCardItems(
  parisItems,
  landingPlacements.parisCards,
  new Set([parisHero?.id].filter(Boolean)),
);

const excludedIds = new Set([cultureHero?.id, parisHero?.id].filter(Boolean));
const carouselItems = allItemsSorted
  .filter(
    (item) => !isHotContent(item) && !item.isNews && !excludedIds.has(item.id),
  )
  .slice(0, 20);

const extractQuoteOrAnswer = (interview: any) => {
  if (!interview || !Array.isArray(interview.content)) {
    return null;
  }
  const quoteBlock = interview.content.find(
    (block) => block.type === "quote" && block.text,
  );
  if (quoteBlock) {
    return quoteBlock.text;
  }
  const qaBlock = interview.content.find(
    (block) => block.type === "qa" && block.answer,
  );
  if (qaBlock) {
    return qaBlock.answer;
  }
  return null;
};

const truncateText = (text: string | null, maxLength: number = 100) => {
  if (!text) return null;
  if (text.length <= maxLength) {
    return text;
  }
  return text.substring(0, maxLength) + "...";
};

const interviewQuote = latestInterview?.mainQuote
  ? truncateText(latestInterview.mainQuote)
  : truncateText(extractQuoteOrAnswer(latestInterview));

const splitTitle = (t: string) => {
  const s = t.trimEnd();
  const i = s.lastIndexOf(" ");
  return {
    start: i >= 0 ? s.slice(0, i) : "",
    last: i >= 0 ? s.slice(i + 1) : s,
  };
};
---

<section
  class="relative w-full max-w-[1440px] mx-auto px-4 pt-8 lg:px-8 bg-base-200 mt-0 pb-12 overflow-x-hidden overflow-y-visible"
>
  <div class="w-full mb-8">
    <hr class="h-px border-1" />
  </div>
  <div
    class="grid grid-cols-1 lg:grid-cols-12 min-h-[200px] gap-6 lg:gap-4 mb-0 lg:mb-6"
  >
    <div class="order-2 lg:order-none lg:col-span-9 flex flex-col">
      <div class="pl-0 pr-0">
        <h2
          class="text-lg font-semibold mb-6 uppercase tracking-[0.3em] font-old_standard"
        >
          {CATEGORY_LABELS[CULTURE_CATEGORY_KEY]}
        </h2>
        <div class="w-full flex flex-col gap-8">
          <article class="grid overflow-hidden bg-white/70 lg:min-h-[21rem] lg:grid-cols-[minmax(0,1.45fr)_minmax(16rem,0.95fr)]">
            {
              cultureHero ? (
                <>
                  {cultureHero.imageUrl ? (
                    <a
                      href={cultureHero.href}
                      class="linked-image-hover aspect-[3/2]"
                      aria-label={cultureHero.title}
                    >
                      <LazyImage
                        src={cultureHero.imageUrl}
                        alt={cultureHero.title}
                        class="linked-image-hover__media block h-full w-full object-cover"
                        transitionName={getTransitionName(cultureHero)}
                      />
                    </a>
                  ) : (
                    <div class="aspect-[3/2] overflow-hidden">
                      <Image
                        src={picture1}
                        alt="Culture image"
                        class="block h-full w-full object-cover"
                        loading="eager"
                      />
                    </div>
                  )}
                  <div class="grid content-start gap-[0.55rem] bg-white/90 p-[1.2rem] lg:px-[1.3rem] lg:pt-[1.35rem] lg:pb-[1.1rem]">
                    <p class="m-0">
                      <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                        {getPrimaryTag(cultureHero) || "Новости"}
                      </span>
                    </p>
                    <a
                      href={cultureHero.href}
                      class="text-current no-underline hover:underline"
                    >
                      <h4 class="text-3xl font-normal font-old_standard tracking-[-0.02em] transition-opacity duration-200 hover:opacity-90 mb-2">
                        {cultureHero.paid ? (
                          <>
                            {splitTitle(cultureHero.title).start && (
                              <>{splitTitle(cultureHero.title).start} </>
                            )}
                            <span class="whitespace-nowrap">
                              {splitTitle(cultureHero.title).last}{" "}
                              <MaagLogoPaid class="w-5 h-5 inline-block align-baseline" />
                            </span>
                          </>
                        ) : (
                          cultureHero.title
                        )}
                      </h4>
                    </a>
                    {getCardLead(cultureHero) && (
                      <p class="text-base lg:text-sm text-black/60 font-inter font-normal">
                        {getCardLead(cultureHero)}
                      </p>
                    )}
                  </div>
                </>
              ) : (
                <>
                  <div class="aspect-[3/2] overflow-hidden">
                    <Image
                      src={picture1}
                      alt="Culture image"
                      class="block h-full w-full object-cover"
                      loading="eager"
                    />
                  </div>
                  <div class="grid content-start gap-[0.55rem] bg-white/90 p-[1.2rem] lg:px-[1.3rem] lg:pt-[1.35rem] lg:pb-[1.1rem]">
                    <p class="text-accent uppercase font-inter text-sm tracking-[.46em]">Балет</p>
                    <h4 class="text-2xl lg:text-3xl leading-tight font-normal font-old_standard">
                      Нет статей в категории
                    </h4>
                  </div>
                </>
              )
            }
          </article>

          <div
            id="culture-articles-box"
            class="grid gap-4 sm:grid-cols-2 sm:items-stretch py-8 border-b border-base-content/15"
          >
            {
              cultureCardItems.length > 0 ? (
                cultureCardItems.slice(0, 2).map((item) => (
                  <ArticleCard
                    key={item.id}
                    isNetlenka={false}
                    title={item.title}
                    category={getPrimaryTag(item)}
                    date={formatArticleDate(item.createdAt)}
                    hideDate={true}
                    lead={truncateText(getCardLead(item), 120) || undefined}
                    transitionName={getTransitionName(item)}
                    imageUrl={item.imageUrl}
                    href={item.href}
                    paid={item.paid}
                  />
                ))
              ) : (
                <>
                  <ArticleCard isNetlenka={false} />
                  <ArticleCard isNetlenka={false} />
                </>
              )
            }
          </div>

          {
            latestInterview && (
              <LatestInterview
                interviewee={latestInterview.interviewee}
                quote={interviewQuote}
                imageUrl={latestInterview.imageUrl}
                href={`/interviews/${latestInterview.id}`}
                transitionName={getTransitionName({
                  id: latestInterview.id,
                  href: `/interviews/${latestInterview.id}`,
                })}
              />
            )
          }
        </div>
      </div>
      <div class="flex flex-row"></div>
    </div>
    <div
      class="relative z-10 order-1 lg:order-none lg:col-span-3 px-0 lg:pl-4 lg:border-l lg:border-gray-300 mt-6 lg:mt-0"
    >
      <div id="netlenka-container" class="relative z-10">
        <h3 class="relative z-10 mb-6 overflow-visible text-black">
          <span
            class="relative z-[1] block font-old_standard text-lg font-semibold uppercase leading-none tracking-[0.3em]"
          >
            ВЫБОР
          </span>
          <MaagLogoMobile
            class="pointer-events-none absolute z-20 left-[105px] top-[-57px] w-[120px] max-w-none lg:left-[110px] lg:top-[-50px] lg:w-[142px]"
          />
        </h3>
        <div
          class="flex gap-6 overflow-x-auto lg:flex-col items-start lg:gap-6 lg:overflow-visible pb-2"
        >
          {
            hotContentItems.length > 0 ? (
              hotContentItems.map((item) => (
                <NetlenkaCard
                  key={item.id}
                  title={item.title}
                  category={getPrimaryTag(item)}
                  date={formatArticleDate(item.createdAt)}
                  hideDate={true}
                  lead={truncateText(getCardLead(item), 90) || undefined}
                  transitionName={getTransitionName(item)}
                  imageUrl={item.imageUrl}
                  href={item.href}
                />
              ))
            ) : (
              <NetlenkaCard
                title="Скоро появится материал"
                category={CATEGORY_LABELS[HOT_CONTENT_CATEGORY_KEY]}
              />
            )
          }
        </div>
      </div>
    </div>
  </div>
  <div class="w-full">
    <hr class="h-px my-8 border-1" />
  </div>
  {
    isLanding && (
      <>
        <div class="grid grid-cols-1 lg:grid-cols-12 min-h-[200px] gap-6 lg:gap-4">
          <div class="order-2 lg:order-none lg:col-span-9 flex flex-col">
            <div class="pl-0 pr-0">
              <h2 class="text-lg font-semibold mb-6 uppercase tracking-[0.3em] font-old_standard">
                {CATEGORY_LABELS[PARIS_CATEGORY_KEY]}
              </h2>

              <div class="w-full flex flex-col gap-8">
                <article class="grid overflow-hidden bg-white/70 lg:min-h-[21rem] lg:grid-cols-[minmax(0,1.45fr)_minmax(16rem,0.95fr)]">
                  {parisHero ? (
                    <>
                      <a
                        href={parisHero.href}
                        class="linked-image-hover aspect-[3/2]"
                        aria-label={parisHero.title}
                      >
                        <LazyImage
                          src={parisHero.imageUrl ?? picture1}
                          alt={parisHero.title}
                          class="linked-image-hover__media block h-full w-full object-cover"
                          transitionName={getTransitionName(parisHero)}
                        />
                      </a>
                      <div class="grid content-start gap-[0.55rem] bg-white/90 p-[1.2rem] lg:px-[1.3rem] lg:pt-[1.35rem] lg:pb-[1.1rem]">
                        <p class="m-0">
                          <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                            {getPrimaryTag(parisHero) || CATEGORY_LABELS[PARIS_CATEGORY_KEY]}
                          </span>
                        </p>
                        <a
                          href={parisHero.href}
                          class="text-current no-underline hover:underline"
                        >
                          <h4 class="text-3xl font-normal font-old_standard tracking-[-0.02em] transition-opacity duration-200 hover:opacity-90 mb-2">
                            {parisHero.paid ? (
                              <>
                                {splitTitle(parisHero.title).start && (
                                  <>{splitTitle(parisHero.title).start} </>
                                )}
                                <span class="whitespace-nowrap">
                                  {splitTitle(parisHero.title).last}{" "}
                                  <MaagLogoPaid class="w-5 h-5 inline-block align-baseline" />
                                </span>
                              </>
                            ) : (
                              parisHero.title
                            )}
                          </h4>
                        </a>
                        {getCardLead(parisHero) && (
                          <p class="text-base lg:text-sm text-black/60 font-inter font-normal">
                            {getCardLead(parisHero)}
                          </p>
                        )}
                      </div>
                    </>
                  ) : (
                    <>
                      <div class="aspect-[3/2] overflow-hidden">
                        <Image
                          src={picture1}
                          alt="Paris image"
                          class="block h-full w-full object-cover"
                          loading="eager"
                        />
                      </div>
                      <div class="grid content-start gap-[0.55rem] bg-white/90 p-[1.2rem] lg:px-[1.3rem] lg:pt-[1.35rem] lg:pb-[1.1rem]">
                        <p class="text-accent uppercase font-inter text-sm tracking-[.46em]">
                          {CATEGORY_LABELS[PARIS_CATEGORY_KEY]}
                        </p>
                        <h4 class="text-2xl lg:text-3xl leading-tight font-normal font-old_standard">
                          Нет статей в категории
                        </h4>
                      </div>
                    </>
                  )}
                </article>

                {parisCardItems.length > 0 ? (
                  <div
                    id="paris-articles-box-1"
                    class="grid gap-4 sm:grid-cols-2 sm:items-stretch py-8 border-b border-base-content/15"
                  >
                    {parisCardItems.slice(0, 2).map((item) => (
                      <ArticleCard
                        key={item.id}
                        isNetlenka={false}
                        title={item.title}
                        category={getPrimaryTag(item)}
                        date={formatArticleDate(item.createdAt)}
                        hideDate={true}
                        lead={truncateText(getCardLead(item), 120) || undefined}
                        transitionName={getTransitionName(item)}
                        imageUrl={item.imageUrl}
                        href={item.href}
                        paid={item.paid}
                      />
                    ))}
                  </div>
                ) : (
                  <div
                    id="paris-articles-box-empty"
                    class="w-full py-4 px-0 min-h-[100px]"
                  >
                    <p class="text-sm text-base-content/70">
                      Пока нет дополнительных материалов в разделе «Париж».
                    </p>
                  </div>
                )}
              </div>
            </div>
          </div>

          <aside class="order-1 lg:order-none lg:col-span-3 px-0 lg:pl-4 lg:border-l lg:border-gray-300 mt-6 lg:mt-0">
            {photoOfTheDay && (
              <section class="grid gap-4 mb-8">
                <h3 class="m-0 text-lg font-semibold uppercase tracking-[0.3em] font-old_standard">
                  Фото дня
                </h3>
                <article class="overflow-hidden bg-white">
                  <a
                    href={`/photo-of-the-day/${photoOfTheDay.id}`}
                    class="block aspect-[2/3] overflow-hidden"
                    aria-label={photoOfTheDay.title}
                  >
                    <LazyImage
                      src={photoOfTheDay.imageUrl}
                      alt={photoOfTheDay.title}
                      class="w-full h-full object-cover object-center"
                    />
                  </a>
                  <div class="grid gap-[0.55rem] p-4 lg:px-4 lg:py-6">
                    <a
                      href={`/photo-of-the-day/${photoOfTheDay.id}`}
                      class="text-current no-underline hover:underline"
                    >
                      <h4 class="m-0 text-xl font-normal font-old_standard tracking-[-0.02em] leading-[1.16]">
                        {photoOfTheDay.title}
                      </h4>
                    </a>
                    {photoOfTheDay.caption && (
                      <p class="m-0 text-sm text-black/60 font-inter font-normal line-clamp-2">
                        {photoOfTheDay.caption}
                      </p>
                    )}
                  </div>
                </article>
              </section>
            )}

            <section class="grid gap-4">
              <h3 class="m-0 text-lg font-semibold uppercase tracking-[0.3em] font-old_standard">
                Le saviez-vous?
              </h3>

              {leSaviezVousArticle ? (
                <article class="overflow-hidden bg-white">
                  <a
                    href={leSaviezVousArticle.href}
                    class="block"
                    aria-label={leSaviezVousArticle.title}
                  >
                    <LazyImage
                      src={leSaviezVousArticle.imageUrl || picture1}
                      alt={leSaviezVousArticle.title}
                      class="block h-auto w-full object-cover lg:h-[240px]"
                    />
                  </a>

                  <div class="grid gap-[0.55rem] p-4 lg:px-4 lg:py-6">
                    <p class="m-0">
                      <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                        {getPrimaryTag(leSaviezVousArticle) ||
                          CATEGORY_LABELS[PARIS_CATEGORY_KEY]}
                      </span>
                    </p>

                    <a
                      href={leSaviezVousArticle.href}
                      class="text-current no-underline hover:underline"
                    >
                      <h4 class="m-0 text-xl font-normal font-old_standard tracking-[-0.02em] leading-[1.16]">
                        {leSaviezVousArticle.paid ? (
                          <>
                            {splitTitle(leSaviezVousArticle.title).start && (
                              <>
                                {
                                  splitTitle(leSaviezVousArticle.title).start
                                }{" "}
                              </>
                            )}
                            <span class="whitespace-nowrap">
                              {splitTitle(leSaviezVousArticle.title).last}{" "}
                              <MaagLogoPaid class="w-5 h-5 inline-block align-baseline" />
                            </span>
                          </>
                        ) : (
                          leSaviezVousArticle.title
                        )}
                      </h4>
                    </a>

                    <p class="m-0 text-sm text-black/60 font-inter font-normal">
                      {truncateText(
                        getCardLead(leSaviezVousArticle) ||
                          leSaviezVousArticle?.lead ||
                          "",
                        150,
                      )}
                    </p>
                  </div>
                </article>
              ) : (
                <article class="overflow-hidden bg-white">
                  <LazyImage
                    src={picture1}
                    alt="Le saviez-vous placeholder"
                    class="block h-auto w-full object-cover lg:h-[240px]"
                  />

                  <div class="grid gap-[0.55rem] p-4 lg:px-4 lg:py-6">
                    <p class="m-0">
                      <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
                        Париж
                      </span>
                    </p>

                    <h4 class="m-0 text-xl font-normal font-old_standard tracking-[-0.02em] leading-[1.16]">
                      Неочевидный факт о городе скоро появится здесь
                    </h4>

                    <p class="m-0 text-sm text-black/60 font-inter font-normal">
                      Пока это плейсхолдер: здесь будет короткий визуальный факт
                      или наблюдение в духе карточки календаря, но без даты.
                    </p>
                  </div>
                </article>
              )}
            </section>
          </aside>
        </div>
        {carouselItems.length > 0 && (
          <>
            <div class="w-full">
              <hr class="h-px my-8 border-1" />
            </div>
            <div class="w-full overflow-hidden">
              <div
                class="articles-marquee-track flex gap-8 items-stretch py-8"
                style="width: max-content;"
              >
                {[...carouselItems, ...carouselItems].map((item) => (
                  <div class="w-[320px] flex-shrink-0">
                    <ArticleCard
                      isNetlenka={false}
                      title={item.title}
                      category={getPrimaryTag(item)}
                      date={formatArticleDate(item.createdAt)}
                      hideDate={true}
                      lead={truncateText(getCardLead(item), 120) || undefined}
                      imageUrl={item.imageUrl}
                      href={item.href}
                      paid={item.paid}
                    />
                  </div>
                ))}
              </div>
            </div>
          </>
        )}
      </>
    )
  }
</section>

<style is:global>
  @keyframes articles-marquee-scroll {
    from {
      transform: translateX(-50%);
    }
    to {
      transform: translateX(0);
    }
  }

  .articles-marquee-track {
    animation: articles-marquee-scroll 270s linear infinite;
  }

  .articles-marquee-track:hover {
    animation-play-state: paused;
  }
</style>
