---
import { Image } from "astro:assets";

import picture1 from "../../assets/images/culture.jpg";

interface ArticleCardProps {
  isNetlenka?: boolean;
  title?: string;
  category?: string;
  date?: string;
  hideDate?: boolean;
  lead?: string;
  transitionName?: string;
  imageUrl?: string;
  href?: string;
}

const {
  isNetlenka = true,
  title = "Без названия",
  category = "Культура",
  date = "",
  hideDate = false,
  lead = "",
  transitionName,
  imageUrl,
  href = "#",
} = Astro.props as ArticleCardProps;

const displayImage = imageUrl || picture1.src;
---

<div class="w-full flex flex-col justify-start gap-2">
  <div class="w-full aspect-[3/2] overflow-hidden">
    <a
      href={href}
      class="linked-image-hover w-full h-full"
    >
      {
        imageUrl ? (
          <img
            src={displayImage}
            alt={title}
            class="linked-image-hover__media w-full h-full object-cover object-center"
            loading="lazy"
            transition:name={transitionName}
          />
        ) : (
          <Image
            src={picture1}
            alt="Culture image"
            class="linked-image-hover__media w-full h-full object-cover object-center"
            loading="eager"
            transition:name={transitionName}
          />
        )
      }
    </a>
  </div>
  {
    (date || category) && (
      <div class="flex flex-row items-center gap-2 text-xs text-base-content/55 font-inter uppercase tracking-[0.22em] mt-1">
        {date && (
          <span class:list={["text-xs", hideDate && "hidden"]}>{date}</span>
        )}
        {date && category && (
          <span
            class:list={[
              "text-black text-lg font-bold font-['Inter'] leading-none",
              hideDate && "hidden",
            ]}
          >
            ·
          </span>
        )}
        {category && (
          <span class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']">
            {category}
          </span>
        )}
      </div>
    )
  }
  <a href={href} class="block">
    <h3
      class="text-2xl font-normal font-old_standard tracking-[-0.02em] hover:underline transition-opacity duration-200 hover:opacity-90"
    >
      {title}
    </h3>
  </a>
  {
    lead && (
      <p class="text-base lg:text-sm text-black/60 font-inter font-normal">
        {lead}
      </p>
    )
  }
</div>
