---
import QuoteIcon from "../../assets/icons/quote.svg";
import { getInitialRichTextHtml } from "@/lib/utils/richText";

interface ColumnData {
  type: "image" | "text" | "quote";
  content: string;
  html?: string;
  caption?: string;
  quoteAuthor?: string;
}

interface Props {
  column: ColumnData;
  altLabel: string;
  desktopTextAlign?: "start" | "end" | "justify";
  imageLayout?: "natural" | "fixed-height";
}

const {
  column,
  altLabel,
  desktopTextAlign = "justify",
  imageLayout = "natural",
} = Astro.props;
const textAlignmentClass =
  desktopTextAlign === "end"
    ? "text-center lg:text-start"
    : desktopTextAlign === "start"
      ? "text-center lg:text-start"
      : "text-justify";
const imageWrapperClass =
  imageLayout === "fixed-height"
    ? "flex h-[620px] w-full items-center justify-center overflow-hidden"
    : "flex w-full items-center justify-center";
const imageClass =
  imageLayout === "fixed-height"
    ? "w-full h-full object-cover object-center"
    : "h-auto w-full object-contain";
const columnRichTextHtml = getInitialRichTextHtml({
  html: column.html,
  text: column.content,
});
---

{
  column.type === "image" ? (
    <figure class="w-full flex flex-col items-center">
      <div class={imageWrapperClass}>
        <img
          src={column.content}
          alt={column.caption || altLabel}
          class={imageClass}
        />
      </div>
      {column.caption && (
        <figcaption class="text-center font-inter text-xs text-gray-500 mt-2">
          {column.caption}
        </figcaption>
      )}
    </figure>
  ) : column.type === "quote" ? (
    <div class="w-full max-w-[420px] flex flex-col items-center">
      <QuoteIcon class="w-8 h-8" />
      <blockquote class="mt-4 text-base lg:text-lg text-base-content/80 font-article-body italic whitespace-pre-line">
        {column.content}
      </blockquote>
      <QuoteIcon class="w-8 h-8 rotate-180 mt-4" />
      {column.quoteAuthor && (
        <p class="w-full mt-4 font-['Inter'] text-sm font-light capitalize tracking-[0.22em] text-base-content text-left">
          {column.quoteAuthor}
        </p>
      )}
    </div>
  ) : (
    <div
      class={`article-rich-text text-lg font-article-body ${textAlignmentClass}`}
      set:html={columnRichTextHtml}
    />
  )
}
