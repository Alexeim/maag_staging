---
import LazyImage from "../common/LazyImage.astro";
import { Info } from "@lucide/astro";

interface Props {
  leftPortraitImageUrl?: string;
  leftPortraitImageCaption?: string;
  topLandscapeImageUrl?: string;
  topLandscapeImageCaption?: string;
  mainLandscapeImageUrl?: string;
  mainLandscapeImageCaption?: string;
  rightPortraitImageUrl?: string;
  rightPortraitImageCaption?: string;
}

const {
  leftPortraitImageUrl = "",
  leftPortraitImageCaption = "",
  topLandscapeImageUrl = "",
  topLandscapeImageCaption = "",
  mainLandscapeImageUrl = "",
  mainLandscapeImageCaption = "",
  rightPortraitImageUrl = "",
  rightPortraitImageCaption = "",
} = Astro.props as Props;
---

<section
  class="mx-auto grid w-full gap-6 lg:relative lg:h-[920px] lg:max-w-[1198px] lg:gap-0"
>
  {
    leftPortraitImageUrl && (
      <figure class="group relative w-full lg:absolute lg:left-0 lg:top-0 lg:w-[25.0417%]">
        <LazyImage
          src={leftPortraitImageUrl}
          alt={leftPortraitImageCaption || "Left portrait collage image"}
          class="block w-full aspect-[3/4] object-cover"
          loading="lazy"
        />
        {leftPortraitImageCaption && (
          <div class="absolute right-2 top-2 z-30">
            <div class="pointer-events-none absolute right-full top-1/2 mr-2 w-max max-w-sm -translate-y-1/2 translate-x-2 bg-black/75 px-3 py-2 text-xs leading-relaxed text-white opacity-0 shadow-xl transition-[opacity,transform] duration-200 group-hover:translate-x-0 group-hover:-translate-y-1/2 group-hover:opacity-100 group-focus-within:translate-x-0 group-focus-within:-translate-y-1/2 group-focus-within:opacity-100">
              {leftPortraitImageCaption}
            </div>
            <button
              type="button"
              class="inline-flex h-8 w-8 items-center justify-center text-white transition-transform duration-200 hover:scale-110 focus-visible:outline-none"
              aria-label="Показать подпись к изображению"
            >
              <Info class="h-4 w-4" />
            </button>
          </div>
        )}
      </figure>
    )
  }

  {
    topLandscapeImageUrl && (
      <figure class="group relative w-full lg:absolute lg:left-1/4 lg:top-1/12 lg:w-[41.7362%]">
        <LazyImage
          src={topLandscapeImageUrl}
          alt={topLandscapeImageCaption || "Top landscape collage image"}
          class="block w-full aspect-[5/3] object-cover"
          loading="lazy"
        />
        {topLandscapeImageCaption && (
          <div class="absolute right-2 top-2 z-30">
            <div class="pointer-events-none absolute right-full top-1/2 mr-2 w-max max-w-sm -translate-y-1/2 translate-x-2 bg-black/75 px-3 py-2 text-xs leading-relaxed text-white opacity-0 shadow-xl transition-[opacity,transform] duration-200 group-hover:translate-x-0 group-hover:-translate-y-1/2 group-hover:opacity-100 group-focus-within:translate-x-0 group-focus-within:-translate-y-1/2 group-focus-within:opacity-100">
              {topLandscapeImageCaption}
            </div>
            <button
              type="button"
              class="inline-flex h-8 w-8 items-center justify-center text-white transition-transform duration-200 hover:scale-110 focus-visible:outline-none"
              aria-label="Показать подпись к изображению"
            >
              <Info class="h-4 w-4" />
            </button>
          </div>
        )}
      </figure>
    )
  }

  {
    mainLandscapeImageUrl && (
      <figure class="group relative w-full lg:absolute lg:left-1/12 lg:top-1/2 lg:w-[66.778%] lg:-translate-y-20">
        <LazyImage
          src={mainLandscapeImageUrl}
          alt={mainLandscapeImageCaption || "Main landscape collage image"}
          class="block w-full aspect-[16/9] object-cover"
          loading="lazy"
        />
        {mainLandscapeImageCaption && (
          <div class="absolute right-2 top-2 z-30">
            <div class="pointer-events-none absolute right-full top-1/2 mr-2 w-max max-w-sm -translate-y-1/2 translate-x-2 bg-black/75 px-3 py-2 text-xs leading-relaxed text-white opacity-0 shadow-xl transition-[opacity,transform] duration-200 group-hover:translate-x-0 group-hover:-translate-y-1/2 group-hover:opacity-100 group-focus-within:translate-x-0 group-focus-within:-translate-y-1/2 group-focus-within:opacity-100">
              {mainLandscapeImageCaption}
            </div>
            <button
              type="button"
              class="inline-flex h-8 w-8 items-center justify-center text-white transition-transform duration-200 hover:scale-110 focus-visible:outline-none"
              aria-label="Показать подпись к изображению"
            >
              <Info class="h-4 w-4" />
            </button>
          </div>
        )}
      </figure>
    )
  }

  {
    rightPortraitImageUrl && (
      <figure class="group relative w-full lg:absolute lg:bottom-0 lg:right-0 lg:w-[25.0417%]">
        <LazyImage
          src={rightPortraitImageUrl}
          alt={rightPortraitImageCaption || "Right portrait collage image"}
          class="block w-full aspect-[3/4] object-cover"
          loading="lazy"
        />
        {rightPortraitImageCaption && (
          <div class="absolute right-2 top-2 z-30">
            <div class="pointer-events-none absolute right-full top-1/2 mr-2 w-max max-w-sm -translate-y-1/2 translate-x-2 bg-black/75 px-3 py-2 text-xs leading-relaxed text-white opacity-0 shadow-xl transition-[opacity,transform] duration-200 group-hover:translate-x-0 group-hover:-translate-y-1/2 group-hover:opacity-100 group-focus-within:translate-x-0 group-focus-within:-translate-y-1/2 group-focus-within:opacity-100">
              {rightPortraitImageCaption}
            </div>
            <button
              type="button"
              class="inline-flex h-8 w-8 items-center justify-center text-white transition-transform duration-200 hover:scale-110 focus-visible:outline-none"
              aria-label="Показать подпись к изображению"
            >
              <Info class="h-4 w-4" />
            </button>
          </div>
        )}
      </figure>
    )
  }
</section>
