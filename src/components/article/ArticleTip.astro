---
import { Image } from "astro:assets";
import { MapPin } from "lucide-astro";
import type { ImageMetadata } from "astro";

interface Tip {
  image: ImageMetadata;
  date: string;
  location: string;
  time: string;
  action: string;
  description: string;
}

interface Props {
  tip: Tip;
}

const { tip } = Astro.props;
---

<div class="flex flex-col lg:flex-row gap-4 lg:gap-8">
  <Image
    src={tip.image}
    alt="Tip image"
    class="w-full lg:w-[216px] h-auto lg:h-[224px] object-cover flex-shrink-0"
  />
  <div class="flex flex-col gap-2 flex-1">
    <div class="flex flex-col gap-2">
      <h4 class="text-xl lg:text-2xl font-serif text-base-content">{tip.date}</h4>
      <hr class="border-base-300" />
    </div>
    <div class="flex flex-col gap-2">
      <div class="flex items-center gap-2">
        <MapPin class="mt-0.5 h-5 w-5 shrink-0 text-accent" strokeWidth={1.75} aria-hidden="true" />
        <span class="font-semibold text-neutral">{tip.location}</span>
      </div>
      <hr class="border-base-300" />
    </div>
    <div class="flex items-center gap-2">
      <span class="font-semibold text-neutral">{tip.time}</span>
      <span class="font-extrabold text-sm text-base-content"
        >{tip.action}</span
      >
    </div>
    <hr class="border-base-300" />
    <p class="text-base lg:text-lg text-base-content font-serif">{tip.description}</p>
  </div>
</div>