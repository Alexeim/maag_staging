---
import {
  CalendarDays,
  CircleAlert,
  Clock3,
  Crown,
  Info,
  Lightbulb,
  MapPin,
  NotebookPen,
  Star,
} from "@lucide/astro";

interface Props {
  type: string;
  class?: string;
  strokeWidth?: number;
}

const {
  type,
  class: className,
  strokeWidth = 1.75,
  ...rest
} = Astro.props as Props;

const ICONS = {
  location: MapPin,
  clock: Clock3,
  calendar: CalendarDays,
  bulb: Lightbulb,
  pen: NotebookPen,
  crown: Crown,
  star: Star,
  alert: CircleAlert,
  info: Info,
} as const;

const normalizedType = type?.trim().toLowerCase() as keyof typeof ICONS;
const Icon = ICONS[normalizedType];
---

{
  Icon && (
    <Icon
      {...rest}
      class={className}
      strokeWidth={strokeWidth}
      aria-hidden="true"
    />
  )
}
