---
import TipsMetaIcon from "@/components/article/TipsMetaIcon.astro";
import { plainTextToRichTextHtml } from "@/lib/utils/richText";

interface TipsMetaItem {
  icon: string;
  text: string;
  isLink?: boolean;
  url?: string;
}

interface TipsItemBlock {
  type: "tips-item";
  heading?: string;
  imageUrl?: string;
  imageCaption?: string;
  metaItems?: TipsMetaItem[];
  html?: string;
  text?: string;
}

interface Props {
  contentBlocks: TipsItemBlock[];
}

const { contentBlocks } = Astro.props;

const items = contentBlocks.filter((b) => b != null && b.type === "tips-item");
---

<div class="max-w-[826px] mx-auto">
  {
    items.map((item, i) => (
      <article class="flex flex-col sm:flex-row py-8 gap-6">
        {/* Left: image */}
        {item.imageUrl && (
          <div class="sm:w-[42%] shrink-0">
            <img
              src={item.imageUrl}
              alt={item.imageCaption || item.heading || `Пункт ${i + 1}`}
              class="w-full h-full object-cover"
              style="min-height: 200px; max-height: 340px;"
            />
          </div>
        )}

        {/* Right: content */}
        <div
          class:list={[
            "flex flex-col justify-start gap-3 px-5",
            item.imageUrl ? "sm:w-[58%]" : "w-full",
          ]}
        >
          {item.heading && (
            <h2 class="text-xl font-bold font-old_standard">
              {item.heading}
            </h2>
          )}
          <hr class="text-gray-300" />

          {/* Meta lines */}
          {item.metaItems && item.metaItems.length > 0 && (
            <div class="flex flex-col gap-1.5">
              {item.metaItems.map((metaItem) => (
                <>
                  <p class="flex items-start gap-4 text-sm font-oswald tracking-wide text-base-content/70">
                    <TipsMetaIcon
                      type={metaItem.icon}
                      class="mt-0.5 h-5 w-5 shrink-0 text-accent"
                      strokeWidth={1.75}
                    />
                    {metaItem.isLink && metaItem.url ? (
                      <a
                        href={metaItem.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="underline hover:text-base-content transition-colors"
                      >
                        {metaItem.text}
                      </a>
                    ) : (
                      <span>{metaItem.text}</span>
                    )}
                  </p>
                  <hr class="text-gray-300" />
                </>
              ))}
            </div>
          )}

          {(item.html || item.text) && (
            <div
              class="tips-rich-text text-sm font-inter text-base-content/80 mt-1"
              set:html={item.html || plainTextToRichTextHtml(item.text)}
            />
          )}
        </div>
      </article>
    ))
  }
</div>

<style>
  .tips-rich-text :global(p) {
    margin: 0 0 0.6rem;
  }

  .tips-rich-text :global(p:last-child) {
    margin-bottom: 0;
  }

  .tips-rich-text :global(strong) {
    font-weight: 600;
  }

  .tips-rich-text :global(em) {
    font-style: italic;
  }

  .tips-rich-text :global(u) {
    text-decoration: underline;
  }

  .tips-rich-text :global(a) {
    text-decoration: underline;
    transition: opacity 0.15s;
  }

  .tips-rich-text :global(a:hover) {
    opacity: 0.7;
  }
</style>
