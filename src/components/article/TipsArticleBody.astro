---
import locationIcon from "@/assets/icons/new/location.svg?raw";
import timeIcon from "@/assets/icons/new/time.svg?raw";

interface TipsItemBlock {
  type: "tips-item";
  heading?: string;
  imageUrl?: string;
  imageCaption?: string;
  meta1?: string;
  meta2?: string;
  meta2IsLink?: boolean;
  meta2Url?: string;
  text?: string;
}

interface Props {
  contentBlocks: TipsItemBlock[];
}

const { contentBlocks } = Astro.props;

const items = contentBlocks.filter((b) => b != null && b.type === "tips-item");
---

<div class="max-w-[826px] mx-auto">
  {
    items.map((item, i) => (
      <article class="flex flex-col sm:flex-row py-8 gap-6">
        {/* Left: image */}
        {item.imageUrl && (
          <div class="sm:w-[42%] shrink-0">
            <img
              src={item.imageUrl}
              alt={item.imageCaption || item.heading || `Пункт ${i + 1}`}
              class="w-full h-full object-cover"
              style="min-height: 200px; max-height: 340px;"
            />
          </div>
        )}

        {/* Right: content */}
        <div
          class:list={[
            "flex flex-col justify-start gap-3 p-5",
            item.imageUrl ? "sm:w-[58%]" : "w-full",
          ]}
        >
          {item.heading && (
            <h2 class="text-xl font-bold font-oswald tracking-wide leading-snug">
              {item.heading}
            </h2>
          )}
          <hr class="text-gray-300" />

          {/* Meta lines */}
          <div class="flex flex-col gap-1.5">
            {item.meta1 && (
              <p class="flex items-center gap-2 text-sm font-oswald tracking-wide text-base-content/70">
                <span class="shrink-0 opacity-60" set:html={locationIcon} />
                <span>{item.meta1}</span>
              </p>
              <hr class="text-gray-300" />
            )}
            {item.meta2 && (
              <p class="flex items-center gap-2 text-sm font-oswald tracking-wide text-base-content/70">
                <span class="shrink-0 opacity-60" set:html={timeIcon} />
                {item.meta2IsLink && item.meta2Url ? (
                  <a
                    href={item.meta2Url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline hover:text-base-content transition-colors"
                  >
                    {item.meta2}
                  </a>
                ) : (
                  <span>{item.meta2}</span>
                )}
              </p>
              <hr class="text-gray-300" />
            )}
          </div>

          {item.text && (
            <p class="text-sm font-oswald font-thin tracking-wide leading-relaxed text-base-content/80 mt-1">
              {item.text}
            </p>
          )}
        </div>
      </article>
    ))
  }
</div>
