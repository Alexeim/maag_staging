---
interface Props {
  category: string;
  title?: string;
  lead?: string;
}

const { category, title, lead } = Astro.props;
---

<div class="flex flex-col gap-8 w-full">
  <div class="flex flex-col items-start gap-2">
    <p
      class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter'] mt-2"
    >
      {category}
    </p>
    <h1
      class="text-3xl lg:text-[52px] leading-tight font-old_standard text-base-content w-full"
    >
      {title}
    </h1>
    {
      lead && (
        <p class="text-lg font-light text-base-content/80 font-article-body mt-2">
          {lead}
        </p>
      )
    }
  </div>
</div>
