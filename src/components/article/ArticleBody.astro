---
import QuoteIcon from "../../assets/icons/quote.svg";
import { ChevronLeft, ChevronRight } from "lucide-astro";
import ArticleVideo from "./ArticleVideo.astro";
import LinkToContent from "./LinkToContent.astro";
import ArticleColumnContent from "./ArticleColumnContent.astro";
import { getInitialRichTextHtml } from "@/lib/utils/richText";
import {
  getLinkedContentKey,
  type LinkedContentLookup,
} from "@/lib/utils/contentCollectionMarquee";

interface Block {
  type: string;
  text?: string;
  html?: string;
  url?: string;
  caption?: string;
  question?: string;
  answer?: string;
  sourceType?: string;
  provider?: string;
  linkedContentType?: "article" | "event" | "interview" | "flipper";
  linkedContentId?: string;
  linkedContentTitle?: string;
}

interface ColumnData {
  type: "image" | "text" | "quote";
  content: string; // url for image, text for text
  html?: string;
  caption?: string;
}

interface TwoColumnBlock extends Block {
  type: "two-columns";
  left: ColumnData;
  right: ColumnData;
}

interface ThreeColumnBlock extends Block {
  type: "three-columns";
  left: ColumnData;
  center: ColumnData;
  right: ColumnData;
}

interface FlipperSlide {
  imageUrl: string;
  caption?: string;
}

interface FlipperBlock extends Block {
  type: "flipper";
  slides: FlipperSlide[];
}

interface RenderableBlock {
  type: "prose-group" | "two-columns" | "three-columns" | "flipper" | "video";
  content?: Block[]; // for prose-group
  block?: TwoColumnBlock; // for two-columns
  threeColumnBlock?: ThreeColumnBlock; // for three-columns
  flipper?: FlipperBlock; // for flipper
  video?: Block;
}

interface Props {
  contentBlocks: (Block | TwoColumnBlock | ThreeColumnBlock)[];
  linkedContentLookup?: LinkedContentLookup;
}

const {
  contentBlocks,
  linkedContentLookup = {},
} = Astro.props;

const proseRailClass = "max-w-full lg:max-w-[826px] mx-0 lg:mx-auto";
const mediaRailClass = "w-full lg:max-w-[1200px] my-12 px-4 lg:px-0";
const breakoutRailClass = "w-full lg:max-w-[1278px] my-12 px-4 lg:px-0";
const wideBreakoutRailClass = "w-full lg:max-w-[1356px] my-12 px-4 lg:px-0";

const renderableGroups: RenderableBlock[] = [];
let currentProseGroup: Block[] = [];

for (const block of contentBlocks) {
  if (block.type === "two-columns") {
    if (currentProseGroup.length > 0) {
      renderableGroups.push({
        type: "prose-group",
        content: currentProseGroup,
      });
      currentProseGroup = [];
    }
    renderableGroups.push({
      type: "two-columns",
      block: block as TwoColumnBlock,
    });
  } else if (block.type === "three-columns") {
    if (currentProseGroup.length > 0) {
      renderableGroups.push({
        type: "prose-group",
        content: currentProseGroup,
      });
      currentProseGroup = [];
    }
    renderableGroups.push({
      type: "three-columns",
      threeColumnBlock: block as ThreeColumnBlock,
    });
  } else if (block.type === "flipper") {
    if (currentProseGroup.length > 0) {
      renderableGroups.push({
        type: "prose-group",
        content: currentProseGroup,
      });
      currentProseGroup = [];
    }
    renderableGroups.push({
      type: "flipper",
      flipper: block as FlipperBlock,
    });
  } else if (block.type === "video") {
    if (currentProseGroup.length > 0) {
      renderableGroups.push({
        type: "prose-group",
        content: currentProseGroup,
      });
      currentProseGroup = [];
    }
    renderableGroups.push({
      type: "video",
      video: block,
    });
  } else {
    currentProseGroup.push(block);
  }
}

if (currentProseGroup.length > 0) {
  renderableGroups.push({ type: "prose-group", content: currentProseGroup });
}
---

<div class="flex flex-col items-center">
  {
    renderableGroups.map((group) => {
      if (group.type === "prose-group" && group.content) {
        return (
          <div class={proseRailClass}>
            <article class="max-w-full space-y-12">
              {group.content.map((block) => {
                switch (block.type) {
                  case "first-paragraph": {
                    const html = getInitialRichTextHtml(block);
                    return (
                      <div
                        class="article-rich-text article-rich-text--dropcap text-lg font-article-body text-justify"
                        set:html={html}
                      />
                    );
                  }
                  case "paragraph": {
                    const html = getInitialRichTextHtml(block);
                    return (
                      <div
                        class="article-rich-text text-lg font-article-body text-justify"
                        set:html={html}
                      />
                    );
                  }
                  case "h2":
                    return (
                      <h2 class="text-2xl font-bold font-old_standard italic">
                        {block.text}
                      </h2>
                    );
                  case "h3":
                    return (
                      <h3 class="text-2xl font-bold font-old_standard italic">
                        {block.text}
                      </h3>
                    );
                  case "quote":
                    return (
                      <div class="p-2 flex flex-col items-center justify-center gap-2">
                        <QuoteIcon class="w-8 h-8" />
                        <blockquote class="text-3xl italic font-article-body pl-4 my-4">
                          {block.text}
                        </blockquote>
                        <QuoteIcon class="w-8 h-8 rotate-180" />
                      </div>
                    );
                  case "image":
                    return (
                      <figure class="not-prose flex flex-col items-center">
                        <img
                          src={block.url}
                          alt={block.caption || "Article image"}
                          class="article-image"
                        />
                        {block.caption && (
                          <figcaption class="text-center font-inter text-xs text-gray-500 mt-2">
                            {block.caption}
                          </figcaption>
                        )}
                      </figure>
                    );
                  case "link": {
                    const linkedItem =
                      linkedContentLookup[
                        getLinkedContentKey(
                          block.linkedContentType,
                          block.linkedContentId,
                        )
                      ];
                    return linkedItem ? <LinkToContent item={linkedItem} /> : null;
                  }
                  case "qa":
                    return (
                      <div class="space-y-4">
                        {block.question && (
                          <p class="text-xl font-article-body font-bold! italic">
                            {block.question}
                          </p>
                        )}
                        {block.answer && (
                          <p class="text-lg font-article-body text-justify">
                            {block.answer}
                          </p>
                        )}
                      </div>
                    );
                  default:
                    return null;
                }
              })}
            </article>
          </div>
        );
      } else if (group.type === "video" && group.video) {
        return (
          <div class={mediaRailClass}>
            <ArticleVideo block={group.video} />
          </div>
        );
      } else if (group.type === "two-columns" && group.block) {
        const twoColumnBlock = group.block;
        return (
          <div class={breakoutRailClass}>
            <div class="flex flex-col lg:flex-row gap-8 items-center">
              <div class="w-full lg:w-1/2 flex justify-center">
                <ArticleColumnContent
                  column={twoColumnBlock.left}
                  altLabel="Left column image"
                  desktopTextAlign="end"
                />
              </div>
              <div class="w-full lg:w-1/2 flex justify-center">
                <ArticleColumnContent
                  column={twoColumnBlock.right}
                  altLabel="Right column image"
                  desktopTextAlign="start"
                />
              </div>
            </div>
          </div>
        );
      } else if (group.type === "three-columns" && group.threeColumnBlock) {
        const threeColumnBlock = group.threeColumnBlock;
        return (
          <div class={wideBreakoutRailClass}>
            <div class="flex flex-col lg:flex-row gap-8 items-center">
              <div class="w-full lg:w-1/3 flex justify-center">
                <ArticleColumnContent
                  column={threeColumnBlock.left}
                  altLabel="Left column image"
                />
              </div>
              <div class="w-full lg:w-1/3 flex justify-center">
                <ArticleColumnContent
                  column={threeColumnBlock.center}
                  altLabel="Center column image"
                />
              </div>
              <div class="w-full lg:w-1/3 flex justify-center">
                <ArticleColumnContent
                  column={threeColumnBlock.right}
                  altLabel="Right column image"
                />
              </div>
            </div>
          </div>
        );
      } else if (group.type === "flipper" && group.flipper) {
        const { slides } = group.flipper;
        if (!slides || slides.length === 0) return null;
        return (
          <div
            class={breakoutRailClass}
            x-data={`{ current: 0, total: ${slides.length}, captions: ${JSON.stringify(slides.map((s) => s.caption || ""))} }`}
          >
            <div class="relative overflow-hidden h-[320px] sm:h-[460px] lg:h-[600px]">
              <div
                class="flex h-full transition-transform duration-500 ease-in-out"
                :style="`transform: translateX(-${current * 100}%)`"
              >
                {slides.map((slide) => (
                  <div class="min-w-full h-full flex items-center justify-center">
                    <img
                      src={slide.imageUrl}
                      alt={slide.caption || "Слайд"}
                      class="h-full w-auto"
                    />
                  </div>
                ))}
              </div>

              {slides.length > 1 && (
                <>
                  <button
                    type="button"
                    class="absolute left-3 top-1/2 -translate-y-1/2 bg-black/40 hover:bg-black/60 text-white rounded-full w-10 h-10 flex items-center justify-center transition cursor-pointer"
                    @click="current = (current - 1 + total) % total"
                    aria-label="Предыдущий слайд"
                  >
                    <ChevronLeft class="h-5 w-5" />
                  </button>
                  <button
                    type="button"
                    class="absolute right-3 top-1/2 -translate-y-1/2 bg-black/40 hover:bg-black/60 text-white rounded-full w-10 h-10 flex items-center justify-center transition cursor-pointer"
                    @click="current = (current + 1) % total"
                    aria-label="Следующий слайд"
                  >
                    <ChevronRight class="h-5 w-5" />
                  </button>
                </>
              )}
            </div>

            <p
              x-show="captions[current]"
              x-text="captions[current]"
              class="text-center font-inter text-xs text-gray-500 mt-2 px-4 min-h-[1rem]"
            ></p>
            {slides.length > 1 && (
              <div class="flex justify-center gap-2 mt-4">
                {slides.map((_, i) => (
                  <button
                    type="button"
                    class="w-2 h-2 rounded-full transition cursor-pointer"
                    :class={`current === ${i} ? 'bg-base-content' : 'bg-base-content/30'`}
                    @click={`current = ${i}`}
                    aria-label={`Слайд ${i + 1}`}
                  />
                ))}
              </div>
            )}
          </div>
        );
      }
      return null;
    })
  }
</div>

<style>
  .article-rich-text :global(p) {
    margin: 0 0 1rem;
  }

  .article-rich-text :global(p:last-child) {
    margin-bottom: 0;
  }

  .article-rich-text--dropcap :global(p:first-child::first-letter) {
    float: left;
    margin-top: -1rem;
    margin-right: 1.5rem;
    font-size: 4rem;
    font-family: 'Great Vibes', cursive;
    color: var(--color-maag-green);
  }
</style>
