---
import QuoteIcon from "../../assets/icons/quote.svg";
import ArticleVideo from "./ArticleVideo.astro";

interface Block {
  type: string;
  text?: string;
  url?: string;
  caption?: string;
  question?: string;
  answer?: string;
  sourceType?: string;
  provider?: string;
  linkedContentType?: "article" | "event" | "interview" | "flipper";
  linkedContentId?: string;
  linkedContentTitle?: string;
}

interface ColumnData {
  type: "image" | "text" | "quote";
  content: string; // url for image, text for text
  caption?: string;
}

interface TwoColumnBlock extends Block {
  type: "two-columns";
  left: ColumnData;
  right: ColumnData;
}

interface FlipperSlide {
  imageUrl: string;
  caption?: string;
}

interface FlipperBlock extends Block {
  type: "flipper";
  slides: FlipperSlide[];
}

interface RenderableBlock {
  type: "prose-group" | "two-columns" | "flipper" | "video";
  content?: Block[]; // for prose-group
  block?: TwoColumnBlock; // for two-columns
  flipper?: FlipperBlock; // for flipper
  video?: Block;
}

interface Props {
  contentBlocks: (Block | TwoColumnBlock)[];
}

const { contentBlocks } = Astro.props;

const renderableGroups: RenderableBlock[] = [];
let currentProseGroup: Block[] = [];

for (const block of contentBlocks) {
  if (block.type === "two-columns") {
    if (currentProseGroup.length > 0) {
      renderableGroups.push({
        type: "prose-group",
        content: currentProseGroup,
      });
      currentProseGroup = [];
    }
    renderableGroups.push({
      type: "two-columns",
      block: block as TwoColumnBlock,
    });
  } else if (block.type === "flipper") {
    if (currentProseGroup.length > 0) {
      renderableGroups.push({
        type: "prose-group",
        content: currentProseGroup,
      });
      currentProseGroup = [];
    }
    renderableGroups.push({
      type: "flipper",
      flipper: block as FlipperBlock,
    });
  } else if (block.type === "video") {
    if (currentProseGroup.length > 0) {
      renderableGroups.push({
        type: "prose-group",
        content: currentProseGroup,
      });
      currentProseGroup = [];
    }
    renderableGroups.push({
      type: "video",
      video: block,
    });
  } else {
    currentProseGroup.push(block);
  }
}

if (currentProseGroup.length > 0) {
  renderableGroups.push({ type: "prose-group", content: currentProseGroup });
}
---

<div class="flex flex-col items-center">
  {
    renderableGroups.map((group) => {
      if (group.type === "prose-group" && group.content) {
        return (
          <div class="max-w-[826px] mx-auto">
            <article class="prose lg:prose-xl max-w-full space-y-12">
              {group.content.map((block) => {
                switch (block.type) {
                  case "first-paragraph":
                    return (
                      <p class="text-lg first-letter:text-5xl first-letter:font-bold first-letter:float-left first-letter:mr-3 font-oswald tracking-wide text-justify font-thin">
                        {block.text}
                      </p>
                    );
                  case "paragraph":
                    return (
                      <p class="text-lg font-oswald text-justify font-thin tracking-wide">
                        {block.text}
                      </p>
                    );
                  case "h2":
                    return (
                      <h2 class="text-xl font-bold font-oswald tracking-wide">
                        {block.text}
                      </h2>
                    );
                  case "h3":
                    return (
                      <h3 class="text-2xl font-bold font-oswald tracking-wide">
                        {block.text}
                      </h3>
                    );
                  case "quote":
                    return (
                      <div class="p-2 flex flex-col items-center justify-center gap-2">
                        <QuoteIcon class="w-8 h-8" />
                        <blockquote class="text-3xl italic font-oswald pl-4 my-4 font-thin">
                          {block.text}
                        </blockquote>
                        <QuoteIcon class="w-8 h-8 rotate-180" />
                      </div>
                    );
                  case "image":
                    return (
                      <figure class="not-prose flex flex-col items-center">
                        <img
                          src={block.url}
                          alt={block.caption || "Article image"}
                          class="article-image"
                        />
                        {block.caption && (
                          <figcaption class="text-center font-oswald tracking-wide text-xs text-gray-500 mt-2">
                            {block.caption}
                          </figcaption>
                        )}
                      </figure>
                    );
                  case "link": {
                    const hrefMap = {
                      article: `/article/${block.linkedContentId}`,
                      event: `/events/${block.linkedContentId}`,
                      interview: `/interviews/${block.linkedContentId}`,
                      flipper: `/flippers/${block.linkedContentId}`,
                    };
                    const href =
                      block.linkedContentType && block.linkedContentId
                        ? hrefMap[block.linkedContentType]
                        : "#";
                    return (
                      <p class="text-lg font-oswald text-justify font-thin">
                        <a
                          href={href}
                          class="text-xl font-oswald tracking-wide font-semibold hover:underline"
                        >
                          {block.text || "Ссылка"}
                        </a>
                      </p>
                    );
                  }
                  case "qa":
                    return (
                      <div class="space-y-4">
                        {block.question && (
                          <p class="text-xl font-oswald tracking-wide font-semibold italic">
                            {block.question}
                          </p>
                        )}
                        {block.answer && (
                          <p class="text-lg font-oswald text-justify font-thin tracking-wide">
                            {block.answer}
                          </p>
                        )}
                      </div>
                    );
                  default:
                    return null;
                }
              })}
            </article>
          </div>
        );
      } else if (group.type === "video" && group.video) {
        return (
          <div class="w-full lg:max-w-[900px] my-12 px-4">
            <ArticleVideo block={group.video} />
          </div>
        );
      } else if (group.type === "two-columns" && group.block) {
        const twoColumnBlock = group.block;
        return (
          <div class="w-full lg:max-w-[900px] my-12 px-4">
            <div class="flex flex-col lg:flex-row gap-8 items-center">
              <div class="w-full lg:w-1/2 flex justify-center">
                {twoColumnBlock.left.type === "image" ? (
                  <figure class="flex flex-col items-center">
                    <img
                      src={twoColumnBlock.left.content}
                      alt={twoColumnBlock.left.caption || "Left column image"}
                      class="article-image"
                    />
                    {twoColumnBlock.left.caption && (
                      <figcaption class="text-center font-oswald tracking-wide text-xs text-gray-500 mt-2">
                        {twoColumnBlock.left.caption}
                      </figcaption>
                    )}
                  </figure>
                ) : twoColumnBlock.left.type === "quote" ? (
                  <div class="w-full max-w-[420px] flex flex-col items-center">
                    <QuoteIcon class="w-8 h-8" />
                    <blockquote class="mt-4 text-base lg:text-lg leading-relaxed text-base-content/80 font-serif italic whitespace-pre-line">
                      {twoColumnBlock.left.content}
                    </blockquote>
                    <QuoteIcon class="w-8 h-8 rotate-180 mt-4" />
                  </div>
                ) : (
                  <p class="text-lg font-oswald tracking-wide text-justify font-thin">
                    {twoColumnBlock.left.content}
                  </p>
                )}
              </div>
              <div class="w-full lg:w-1/2 flex justify-center">
                {twoColumnBlock.right.type === "image" ? (
                  <figure class="flex flex-col items-center">
                    <img
                      src={twoColumnBlock.right.content}
                      alt={twoColumnBlock.right.caption || "Right column image"}
                      class="article-image"
                    />
                    {twoColumnBlock.right.caption && (
                      <figcaption class="text-center font-oswald tracking-wide text-xs text-gray-500 mt-2">
                        {twoColumnBlock.right.caption}
                      </figcaption>
                    )}
                  </figure>
                ) : twoColumnBlock.right.type === "quote" ? (
                  <div class="w-full max-w-[420px] flex flex-col items-center">
                    <QuoteIcon class="w-8 h-8" />
                    <blockquote class="mt-4 text-base lg:text-lg leading-relaxed text-base-content/80 font-serif italic whitespace-pre-line">
                      {twoColumnBlock.right.content}
                    </blockquote>
                    <QuoteIcon class="w-8 h-8 rotate-180 mt-4" />
                  </div>
                ) : (
                  <p class="text-lg font-oswald tracking-wide text-justify font-thin">
                    {twoColumnBlock.right.content}
                  </p>
                )}
              </div>
            </div>
          </div>
        );
      } else if (group.type === "flipper" && group.flipper) {
        const { slides } = group.flipper;
        if (!slides || slides.length === 0) return null;
        return (
          <div
            class="w-full lg:max-w-[900px] my-12 px-4"
            x-data={`{ current: 0, total: ${slides.length}, captions: ${JSON.stringify(slides.map((s) => s.caption || ""))} }`}
          >
            <div class="relative overflow-hidden h-[600px] bg-white">
              <div
                class="flex h-full transition-transform duration-500 ease-in-out"
                :style="`transform: translateX(-${current * 100}%)`"
              >
                {slides.map((slide) => (
                  <div class="min-w-full h-full flex items-center justify-center bg-white">
                    <img
                      src={slide.imageUrl}
                      alt={slide.caption || "Слайд"}
                      class="h-full w-auto"
                    />
                  </div>
                ))}
              </div>

              {slides.length > 1 && (
                <>
                  <button
                    type="button"
                    class="absolute left-3 top-1/2 -translate-y-1/2 bg-black/40 hover:bg-black/60 text-white rounded-full w-10 h-10 flex items-center justify-center transition cursor-pointer"
                    @click="current = (current - 1 + total) % total"
                    aria-label="Предыдущий слайд"
                  >
                    ‹
                  </button>
                  <button
                    type="button"
                    class="absolute right-3 top-1/2 -translate-y-1/2 bg-black/40 hover:bg-black/60 text-white rounded-full w-10 h-10 flex items-center justify-center transition cursor-pointer"
                    @click="current = (current + 1) % total"
                    aria-label="Следующий слайд"
                  >
                    ›
                  </button>
                </>
              )}
            </div>

            <p
              x-show="captions[current]"
              x-text="captions[current]"
              class="text-center font-oswald tracking-wide text-xs text-gray-500 mt-2 px-4 min-h-[1rem]"
            ></p>
            {slides.length > 1 && (
              <div class="flex justify-center gap-2 mt-4">
                {slides.map((_, i) => (
                  <button
                    type="button"
                    class="w-2 h-2 rounded-full transition cursor-pointer"
                    :class={`current === ${i} ? 'bg-base-content' : 'bg-base-content/30'`}
                    @click={`current = ${i}`}
                    aria-label={`Слайд ${i + 1}`}
                  />
                ))}
              </div>
            )}
          </div>
        );
      }
      return null;
    })
  }
</div>
