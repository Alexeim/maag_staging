---
import TipIcon from "@/components/article/TipIcon.astro";

interface Tip {
  type: string;
  text: string;
  url?: string;
}

interface Props {
  tips?: Tip[];
}

const { tips = [] } = Astro.props as Props;

const ICONS = {
  location: true,
  time: true,
  money: true,
  idea: true,
  like: true,
  dislike: true,
  link: true,
} as const;

type TipType = keyof typeof ICONS;

const TIP_ORDER: TipType[] = [
  "location",
  "time",
  "money",
  "idea",
  "like",
  "dislike",
  "link",
];

const sortTips = (tips: { type: TipType; text: string; url?: string }[]) =>
  [...tips].sort((left, right) => {
    return TIP_ORDER.indexOf(left.type) - TIP_ORDER.indexOf(right.type);
  });

const preparedTips = tips
  .filter(
    (tip) =>
      tip &&
      typeof tip.type === "string" &&
      typeof tip.text === "string" &&
      tip.text.trim().length > 0,
  )
  .map((tip) => ({
    type: tip.type.trim().toLowerCase(),
    text: tip.text.trim(),
    url: typeof tip.url === "string" ? tip.url.trim() : undefined,
  }))
  .filter(
    (tip): tip is { type: TipType; text: string; url?: string } =>
      tip.type in ICONS,
  );

const orderedTips = sortTips(preparedTips);
---

{
  orderedTips.length > 0 && (
    <section class="max-w-[826px] mx-auto mt-12">
      <div class="border border-base-300 bg-white">
        {orderedTips.map((tip) => {
          const isLink = tip.type === "link" && tip.url;
          return (
            <div class="flex flex-row items-start justify-start gap-4 px-4 py-2 border-b border-base-300 last:border-b-0">
              <div class="pt-1">
                <TipIcon
                  type={tip.type}
                  class="mt-0.5 h-5 w-5 shrink-0 text-accent"
                />
              </div>
              <div>
                {isLink ? (
                  <a
                    href={tip.url}
                    target="_blank"
                    rel="noreferrer"
                    class="font-oswald text-lg font-light tracking-[0.012em] text-base-content/90 hover:underline"
                  >
                    {tip.text}
                  </a>
                ) : (
                  <p class="font-oswald text-lg font-light tracking-[0.012em] text-base-content/90">
                    {tip.text}
                  </p>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </section>
  )
}
