---
import TipIcon from "@/components/article/TipIcon.astro";

interface Tip {
  type: string;
  text: string;
}

interface Props {
  tips?: Tip[];
}

const { tips = [] } = Astro.props as Props;

const ICONS = {
  location: true,
  time: true,
  money: true,
  idea: true,
  like: true,
  dislike: true,
} as const;

type TipType = keyof typeof ICONS;

const sortTips = (tips: { type: TipType; text: string }[]) =>
  [...tips].sort((left, right) => {
    if (left.type === "like" && right.type === "dislike") {
      return -1;
    }

    if (left.type === "dislike" && right.type === "like") {
      return 1;
    }

    return 0;
  });

const preparedTips = tips
  .filter(
    (tip) =>
      tip &&
      typeof tip.type === "string" &&
      typeof tip.text === "string" &&
      tip.text.trim().length > 0,
  )
  .map((tip) => ({
    type: tip.type.trim().toLowerCase(),
    text: tip.text.trim(),
  }))
  .filter((tip): tip is { type: TipType; text: string } => tip.type in ICONS);

const orderedTips = sortTips(preparedTips);
---

{
  orderedTips.length > 0 && (
    <section class="max-w-[826px] mx-auto mt-12">
      <div class="border border-base-300 bg-white/85">
        {orderedTips.map((tip) => {
          return (
            <div class="flex flex-row items-center justify-start gap-4 px-4 py-2 border-b border-base-300 last:border-b-0">
              <TipIcon
                type={tip.type}
                class="mt-0.5 h-5 w-5 shrink-0 text-accent"
              />
              <p class="font-oswald text-lg font-light tracking-[0.012em] text-base-content/90">
                {tip.text}
              </p>
            </div>
          );
        })}
      </div>
    </section>
  )
}
