---
import {
  Clock3,
  Heart,
  HeartOff,
  Lightbulb,
  Link2,
  MapPin,
  Wallet,
} from "lucide-astro";

interface Props {
  type: string;
  class?: string;
  strokeWidth?: number;
}

const {
  type,
  class: className,
  strokeWidth = 1.75,
  ...rest
} = Astro.props as Props;

const ICONS = {
  location: MapPin,
  time: Clock3,
  money: Wallet,
  idea: Lightbulb,
  like: Heart,
  dislike: HeartOff,
  link: Link2,
} as const;

const normalizedType = type.trim().toLowerCase() as keyof typeof ICONS;
const Icon = ICONS[normalizedType];
---

{
  Icon && (
    <Icon
      {...rest}
      class={className}
      strokeWidth={strokeWidth}
      aria-hidden="true"
    />
  )
}
