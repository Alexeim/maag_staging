---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata | string;
  alt: string;
  caption?: string;
  transitionName?: string;
  transitionAliases?: string[];
  figureClass?: string;
  imageClass?: string;
  figcaptionClass?: string;
  objectFit?: "contain" | "cover";
}
const {
  src,
  alt,
  caption,
  transitionName,
  transitionAliases = [],
  figureClass,
  imageClass,
  figcaptionClass,
  objectFit = "contain",
} = Astro.props;

const defaultImageClasses =
  `w-full h-auto lg:h-[649px] ${objectFit === "cover" ? "object-cover" : "object-contain"} object-center`;
const finalImageClasses = `${defaultImageClasses} ${imageClass || ""}`;

const defaultFigureClasses =
  "flex flex-col items-center gap-[13px] w-full mx-auto";
const finalFigureClasses = `${defaultFigureClasses} ${figureClass || ""}`;

const defaultFigcaptionClasses =
  "text-xs text-gray-500 font-inter text-center mb-8";
const finalFigcaptionClasses = `${defaultFigcaptionClasses} ${figcaptionClass || ""}`;
const imageSrc = typeof src === "string" ? src : src.src;
---

<div class={finalFigureClasses}>
  <div class="w-full lg:h-[649px] bg-base-200 overflow-hidden">
    {
      typeof src === "string" ? (
        <img
          src={src}
          alt={alt}
          class={finalImageClasses}
          transition:name={transitionName}
        />
      ) : (
        <Image
          src={src}
          alt={alt}
          class={finalImageClasses}
          transition:name={transitionName}
        />
      )
    }
  </div>
  {
    transitionAliases.map((alias) => (
      <img
        src={imageSrc}
        alt=""
        aria-hidden="true"
        class="fixed w-px h-px opacity-0 pointer-events-none -z-10"
        transition:name={alias}
      />
    ))
  }
  <div class="max-w-[826px] w-full">
    <p class={finalFigcaptionClasses}>
      {caption}
    </p>
    <hr class="w-full border-t border-neutral-200 mt-[13px]" />
  </div>
</div>
