---
interface Props {
  model: string;
}

const { model } = Astro.props as Props;
---

<label class="inline-flex items-center gap-2 rounded-lg border border-base-300 bg-base-100 px-3 py-2 text-sm cursor-pointer">
  <input
    type="checkbox"
    class="w-4 h-4 text-primary bg-base-200 border-base-300 rounded-sm focus:ring-primary focus:ring-2 cursor-pointer"
    x-model={`${model}.published`}
  />
  <span class="font-medium text-base-content">Опубликовано</span>
</label>
