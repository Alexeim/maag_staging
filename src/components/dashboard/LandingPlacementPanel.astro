---
interface Props {
  allowMainHero?: boolean;
  allowEventCard?: boolean;
  allowCultureInterviewBlock?: boolean;
  featuredEventOnly?: boolean;
  allowCategoryLandingHero?: boolean;
  allowCategoryPageHero?: boolean;
}

const {
  allowMainHero = false,
  allowEventCard = false,
  allowCultureInterviewBlock = false,
  featuredEventOnly = false,
  allowCategoryLandingHero = false,
  allowCategoryPageHero = false,
} = Astro.props as Props;

const isFeaturedEventOnly =
  featuredEventOnly &&
  allowEventCard &&
  !allowMainHero &&
  !allowCultureInterviewBlock;
---

<section class="mb-6 p-6 bg-base-100 border border-base-300 rounded-xl shadow-sm">
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div>
      {
        isFeaturedEventOnly ? (
          <>
            <h2 class="text-xl font-semibold">Карточка события на landing</h2>
            <p class="text-sm text-base-content/70 mt-1">
              Здесь выбирается, какое событие показывать в календарной карточке на landing.
            </p>
          </>
        ) : (
          <>
            <h2 class="text-xl font-semibold">Размещение на landing</h2>
            <p class="text-sm text-base-content/70 mt-1">
              Здесь управляются глобальные editorial slots без старых checkbox-флагов.
            </p>
          </>
        )
      }
    </div>

    <button
      type="button"
      class="px-3 py-2 border text-sm cursor-pointer bg-base-100 border-base-300 text-base-content hover:bg-base-200"
      @click="loadLandingPlacements()"
      :disabled="placementLoading || placementSaving"
    >
      {isFeaturedEventOnly ? "Обновить карточку" : "Обновить статусы"}
    </button>
  </div>

  <p
    x-show="!hasPlacementEntityId()"
    class="mt-4 text-sm text-base-content/70"
  >
    {
      isFeaturedEventOnly
        ? "Сначала сохрани событие. После первого сохранения здесь можно вручную назначить его в карточку события на landing."
        : "Сначала сохрани материал. После первого сохранения здесь появятся действия для placement'ов."
    }
  </p>

  <div x-show="hasPlacementEntityId()" class="mt-4 space-y-4">
    <p x-show="placementLoading" class="text-sm text-base-content/70">
      {isFeaturedEventOnly ? "Загружаем настройки карточки события..." : "Загружаем текущие размещения..."}
    </p>

    <p x-show="placementError" class="text-sm text-error" x-text="placementError"></p>

    <div class="grid gap-3 text-sm">
      {
        isFeaturedEventOnly ? (
          <>
            <p class="text-base-content/70">
              Текущая карточка события на landing:
              <span
                class="font-medium text-base-content"
                x-text="getCurrentEventCardSummary()"
              ></span>
            </p>
            <p x-show="isCurrentEventCard()" class="text-success">
              Это событие сейчас вручную стоит в карточке «Календарь» на landing.
            </p>
          </>
        ) : (
          <>
            <p class="text-base-content/70">
              Текущий главный материал landing:
              <span class="font-medium text-base-content" x-text="getCurrentMainHeroSummary()"></span>
            </p>
            <p x-show="isCurrentMainHero()" class="text-success">
              Этот материал сейчас стоит главным в блоке «Главное».
            </p>
            <p x-show="isCurrentEventCard()" class="text-success">
              Это событие сейчас стоит в блоке «Календарь» на landing.
            </p>
            <p x-show="isCurrentCultureInterviewBlock()" class="text-success">
              Это интервью сейчас стоит в special block «Культура».
            </p>
            <p x-show="isCurrentCultureLandingHero()" class="text-success">
              Этот материал сейчас стоит hero блока «Культура» на landing.
            </p>
            <p x-show="isCurrentParisLandingHero()" class="text-success">
              Этот материал сейчас стоит hero блока «Париж» на landing.
            </p>
            <p x-show="isCurrentCulturePageHero()" class="text-success">
              Этот материал сейчас стоит hero страницы /culture.
            </p>
            <p x-show="isCurrentParisPageHero()" class="text-success">
              Этот материал сейчас стоит hero страницы /paris.
            </p>
          </>
        )
      }
    </div>

    <div class="flex flex-wrap gap-3">
      {allowMainHero && (
        <>
          <button
            type="button"
            class="px-4 py-2 rounded-lg border text-sm transition cursor-pointer bg-primary text-primary-content border-primary disabled:opacity-50 disabled:cursor-not-allowed"
            @click="setAsMainHero()"
            x-show="canSetAsMainHero() && !isCurrentMainHero()"
            :disabled="placementSaving"
          >
            Сделать главным материалом landing
          </button>
          <button
            type="button"
            class="px-4 py-2 rounded-lg border text-sm transition cursor-pointer bg-base-100 text-base-content border-base-300 hover:bg-base-200 disabled:opacity-50 disabled:cursor-not-allowed"
            @click="clearMainHero()"
            x-show="isCurrentMainHero()"
            :disabled="placementSaving"
          >
            Снять из главного материала
          </button>
        </>
      )}

      {allowEventCard && (
        <>
          <button
            type="button"
            class="px-4 py-2 rounded-lg border text-sm transition cursor-pointer bg-primary text-primary-content border-primary disabled:opacity-50 disabled:cursor-not-allowed"
            @click="setAsEventCard()"
            x-show="canSetAsEventCard() && !isCurrentEventCard()"
            :disabled="placementSaving"
          >
            {isFeaturedEventOnly ? "Поставить в карточку события" : "Поставить в блок события"}
          </button>
          <button
            type="button"
            class="px-4 py-2 rounded-lg border text-sm transition cursor-pointer bg-base-100 text-base-content border-base-300 hover:bg-base-200 disabled:opacity-50 disabled:cursor-not-allowed"
            @click="clearEventCard()"
            x-show="isCurrentEventCard()"
            :disabled="placementSaving"
          >
            {isFeaturedEventOnly ? "Вернуть авто-выбор события" : "Снять из блока события"}
          </button>
        </>
      )}

      {allowCultureInterviewBlock && (
        <>
          <button
            type="button"
            class="px-4 py-2 rounded-lg border text-sm transition cursor-pointer bg-primary text-primary-content border-primary disabled:opacity-50 disabled:cursor-not-allowed"
            @click="setAsCultureInterviewBlock()"
            x-show="canSetAsCultureInterviewBlock() && !isCurrentCultureInterviewBlock()"
            :disabled="placementSaving"
          >
            Поставить в блок интервью «Культура»
          </button>
          <button
            type="button"
            class="px-4 py-2 rounded-lg border text-sm transition cursor-pointer bg-base-100 text-base-content border-base-300 hover:bg-base-200 disabled:opacity-50 disabled:cursor-not-allowed"
            @click="clearCultureInterviewBlock()"
            x-show="isCurrentCultureInterviewBlock()"
            :disabled="placementSaving"
          >
            Снять из блока интервью
          </button>
        </>
      )}

      {allowCategoryLandingHero && (
        <>
          <button
            type="button"
            class="px-4 py-2 rounded-lg border text-sm transition cursor-pointer bg-primary text-primary-content border-primary disabled:opacity-50 disabled:cursor-not-allowed"
            @click="setCultureLandingHero()"
            x-show="canSetAsCultureLandingHero() && !isCurrentCultureLandingHero()"
            :disabled="placementSaving"
          >
            Hero «Культура» на landing
          </button>
          <button
            type="button"
            class="px-4 py-2 rounded-lg border text-sm transition cursor-pointer bg-base-100 text-base-content border-base-300 hover:bg-base-200 disabled:opacity-50 disabled:cursor-not-allowed"
            @click="clearCultureLandingHero()"
            x-show="isCurrentCultureLandingHero()"
            :disabled="placementSaving"
          >
            Снять hero «Культура» landing
          </button>
          <button
            type="button"
            class="px-4 py-2 rounded-lg border text-sm transition cursor-pointer bg-primary text-primary-content border-primary disabled:opacity-50 disabled:cursor-not-allowed"
            @click="setParisLandingHero()"
            x-show="canSetAsParisLandingHero() && !isCurrentParisLandingHero()"
            :disabled="placementSaving"
          >
            Hero «Париж» на landing
          </button>
          <button
            type="button"
            class="px-4 py-2 rounded-lg border text-sm transition cursor-pointer bg-base-100 text-base-content border-base-300 hover:bg-base-200 disabled:opacity-50 disabled:cursor-not-allowed"
            @click="clearParisLandingHero()"
            x-show="isCurrentParisLandingHero()"
            :disabled="placementSaving"
          >
            Снять hero «Париж» landing
          </button>
        </>
      )}

      {allowCategoryPageHero && (
        <>
          <button
            type="button"
            class="px-4 py-2 rounded-lg border text-sm transition cursor-pointer bg-primary text-primary-content border-primary disabled:opacity-50 disabled:cursor-not-allowed"
            @click="setCulturePageHero()"
            x-show="canSetAsCulturePageHero() && !isCurrentCulturePageHero()"
            :disabled="placementSaving"
          >
            Hero страницы /culture
          </button>
          <button
            type="button"
            class="px-4 py-2 rounded-lg border text-sm transition cursor-pointer bg-base-100 text-base-content border-base-300 hover:bg-base-200 disabled:opacity-50 disabled:cursor-not-allowed"
            @click="clearCulturePageHero()"
            x-show="isCurrentCulturePageHero()"
            :disabled="placementSaving"
          >
            Снять hero /culture
          </button>
          <button
            type="button"
            class="px-4 py-2 rounded-lg border text-sm transition cursor-pointer bg-primary text-primary-content border-primary disabled:opacity-50 disabled:cursor-not-allowed"
            @click="setParisPageHero()"
            x-show="canSetAsParisPageHero() && !isCurrentParisPageHero()"
            :disabled="placementSaving"
          >
            Hero страницы /paris
          </button>
          <button
            type="button"
            class="px-4 py-2 rounded-lg border text-sm transition cursor-pointer bg-base-100 text-base-content border-base-300 hover:bg-base-200 disabled:opacity-50 disabled:cursor-not-allowed"
            @click="clearParisPageHero()"
            x-show="isCurrentParisPageHero()"
            :disabled="placementSaving"
          >
            Снять hero /paris
          </button>
        </>
      )}
    </div>
  </div>
</section>
