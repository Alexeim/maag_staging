---
import Button from "@/components/common/Button.astro";

interface Props {
  heading?: string;
  className?: string;
}

const { heading = "Подвязка контента", className = "mt-8 mb-8" } =
  Astro.props as Props;
---

<section class={className}>
  <div class="rounded-2xl border border-base-300 bg-base-100 p-5 lg:p-6">
    <div class="flex flex-col gap-2">
      <h2 class="m-0 text-xl font-semibold text-base-content">{heading}</h2>
      <p class="m-0 text-sm text-base-content/70">
        Привяжи материалы по типам. В базу сохранится только массив ID для
        каждой коллекции.
      </p>
      <p x-show="contentListsLoading" class="m-0 text-sm text-base-content/60">
        Загружаем списки контента...
      </p>
    </div>

    <div
      class="mt-5 grid gap-3 lg:grid-cols-[220px_minmax(0,1fr)_auto] lg:items-end"
    >
      <div>
        <label class="mb-1 block text-sm font-medium text-base-content"
          >Тип контента</label
        >
        <select
          x-model="selectedRelatedContentType"
          @change="selectedRelatedContentId = ''"
          class="block w-full rounded-lg border border-base-300 bg-base-100 p-2.5 text-sm text-base-content focus:border-primary focus:ring-primary"
        >
          <option value="" disabled>Выберите тип...</option>
          <template x-for="type in relatedContentTypeOptions" :key="type.value">
            <option :value="type.value" x-text="type.label"></option>
          </template>
        </select>
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-base-content"
          >Контент</label
        >
        <select
          x-model="selectedRelatedContentId"
          :disabled="!selectedRelatedContentType || contentListsLoading"
          class="block w-full rounded-lg border border-base-300 bg-base-100 p-2.5 text-sm text-base-content focus:border-primary focus:ring-primary disabled:cursor-not-allowed disabled:opacity-60"
        >
          <option value="" disabled>Выберите материал...</option>
          <template
            x-for="item in getAvailableRelatedContentItems()"
            :key="item.id"
          >
            <option :value="item.id" x-text="item.title || item.id"></option>
          </template>
        </select>
      </div>

      <div class="flex justify-end">
        <Button
          variant="primary"
          type="button"
          @click="addRelatedContent()"
          :disabled="!selectedRelatedContentType || !selectedRelatedContentId || contentListsLoading"
          :class="{ 'opacity-50 cursor-not-allowed': !selectedRelatedContentType || !selectedRelatedContentId || contentListsLoading }"
        >
          Добавить
        </Button>
      </div>
    </div>

    <div class="mt-6 grid gap-4">
      <template x-for="type in relatedContentTypeOptions" :key="type.value">
        <section
          x-show="getSelectedEntityRelatedContent(type.value).length > 0"
          class="rounded-xl border border-base-300 bg-white p-4"
        >
          <div class="mb-3 flex items-center justify-between gap-3">
            <h3
              class="m-0 text-sm font-semibold uppercase tracking-[0.18em] text-base-content/65"
              x-text="type.label"
            >
            </h3>
            <span
              class="rounded-full bg-base-200 px-2.5 py-1 text-xs text-base-content/70"
              x-text="getSelectedEntityRelatedContent(type.value).length + ' шт.'"
            ></span>
          </div>

          <div class="grid gap-2">
            <template
              x-for="contentId in getSelectedEntityRelatedContent(type.value)"
              :key="`${type.value}-${contentId}`"
            >
              <div
                class="flex items-center justify-between gap-3 rounded-lg border border-base-300 bg-base-100 px-3 py-2"
              >
                <span
                  class="truncate text-sm text-base-content"
                  x-text="getRelatedContentItemLabel(type.value, contentId)"
                ></span>
                <Button
                  variant="error"
                  size="sm"
                  type="button"
                  @click="removeRelatedContent(type.value, contentId)"
                >
                  Удалить
                </Button>
              </div>
            </template>
          </div>
        </section>
      </template>
    </div>
  </div>
</section>
