---
import QuoteIcon from "@/assets/icons/quote.svg";
import { ChevronLeft, ChevronRight } from "lucide-astro";

interface Props {
  contentExpression?: string;
  imageAltLabel?: string;
}

const {
  contentExpression = "article.contentBlocks",
  imageAltLabel = "Article image",
} = Astro.props as Props;

const imageAltFallback = JSON.stringify(imageAltLabel);
const proseRailClass = "max-w-full lg:max-w-[826px] mx-0 lg:mx-auto";
const mediaRailClass = "w-full lg:max-w-[1200px] my-12 px-4 lg:px-0";
const breakoutRailClass = "w-full lg:max-w-[1278px] my-12 px-4 lg:px-0";
const wideBreakoutRailClass = "w-full lg:max-w-[1356px] my-12 px-4 lg:px-0";
---

<div class="flex flex-col items-center">
  <template x-for={`(block, index) in ${contentExpression}`} :key="block.id || `${block.type}-${index}`">
    <div class="w-full">
      <template x-if="['first-paragraph', 'paragraph', 'h1', 'h2', 'h3', 'quote', 'image', 'qa', 'link', 'url-link'].includes(block.type)">
        <div class={proseRailClass}>
          <article class="max-w-full space-y-12">
          <div
            x-show="block.type === 'first-paragraph'"
            class="article-rich-text article-rich-text--dropcap text-lg font-article-body text-justify"
            x-html="block.html || block.text"
          ></div>
          <div
            x-show="block.type === 'paragraph'"
            class="article-rich-text text-lg font-article-body text-justify"
            x-html="block.html || block.text"
          ></div>
          <h1
            x-show="block.type === 'h1'"
            class="text-3xl font-bold font-old_standard italic"
            x-text="block.text"
          ></h1>
          <h2
            x-show="block.type === 'h2'"
            class="text-2xl font-bold font-old_standard italic"
            x-text="block.text"
          ></h2>
          <h3
            x-show="block.type === 'h3'"
            class="text-2xl font-bold font-old_standard italic"
            x-text="block.text"
          ></h3>
          <div
            x-show="block.type === 'quote'"
            class="p-2 flex flex-col items-center justify-center gap-2"
          >
            <QuoteIcon class="w-8 h-8" />
            <blockquote
              class="text-3xl italic font-article-body pl-4 my-4"
              x-text="block.text"
            ></blockquote>
            <QuoteIcon class="w-8 h-8 rotate-180" />
          </div>
          <figure
            x-show="block.type === 'image' && block.url"
            class="not-prose flex flex-col items-center"
          >
            <img
              :src="block.url"
              :alt={`block.caption || ${imageAltFallback}`}
              class="article-image"
            />
            <figcaption
              x-show="block.caption"
              x-text="block.caption"
              class="text-center font-inter text-xs text-gray-500 mt-2"
            ></figcaption>
          </figure>
          <div x-show="block.type === 'qa'" class="space-y-4">
            <p
              x-show="block.question"
              x-text="block.question"
              class="text-xl font-article-body font-bold! italic"
            ></p>
            <p
              x-show="block.answer"
              x-text="block.answer"
              class="text-lg font-article-body text-justify"
            ></p>
          </div>
          <div
            x-show="block.type === 'link'"
            class="rounded-lg border border-base-300 bg-base-200/40 p-4 space-y-2"
          >
            <p
              class="text-xs uppercase tracking-[0.2em] text-base-content/60"
              x-text="getLinkedContentTypeLabel(block.linkedContentType)"
            ></p>
            <p
              class="text-sm font-medium text-base-content"
              x-text="getLinkedBlockTitle(block) || block.linkedContentTitle || 'Контент не выбран'"
            ></p>
            <p
              x-show="block.linkedContentId"
              class="text-xs text-base-content/60 break-all"
              x-text="block.linkedContentId"
            ></p>
          </div>
          <p
            x-show="block.type === 'url-link' && !(block.url || '').match(/^(https?:\\/\\/|\\/)/)"
            class="rounded-lg border border-base-300 bg-base-200/40 p-4 text-sm text-base-content/70"
          >
            <span class="font-medium text-base-content" x-text="block.text || '(без текста)'"></span>
            <span class="ml-2 break-all" x-text="block.url"></span>
          </p>
          <a
            x-show="block.type === 'url-link' && (block.url || '').match(/^(https?:\\/\\/|\\/)/)"
            :href="block.url"
            target="_blank"
            rel="noopener noreferrer"
            class="block rounded-lg border border-base-300 bg-base-200/40 p-4 text-sm text-primary hover:underline"
          >
            <span class="font-medium" x-text="block.text || block.url"></span>
            <span class="ml-2 break-all text-base-content/60" x-text="block.url"></span>
          </a>
          </article>
        </div>
      </template>

      <template x-if="block.type === 'video'">
        <div class={mediaRailClass}>
          <figure class="space-y-2">
          <video
            x-show="block.sourceType === 'upload' && block.url"
            :src="block.url"
            controls
            playsinline
            class="rounded-md w-full max-h-[620px] bg-black"
          ></video>
          <video
            x-show="block.sourceType === 'embed' && getVideoDirectUrl(block.url)"
            :src="getVideoDirectUrl(block.url)"
            controls
            playsinline
            class="rounded-md w-full max-h-[620px] bg-black"
          ></video>
          <div
            x-show="block.sourceType === 'embed' && getVideoEmbedUrl(block.url)"
            class="w-full aspect-video rounded-md overflow-hidden bg-black"
          >
            <iframe
              :src="getVideoEmbedUrl(block.url)"
              class="w-full h-full border-0"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          </div>
          <figcaption
            x-show="block.caption"
            x-text="block.caption"
            class="text-center font-inter text-xs text-gray-500 mt-2"
          ></figcaption>
          </figure>
        </div>
      </template>

      <template x-if="block.type === 'two-columns'">
        <div class={breakoutRailClass}>
          <div class="flex flex-col lg:flex-row gap-8 items-center">
          <div class="w-full lg:w-1/2 flex justify-center">
            <div x-show="block.left?.type === 'text'" class="article-rich-text text-lg font-article-body text-justify" x-html="getColumnRichTextInitialHtml(block.left)"></div>
            <figure x-show="block.left?.type === 'image'" class="flex flex-col items-center">
              <img :src="block.left?.content" :alt="block.left?.caption || 'Left column image'" class="article-image" />
              <figcaption x-show="block.left?.caption" x-text="block.left?.caption" class="text-center text-sm text-gray-500 mt-2"></figcaption>
            </figure>
            <div x-show="block.left?.type === 'quote'" class="w-full max-w-[420px]">
              <QuoteIcon class="w-8 h-8" />
              <blockquote x-text="block.left?.content" class="mt-4 text-base lg:text-lg leading-relaxed text-base-content/80 font-serif italic whitespace-pre-line"></blockquote>
              <QuoteIcon class="w-8 h-8 rotate-180 mt-4" />
            </div>
          </div>
          <div class="w-full lg:w-1/2 flex justify-center">
            <div x-show="block.right?.type === 'text'" class="article-rich-text text-lg font-article-body text-justify" x-html="getColumnRichTextInitialHtml(block.right)"></div>
            <figure x-show="block.right?.type === 'image'" class="flex flex-col items-center">
              <img :src="block.right?.content" :alt="block.right?.caption || 'Right column image'" class="article-image" />
              <figcaption x-show="block.right?.caption" x-text="block.right?.caption" class="text-center text-sm text-gray-500 mt-2"></figcaption>
            </figure>
            <div x-show="block.right?.type === 'quote'" class="w-full max-w-[420px]">
              <QuoteIcon class="w-8 h-8" />
              <blockquote x-text="block.right?.content" class="mt-4 text-base lg:text-lg leading-relaxed text-base-content/80 font-serif italic whitespace-pre-line"></blockquote>
              <QuoteIcon class="w-8 h-8 rotate-180 mt-4" />
            </div>
          </div>
          </div>
        </div>
      </template>

      <template x-if="block.type === 'three-columns'">
        <div class={wideBreakoutRailClass}>
          <div class="flex flex-col lg:flex-row gap-8 items-center">
          <template x-for="columnKey in ['left', 'center', 'right']" :key="columnKey">
            <div class="w-full lg:w-1/3 flex justify-center">
              <div x-show="block[columnKey]?.type === 'text'" class="article-rich-text text-lg font-article-body" x-html="getColumnRichTextInitialHtml(block[columnKey])"></div>
              <figure x-show="block[columnKey]?.type === 'image'" class="flex flex-col items-center">
                <img :src="block[columnKey]?.content" :alt="block[columnKey]?.caption || 'Column image'" class="article-image" />
                <figcaption x-show="block[columnKey]?.caption" x-text="block[columnKey]?.caption" class="text-center text-sm text-gray-500 mt-2"></figcaption>
              </figure>
              <div x-show="block[columnKey]?.type === 'quote'" class="w-full max-w-[420px]">
                <QuoteIcon class="w-8 h-8" />
                <blockquote x-text="block[columnKey]?.content" class="mt-4 text-base lg:text-lg leading-relaxed text-base-content/80 font-serif italic whitespace-pre-line"></blockquote>
                <QuoteIcon class="w-8 h-8 rotate-180 mt-4" />
              </div>
            </div>
          </template>
          </div>
        </div>
      </template>

      <template x-if="block.type === 'flipper' && Array.isArray(block.slides) && block.slides.length">
        <div class={breakoutRailClass}>
          <div x-data="{ current: 0 }">
          <div class="relative h-[360px] w-full sm:h-[460px] lg:h-[600px]">
            <div class="absolute inset-0 overflow-hidden">
              <div class="flex h-full transition-transform duration-500 ease-in-out" :style="`transform: translateX(-${current * 100}%)`">
                <template x-for="(slide, slideIndex) in (block.slides || [])" :key="slideIndex">
                  <div class="min-w-full h-full flex items-center justify-center">
                    <img :src="slide.imageUrl" :alt="slide.caption || 'Слайд'" class="block h-full w-auto max-w-full object-contain object-center" />
                  </div>
                </template>
              </div>
            </div>
            <button
              type="button"
              x-show="(block.slides || []).length > 1"
              class="absolute top-1/2 left-0 -translate-y-1/2 p-2 transition cursor-pointer text-neutral-400 hover:text-neutral-900 lg:-left-12"
              @click="current = (current - 1 + (block.slides || []).length) % (block.slides || []).length"
              aria-label="Предыдущий слайд"
            >
              <ChevronLeft class="h-6 w-6" />
            </button>
            <button
              type="button"
              x-show="(block.slides || []).length > 1"
              class="absolute top-1/2 right-0 -translate-y-1/2 p-2 transition cursor-pointer text-neutral-400 hover:text-neutral-900 lg:-right-12"
              @click="current = (current + 1) % (block.slides || []).length"
              aria-label="Следующий слайд"
            >
              <ChevronRight class="h-6 w-6" />
            </button>
          </div>
          <p
            x-show="(block.slides || [])[current]?.caption"
            x-text="(block.slides || [])[current]?.caption"
            class="text-center font-inter text-xs text-gray-500 mt-2 px-4 min-h-[1rem]"
          ></p>
          <div x-show="(block.slides || []).length > 1" class="flex justify-center gap-2 mt-4">
            <template x-for="(_, dotIndex) in (block.slides || [])" :key="dotIndex">
              <button
                type="button"
                class="w-2 h-2 rounded-full transition cursor-pointer"
                :class="current === dotIndex ? 'bg-base-content' : 'bg-base-content/30'"
                @click="current = dotIndex"
                :aria-label="'Слайд ' + (dotIndex + 1)"
              ></button>
            </template>
          </div>
          </div>
        </div>
      </template>

      <template x-if="block.type === 'one-big-one-small'">
        <div class={wideBreakoutRailClass}>
          <section class="w-full h-auto lg:relative lg:h-[calc(100vh-90px)]">
          <figure class="w-full lg:absolute lg:top-0 lg:left-0 lg:w-[300px]">
            <img x-show="block.portraitImageUrl" :src="block.portraitImageUrl" :alt="block.portraitImageCaption || 'Portrait article image'" class="block w-full aspect-[2/3] object-cover" />
            <figcaption x-show="block.portraitImageCaption" x-text="block.portraitImageCaption" class="mt-2 text-center font-inter text-xs text-gray-500"></figcaption>
          </figure>
          <figure class="mt-4 w-full lg:absolute lg:right-0 lg:bottom-0 lg:mt-0 lg:w-[1056px]">
            <img x-show="block.landscapeImageUrl" :src="block.landscapeImageUrl" :alt="block.landscapeImageCaption || 'Landscape article image'" class="block w-full aspect-[16/9] object-cover" />
            <figcaption x-show="block.landscapeImageCaption" x-text="block.landscapeImageCaption" class="mt-2 text-center font-inter text-xs text-gray-500"></figcaption>
          </figure>
          </section>
        </div>
      </template>

      <template x-if="block.type === 'collage'">
        <div class={wideBreakoutRailClass}>
          <section class="grid gap-4 lg:grid-cols-[280px_1fr_280px] lg:items-center">
            <figure x-show="block.leftPortraitImageUrl">
              <img :src="block.leftPortraitImageUrl" :alt="block.leftPortraitImageCaption || 'Left portrait image'" class="w-full aspect-[2/3] object-cover" />
              <figcaption x-show="block.leftPortraitImageCaption" x-text="block.leftPortraitImageCaption" class="mt-2 text-center font-inter text-xs text-gray-500"></figcaption>
            </figure>
            <div class="space-y-4">
              <figure x-show="block.topLandscapeImageUrl">
                <img :src="block.topLandscapeImageUrl" :alt="block.topLandscapeImageCaption || 'Top landscape image'" class="w-full aspect-[16/9] object-cover" />
                <figcaption x-show="block.topLandscapeImageCaption" x-text="block.topLandscapeImageCaption" class="mt-2 text-center font-inter text-xs text-gray-500"></figcaption>
              </figure>
              <figure x-show="block.mainLandscapeImageUrl">
                <img :src="block.mainLandscapeImageUrl" :alt="block.mainLandscapeImageCaption || 'Main landscape image'" class="w-full aspect-[16/9] object-cover" />
                <figcaption x-show="block.mainLandscapeImageCaption" x-text="block.mainLandscapeImageCaption" class="mt-2 text-center font-inter text-xs text-gray-500"></figcaption>
              </figure>
            </div>
            <figure x-show="block.rightPortraitImageUrl">
              <img :src="block.rightPortraitImageUrl" :alt="block.rightPortraitImageCaption || 'Right portrait image'" class="w-full aspect-[2/3] object-cover" />
              <figcaption x-show="block.rightPortraitImageCaption" x-text="block.rightPortraitImageCaption" class="mt-2 text-center font-inter text-xs text-gray-500"></figcaption>
            </figure>
          </section>
        </div>
      </template>
    </div>
  </template>
</div>

<style>
  .article-rich-text :global(p) {
    margin: 0 0 1rem;
  }

  .article-rich-text :global(p:last-child) {
    margin-bottom: 0;
  }

  .article-rich-text--dropcap :global(p:first-child::first-letter) {
    float: left;
    margin-top: -1rem;
    margin-right: 1.5rem;
    font-size: 4rem;
    font-family: 'Great Vibes', cursive;
    color: var(--color-maag-green);
  }
</style>
