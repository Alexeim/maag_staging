---
import {
  CalendarDays,
  CircleAlert,
  Clock3,
  Crown,
  Info,
  Lightbulb,
  MapPin,
  NotebookPen,
  Star,
} from "@lucide/astro";

interface Props {
  contentExpression?: string;
}

const { contentExpression = "article.contentBlocks" } = Astro.props as Props;

const iconClass = "mt-0.5 h-5 w-5 shrink-0 text-accent";
const iconStroke = 1.75;
---

<div class="max-w-[826px] mx-auto">
  <template x-for={`(item, index) in (${contentExpression} || []).filter((block) => block?.type === 'tips-item')`} :key="item.id || index">
    <article class="flex flex-col sm:flex-row py-8 gap-6">
      <div x-show="item.imageUrl" class="sm:w-[42%] shrink-0">
        <img
          :src="item.imageUrl"
          :alt="item.imageCaption || item.heading || `Пункт ${index + 1}`"
          class="w-full h-full object-cover min-h-[200px] max-h-[340px]"
        />
      </div>

      <div
        class="flex flex-col justify-start gap-3 px-5"
        :class="item.imageUrl ? 'sm:w-[58%]' : 'w-full'"
      >
        <h2
          x-show="item.heading"
          x-text="item.heading"
          class="text-xl font-bold font-old_standard"
        ></h2>
        <hr class="text-gray-300" />

        <template x-if="item.metaItems && item.metaItems.length > 0">
          <div class="flex flex-col gap-1.5">
            <template x-for="(metaItem, mi) in item.metaItems" :key="mi">
              <div>
                <p class="flex items-start gap-4 text-sm font-oswald tracking-wide text-base-content/70">
                  <!-- All icons pre-rendered at build time; Alpine shows the matching one -->
                  <span x-show="metaItem.icon === 'location'" class="contents">
                    <MapPin class={iconClass} strokeWidth={iconStroke} aria-hidden="true" />
                  </span>
                  <span x-show="metaItem.icon === 'clock'" class="contents">
                    <Clock3 class={iconClass} strokeWidth={iconStroke} aria-hidden="true" />
                  </span>
                  <span x-show="metaItem.icon === 'calendar'" class="contents">
                    <CalendarDays class={iconClass} strokeWidth={iconStroke} aria-hidden="true" />
                  </span>
                  <span x-show="metaItem.icon === 'bulb'" class="contents">
                    <Lightbulb class={iconClass} strokeWidth={iconStroke} aria-hidden="true" />
                  </span>
                  <span x-show="metaItem.icon === 'pen'" class="contents">
                    <NotebookPen class={iconClass} strokeWidth={iconStroke} aria-hidden="true" />
                  </span>
                  <span x-show="metaItem.icon === 'crown'" class="contents">
                    <Crown class={iconClass} strokeWidth={iconStroke} aria-hidden="true" />
                  </span>
                  <span x-show="metaItem.icon === 'star'" class="contents">
                    <Star class={iconClass} strokeWidth={iconStroke} aria-hidden="true" />
                  </span>
                  <span x-show="metaItem.icon === 'alert'" class="contents">
                    <CircleAlert class={iconClass} strokeWidth={iconStroke} aria-hidden="true" />
                  </span>
                  <span x-show="metaItem.icon === 'info'" class="contents">
                    <Info class={iconClass} strokeWidth={iconStroke} aria-hidden="true" />
                  </span>

                  <a
                    x-show="metaItem.isLink && metaItem.url"
                    :href="metaItem.url"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline hover:text-base-content transition-colors"
                    x-text="metaItem.text"
                  ></a>
                  <span
                    x-show="!metaItem.isLink || !metaItem.url"
                    x-text="metaItem.text"
                  ></span>
                </p>
                <hr class="text-gray-300" />
              </div>
            </template>
          </div>
        </template>

        <div
          x-show="item.html || item.text"
          x-html="item.html || item.text"
          class="tips-rich-text text-sm font-inter text-base-content/80 mt-1"
        ></div>
      </div>
    </article>
  </template>
</div>

<style>
  .tips-rich-text :global(p) {
    margin: 0 0 0.6rem;
  }

  .tips-rich-text :global(p:last-child) {
    margin-bottom: 0;
  }

  .tips-rich-text :global(strong) {
    font-weight: 600;
  }

  .tips-rich-text :global(em) {
    font-style: italic;
  }

  .tips-rich-text :global(u) {
    text-decoration: underline;
  }

  .tips-rich-text :global(a) {
    text-decoration: underline;
    transition: opacity 0.15s;
  }

  .tips-rich-text :global(a:hover) {
    opacity: 0.7;
  }
</style>
