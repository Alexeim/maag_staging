                  <span x-show="block.left?.type === 'image' && block.left?.caption" x-text="block.left?.caption" class="text-xs text-base-content/60 mt-1"></span>
                </div>
                <div x-show="block.type === 'three-columns'" class="w-full lg:w-1/3 flex flex-col items-center rounded-lg border border-base-300 bg-base-200/30 p-3">
                  <p class="text-xs uppercase tracking-[0.2em] text-base-content/60 mb-2">Центральная колонка</p>
                  <img
                    x-show="block.center?.type === 'image'"
                    :src="block.center?.content"
                    :alt="block.center?.caption || 'Центральная колонка'"
                    class="rounded-md max-h-32 object-cover"
                  />
                  <div
                    x-show="block.center?.type === 'text'"
                    x-html="getColumnRichTextInitialHtml(block.center)"
                    class="article-rich-text text-sm text-base-content/80"
                  ></div>
                  <div x-show="block.center?.type === 'quote'" class="w-full max-w-[420px]">
                    <QuoteIcon class="w-8 h-8" />
                    <blockquote
                      x-text="block.center?.content"
                      class="mt-4 text-base lg:text-lg leading-relaxed text-base-content/80 font-serif italic whitespace-pre-line"
                    ></blockquote>
                    <QuoteIcon class="w-8 h-8 rotate-180 mt-4" />
                  </div>
                  <span x-show="block.center?.type === 'image' && block.center?.caption" x-text="block.center?.caption" class="text-xs text-base-content/60 mt-1"></span>
                </div>
                <div class="w-full flex flex-col items-center rounded-lg border border-base-300 bg-base-200/30 p-3" :class="block.type === 'three-columns' ? 'lg:w-1/3' : 'lg:w-1/2'">
                  <p class="text-xs uppercase tracking-[0.2em] text-base-content/60 mb-2">Правая колонка</p>
                  <img
                    x-show="block.right?.type === 'image'"
                    :src="block.right?.content"
                    :alt="block.right?.caption || 'Правая колонка'"
                    class="rounded-md max-h-32 object-cover"
                  />
                  <div
                    x-show="block.right?.type === 'text'"
                    x-html="getColumnRichTextInitialHtml(block.right)"
                    class="article-rich-text text-sm text-base-content/80"
                  ></div>
                  <div x-show="block.right?.type === 'quote'" class="w-full max-w-[420px]">
                    <QuoteIcon class="w-8 h-8" />
                    <blockquote
                      x-text="block.right?.content"
                      class="mt-4 text-base lg:text-lg leading-relaxed text-base-content/80 font-serif italic whitespace-pre-line"
                    ></blockquote>
                    <QuoteIcon class="w-8 h-8 rotate-180 mt-4" />
                  </div>
                  <span x-show="block.right?.type === 'image' && block.right?.caption" x-text="block.right?.caption" class="text-xs text-base-content/60 mt-1"></span>
                </div>
                </div>
              </div>

              <template x-if="block.type === 'link'">
                <div class="rounded-lg border border-base-300 bg-base-200/40 p-4 space-y-2">
                  <p
                    class="text-xs uppercase tracking-[0.2em] text-base-content/60"
                    x-text="getLinkedContentTypeLabel(block.linkedContentType)"
                  ></p>
                  <p
                    class="text-sm font-medium text-base-content"
                    x-text="getLinkedBlockTitle(block) || 'Контент не выбран'"
                  ></p>
                  <p
                    x-show="block.linkedContentId"
                    class="text-xs text-base-content/60 break-all"
                    x-text="block.linkedContentId"
                  ></p>
                </div>
              </template>

              <template x-if="block.type === 'url-link'">
                <p class="rounded-lg border border-base-300 bg-base-200/40 p-4 text-sm text-base-content/70">
                  <span class="font-medium text-base-content" x-text="block.text || '(без текста)'"></span>
                  <span class="ml-2" x-text="block.url"></span>
                </p>
              </template>

              <template x-if="block.type === 'flipper'">
                <div class="space-y-2">
                  <p class="text-xs uppercase tracking-[0.2em] text-base-content/60">Листалка</p>
                  <div class="flex gap-2 overflow-x-auto pb-1">
                    <template x-for="(slide, si) in block.slides" :key="si">
                      <div class="flex-none">
                        <img x-show="slide.imageUrl" :src="slide.imageUrl" alt="Слайд" class="rounded max-h-24 object-cover" />
                        <div x-show="!slide.imageUrl" class="w-24 h-24 bg-base-200 rounded flex items-center justify-center text-xs text-base-content/50">Нет фото</div>
                      </div>
                    </template>
                  </div>
                  <p class="text-xs text-base-content/60" x-text="(block.slides?.length || 0) + ' слайд(ов)'"></p>
                </div>
              </template>

              <div
                class="absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity flex gap-2"
              >
                <Button variant="outline" size="sm" @click="editBlock(index)"
                  >Редактировать</Button
                >
                <Button variant="error" size="sm" @click="deleteBlock(index)"
                  >Удалить</Button
                >
              </div>
            </div>
          </template>
        </div>
      </template>
    </div>

    <div class="mt-6">
      <template x-if="showBlockOptions">
        <div
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 p-4 border border-base-300 rounded-lg bg-base-100"
        >
          <button
            @click="addBlock('paragraph')"
            class="p-2 rounded-lg cursor-pointer text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-gray-100"
            >Обычный абзац</button
          >
          <button
            @click="addBlock('first-paragraph')"
            class="p-2 rounded-lg cursor-pointer text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-gray-100"
            >Абзац с буквицей</button
          >
          <button
            @click="addBlock('h2')"
            class="p-2 rounded-lg cursor-pointer text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-gray-100"
            >Подзаголовок H2</button
          >
          <button
            @click="addBlock('h3')"
            class="p-2 rounded-lg cursor-pointer text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-gray-100"
            >Подзаголовок H3</button
          >
          <button
            @click="addBlock('quote')"
            class="p-2 rounded-lg cursor-pointer text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-gray-100"
            >Цитата</button
          >
          <button
            @click="addBlock('image')"
            class="p-2 rounded-lg cursor-pointer text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-gray-100"
            >Картинка</button
          >
          <button
            @click="addBlock('two-columns')"
            class="p-2 rounded-lg cursor-pointer text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-gray-100"
            >Две колонки</button
          >
          <button
            @click="addBlock('three-columns')"
            class="p-2 rounded-lg cursor-pointer text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-gray-100"
            >Три колонки</button
          >
          <button
            @click="addBlock('link')"
            class="p-2 rounded-lg cursor-pointer text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-gray-100"
            >Блок-ссылка</button
          >
          <button
            @click="addBlock('url-link')"
            class="p-2 rounded-lg cursor-pointer text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-gray-100"
            >Ссылка на URL</button
          >
          <button
            @click="addBlock('video')"
            class="p-2 rounded-lg cursor-pointer text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-gray-100"
            >Видео</button
          >
          <button
            @click="addBlock('flipper')"
            class="p-2 rounded-lg cursor-pointer text-gray-900 bg-white border border-gray-300 hover:bg-gray-100 focus:ring-gray-100"
            >Листалка</button
          >
        </div>
      </template>

      <div x-show="!showBlockOptions" class="text-center">
        <Button variant="primary" @click="openBlockSelector()"
          >+ Добавить блок</Button
        >
      </div>
    </div>
  </section>

  <div
    class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
  >
    <div class="flex gap-2">
      <template x-if="isEditMode && articleId">
        <button
          type="button"
          class="cursor-pointer text-white bg-red-700 hover:bg-red-800 focus:ring-red-300 flex flex-row items-center justify-center px-4 py-2 rounded-lg"
          @click="deleteArticle(deleteRedirect)"
        >
          Удалить статью
        </button>
      </template>
    </div>
    <div class="flex justify-end gap-3">
      <Button variant="secondary" @click="previewArticle()">Предпросмотр</Button
      >
      {
        cancelHref && (
          <a
            href={cancelHref}
            class="cursor-pointer text-white bg-yellow-400 hover:bg-yellow-500 focus:ring-yellow-300 flex flex-row items-center justify-center px-4 py-2 rounded-lg"
          >
            Отмена
          </a>
        )
      }
      <Button variant="primary" @click="saveArticle()" :disabled="isSaving" :class="{'opacity-50 cursor-not-allowed': isSaving}">{submitLabel}</Button>
    </div>
  </div>
</div>
