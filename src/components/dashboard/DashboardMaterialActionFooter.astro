---
import Button from "@/components/common/Button.astro";
import PublicationToggle from "@/components/dashboard/PublicationToggle.astro";

interface Props {
  cancelHref?: string;
  deleteAction?: string;
  deleteDisabled?: string;
  deleteLabel?: string;
  deleteVisible?: string;
  previewAction: string;
  previewDisabled?: string;
  publishedModel: string;
  saveAction: string;
  saveDisabled?: string;
  saveLabel: string;
  showDelete?: boolean;
}

const {
  cancelHref,
  deleteAction,
  deleteDisabled,
  deleteLabel = "Удалить",
  deleteVisible,
  previewAction,
  previewDisabled,
  publishedModel,
  saveAction,
  saveDisabled,
  saveLabel,
  showDelete = false,
} = Astro.props as Props;

const disabledClass = (expression?: string) =>
  expression ? `{'opacity-50 cursor-not-allowed': ${expression}}` : undefined;
---

<div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
  <div class="flex gap-2">
    {
      showDelete && deleteAction && (
        <Button
          variant="error"
          @click={deleteAction}
          :disabled={deleteDisabled}
          :class={disabledClass(deleteDisabled)}
          x-show={deleteVisible}
        >
          {deleteLabel}
        </Button>
      )
    }
  </div>
  <div class="flex justify-end gap-3">
    <PublicationToggle model={publishedModel} />
    {cancelHref && <Button href={cancelHref} variant="secondary">Отмена</Button>}
    <Button
      variant="secondary"
      @click={previewAction}
      :disabled={previewDisabled}
      :class={disabledClass(previewDisabled)}
    >
      Предпросмотр
    </Button>
    <Button
      variant="primary"
      @click={saveAction}
      :disabled={saveDisabled}
      :class={disabledClass(saveDisabled)}
    >
      {saveLabel}
    </Button>
  </div>
</div>
