---
interface Props {
  published?: boolean | null;
}

const { published = false } = Astro.props as Props;
---

<span class="inline-flex items-center gap-2">
  <span
    class:list={[
      "h-3 w-3 rounded-full border",
      published ? "border-success bg-success" : "border-base-content/30 bg-transparent",
    ]}
    aria-hidden="true"
  ></span>
  <span class="sr-only">{published ? "Опубликовано" : "Черновик"}</span>
</span>
