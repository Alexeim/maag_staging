---
import Button from "@/components/common/Button.astro";
import { CloudUpload } from "lucide-astro";
import cultureTags from "@/content/tags/CultureTags.json";
import parisTags from "@/content/tags/ParisTags.json";
import locationIcon from "@/assets/icons/new/location.svg?raw";
import timeIcon from "@/assets/icons/new/time.svg?raw";

interface Props {
  heading: string;
  submitLabel: string;
  tipsCreatorState: string;
  cancelHref?: string;
  deleteArticleId?: string | null;
  deleteRedirect?: string;
}

const {
  heading,
  submitLabel,
  tipsCreatorState,
  cancelHref,
  deleteArticleId,
  deleteRedirect = "/dashboard",
} = Astro.props as Props;

const allCultureTags = cultureTags.cultureTags;
const allParisTags = parisTags.parisTags;
---

<div
  class="max-w-4xl mx-auto"
  x-data={`$lazy('tipsArticleCreator', ${tipsCreatorState})`}
>
  <h1 class="text-3xl font-bold mb-6">{heading}</h1>

  <!-- ── Основная информация ──────────────────────────────────────────────── -->
  <section class="mb-6 p-6 bg-base-100 border border-base-300 rounded-xl shadow-sm">
    <h2 class="text-xl font-semibold mb-4">Основная информация</h2>

    <!-- Title -->
    <label class="block text-sm font-medium text-base-content mb-2">Заголовок</label>
    <template x-if="isEditingTitle">
      <div>
        <input
          type="text"
          x-model="editingTitleText"
          class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
          placeholder="Например: 10 спектаклей, которые нельзя пропустить"
        />
        <div class="flex justify-end gap-3 mt-3">
          <Button variant="secondary" size="sm" @click="cancelEditTitle()">Отмена</Button>
          <Button variant="primary" size="sm" @click="saveTitle()">Сохранить</Button>
        </div>
      </div>
    </template>
    <template x-if="!isEditingTitle">
      <div class="flex justify-between items-center border border-base-300 rounded-lg px-4 py-3">
        <h3 class="text-lg font-semibold" x-text="article.title || 'Введите заголовок...'"></h3>
        <Button variant="outline" size="sm" @click="editTitle()">Редактировать</Button>
      </div>
    </template>

    <!-- Lead -->
    <div class="mt-4">
      <label class="block text-sm font-medium text-base-content mb-2">Вводка (лид)</label>
      <textarea
        x-model="article.lead"
        rows="3"
        class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
        placeholder="Краткое описание под заголовком (необязательно)"
      ></textarea>
    </div>

    <!-- Author -->
    <div class="mt-6 space-y-3">
      <label class="block text-sm font-medium text-base-content">Автор</label>
      <div class="flex flex-wrap gap-2">
        <button
          type="button"
          @click="useNewAuthor = false"
          class="px-3 py-2 border text-sm cursor-pointer"
          :class="!useNewAuthor ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 border-base-300 text-base-content'"
        >
          Выбрать из списка
        </button>
        <button
          type="button"
          @click="useNewAuthor = true"
          class="px-3 py-2 border text-sm cursor-pointer"
          :class="useNewAuthor ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 border-base-300 text-base-content'"
        >
          Новый автор
        </button>
      </div>

      <div x-show="!useNewAuthor">
        <select
          x-model="selectedAuthorId"
          class="bg-base-100 border border-base-300 text-base-content text-sm focus:ring-primary focus:border-primary block w-full p-2.5 cursor-pointer"
        >
          <option value="">Выберите автора...</option>
          <template x-for="author in authors" :key="author.id">
            <option :value="author.id" x-text="getAuthorLabel(author)"></option>
          </template>
        </select>
        <p x-show="authorsLoading" class="text-xs text-base-content/60 mt-1">Загружаем авторов...</p>
      </div>

      <div x-show="useNewAuthor" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <input
          type="text"
          x-model="newAuthorFirstName"
          class="bg-base-100 border border-base-300 text-base-content text-sm focus:ring-primary focus:border-primary block w-full p-2.5"
          placeholder="Имя автора"
        />
        <input
          type="text"
          x-model="newAuthorLastName"
          class="bg-base-100 border border-base-300 text-base-content text-sm focus:ring-primary focus:border-primary block w-full p-2.5"
          placeholder="Фамилия автора"
        />
      </div>
    </div>

    <hr class="my-6" />

    <!-- Category -->
    <label class="block text-sm font-medium text-base-content mb-2">Категория</label>
    <select
      x-model="article.category"
      class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 cursor-pointer"
    >
      <option value="culture">Культура</option>
      <option value="paris">Париж</option>
    </select>

    <!-- Flags -->
    <div class="mt-4 flex items-center gap-3">
      <input
        id="hot-content-flag"
        type="checkbox"
        x-model="article.isHotContent"
        class="w-4 h-4 text-primary bg-base-200 border-base-300 rounded-sm focus:ring-primary focus:ring-2 cursor-pointer"
      />
      <label for="hot-content-flag" class="text-sm font-medium text-base-content cursor-pointer">
        Отметить как «Самое читаемое»
      </label>
    </div>
    <div class="mt-4 flex items-center gap-3">
      <input
        id="on-landing-flag"
        type="checkbox"
        x-model="article.isOnLanding"
        class="w-4 h-4 text-primary bg-base-200 border-base-300 rounded-sm focus:ring-primary focus:ring-2 cursor-pointer"
      />
      <label for="on-landing-flag" class="text-sm font-medium text-base-content cursor-pointer">
        Показывать как главную статью на посадочной странице
      </label>
    </div>
    <div class="mt-4 flex items-center gap-3">
      <input
        id="main-in-category-flag"
        type="checkbox"
        x-model="article.isMainInCategory"
        class="w-4 h-4 text-primary bg-base-200 border-base-300 rounded-sm focus:ring-primary focus:ring-2 cursor-pointer"
      />
      <label for="main-in-category-flag" class="text-sm font-medium text-base-content cursor-pointer">
        Показывать как главную статью в категории
      </label>
    </div>

    <hr class="my-6" />

    <!-- Tags -->
    <label class="block text-sm font-medium text-base-content mb-3">Теги</label>
    <div class="flex flex-wrap gap-2">
      <template x-if="article.category === 'culture'">
        <template x-for={`tag in ${JSON.stringify(allCultureTags)}`} :key="tag.value">
          <button
            type="button"
            class="px-4 py-2 rounded-full border text-sm transition cursor-pointer"
            :class="isTagSelected(tag.value) ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 text-base-content border-base-300 hover:bg-base-200'"
            @click="toggleTag(tag.value)"
          >
            <span x-text="tag.title"></span>
          </button>
        </template>
      </template>
      <template x-if="article.category === 'paris'">
        <template x-for={`tag in ${JSON.stringify(allParisTags)}`} :key="tag.value">
          <button
            type="button"
            class="px-4 py-2 rounded-full border text-sm transition cursor-pointer"
            :class="isTagSelected(tag.value) ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 text-base-content border-base-300 hover:bg-base-200'"
            @click="toggleTag(tag.value)"
          >
            <span x-text="tag.title"></span>
          </button>
        </template>
      </template>
    </div>

    <div class="mt-4 flex flex-col sm:flex-row gap-2">
      <input
        type="text"
        x-model="newTagInput"
        class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
        placeholder="Добавь тег латиницей, например theatre"
      />
      <Button variant="outline" size="sm" type="button" @click="addCustomTag()">Добавить тег</Button>
    </div>
    <p class="text-xs text-base-content/60 mt-1">
      Техническое значение тега уходит в базу данных, поэтому используй латиницу.
    </p>

    <div class="mt-3 flex flex-wrap gap-2">
      <template x-for="tag in article.tags" :key="tag">
        <span class="inline-flex items-center gap-2 px-3 py-1 bg-base-200 rounded-full text-sm">
          <span x-text="tag"></span>
          <button
            type="button"
            class="text-base-content/60 hover:text-base-content cursor-pointer"
            @click="removeTag(tag)"
          >×</button>
        </span>
      </template>
    </div>

    <hr class="my-6" />

    <!-- Cover image -->
    <label class="block text-sm font-medium text-base-content mb-2">Обложка (необязательно)</label>
    <div class="flex items-center" x-data="{ fileName: '' }">
      <label
        for="cover-upload"
        class="cursor-pointer text-white bg-green-700 hover:bg-green-800 rounded-2xl flex flex-row gap-2 items-center justify-center py-2 px-4"
      >
        <CloudUpload />
        Загрузить файл
      </label>
      <input
        id="cover-upload"
        type="file"
        class="hidden"
        @change="handleCoverUpload($event); fileName = $event.target.files[0]?.name || ''"
        accept="image/png, image/jpeg, image/webp"
      />
      <span
        x-text="fileName ? fileName : (article.imageUrl ? 'Изображение загружено' : 'Файл не выбран')"
        class="ml-4 text-sm text-base-content/70"
      ></span>
    </div>
    <div x-show="uploading" class="mt-4">
      <p>Загрузка: <span x-text="uploadProgress.toFixed(2) + '%'"></span></p>
      <div class="w-full bg-base-200 rounded-full h-2">
        <div class="bg-primary h-2 rounded-full" :style="{ width: uploadProgress + '%' }"></div>
      </div>
    </div>
    <div x-show="article.imageUrl && !uploading" class="mt-4 space-y-4">
      <p class="text-sm text-success">Главное изображение загружено!</p>
      <img :src="article.imageUrl" alt="Предпросмотр обложки" class="rounded-md max-h-60 w-full object-cover" />
      <div>
        <label class="block text-sm font-medium text-base-content mb-2">Подпись к изображению</label>
        <template x-if="isEditingCaption">
          <div>
            <input
              type="text"
              x-model="editingCaptionText"
              class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
              placeholder="Введите подпись..."
            />
            <div class="flex justify-end gap-3 mt-3">
              <Button variant="secondary" size="sm" @click="cancelEditCaption()">Отмена</Button>
              <Button variant="primary" size="sm" @click="saveCaption()">Сохранить</Button>
            </div>
          </div>
        </template>
        <template x-if="!isEditingCaption">
          <div class="flex justify-between items-center border border-base-300 rounded-lg px-4 py-3">
            <p class="text-base-content" x-text="article.imageCaption || 'Подпись отсутствует...'"></p>
            <Button variant="outline" size="sm" @click="editCaption()">Редактировать</Button>
          </div>
        </template>
      </div>
    </div>
  </section>

  <!-- ── Пункты списка ─────────────────────────────────────────────────────── -->
  <section class="mb-6 p-6 bg-base-100 border border-base-300 rounded-xl shadow-sm">
    <h2 class="text-xl font-semibold mb-1">Пункты статьи</h2>
    <p class="text-sm text-base-content/60 mb-6">
      Каждый пункт — отдельная «главка» со своим заголовком, мета-строками и текстом.
    </p>

    <div class="space-y-4">
      <template x-for="(block, index) in article.contentBlocks" :key="index">
        <div>

          <!-- Collapsed preview — card layout matching public page -->
          <template x-if="editingIndex !== index">
            <div>
              <!-- Card preview -->
              <div class="flex flex-col sm:flex-row gap-6 py-6">
                <!-- Left: image -->
                <template x-if="block.imageUrl">
                  <div class="sm:w-[42%] shrink-0 bg-base-200">
                    <img
                      :src="block.imageUrl"
                      :alt="block.heading || 'Фото'"
                      class="w-full h-full object-cover"
                      style="min-height:160px; max-height:220px;"
                    />
                  </div>
                </template>
                <!-- Right: content -->
                <div class="flex flex-col justify-start gap-2 p-4" :class="block.imageUrl ? 'sm:w-[58%]' : 'w-full'">
                  <p class="font-bold font-oswald tracking-wide leading-snug" x-text="block.heading || '(без заголовка)'"></p>
                  <template x-if="block.meta1">
                    <p class="flex items-center gap-1.5 text-xs text-base-content/60 font-oswald">
                      <span class="opacity-50" set:html={locationIcon} />
                      <span x-text="block.meta1"></span>
                    </p>
                  </template>
                  <template x-if="block.meta2">
                    <p class="flex items-center gap-1.5 text-xs text-base-content/60 font-oswald">
                      <span class="opacity-50" set:html={timeIcon} />
                      <span x-text="block.meta2"></span>
                    </p>
                  </template>
                  <p class="text-xs text-base-content/50 font-oswald font-thin line-clamp-2" x-show="block.text" x-text="block.text"></p>
                </div>
              </div>
              <!-- Controls row -->
              <div class="flex items-center justify-between gap-2 px-4 py-2 border-t border-base-300 bg-base-200/40">
                <span class="text-base-content/40 text-xs font-mono" x-text="'#' + (index + 1)"></span>
                <div class="flex items-center gap-2">
                  <button
                    type="button"
                    @click="moveBlock(index, 'up')"
                    :disabled="index === 0"
                    class="p-1 rounded hover:bg-base-200 disabled:opacity-30 cursor-pointer"
                    title="Вверх"
                  >↑</button>
                  <button
                    type="button"
                    @click="moveBlock(index, 'down')"
                    :disabled="index === article.contentBlocks.length - 1"
                    class="p-1 rounded hover:bg-base-200 disabled:opacity-30 cursor-pointer"
                    title="Вниз"
                  >↓</button>
                  <Button variant="outline" size="sm" @click="editBlock(index)">Редактировать</Button>
                  <Button variant="error" size="sm" @click="deleteBlock(index)">Удалить</Button>
                </div>
              </div>
            </div>
          </template>

          <!-- Expanded editor -->
          <template x-if="editingIndex === index">
            <div class="p-5 space-y-5" x-data="{ itemFileName: '' }">
              <h3 class="font-semibold text-base-content">
                Пункт <span x-text="index + 1"></span>
              </h3>

              <!-- Heading -->
              <div>
                <label class="block text-sm font-medium text-base-content mb-1">Заголовок главки</label>
                <input
                  type="text"
                  x-model="editingBlock.heading"
                  class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
                  placeholder="Например: Большой театр"
                />
              </div>

              <!-- Item image -->
              <div>
                <label class="block text-sm font-medium text-base-content mb-2">
                  Фотография пункта (необязательно)
                </label>
                <div class="flex items-center gap-3">
                  <label
                    :for="'item-img-' + index"
                    class="cursor-pointer text-white bg-green-700 hover:bg-green-800 rounded-2xl flex flex-row gap-2 items-center justify-center py-2 px-4 text-sm"
                  >
                    <CloudUpload class="w-4 h-4" />
                    Загрузить
                  </label>
                  <input
                    :id="'item-img-' + index"
                    type="file"
                    class="hidden"
                    @change="handleItemImageUpload($event); itemFileName = $event.target.files[0]?.name || ''"
                    accept="image/png, image/jpeg, image/webp"
                  />
                  <span
                    x-text="itemFileName || (editingBlock.imageUrl ? 'Фото загружено' : 'Файл не выбран')"
                    class="text-sm text-base-content/70"
                  ></span>
                </div>
                <div x-show="uploading" class="mt-3">
                  <div class="w-full bg-base-200 rounded-full h-2">
                    <div class="bg-primary h-2 rounded-full" :style="{ width: uploadProgress + '%' }"></div>
                  </div>
                </div>
                <div x-show="editingBlock.imageUrl && !uploading" class="mt-3 space-y-2">
                  <img :src="editingBlock.imageUrl" alt="Фото пункта" class="rounded-md max-h-48 object-cover" />
                  <input
                    type="text"
                    x-model="editingBlock.imageCaption"
                    class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
                    placeholder="Подпись к фото (необязательно)"
                  />
                </div>
              </div>

              <!-- Meta 1 -->
              <div>
                <label class="block text-sm font-medium text-base-content mb-1">
                  Мета-строка 1
                  <span class="text-base-content/50 font-normal">(место, время, цена и т.д.)</span>
                </label>
                <input
                  type="text"
                  x-model="editingBlock.meta1"
                  class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
                  placeholder="Например: ул. Театральная пл., 1 / с 14:00 до 18:00"
                />
              </div>

              <!-- Meta 2 -->
              <div class="space-y-2">
                <label class="block text-sm font-medium text-base-content mb-1">
                  Мета-строка 2
                  <span class="text-base-content/50 font-normal">(ссылка или доп. инфо)</span>
                </label>
                <input
                  type="text"
                  x-model="editingBlock.meta2"
                  class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
                  placeholder="Текст строки или текст ссылки"
                />
                <div class="flex items-center gap-3">
                  <input
                    :id="'meta2-link-' + index"
                    type="checkbox"
                    x-model="editingBlock.meta2IsLink"
                    class="w-4 h-4 text-primary bg-base-200 border-base-300 rounded-sm focus:ring-primary focus:ring-2 cursor-pointer"
                  />
                  <label :for="'meta2-link-' + index" class="text-sm text-base-content cursor-pointer">
                    Это ссылка
                  </label>
                </div>
                <div x-show="editingBlock.meta2IsLink">
                  <input
                    type="url"
                    x-model="editingBlock.meta2Url"
                    class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
                    placeholder="https://..."
                  />
                </div>
              </div>

              <!-- Body text -->
              <div>
                <label class="block text-sm font-medium text-base-content mb-1">Текст</label>
                <textarea
                  x-model="editingBlock.text"
                  rows="5"
                  class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
                  placeholder="Основной текст пункта..."
                ></textarea>
              </div>

              <div class="flex justify-end gap-3">
                <Button variant="secondary" size="sm" @click="cancelEdit()">Отмена</Button>
                <Button variant="primary" size="sm" @click="updateBlock()">Сохранить пункт</Button>
              </div>
            </div>
          </template>
          <hr x-show="index < article.contentBlocks.length - 1" class="border-base-300 my-2" />
        </div>
      </template>
    </div>

    <div class="mt-6">
      <Button variant="outline" size="md" @click="addTipsItem()">
        + Добавить пункт
      </Button>
    </div>
  </section>

  <!-- ── Кнопки действий ───────────────────────────────────────────────────── -->
  <div class="flex justify-between items-center gap-4 mt-4 pb-16">
    <div class="flex gap-3">
      {cancelHref && (
        <a href={cancelHref}>
          <Button variant="secondary" size="md">Отмена</Button>
        </a>
      )}
      {deleteArticleId && (
        <Button
          variant="error"
          size="md"
          @click={`$store.ui.showConfirmation('Удалить статью?', async () => { await fetch('/api/articles/${deleteArticleId}', { method: 'DELETE', headers: { Authorization: 'Bearer ' + (await import('/src/lib/firebase/client.js').then(m => m.getIdToken())) } }); window.location.href = '${deleteRedirect}'; })`}
        >
          Удалить
        </Button>
      )}
    </div>
    <Button variant="primary" size="md" @click="saveArticle()">{submitLabel}</Button>
  </div>
</div>
