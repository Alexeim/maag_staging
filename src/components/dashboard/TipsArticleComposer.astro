---
import Button from "@/components/common/Button.astro";
import {
  CalendarDays,
  CircleAlert,
  Clock3,
  CloudUpload,
  Crown,
  Info,
  Lightbulb,
  MapPin,
  NotebookPen,
  Star,
} from "@lucide/astro";
import {
  categoryTags,
  parisDistrictTags,
} from "@/content/tags/parisTags";
import RelatedContentEditor from "@/components/dashboard/RelatedContentEditor.astro";
import LandingPlacementPanel from "@/components/dashboard/LandingPlacementPanel.astro";
import ContentCollectionsEditor from "@/components/dashboard/ContentCollectionsEditor.astro";
import PublicationStatusBanner from "@/components/dashboard/PublicationStatusBanner.astro";
import DashboardMaterialActionFooter from "@/components/dashboard/DashboardMaterialActionFooter.astro";

interface Props {
  heading: string;
  submitLabel: string;
  tipsCreatorState: string;
  cancelHref?: string;
  deleteArticleId?: string | null;
  deleteRedirect?: string;
}

const {
  heading,
  submitLabel,
  tipsCreatorState,
  cancelHref,
  deleteArticleId,
  deleteRedirect = "/dashboard/tips",
} = Astro.props as Props;

const allCultureTags = categoryTags.culture;
const allParisTags = categoryTags.paris;
const allParisDistricts = parisDistrictTags;
---

<div
  class="max-w-4xl mx-auto"
  x-data={`$lazy('tipsArticleCreator', ${tipsCreatorState})`}
>
  <h1 class="text-3xl font-bold mb-6">{heading}</h1>
  <PublicationStatusBanner model="article" />

  <!-- ── Основная информация ──────────────────────────────────────────────── -->
  <section class="mb-6 p-6 bg-base-100 border border-base-300 rounded-xl shadow-sm">
    <h2 class="text-xl font-semibold mb-4">Основная информация</h2>

    <!-- Title -->
    <label class="block text-sm font-medium text-base-content mb-2">Заголовок</label>
    <template x-if="isEditingTitle">
      <div>
        <input
          type="text"
          x-model="editingTitleText"
          class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
          placeholder="Например: 10 спектаклей, которые нельзя пропустить"
        />
        <div class="flex justify-end gap-3 mt-3">
          <Button variant="secondary" size="sm" @click="cancelEditTitle()">Отмена</Button>
          <Button variant="primary" size="sm" @click="saveTitle()">Сохранить</Button>
        </div>
      </div>
    </template>
    <template x-if="!isEditingTitle">
      <div class="flex justify-between items-center border border-base-300 rounded-lg px-4 py-3">
        <h3 class="text-lg font-semibold" x-text="article.title || 'Введите заголовок...'"></h3>
        <Button variant="outline" size="sm" @click="editTitle()">Редактировать</Button>
      </div>
    </template>

    <!-- Lead -->
    <div class="mt-4">
      <label class="block text-sm font-medium text-base-content mb-2">Вводка (лид)</label>
      <textarea
        x-model="article.lead"
        rows="3"
        class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
        placeholder="Краткое описание под заголовком (необязательно)"
      ></textarea>
    </div>

    <div class="mt-4">
      <label class="block text-sm font-medium text-base-content mb-2">Лид для карточки</label>
      <textarea
        x-model="article.cardLead"
        rows="2"
        class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
        placeholder="Короткий текст для карточек на лендинге и страницах категорий..."
      ></textarea>
    </div>

    <!-- Author -->
    <div class="mt-6 space-y-3">
      <label class="block text-sm font-medium text-base-content">Автор</label>
      <div class="flex flex-wrap gap-2">
        <button
          type="button"
          @click="useNewAuthor = false"
          class="px-3 py-2 border text-sm cursor-pointer"
          :class="!useNewAuthor ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 border-base-300 text-base-content'"
        >
          Выбрать из списка
        </button>
        <button
          type="button"
          @click="useNewAuthor = true"
          class="px-3 py-2 border text-sm cursor-pointer"
          :class="useNewAuthor ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 border-base-300 text-base-content'"
        >
          Новый автор
        </button>
      </div>

      <div x-show="!useNewAuthor">
        <select
          x-model="selectedAuthorId"
          class="bg-base-100 border border-base-300 text-base-content text-sm focus:ring-primary focus:border-primary block w-full p-2.5 cursor-pointer"
        >
          <option value="">Выберите автора...</option>
          <template x-for="author in authors" :key="author.id">
            <option :value="author.id" x-text="getAuthorLabel(author)"></option>
          </template>
        </select>
        <p x-show="authorsLoading" class="text-xs text-base-content/60 mt-1">Загружаем авторов...</p>
      </div>

      <div x-show="useNewAuthor" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <input
          type="text"
          x-model="newAuthorFirstName"
          class="bg-base-100 border border-base-300 text-base-content text-sm focus:ring-primary focus:border-primary block w-full p-2.5"
          placeholder="Имя автора"
        />
        <input
          type="text"
          x-model="newAuthorLastName"
          class="bg-base-100 border border-base-300 text-base-content text-sm focus:ring-primary focus:border-primary block w-full p-2.5"
          placeholder="Фамилия автора"
        />
      </div>
    </div>

    <hr class="my-6" />

    <!-- Category -->
    <label class="block text-sm font-medium text-base-content mb-2">Категория</label>
    <select
      x-model="article.category"
      @change="handleCategoryChange($event.target.value)"
      class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 cursor-pointer"
    >
      <option value="culture">Культура</option>
      <option value="paris">Париж</option>
    </select>

    <!-- Flags -->
    <div class="mt-4 flex items-center gap-3">
      <input
        id="hot-content-flag"
        type="checkbox"
        x-model="article.isHotContent"
        class="w-4 h-4 text-primary bg-base-200 border-base-300 rounded-sm focus:ring-primary focus:ring-2 cursor-pointer"
      />
      <label for="hot-content-flag" class="text-sm font-medium text-base-content cursor-pointer">
        Отметить как «Самое Читаемое»
      </label>
    </div>

    <div class="mt-4 flex items-center gap-3">
      <input
        id="tips-notebook-content-flag"
        type="checkbox"
        x-model="article.isNotebookContent"
        class="w-4 h-4 text-primary bg-base-200 border-base-300 rounded-sm focus:ring-primary focus:ring-2 cursor-pointer"
      />
      <label for="tips-notebook-content-flag" class="text-sm font-medium text-base-content cursor-pointer">
        Добавить в «Записную книжку»
      </label>
    </div>

    <div class="mt-4 flex items-center gap-3">
      <input
        id="tips-maag-choice-flag"
        type="checkbox"
        x-model="article.isMaagChoice"
        class="w-4 h-4 text-primary bg-base-200 border-base-300 rounded-sm focus:ring-primary focus:ring-2 cursor-pointer"
      />
      <label for="tips-maag-choice-flag" class="text-sm font-medium text-base-content cursor-pointer">
        Добавить в «Выбор MAAG»
      </label>
    </div>

    <hr class="my-6" />

    <!-- Tags -->
    <label
      class="block text-sm font-medium text-base-content mb-3"
      x-text="article.category === 'paris' ? 'Подкатегории Парижа' : 'Теги'"
    ></label>
    <div class="flex flex-wrap gap-2">
      <template x-if="article.category === 'culture'">
        <template x-for={`tag in ${JSON.stringify(allCultureTags)}`} :key="tag.value">
          <button
            type="button"
            class="px-4 py-2 rounded-full border text-sm transition cursor-pointer"
            :class="isTagSelected(tag.value) ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 text-base-content border-base-300 hover:bg-base-200'"
            @click="toggleTag(tag.value)"
          >
            <span x-text="tag.title"></span>
          </button>
        </template>
      </template>
      <template x-if="article.category === 'paris'">
        <template x-for={`tag in ${JSON.stringify(allParisTags)}`} :key="tag.value">
          <button
            type="button"
            class="px-4 py-2 rounded-full border text-sm transition cursor-pointer"
            :class="isTagSelected(tag.value) ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 text-base-content border-base-300 hover:bg-base-200'"
            @click="toggleTag(tag.value)"
          >
            <span x-text="tag.title"></span>
          </button>
        </template>
      </template>
    </div>

    <div class="mt-3 flex flex-col gap-3">
      <template x-if="getSelectedCategoryTags().length > 0">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-base-content/60">
            <span x-text="article.category === 'paris' ? 'Подкатегории Парижа' : 'Категорийные теги'"></span>
          </p>
          <div class="mt-1 flex flex-wrap gap-2">
            <template x-for="tag in getSelectedCategoryTags()" :key="tag">
              <span class="inline-flex items-center gap-2 px-3 py-1 bg-base-200 rounded-full text-sm">
                <span x-text="getTagLabel(tag)"></span>
                <button
                  type="button"
                  class="text-base-content/60 hover:text-base-content cursor-pointer"
                  @click="removeTag(tag)"
                >×</button>
              </span>
            </template>
          </div>
        </div>
      </template>

    </div>

    <template x-if="article.category === 'paris'">
      <div class="mt-6">
        <label class="block text-sm font-medium text-base-content mb-2">
          Округ Парижа
        </label>
        <select
          x-model="article.parisDistrict"
          class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5 cursor-pointer"
        >
          <option value="">Не указывать округ</option>
          <template x-for={`district in ${JSON.stringify(allParisDistricts)}`} :key="district.value">
            <option :value="district.value" x-text="district.title"></option>
          </template>
        </select>
      </div>
    </template>

    <hr class="my-6" />

    <!-- Cover image -->
    <label class="block text-sm font-medium text-base-content mb-2">Обложка (необязательно)</label>
    <div class="flex items-center" x-data="{ fileName: '' }">
      <label
        for="cover-upload"
        class="cursor-pointer text-white bg-green-700 hover:bg-green-800 rounded-2xl flex flex-row gap-2 items-center justify-center py-2 px-4"
      >
        <CloudUpload />
        Загрузить файл
      </label>
      <input
        id="cover-upload"
        type="file"
        class="hidden"
        @change="handleCoverUpload($event); fileName = $event.target.files[0]?.name || ''"
        accept="image/png, image/jpeg, image/webp"
      />
      <span
        x-text="fileName ? fileName : (article.imageUrl ? 'Изображение загружено' : 'Файл не выбран')"
        class="ml-4 text-sm text-base-content/70"
      ></span>
    </div>
    <div x-show="uploading" class="mt-4">
      <p>Загрузка: <span x-text="uploadProgress.toFixed(2) + '%'"></span></p>
      <div class="w-full bg-base-200 rounded-full h-2">
        <div class="bg-primary h-2 rounded-full" :style="{ width: uploadProgress + '%' }"></div>
      </div>
    </div>
    <div x-show="article.imageUrl && !uploading" class="mt-4 space-y-4">
      <p class="text-sm text-success">Главное изображение загружено!</p>
      <img :src="article.imageUrl" alt="Предпросмотр обложки" class="rounded-md max-h-60 w-full object-cover" />
      <div>
        <label class="block text-sm font-medium text-base-content mb-2">Подпись к изображению</label>
        <template x-if="isEditingCaption">
          <div>
            <input
              type="text"
              x-model="editingCaptionText"
              class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
              placeholder="Введите подпись..."
            />
            <div class="flex justify-end gap-3 mt-3">
              <Button variant="secondary" size="sm" @click="cancelEditCaption()">Отмена</Button>
              <Button variant="primary" size="sm" @click="saveCaption()">Сохранить</Button>
            </div>
          </div>
        </template>
        <template x-if="!isEditingCaption">
          <div class="flex justify-between items-center border border-base-300 rounded-lg px-4 py-3">
            <p class="text-base-content" x-text="article.imageCaption || 'Подпись отсутствует...'"></p>
            <Button variant="outline" size="sm" @click="editCaption()">Редактировать</Button>
          </div>
        </template>
      </div>
    </div>
  </section>

  <!-- ── Пункты списка ─────────────────────────────────────────────────────── -->
  <section class="mb-6 p-6 bg-base-100 border border-base-300 rounded-xl shadow-sm">
    <h2 class="text-xl font-semibold mb-1">Пункты статьи</h2>
    <p class="text-sm text-base-content/60 mb-6">
      Каждый пункт — отдельная «главка» со своим заголовком, мета-строками и текстом.
    </p>

    <div class="space-y-4">
      <template x-for="(block, index) in article.contentBlocks" :key="index">
        <div>

          <!-- Collapsed preview — card layout matching public page -->
          <template x-if="editingIndex !== index">
            <div>
              <!-- Card preview -->
              <div class="flex flex-col sm:flex-row gap-6 py-6">
                <!-- Left: image -->
                <template x-if="block.imageUrl">
                  <div class="sm:w-[42%] shrink-0 bg-base-200">
                    <img
                      :src="block.imageUrl"
                      :alt="block.heading || 'Фото'"
                      class="w-full h-full object-cover"
                      style="min-height:160px; max-height:220px;"
                    />
                  </div>
                </template>
                <!-- Right: content -->
                <div class="flex flex-col justify-start gap-2 p-4" :class="block.imageUrl ? 'sm:w-[58%]' : 'w-full'">
                  <p class="font-bold font-oswald tracking-wide leading-snug" x-text="block.heading || '(без заголовка)'"></p>
                  <template x-if="block.metaItems && block.metaItems.length > 0">
                    <div class="flex flex-col gap-0.5">
                      <template x-for="(mi, mii) in block.metaItems" :key="mii">
                        <p class="flex items-center gap-1.5 text-xs text-base-content/60 font-oswald">
                          <span class="opacity-40">·</span>
                          <span x-text="mi.text"></span>
                        </p>
                      </template>
                    </div>
                  </template>
                  <p class="text-xs text-base-content/50 font-oswald font-thin line-clamp-2" x-show="block.text" x-text="block.text"></p>
                </div>
              </div>
              <!-- Controls row -->
              <div class="flex items-center justify-between gap-2 px-4 py-2 border-t border-base-300 bg-base-200/40">
                <span class="text-base-content/40 text-xs font-mono" x-text="'#' + (index + 1)"></span>
                <div class="flex items-center gap-2">
                  <button
                    type="button"
                    @click="moveBlock(index, 'up')"
                    :disabled="index === 0"
                    class="p-1 rounded hover:bg-base-200 disabled:opacity-30 cursor-pointer"
                    title="Вверх"
                  >↑</button>
                  <button
                    type="button"
                    @click="moveBlock(index, 'down')"
                    :disabled="index === article.contentBlocks.length - 1"
                    class="p-1 rounded hover:bg-base-200 disabled:opacity-30 cursor-pointer"
                    title="Вниз"
                  >↓</button>
                  <Button variant="outline" size="sm" @click="editBlock(index)">Редактировать</Button>
                  <Button variant="error" size="sm" @click="deleteBlock(index)">Удалить</Button>
                </div>
              </div>
            </div>
          </template>

          <!-- Expanded editor -->
          <template x-if="editingIndex === index">
            <div class="p-5 space-y-5" x-data="{ itemFileName: '' }">
              <h3 class="font-semibold text-base-content">
                Пункт <span x-text="index + 1"></span>
              </h3>

              <!-- Heading -->
              <div>
                <label class="block text-sm font-medium text-base-content mb-1">Заголовок главки</label>
                <input
                  type="text"
                  x-model="editingBlock.heading"
                  class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
                  placeholder="Например: Большой театр"
                />
              </div>

              <!-- Item image -->
              <div>
                <label class="block text-sm font-medium text-base-content mb-2">
                  Фотография пункта (необязательно)
                </label>
                <div class="flex items-center gap-3">
                  <label
                    :for="'item-img-' + index"
                    class="cursor-pointer text-white bg-green-700 hover:bg-green-800 rounded-2xl flex flex-row gap-2 items-center justify-center py-2 px-4 text-sm"
                  >
                    <CloudUpload class="w-4 h-4" />
                    Загрузить
                  </label>
                  <input
                    :id="'item-img-' + index"
                    type="file"
                    class="hidden"
                    @change="handleItemImageUpload($event); itemFileName = $event.target.files[0]?.name || ''"
                    accept="image/png, image/jpeg, image/webp"
                  />
                  <span
                    x-text="itemFileName || (editingBlock.imageUrl ? 'Фото загружено' : 'Файл не выбран')"
                    class="text-sm text-base-content/70"
                  ></span>
                </div>
                <div x-show="uploading && uploadingBlockIndex === index" class="mt-3">
                  <p class="mb-1 text-xs text-base-content/60">
                    Загружаем фото пункта <span x-text="index + 1"></span>: <span x-text="uploadProgress.toFixed(0) + '%'"></span>
                  </p>
                  <div class="w-full bg-base-200 rounded-full h-2">
                    <div class="bg-primary h-2 rounded-full" :style="{ width: uploadProgress + '%' }"></div>
                  </div>
                </div>
                <div x-show="editingBlock.imageUrl && !uploading" class="mt-3 space-y-2">
                  <img :src="editingBlock.imageUrl" alt="Фото пункта" class="rounded-md max-h-48 object-cover" />
                  <input
                    type="text"
                    x-model="editingBlock.imageCaption"
                    class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
                    placeholder="Подпись к фото (необязательно)"
                  />
                </div>
              </div>

              <!-- Meta items -->
              <div class="space-y-3">
                <div class="flex items-center justify-between">
                  <label class="block text-sm font-medium text-base-content">
                    Мета-строки
                    <span class="text-base-content/50 font-normal">(место, время, цена и т.д.)</span>
                  </label>
                  <button
                    type="button"
                    class="px-3 py-1.5 rounded-lg border border-base-300 bg-base-100 text-xs text-base-content transition hover:bg-base-200 cursor-pointer"
                    @click="editingBlock.metaItems.push({ icon: 'location', text: '', isLink: false, url: '' })"
                  >
                    + Добавить строку
                  </button>
                </div>

                <template x-for="(metaItem, mi) in editingBlock.metaItems" :key="mi">
                  <div class="rounded-lg border border-base-300 bg-base-100 p-4 space-y-3">
                    <!-- Icon picker -->
                    <div class="flex flex-wrap gap-2">
                      <button
                        type="button"
                        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border transition cursor-pointer"
                        :class="metaItem.icon === 'location' ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 text-base-content border-base-300 hover:bg-base-200'"
                        title="Место"
                        @click="metaItem.icon = 'location'"
                      >
                        <MapPin class="h-4 w-4" />
                      </button>
                      <button
                        type="button"
                        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border transition cursor-pointer"
                        :class="metaItem.icon === 'clock' ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 text-base-content border-base-300 hover:bg-base-200'"
                        title="Время"
                        @click="metaItem.icon = 'clock'"
                      >
                        <Clock3 class="h-4 w-4" />
                      </button>
                      <button
                        type="button"
                        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border transition cursor-pointer"
                        :class="metaItem.icon === 'calendar' ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 text-base-content border-base-300 hover:bg-base-200'"
                        title="Дата"
                        @click="metaItem.icon = 'calendar'"
                      >
                        <CalendarDays class="h-4 w-4" />
                      </button>
                      <button
                        type="button"
                        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border transition cursor-pointer"
                        :class="metaItem.icon === 'bulb' ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 text-base-content border-base-300 hover:bg-base-200'"
                        title="Идея"
                        @click="metaItem.icon = 'bulb'"
                      >
                        <Lightbulb class="h-4 w-4" />
                      </button>
                      <button
                        type="button"
                        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border transition cursor-pointer"
                        :class="metaItem.icon === 'pen' ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 text-base-content border-base-300 hover:bg-base-200'"
                        title="Примечание"
                        @click="metaItem.icon = 'pen'"
                      >
                        <NotebookPen class="h-4 w-4" />
                      </button>
                      <button
                        type="button"
                        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border transition cursor-pointer"
                        :class="metaItem.icon === 'crown' ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 text-base-content border-base-300 hover:bg-base-200'"
                        title="Особое"
                        @click="metaItem.icon = 'crown'"
                      >
                        <Crown class="h-4 w-4" />
                      </button>
                      <button
                        type="button"
                        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border transition cursor-pointer"
                        :class="metaItem.icon === 'star' ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 text-base-content border-base-300 hover:bg-base-200'"
                        title="Рекомендовано"
                        @click="metaItem.icon = 'star'"
                      >
                        <Star class="h-4 w-4" />
                      </button>
                      <button
                        type="button"
                        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border transition cursor-pointer"
                        :class="metaItem.icon === 'alert' ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 text-base-content border-base-300 hover:bg-base-200'"
                        title="Внимание"
                        @click="metaItem.icon = 'alert'"
                      >
                        <CircleAlert class="h-4 w-4" />
                      </button>
                      <button
                        type="button"
                        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border transition cursor-pointer"
                        :class="metaItem.icon === 'info' ? 'bg-primary text-primary-content border-primary' : 'bg-base-100 text-base-content border-base-300 hover:bg-base-200'"
                        title="Инфо"
                        @click="metaItem.icon = 'info'"
                      >
                        <Info class="h-4 w-4" />
                      </button>
                    </div>

                    <!-- Text input -->
                    <input
                      type="text"
                      x-model="metaItem.text"
                      class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
                      placeholder="Текст строки или текст ссылки"
                    />

                    <!-- Link toggle -->
                    <div class="flex items-center justify-between gap-3">
                      <div class="flex items-center gap-3">
                        <input
                          :id="'meta-link-' + index + '-' + mi"
                          type="checkbox"
                          x-model="metaItem.isLink"
                          class="w-4 h-4 text-primary bg-base-200 border-base-300 rounded-sm focus:ring-primary focus:ring-2 cursor-pointer"
                        />
                        <label :for="'meta-link-' + index + '-' + mi" class="text-sm text-base-content cursor-pointer">
                          Это ссылка
                        </label>
                      </div>
                      <button
                        type="button"
                        class="text-xs text-error hover:underline cursor-pointer"
                        @click="editingBlock.metaItems.splice(mi, 1)"
                      >
                        Удалить
                      </button>
                    </div>

                    <!-- URL input -->
                    <div x-show="metaItem.isLink">
                      <input
                        type="url"
                        x-model="metaItem.url"
                        class="bg-base-100 border border-base-300 text-base-content text-sm rounded-lg focus:ring-primary focus:border-primary block w-full p-2.5"
                        placeholder="https://..."
                      />
                    </div>
                  </div>
                </template>

                <p
                  x-show="!editingBlock.metaItems || editingBlock.metaItems.length === 0"
                  class="text-xs text-base-content/40 italic"
                >
                  Нет мета-строк. Нажми «+ Добавить строку» чтобы добавить место, время, цену...
                </p>
              </div>

              <!-- Body text (Quill rich text editor) -->
              <div>
                <label class="block text-sm font-medium text-base-content mb-1">Текст</label>
                <div
                  class="rich-text-editor"
                  x-data="blockRichTextEditor({ initialHtml: getRichTextInitialHtml(editingBlock), placeholder: 'Основной текст пункта...' })"
                  @rich-text-change="editingBlock.html = $event.detail.html; editingBlock.text = $event.detail.text"
                >
                  <div x-ref="editor"></div>
                </div>
              </div>

              <div class="flex justify-end gap-3">
                <Button variant="secondary" size="sm" @click="cancelEdit()" :disabled="uploading" :class="{'opacity-50 cursor-not-allowed': uploading}">Отмена</Button>
                <Button variant="primary" size="sm" @click="updateBlock()" :disabled="uploading" :class="{'opacity-50 cursor-not-allowed': uploading}">Сохранить пункт</Button>
              </div>
            </div>
          </template>
          <hr x-show="index < article.contentBlocks.length - 1" class="border-base-300 my-2" />
        </div>
      </template>
    </div>

    <div class="mt-6">
      <Button variant="outline" size="md" @click="addTipsItem()" :disabled="uploading" :class="{'opacity-50 cursor-not-allowed': uploading}">
        + Добавить пункт
      </Button>
    </div>
  </section>

  <LandingPlacementPanel allowMainHero={true} allowCategoryLandingHero={true} allowCategoryPageHero={true} />

  <ContentCollectionsEditor />
  <RelatedContentEditor />

  <DashboardMaterialActionFooter
    cancelHref={cancelHref}
    deleteAction={`deleteArticle('${deleteRedirect}')`}
    deleteLabel="Удалить"
    previewAction="previewArticle()"
    previewDisabled="uploading || isSaving"
    publishedModel="article"
    saveAction="saveArticle()"
    saveDisabled="isSaving || uploading"
    saveLabel={submitLabel}
    showDelete={Boolean(deleteArticleId)}
  />
</div>
