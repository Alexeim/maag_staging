---
import AuthorIcon from "@/assets/icons/ix_pen-filled.svg";

interface Props {
  category: string;
  title: string;
  lead?: string;
  authorName: string;
  createdAt: string | Date | { toDate: () => Date } | { _seconds: number };
}

const {
  category,
  title,
  lead = "",
  authorName,
  createdAt,
} = Astro.props as Props;

let date: Date;

if (typeof createdAt === "object" && createdAt !== null) {
  if ("toDate" in createdAt && typeof createdAt.toDate === "function") {
    date = createdAt.toDate();
  } else if (
    "_seconds" in createdAt &&
    typeof createdAt._seconds === "number"
  ) {
    date = new Date(createdAt._seconds * 1000);
  } else {
    date = new Date(createdAt as any);
  }
} else {
  date = new Date(createdAt);
}

const formattedDate = !Number.isNaN(date.getTime())
  ? date
      .toLocaleDateString("ru-RU", {
        year: "numeric",
        month: "long",
        day: "numeric",
      })
      .replace(" г.", "")
  : "Некорректная дата";
---

<header class="flex w-full max-w-[980px] flex-col gap-5">
  <p
    class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']"
  >
    {category}
  </p>
  <h1
    class="text-3xl leading-tight font-old_standard text-base-content lg:text-[46px]"
  >
    {title}
  </h1>

  {
    lead && (
      <p class="max-w-[760px] text-lg font-light text-base-content/80 font-article-body lg:text-[22px]">
        {lead}
      </p>
    )
  }

  <div
    class="flex flex-wrap items-center gap-x-6 gap-y-3 border-t border-base-content/10 pt-5"
  >
    <div class="flex items-center gap-3">
      <AuthorIcon class="h-4 w-4" />
      <span
        class="text-base font-thin italic text-base-content font-old_standard lg:text-xl"
      >
        {authorName}
      </span>
    </div>
    <span class="text-sm text-base-content/60 font-inter">
      {formattedDate}
    </span>
  </div>
</header>
