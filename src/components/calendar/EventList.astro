---
import EventMetaIcon from "@/components/common/EventMetaIcon.astro";
---

<div>
  <div
    x-show="isLazyLoading"
    class="text-center font-inter text-[0.9rem] text-[#7d726a]"
  >
    Загрузка событий...
  </div>

  <div x-show="!isLazyLoading">
    <!-- Main events for selected date -->
    <div>
      <h2
        class="m-0 font-old_standard font-normal uppercase leading-[1.08] text-[#15110e]"
        :class="hasCompletedRange() ? 'text-[1.3rem] tracking-[0.38em] sm:text-[1.45rem]' : 'text-[1.05rem] tracking-[0.5em]'"
        x-text="getSelectedDateHeading()"
      >
      </h2>

      <div
        class="mt-6"
        :class="hasCompletedRange() ? 'mt-8' : 'mt-6'"
      >
        <template x-if="hasCompletedRange()">
          <div class="space-y-10">
            <template x-if="filteredEvents.length === 0">
              <p class="py-8 font-inter text-[0.9rem] text-[#7d726a]">
                На эти даты событий не найдено.
              </p>
            </template>

            <template x-if="rangeSpecificEvents.length > 0">
              <section>
                <h3 class="m-0 font-old_standard text-[1rem] font-normal uppercase tracking-[0.24em] text-[#15110e]">
                  Только в эти даты
                </h3>

                <div class="mt-6 divide-y divide-[#30282115]">
                  <template x-for="event in rangeSpecificEvents" :key="event.id">
                    <article class="flex flex-col gap-6 py-8 sm:flex-row">
                      <a
                        :href="event.url"
                        class="linked-image-hover aspect-[3/2] shrink-0 self-start sm:w-[38%]"
                        :aria-label="event.title"
                      >
                        <img
                          :src="event.image"
                          alt="Event Image"
                          class="linked-image-hover__media block h-full w-full object-cover"
                        />
                      </a>

                      <div class="flex min-w-0 flex-col gap-3">
                        <p class="m-0">
                          <span
                            class="font-inter text-[0.68rem] font-bold uppercase tracking-[0.25em] text-accent"
                            x-text="event.tag"
                          ></span>
                        </p>

                        <a
                          :href="event.url"
                          class="text-current no-underline hover:underline [text-decoration-thickness:1px] underline-offset-[0.14em]"
                        >
                          <h3
                            class="m-0 font-old_standard text-[1.5rem] font-normal leading-[1.08] lg:text-[1.9rem] lg:leading-[1.06]"
                            x-text="event.title"
                          >
                          </h3>
                        </a>

                        <p
                          class="m-0 font-inter text-[0.82rem] leading-[1.55] text-[#302821a0]"
                          x-text="event.description"
                        >
                        </p>

                        <div>
                          <a
                            :href="event.url"
                            class="inline-block border border-[#30282133] px-4 py-2 font-inter text-[0.7rem] uppercase tracking-[0.22em] text-[#302821] transition-colors hover:border-[#302821] hover:bg-[#302821] hover:text-white"
                          >
                            Подробнее
                          </a>
                        </div>

                        <div class="mt-auto pt-2">
                          <hr class="border-[#30282115]" />
                          <p
                            class="m-0 flex items-center gap-2 py-2 font-inter text-[0.82rem] text-[#302821bd]"
                          >
                            <EventMetaIcon type="location" class="h-4 w-4 shrink-0" />
                            <span x-text="event.location"></span>
                          </p>

                          <hr class="border-[#30282115]" />
                          <p
                            class="m-0 flex items-center gap-2 py-2 font-inter text-[0.82rem] text-[#302821bd]"
                          >
                            <EventMetaIcon type="time" class="h-4 w-4 shrink-0" />
                            <span x-text="event.time"></span>
                          </p>

                          <hr class="border-[#30282115]" />
                          <p
                            class="m-0 flex items-center gap-2 py-2 font-inter text-[0.82rem] text-[#302821bd]"
                          >
                            <EventMetaIcon type="date" class="h-4 w-4 shrink-0" />
                            <span x-text="event.dateRangeLabel"></span>
                          </p>
                        </div>
                      </div>
                    </article>
                  </template>
                </div>
              </section>
            </template>

            <template x-if="rangeFlexibleEvents.length > 0">
              <section>
                <h3 class="m-0 font-old_standard text-[1rem] font-normal uppercase tracking-[0.24em] text-[#15110e]">
                  Можно в любой день
                </h3>

                <div class="mt-6 divide-y divide-[#30282115]">
                  <template x-for="event in rangeFlexibleEvents" :key="event.id">
                    <article class="flex flex-col gap-6 py-8 sm:flex-row">
                      <a
                        :href="event.url"
                        class="linked-image-hover aspect-[3/2] shrink-0 self-start sm:w-[38%]"
                        :aria-label="event.title"
                      >
                        <img
                          :src="event.image"
                          alt="Event Image"
                          class="linked-image-hover__media block h-full w-full object-cover"
                        />
                      </a>

                      <div class="flex min-w-0 flex-col gap-3">
                        <p class="m-0">
                          <span
                            class="font-inter text-[0.68rem] font-bold uppercase tracking-[0.25em] text-accent"
                            x-text="event.tag"
                          ></span>
                        </p>

                        <a
                          :href="event.url"
                          class="text-current no-underline hover:underline [text-decoration-thickness:1px] underline-offset-[0.14em]"
                        >
                          <h3
                            class="m-0 font-old_standard text-[1.5rem] font-normal leading-[1.08] lg:text-[1.9rem] lg:leading-[1.06]"
                            x-text="event.title"
                          >
                          </h3>
                        </a>

                        <p
                          class="m-0 font-inter text-[0.82rem] leading-[1.55] text-[#302821a0]"
                          x-text="event.description"
                        >
                        </p>

                        <div>
                          <a
                            :href="event.url"
                            class="inline-block border border-[#30282133] px-4 py-2 font-inter text-[0.7rem] uppercase tracking-[0.22em] text-[#302821] transition-colors hover:border-[#302821] hover:bg-[#302821] hover:text-white"
                          >
                            Подробнее
                          </a>
                        </div>

                        <div class="mt-auto pt-2">
                          <hr class="border-[#30282115]" />
                          <p
                            class="m-0 flex items-center gap-2 py-2 font-inter text-[0.82rem] text-[#302821bd]"
                          >
                            <EventMetaIcon type="location" class="h-4 w-4 shrink-0" />
                            <span x-text="event.location"></span>
                          </p>

                          <hr class="border-[#30282115]" />
                          <p
                            class="m-0 flex items-center gap-2 py-2 font-inter text-[0.82rem] text-[#302821bd]"
                          >
                            <EventMetaIcon type="time" class="h-4 w-4 shrink-0" />
                            <span x-text="event.time"></span>
                          </p>

                          <hr class="border-[#30282115]" />
                          <p
                            class="m-0 flex items-center gap-2 py-2 font-inter text-[0.82rem] text-[#302821bd]"
                          >
                            <EventMetaIcon type="date" class="h-4 w-4 shrink-0" />
                            <span x-text="event.dateRangeLabel"></span>
                          </p>
                        </div>
                      </div>
                    </article>
                  </template>
                </div>
              </section>
            </template>
          </div>
        </template>

        <template x-if="!hasCompletedRange()">
          <div class="divide-y divide-[#30282115]">
            <template x-if="filteredEvents.length === 0">
              <p class="py-8 font-inter text-[0.9rem] text-[#7d726a]">
                На эту дату событий не найдено.
              </p>
            </template>

            <template x-for="event in filteredEvents" :key="event.id">
              <article class="flex flex-col gap-6 py-8 sm:flex-row">
                <a
                  :href="event.url"
                  class="linked-image-hover aspect-[3/2] shrink-0 self-start sm:w-[38%]"
                  :aria-label="event.title"
                >
                  <img
                    :src="event.image"
                    alt="Event Image"
                    class="linked-image-hover__media block h-full w-full object-cover"
                  />
                </a>

                <div class="flex min-w-0 flex-col gap-3">
                  <p class="m-0">
                    <span
                      class="font-inter text-[0.68rem] font-bold uppercase tracking-[0.25em] text-accent"
                      x-text="event.tag"
                    ></span>
                  </p>

                  <a
                    :href="event.url"
                    class="text-current no-underline hover:underline [text-decoration-thickness:1px] underline-offset-[0.14em]"
                  >
                    <h3
                      class="m-0 font-old_standard text-[1.5rem] font-normal leading-[1.08] lg:text-[1.9rem] lg:leading-[1.06]"
                      x-text="event.title"
                    >
                    </h3>
                  </a>

                  <p
                    class="m-0 font-inter text-[0.82rem] leading-[1.55] text-[#302821a0]"
                    x-text="event.description"
                  >
                  </p>

                  <div>
                    <a
                      :href="event.url"
                      class="inline-block border border-[#30282133] px-4 py-2 font-inter text-[0.7rem] uppercase tracking-[0.22em] text-[#302821] transition-colors hover:border-[#302821] hover:bg-[#302821] hover:text-white"
                    >
                      Подробнее
                    </a>
                  </div>

                  <div class="mt-auto pt-2">
                    <hr class="border-[#30282115]" />
                    <p
                      class="m-0 flex items-center gap-2 py-2 font-inter text-[0.82rem] text-[#302821bd]"
                    >
                      <EventMetaIcon type="location" class="h-4 w-4 shrink-0" />
                      <span x-text="event.location"></span>
                    </p>

                    <hr class="border-[#30282115]" />
                    <p
                      class="m-0 flex items-center gap-2 py-2 font-inter text-[0.82rem] text-[#302821bd]"
                    >
                      <EventMetaIcon type="time" class="h-4 w-4 shrink-0" />
                      <span x-text="event.time"></span>
                    </p>

                    <template x-if="event.endDate.getTime() !== event.startDate.getTime()">
                      <div>
                        <hr class="border-[#30282115]" />
                        <p
                          class="m-0 flex items-center gap-2 py-2 font-inter text-[0.82rem] text-[#302821bd]"
                        >
                          <EventMetaIcon type="date" class="h-4 w-4 shrink-0" />
                          <span
                            x-text="'до ' + event.endDate.toLocaleDateString('ru-RU', {day: 'numeric', month: 'long', timeZone: 'UTC'})"
                          ></span>
                        </p>
                      </div>
                    </template>
                  </div>
                </div>
              </article>
            </template>
          </div>
        </template>
      </div>
    </div>

    <!-- Ongoing events (Ещё в этот день) -->
    <template x-if="smallEvents.length > 0">
      <div class="mt-10">
        <h3
          class="m-0 font-old_standard text-lg font-normal uppercase tracking-[0.3em] text-base-content"
        >
          Ещё в этот день
        </h3>

        <div
          class="mt-6 grid grid-cols-2 gap-x-4 gap-y-6 lg:grid-cols-4 lg:gap-x-5"
        >
          <template x-for="(event, index) in smallEvents" :key="index">
            <article class="grid h-full grid-rows-[auto_1fr] gap-[0.8rem]">
              <a
                :href="event.url"
                class="linked-image-hover aspect-[3/2]"
                :aria-label="event.title"
              >
                <img
                  :src="event.image"
                  alt="Event Image"
                  class="linked-image-hover__media block h-full w-full object-cover"
                />
              </a>

              <div
                class="grid h-full grid-rows-[auto_1fr_auto] gap-[0.45rem] content-start"
              >
                <p class="m-0">
                  <span
                    class="text-xs font-bold uppercase tracking-[0.25em] text-accent font-['Inter']"
                    x-text="event.tag"></span>
                </p>

                <a
                  :href="event.url"
                  class="text-current no-underline hover:underline [text-decoration-thickness:1px] underline-offset-[0.14em]"
                >
                  <h4
                    class="m-0 line-clamp-3 font-old_standard text-[1.15rem] font-normal leading-[1.16]"
                    x-text="event.title"
                  >
                  </h4>
                </a>

                <p
                  class="m-0 flex items-center gap-2 font-inter text-[0.82rem] text-[#302821bd]"
                >
                  <EventMetaIcon type="location" class="h-4 w-4 shrink-0" />
                  <span x-text="event.location"></span>
                </p>
              </div>
            </article>
          </template>
        </div>
      </div>
    </template>
  </div>
</div>
