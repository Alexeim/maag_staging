---
import locationIcon from "../../assets/images/calendar/location.svg?raw";
import timeIcon from "../../assets/images/calendar/time.svg?raw";
---

<div>
  <div x-show="isLazyLoading" class="text-center font-inter text-[0.9rem] text-[#7d726a]">
    Загрузка событий...
  </div>

  <div x-show="!isLazyLoading">
    <!-- Main events for selected date -->
    <div>
      <h2
        class="m-0 font-old_standard text-[1.05rem] font-normal uppercase tracking-[0.5em] text-[#15110e]"
        x-text="selectedDate ? selectedDate.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', timeZone: 'UTC' }) : ''"
      ></h2>

      <div class="mt-6 space-y-5">
        <template x-if="filteredEvents.length === 0">
          <p class="font-inter text-[0.9rem] text-[#7d726a]">
            На эту дату событий не найдено.
          </p>
        </template>

        <template x-for="event in filteredEvents" :key="event.id">
          <article class="grid overflow-hidden bg-white/80 md:grid-cols-[minmax(0,1.2fr)_minmax(0,1fr)]">
            <a
              :href="event.url"
              class="block aspect-[4/3] overflow-hidden md:aspect-auto"
              :aria-label="event.title"
            >
              <img
                :src="event.image"
                alt="Event Image"
                class="block h-full w-full object-cover"
              />
            </a>

            <div class="grid content-start gap-[0.55rem] p-5 lg:px-6 lg:py-5">
              <p class="m-0 font-inter text-[0.68rem] uppercase tracking-[0.18em] text-[#30282185]"
                x-text="event.dateRangeLabel">
              </p>

              <p class="m-0">
                <span
                  class="font-inter text-xs font-medium uppercase tracking-[0.25em] text-accent"
                  x-text="event.tag"
                ></span>
              </p>

              <a
                :href="event.url"
                class="text-current no-underline hover:underline [text-decoration-thickness:1px] underline-offset-[0.14em]"
              >
                <h3
                  class="m-0 max-w-[14ch] font-old_standard text-[clamp(1.4rem,2.5vw,2rem)] font-normal leading-[1.06]"
                  x-text="event.title"
                ></h3>
              </a>

              <p
                class="m-0 font-inter text-[0.82rem] leading-[1.55] text-[#302821a0]"
                x-text="event.description"
              ></p>

              <div class="mt-2 space-y-[0.35rem]">
                <p class="m-0 flex items-center gap-2 font-inter text-[0.82rem] text-[#302821bd]">
                  <span class="h-4 w-4 shrink-0" set:html={locationIcon} />
                  <span x-text="event.location"></span>
                </p>
                <p class="m-0 flex items-center gap-2 font-inter text-[0.82rem] text-[#302821bd]">
                  <span class="h-4 w-4 shrink-0" set:html={timeIcon} />
                  <span x-text="event.time"></span>
                </p>
              </div>

              <div class="mt-3">
                <a
                  :href="event.url"
                  class="inline-block border border-[#30282133] px-4 py-2 font-inter text-[0.7rem] uppercase tracking-[0.22em] text-[#302821] transition-colors hover:border-[#302821] hover:bg-[#302821] hover:text-white"
                >
                  Подробнее
                </a>
              </div>
            </div>
          </article>
        </template>
      </div>
    </div>

    <!-- Ongoing events (Ещё в этот день) -->
    <template x-if="smallEvents.length > 0">
      <div class="mt-10">
        <h3 class="m-0 font-old_standard text-[1.05rem] font-normal uppercase tracking-[0.5em] text-[#15110e]">
          Ещё в этот день
        </h3>

        <div class="mt-6 grid grid-cols-2 gap-x-4 gap-y-6 lg:grid-cols-4 lg:gap-x-5">
          <template x-for="(event, index) in smallEvents" :key="index">
            <article class="grid gap-[0.8rem]">
              <a
                :href="event.url"
                class="block aspect-[3/2] overflow-hidden"
                :aria-label="event.title"
              >
                <img
                  :src="event.image"
                  alt="Event Image"
                  class="block h-full w-full object-cover"
                />
              </a>

              <div class="grid gap-[0.45rem]">
                <p class="m-0">
                  <span
                    class="font-inter text-xs font-medium uppercase tracking-[0.25em] text-accent"
                    x-text="event.tag"
                  ></span>
                </p>

                <a
                  :href="event.url"
                  class="text-current no-underline hover:underline [text-decoration-thickness:1px] underline-offset-[0.14em]"
                >
                  <h4
                    class="m-0 max-w-[11ch] font-old_standard text-[1.15rem] font-normal leading-[1.1]"
                    x-text="event.title"
                  ></h4>
                </a>

                <p class="m-0 flex items-center gap-2 font-inter text-[0.82rem] text-[#302821bd]">
                  <span class="h-4 w-4 shrink-0" set:html={locationIcon} />
                  <span x-text="event.location"></span>
                </p>
              </div>
            </article>
          </template>
        </div>
      </div>
    </template>
  </div>
</div>
