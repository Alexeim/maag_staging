---
// This component is controlled by Alpine.js from the parent page
---

<div class="w-full max-w-[25.5rem]">
  <div x-show="isLazyLoading" class="text-center">Загрузка...</div>

  <div x-show="!isLazyLoading">
    <div class="mb-6 flex items-center gap-4">
      <h3
        class="m-0 font-inter text-[2.05rem] font-semibold capitalize text-[#302821]"
        x-text="`${monthName} ${year}`"
      ></h3>

      <div class="ml-auto flex items-center gap-2">
        <button
          @click="$dispatch('change-month', -1)"
          class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border border-[#30282133] bg-white transition-colors hover:bg-[#f7f2ee]"
          aria-label="Предыдущий месяц"
        >
          <svg width="8" height="14" viewBox="0 0 8 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M7 13L1 7L7 1" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
        <button
          @click="$dispatch('change-month', 1)"
          class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border border-[#30282133] bg-white transition-colors hover:bg-[#f7f2ee]"
          aria-label="Следующий месяц"
        >
          <svg width="8" height="14" viewBox="0 0 8 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 13L7 7L1 1" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
    </div>

    <div class="mb-3 grid grid-cols-7 text-center font-inter text-[0.95rem] text-[#7d726a]">
      <div>Пн</div>
      <div>Вт</div>
      <div>Ср</div>
      <div>Чт</div>
      <div>Пт</div>
      <div>Сб</div>
      <div>Вс</div>
    </div>

    <div class="grid grid-cols-7 gap-1.5">
      <template x-for="cell in calendarDays" :key="cell.date.toISOString()">
        <button
          @click="$dispatch('date-selected', cell)"
          class="flex aspect-square min-h-[52px] cursor-pointer items-center justify-center bg-[#f9f5f0] font-inter text-[1.05rem] transition-colors hover:bg-[#f0e9e1]"
        >
          <span
            :class="{
              'bg-error text-error-content': hasEvent(cell),
              'text-[#b5aaa2]': !cell.isCurrentMonth && !hasEvent(cell),
              'text-[#302821]': cell.isCurrentMonth && !hasEvent(cell)
            }"
            class="flex h-12 w-12 items-center justify-center rounded-full"
            x-text="cell.day"
          ></span>
        </button>
      </template>
    </div>
  </div>
</div>
