---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import ArticleAuthor from "@/components/article/ArticleAuthor.astro";
import ArticleDate from "@/components/article/ArticleDate.astro";

interface Props {
  category: string;
  title: string;
  lead?: string;
  authorName: string;
  authorAvatar?: string;
  createdAt: string | Date | { toDate: () => Date } | { _seconds: number };
  imageUrl?: ImageMetadata | string;
  imageAlt?: string;
  imageCaption?: string;
  transitionName?: string;
  transitionAliases?: string[];
}

const {
  category,
  title,
  lead,
  authorName,
  authorAvatar,
  createdAt,
  imageUrl,
  imageAlt = "Interview image",
  imageCaption,
  transitionName,
  transitionAliases = [],
} = Astro.props;

const imageSrc = imageUrl
  ? typeof imageUrl === "string"
    ? imageUrl
    : imageUrl.src
  : null;
---

<section class="w-full px-4 sm:px-6 lg:px-10">
  <div class="overflow-visible lg:h-[calc(100svh-90px)]">
    <div
      class:list={[
        "grid h-auto gap-8 lg:h-full lg:gap-0 lg:items-stretch",
        imageUrl
          ? "lg:grid-cols-[minmax(0,1.08fr)_minmax(0,0.92fr)]"
          : "grid-cols-1",
      ]}
    >
      {
        imageUrl && (
          <div class="order-2 flex flex-col bg-white lg:order-1 lg:h-full lg:min-h-0">
            <div class="flex items-center justify-center overflow-hidden lg:min-h-0 lg:flex-1">
              {typeof imageUrl === "string" ? (
                <img
                  src={imageUrl}
                  alt={imageAlt}
                  class="block h-auto w-full object-cover lg:h-full lg:w-auto lg:max-w-full lg:object-contain"
                  transition:name={transitionName}
                />
              ) : (
                <Image
                  src={imageUrl}
                  alt={imageAlt}
                  class="block h-auto w-full object-cover lg:h-full lg:w-auto lg:max-w-full lg:object-contain"
                  transition:name={transitionName}
                />
              )}
            </div>
            {imageCaption && (
              <p class="border-t border-black/8 px-6 py-4 font-inter text-xs uppercase tracking-[0.12em] text-base-content/60">
                {imageCaption}
              </p>
            )}
          </div>
        )
      }

      <div class="order-1 flex flex-col justify-center px-2 py-8 text-center text-base-content sm:px-6 sm:py-10 lg:order-2 lg:h-full lg:px-16 lg:py-12 xl:px-24">
        <p class="font-['Inter'] text-xs font-medium uppercase tracking-[0.25em] text-accent sm:text-sm">
          {category}
        </p>
        <h1 class="mt-8 font-old_standard text-4xl font-normal leading-[1.05] text-base-content sm:text-5xl lg:text-[4rem]">
          {title}
        </h1>
        {
          lead && (
            <p class="mx-auto mt-8 max-w-[34rem] font-article-body text-lg font-light text-base-content lg:mt-10">
              {lead}
            </p>
          )
        }
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4 text-base-content lg:mt-10">
          <ArticleAuthor name={authorName} avatarUrl={authorAvatar} />
          <span aria-hidden="true" class="text-sm text-base-content/50">•</span>
          <ArticleDate createdAt={createdAt} />
        </div>
      </div>
    </div>
  </div>
  <hr class="mt-10 w-full border-t border-neutral-200 lg:mt-16" />

  {
    transitionAliases.map((alias) => (
      <img
        src={imageSrc ?? ""}
        alt=""
        aria-hidden="true"
        class="fixed -z-10 h-px w-px pointer-events-none opacity-0"
        transition:name={alias}
      />
    ))
  }
</section>
