---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import ArticleAuthor from "@/components/article/ArticleAuthor.astro";
import ArticleDate from "@/components/article/ArticleDate.astro";

interface Props {
  category: string;
  title: string;
  interviewee: string;
  mainQuote: string;
  lead?: string;
  authorName: string;
  authorAvatar?: string;
  createdAt: string | Date | { toDate: () => Date } | { _seconds: number };
  imageUrl?: ImageMetadata | string;
  imageAlt?: string;
  imageCaption?: string;
  transitionName?: string;
}

const {
  category,
  title,
  interviewee,
  mainQuote,
  lead,
  authorName,
  authorAvatar,
  createdAt,
  imageUrl,
  imageAlt = "Interview image",
  imageCaption,
  transitionName,
} = Astro.props;

const isLongTitle = title.trim().split(/\s+/).filter(Boolean).length > 3;
---

<section class="w-full px-4 sm:px-6 lg:px-10">
  <div class="overflow-visible lg:h-[calc(100svh-90px)]">
    <div
      class:list={[
        "grid h-auto gap-8 lg:h-full lg:gap-0 lg:items-stretch",
        imageUrl
          ? "lg:grid-cols-[minmax(0,1.08fr)_minmax(0,0.92fr)]"
          : "grid-cols-1",
      ]}
    >
      {
        imageUrl && (
          <div class="order-2 flex flex-col lg:order-1 lg:h-full lg:min-h-0">
            <div class="flex items-center justify-center overflow-hidden lg:min-h-0 lg:flex-1">
              {typeof imageUrl === "string" ? (
                <img
                  src={imageUrl}
                  alt={imageAlt}
                  class="block h-auto w-full object-cover lg:h-full lg:w-auto lg:max-w-full lg:object-contain"
                  transition:name={transitionName}
                />
              ) : (
                <Image
                  src={imageUrl}
                  alt={imageAlt}
                  class="block h-auto w-full object-cover lg:h-full lg:w-auto lg:max-w-full lg:object-contain"
                  transition:name={transitionName}
                />
              )}
            </div>
            {imageCaption && (
              <p class="px-6 py-2 font-inter text-xs text-base-content/60 text-center">
                {imageCaption}
              </p>
            )}
          </div>
        )
      }

      <div
        class="order-1 flex flex-col justify-center px-2 py-8 text-center text-base-content sm:px-6 sm:py-10 lg:order-2 lg:h-full lg:px-16 lg:py-12"
      >
        <p
          class="font-['Inter'] text-xs font-medium uppercase tracking-[0.25em] text-accent sm:text-sm"
        >
          {category}
        </p>
        <h1
          class:list={[
            "mt-8 font-old_standard font-semibold leading-[1.05] text-base-content",
            isLongTitle ? "text-4xl lg:text-5xl" : "text-5xl lg:text-7xl",
          ]}
        >
          {interviewee}:
        </h1>
        <h2
          class:list={[
            "font-old_standard font-normal italic leading-[1.05] text-base-content",
            isLongTitle ? "text-4xl lg:text-5xl" : "text-5xl lg:text-7xl",
          ]}
        >
          "{mainQuote}"
        </h2>
        {
          lead && (
            <p class="mx-auto mt-8 max-w-[34rem] font-article-body text-base font-light text-base-content lg:mt-10">
              {lead}
            </p>
          )
        }
        <div
          class="mt-8 flex flex-col items-center justify-center gap-4 text-base-content lg:mt-10"
        >
          <ArticleAuthor name={authorName} avatarUrl={authorAvatar} />
          <!-- <p class="font-inter text-base-content/50">|</p> -->
          <ArticleDate createdAt={createdAt} />
        </div>
      </div>
    </div>
  </div>
  <hr class="mt-10 w-full border-t border-neutral-200 lg:mt-16" />
</section>
