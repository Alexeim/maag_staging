---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import ArticleAuthor from "@/components/article/ArticleAuthor.astro";
import ArticleDate from "@/components/article/ArticleDate.astro";

interface Props {
  category: string;
  title: string;
  lead?: string;
  authorName: string;
  authorAvatar?: string;
  createdAt: string | Date | { toDate: () => Date } | { _seconds: number };
  imageUrl?: ImageMetadata | string;
  imageAlt?: string;
  imageCaption?: string;
  transitionName?: string;
  transitionAliases?: string[];
}

const {
  category,
  title,
  lead,
  authorName,
  authorAvatar,
  createdAt,
  imageUrl,
  imageAlt = "Guide image",
  imageCaption,
  transitionName,
  transitionAliases = [],
} = Astro.props;

const imageSrc = imageUrl
  ? typeof imageUrl === "string"
    ? imageUrl
    : imageUrl.src
  : null;
---

<section class="w-full px-4 pt-8 pb-12 sm:px-6 lg:px-10 lg:pt-12 lg:pb-16">
  <div class="overflow-hidden">
    <div
      class:list={[
        "grid items-stretch",
        imageUrl
          ? "lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)]"
          : "grid-cols-1",
      ]}
    >
      <div
        class="flex min-h-[420px] flex-col justify-center px-6 py-10 text-center text-base-content sm:px-10 lg:min-h-[760px] lg:px-16 xl:px-24"
      >
        <p
          class="font-['Inter'] text-xs font-medium uppercase tracking-[0.25em] text-accent sm:text-sm"
        >
          {category}
        </p>
        <h1
          class="mt-8 font-oswald text-4xl font-thin leading-[1.05] text-base-content sm:text-5xl lg:text-[4rem]"
        >
          {title}
        </h1>
        {
          lead && (
            <p class="mx-auto mt-10 max-w-[34rem] font-oswald text-xl font-thin leading-[1.4] tracking-[0.01em] text-base-content/80 sm:text-2xl">
              {lead}
            </p>
          )
        }
        <div
          class="mt-10 flex flex-wrap items-center justify-center gap-4 text-base-content"
        >
          <ArticleAuthor name={authorName} avatarUrl={authorAvatar} />
          <span aria-hidden="true" class="text-sm text-base-content/50">•</span>
          <ArticleDate createdAt={createdAt} />
        </div>
      </div>

      {
        imageUrl && (
          <div class="flex h-full flex-col bg-white">
            <div class="min-h-[320px] flex-1 lg:min-h-[760px]">
              {typeof imageUrl === "string" ? (
                <img
                  src={imageUrl}
                  alt={imageAlt}
                  class="h-full w-full object-cover"
                  transition:name={transitionName}
                />
              ) : (
                <Image
                  src={imageUrl}
                  alt={imageAlt}
                  class="h-full w-full object-cover"
                  transition:name={transitionName}
                />
              )}
            </div>
            {imageCaption && (
              <p class="border-t border-black/8 px-6 py-4 font-oswald text-xs tracking-[0.12em] text-base-content/60 uppercase">
                {imageCaption}
              </p>
            )}
          </div>
        )
      }
    </div>
  </div>
  <hr class="mt-4 w-full border-t border-neutral-200" />

  {
    transitionAliases.map((alias) => (
      <img
        src={imageSrc ?? ""}
        alt=""
        aria-hidden="true"
        class="fixed -z-10 h-px w-px opacity-0 pointer-events-none"
        transition:name={alias}
      />
    ))
  }
</section>
