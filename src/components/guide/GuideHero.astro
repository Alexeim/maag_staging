---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import ArticleAuthor from "@/components/article/ArticleAuthor.astro";
import ArticleDate from "@/components/article/ArticleDate.astro";
import ImageCaptionHint from "@/components/common/ImageCaptionHint.astro";

interface Props {
  category: string;
  title: string;
  lead?: string;
  authorName: string;
  authorAvatar?: string;
  createdAt: string | Date | { toDate: () => Date } | { _seconds: number };
  imageUrl?: ImageMetadata | string;
  imageAlt?: string;
  imageCaption?: string;
  transitionName?: string;
  heroOrientation?: "image-left" | "image-right";
}

const {
  category,
  title,
  lead,
  authorName,
  authorAvatar,
  createdAt,
  imageUrl,
  imageAlt = "Guide image",
  imageCaption,
  transitionName,
  heroOrientation = "image-right",
} = Astro.props;

const isLongTitle = title.trim().split(/\s+/).filter(Boolean).length > 3;
const imageOnLeft = heroOrientation === "image-left";
---

<section class="w-full px-4 sm:px-6 lg:px-10">
  <div class="overflow-hidden lg:h-[calc(100svh-90px)]">
    <div
      class:list={[
        "grid h-auto gap-8 lg:h-full lg:grid-rows-1 lg:gap-0 lg:items-stretch",
        imageUrl
          ? "lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)]"
          : "grid-cols-1",
      ]}
    >
      <div
        class:list={[
          "flex flex-col justify-center px-2 py-8 text-center text-base-content sm:px-6 sm:py-10 lg:h-full lg:px-16 lg:py-12",
          imageUrl && imageOnLeft ? "order-1 lg:order-2" : "",
        ]}
      >
        <p
          class="font-['Inter'] text-xs font-medium uppercase tracking-[0.25em] text-accent sm:text-sm"
        >
          {category}
        </p>
        <h1
          class:list={[
            "mt-8 font-old_standard font-normal leading-[1.05] text-base-content",
            isLongTitle ? "text-4xl lg:text-5xl" : "text-5xl lg:text-7xl",
          ]}
        >
          {title}
        </h1>
        {
          lead && (
            <p class="mx-auto mt-8 max-w-[34rem] font-article-body text-base font-light text-base-content lg:mt-10">
              {lead}
            </p>
          )
        }
        <div
          class="mt-8 flex flex-col items-center justify-center gap-4 text-base-content lg:mt-10"
        >
          <ArticleAuthor name={authorName} avatarUrl={authorAvatar} />
          <ArticleDate createdAt={createdAt} />
        </div>
      </div>

      {
        imageUrl && (
          <div class:list={["flex flex-col lg:h-full lg:min-h-0", imageOnLeft ? "order-2 lg:order-1" : ""]}>
            <div class="flex items-center justify-center overflow-hidden lg:min-h-0 lg:flex-1">
              <div class="relative w-full lg:h-full lg:w-auto">
                {typeof imageUrl === "string" ? (
                  <img
                    src={imageUrl}
                    alt={imageAlt}
                    class="block h-auto w-full object-cover lg:h-full lg:max-h-full lg:w-full lg:object-cover"
                    transition:name={transitionName}
                  />
                ) : (
                  <Image
                    src={imageUrl}
                    alt={imageAlt}
                    class="block h-auto w-full object-cover lg:h-full lg:max-h-full lg:w-full lg:object-cover"
                    transition:name={transitionName}
                  />
                )}
                {imageCaption && <ImageCaptionHint caption={imageCaption} />}
              </div>
            </div>
          </div>
        )
      }
    </div>
  </div>
  <hr class="mt-10 w-full border-t border-neutral-200 lg:mt-16" />
</section>
