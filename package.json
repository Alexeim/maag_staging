{
  "name": "maag",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -p \"[{name}]\" -n \"FRONT,BACK\" -c \"black.bgMagenta.bold,blue.bgCyan.bold\" \"npm:dev:frontend\" \"npm:dev:backend\"",
    "dev:frontend": "astro dev",
    "dev:backend": "npm run dev --prefix server",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "predeploy": "npm run build && touch dist/.nojekyll",
    "deploy:front": "bash deploy.sh",
    "deploy:back": "cd server && bash deploy.sh"
  },
  "dependencies": {
    "@astrojs/alpinejs": "^0.5.0",
    "@astrojs/check": "^0.9.9",
    "@astrojs/node": "^10.1.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/alpinejs": "^3.13.11",
    "alpinejs": "^3.14.9",
    "astro": "^6.3.1",
    "astro-compressor": "^1.3.0",
    "firebase": "^12.3.0",
    "firebase-tools": "^15.16.0",
    "heic2any": "^0.0.4",
    "lucide-astro": "^0.532.0",
    "quill": "^2.0.3",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "gh-pages": "^6.3.0"
  }
}
